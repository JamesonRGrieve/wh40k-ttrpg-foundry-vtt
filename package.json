{
  "name": "wh40k-rpg",
  "version": "0.0.1",
  "description": "Warhammer 40K RPG Foundry VTT System",
  "scripts": {
    "version": "json -I -f package.json -e \"this.version='$NEXT_VERSION'\" && json -I -f src/system.json -e \"this.version='$NEXT_VERSION'\"",
    "clean": "gulp clean",
    "build": "gulp build",
    "packs": "gulp packs",
    "css": "gulp css",
    "watch": "gulp",
    "lint": "eslint src/module/ --ext .ts",
    "lint:fix": "eslint src/module/ --ext .ts --fix",
    "lint:ratchet": "node scripts/lint-ratchet.mjs",
    "lint:ratchet:update": "node scripts/lint-ratchet.mjs --update",
    "css:coverage": "node scripts/css-coverage.mjs",
    "css:block-index": "node scripts/css-block-index.mjs",
    "css:block": "node scripts/css-block.mjs",
    "css:ratchet": "node scripts/css-ratchet.mjs",
    "css:ratchet:update": "node scripts/css-ratchet.mjs --update",
    "animation:coverage": "node scripts/animation-coverage.mjs",
    "animation:ratchet": "node scripts/animation-ratchet.mjs",
    "animation:ratchet:update": "node scripts/animation-ratchet-update.mjs",
    "theme:coverage": "node scripts/theme-coverage.mjs",
    "theme:ratchet": "node scripts/theme-ratchet.mjs",
    "theme:ratchet:update": "node scripts/theme-ratchet-update.mjs",
    "ts:coverage": "node scripts/ts-coverage.mjs",
    "ts:ratchet": "node scripts/ts-ratchet.mjs",
    "ts:ratchet:update": "node scripts/ts-ratchet.mjs --update",
    "i18n:gen": "node scripts/gen-i18n-types.mjs",
    "i18n:check": "node scripts/gen-i18n-types.mjs --check",
    "icons:gen": "node scripts/gen-icons.mjs",
    "icons:check": "node scripts/gen-icons.mjs --check",
    "symmetry": "node scripts/coverage-symmetry.mjs",
    "symmetry:ratchet": "node scripts/symmetry-ratchet.mjs",
    "symmetry:ratchet:update": "node scripts/symmetry-ratchet.mjs --update",
    "preload:drift": "node scripts/preload-drift.mjs",
    "scaffold:story": "node scripts/scaffold-story.mjs",
    "scaffold:test": "node scripts/scaffold-datamodel-test.mjs",
    "format": "prettier --check 'src/**/*.{ts,json,css,hbs}'",
    "format:fix": "prettier --write 'src/**/*.{ts,json,css,hbs}'",
    "typecheck": "tsc --noEmit",
    "validate:json": "node -e \"const fs=require('fs'); const f='src/lang/en.json'; JSON.parse(fs.readFileSync(f,'utf8')); console.log(f+' OK')\"",
    "stylelint": "stylelint 'src/css/**/*.css'",
    "stylelint:fix": "stylelint 'src/css/**/*.css' --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook:integration": "sh ./scripts/run-storybook-playwright-tests.sh",
    "check": "pnpm validate:json && pnpm lint && pnpm format && pnpm stylelint && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Andru Quiroga",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "src/module/**/*.ts": [
      "eslint --fix --quiet",
      "prettier --write"
    ],
    "src/css/**/*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "stories/**/*.ts": [
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ],
    "src/**/*.{json,hbs}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "tinymce": "^7.0.0"
  },
  "pnpm": {
    "overrides": {
      "braces@<3.0.3": "^3.0.3",
      "micromatch@<4.0.8": "^4.0.8",
      "postcss@<8.4.31": "^8.4.31",
      "tinymce@<7.0.0": "^7.0.0"
    }
  },
  "devDependencies": {
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@playwright/test": "^1.55.1",
    "@storybook/html-vite": "^10.3.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@typhonjs-fvtt/eslint-config-foundry.js": "0.8.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "classic-level": "^1.4.1",
    "cssnano": "^7.1.5",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "4.2.1",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "gulp": "4.0.2",
    "gulp-clean": "0.4.0",
    "gulp-postcss": "^10.0.0",
    "gulp-zip": "5.1.0",
    "handlebars": "^4.7.9",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "js-yaml": "4.1.1",
    "json": "11.0.0",
    "lint-staged": "^16.4.0",
    "lucide": "^0.500.0",
    "merge-stream": "2.0.0",
    "postcss": "^8.5.9",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "2.8.8",
    "storybook": "^10.3.5",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^3.4.19",
    "through2": "4.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "main": "gulpfile.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JamesonRGrieve/wh40k-ttrpg-foundry-vtt.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/JamesonRGrieve/wh40k-ttrpg-foundry-vtt/issues"
  },
  "homepage": "https://github.com/JamesonRGrieve/wh40k-ttrpg-foundry-vtt#readme",
  "dependencies": {
    "zod": "^4.4.3"
  }
}
