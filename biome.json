{
    "$schema": "https://biomejs.dev/schemas/2.3.2/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noRedeclare": "off",
                "noExplicitAny": "warn"
            },
            "complexity": {
                "noThisInStatic": "off",
                "useLiteralKeys": "off"
            },
            "style": {
                "useFilenamingConvention": {
                    "level": "warn",
                    "options": {
                        "filenameCases": ["kebab-case"],
                        "strictCase": false,
                        "requireAscii": true
                    }
                }
            }
        },
        "includes": [
            "**",
            "!**/node_modules",
            "!**/dist",
            "!**/coverage",
            "!**/*.test.ts",
            "!**/*.spec.ts",
            "!**/*.stories.ts",
            "!**/src/packs/**",
            "!**/src/module/icons/registry.generated.ts",
            "!**/src/module/types/icon-keys.d.ts",
            "!**/src/module/types/i18n-keys.d.ts",
            "!gulpfile.js"
        ]
    },
    "formatter": {
        "enabled": false
    }
}
