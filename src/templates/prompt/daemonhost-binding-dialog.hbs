{{!-- Daemonhost Binding Dialog (GitHub #85) --}}
{{!-- Five tier cards in a grid; click selects, "Bind" emits chat card. --}}
<div class="tw-p-5 tw-bg-transparent tw-font-ui tw-text-[#e8e4d9]" data-wh40k-system="dh2">

    <div class="tw-mb-4 tw-text-center tw-text-[0.85rem] tw-text-[#9a9a8a] tw-italic">
        {{localize "WH40K.Daemonhost.DialogIntro"}}
    </div>

    {{!-- Tier card grid --}}
    <div class="tw-grid tw-grid-cols-1 sm:tw-grid-cols-2 lg:tw-grid-cols-5 tw-gap-3 tw-mb-5">
        {{#each tiers}}
            <button type="button"
                    data-action="selectTier"
                    data-tier="{{this.id}}"
                    class="tw-flex tw-flex-col tw-items-stretch tw-gap-2 tw-p-3 tw-rounded-md tw-border-2 tw-cursor-pointer tw-text-left tw-bg-[rgba(0,0,0,0.35)] tw-transition-colors {{#if this.selected}}tw-border-gold dh2:tw-border-bronze bc:tw-border-crimson dh1:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass rt:tw-border-amber-700 im:tw-border-failure tw-shadow-[0_0_18px_rgba(201,162,39,0.35)]{{else}}tw-border-[rgba(201,162,39,0.25)]{{/if}}">
                <div class="tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-gold dh2:tw-text-bronze bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-amber-700 im:tw-text-failure">
                    {{this.label}}
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1 tw-text-[0.8rem]">
                    <div class="tw-flex tw-justify-between tw-gap-2">
                        <span class="tw-text-[#9a9a8a]">{{localize "WH40K.Daemonhost.UnholyChanges"}}</span>
                        <span class="tw-font-bold tw-tabular-nums">{{this.unholyChanges}}</span>
                    </div>
                    <div class="tw-flex tw-justify-between tw-gap-2">
                        <span class="tw-text-[#9a9a8a]">{{localize "WH40K.Daemonhost.MinInfluence"}}</span>
                        <span class="tw-font-bold tw-tabular-nums">{{this.minimumInfluence}}</span>
                    </div>
                    <div class="tw-flex tw-justify-between tw-gap-2">
                        <span class="tw-text-[#9a9a8a]">{{localize "WH40K.Daemonhost.ReinforcementMod"}}</span>
                        <span class="tw-font-bold tw-tabular-nums">{{this.reinforcementModifierLabel}}</span>
                    </div>
                </div>
            </button>
        {{/each}}
    </div>

    {{!-- Action buttons --}}
    <div class="tw-flex tw-gap-2.5 tw-mt-5 tw-pt-5 tw-border-t tw-border-[rgba(201,162,39,0.2)]">
        <button type="button"
                data-action="bind"
                {{#unless canBind}}disabled{{/unless}}
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-5 tw-py-3 tw-border-none tw-rounded-md tw-font-ui tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-cursor-pointer tw-bg-gradient-to-br tw-from-gold tw-to-[#8b6914] dh2:tw-from-bronze tw-text-[#0a0a0f] tw-shadow-[0_4px_12px_rgba(201,162,39,0.3)]">
            <i class="fas fa-skull"></i> {{localize "WH40K.Daemonhost.BindButton"}}
        </button>
        <button type="button"
                data-action="cancel"
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-5 tw-py-3 tw-border tw-border-[rgba(255,255,255,0.15)] tw-rounded-md tw-font-ui tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-cursor-pointer tw-bg-[rgba(255,255,255,0.05)] tw-text-[rgba(255,255,255,0.7)]">
            <i class="fas fa-times"></i> {{localize "WH40K.Daemonhost.Cancel"}}
        </button>
    </div>

</div>
