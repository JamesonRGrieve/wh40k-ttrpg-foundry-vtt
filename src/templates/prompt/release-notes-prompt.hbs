{{! Rogue Trader Release Notes Prompt - Modern Design }}
<div class="tw-relative tw-font-ui tw-text-[var(--wh40k-text-primary)] tw-p-5">
    <div class="tw-relative tw-py-4 tw-px-[18px] tw-mb-4 tw-bg-[linear-gradient(135deg,var(--wh40k-bg-secondary)_0%,var(--wh40k-bg-primary)_100%)] tw-border tw-border-[var(--wh40k-border-accent)] tw-rounded-[6px] tw-shadow-[0_4px_20px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.03)]">
        <div class="tw-flex tw-items-center tw-gap-[14px] tw-mb-4 tw-pb-[14px] tw-border-b tw-border-[var(--wh40k-border-subtle)]">
            <h2 class="tw-font-display tw-text-[1.1rem] tw-font-semibold tw-text-[var(--wh40k-color-gold)] tw-uppercase tw-tracking-[0.1em] tw-m-0 tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis">Release Notes</h2>
            <div class="tw-text-[0.9rem] tw-text-[var(--wh40k-text-secondary)] tw-mt-1 tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis">Version {{version}}</div>
        </div>

        <div class="tw-mb-3 last:tw-mb-0">
            <ul class="tw-m-0 tw-pl-5 tw-leading-relaxed">
                {{#each notes as |note|}}
                    <li class="tw-mb-1.5">{{note}}</li>
                {{/each}}
            </ul>
        </div>
    </div>
</div>