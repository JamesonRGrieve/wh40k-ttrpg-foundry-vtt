{{!-- Fear (X) test dialog (#65) — GM-only. --}}
{{!-- Pick an observer actor, edit WP / fear rating, roll a 1d100 Willpower test. --}}
<div class="tw-p-5 tw-bg-transparent tw-font-ui tw-text-[#e8e4d9]" data-wh40k-system="dh2e">

    <div class="tw-mb-4 tw-text-center tw-text-[0.85rem] tw-text-[#9a9a8a] tw-italic">
        {{localize "WH40K.Fear.DialogTitle"}}
    </div>

    {{!-- Observer selector --}}
    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-mb-4">
        <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-[#9a9a8a]">
            {{localize "WH40K.Fear.ObserverLabel"}}
        </label>
        <select name="observer"
                data-action="selectObserver"
                class="tw-w-full tw-px-3 tw-py-2 tw-bg-[rgba(0,0,0,0.35)] tw-border tw-border-[rgba(201,162,39,0.25)] tw-rounded-sm tw-text-[#e8e4d9] tw-text-sm focus:tw-outline-none focus:tw-border-gold">
            <option value="">— {{localize "WH40K.Fear.ObserverLabel"}} —</option>
            {{#each observers}}
                <option value="{{this.id}}" {{#if (eq this.id ../selectedObserverId)}}selected{{/if}}>{{this.name}} (WP {{this.willpower}})</option>
            {{/each}}
        </select>
    </div>

    {{!-- Inputs: WP + Fear rating --}}
    <div class="tw-grid tw-grid-cols-2 tw-gap-3 tw-mb-4">
        <div class="tw-flex tw-flex-col tw-gap-1.5">
            <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-[#9a9a8a]">
                WP
            </label>
            <input type="number"
                   name="willpower"
                   value="{{willpower}}"
                   min="0"
                   data-action="updateInputs"
                   class="tw-w-full tw-px-3 tw-py-2 tw-bg-[rgba(0,0,0,0.35)] tw-border tw-border-[rgba(201,162,39,0.25)] tw-rounded-sm tw-text-[#e8e4d9] tw-text-sm focus:tw-outline-none focus:tw-border-gold" />
        </div>
        <div class="tw-flex tw-flex-col tw-gap-1.5">
            <label class="tw-flex tw-items-center tw-gap-2 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] {{#if fearRatingHigh}}tw-text-red-600{{else}}tw-text-[#9a9a8a]{{/if}}">
                <i class="fas fa-skull"></i> {{localize "WH40K.Fear.FearRating"}}
            </label>
            <input type="number"
                   name="fearRating"
                   value="{{fearRating}}"
                   min="0"
                   max="{{maxFearRating}}"
                   step="1"
                   data-action="updateInputs"
                   class="tw-w-full tw-px-3 tw-py-2 tw-bg-[rgba(0,0,0,0.35)] tw-border tw-rounded-sm tw-text-sm focus:tw-outline-none {{#if fearRatingHigh}}tw-border-red-700 tw-text-red-600 focus:tw-border-red-600{{else}}tw-border-[rgba(201,162,39,0.25)] tw-text-[#e8e4d9] focus:tw-border-gold{{/if}}" />
        </div>
    </div>

    {{!-- Pip indicator --}}
    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4">
        <span class="tw-text-xs tw-uppercase tw-tracking-[0.08em] tw-text-[#9a9a8a]">{{localize "WH40K.Fear.RatingLabel"}}</span>
        <span class="tw-inline-flex tw-items-center tw-gap-1" aria-label="Fear {{fearRating}}">
            {{#each pips}}
                {{#if this.on}}
                    <span class="tw-inline-block tw-w-2.5 tw-h-2.5 tw-rounded-full tw-border {{#if ../fearRatingHigh}}tw-border-red-600 tw-bg-red-600{{else}}tw-border-gold tw-bg-gold{{/if}}"></span>
                {{else}}
                    <span class="tw-inline-block tw-w-2.5 tw-h-2.5 tw-rounded-full tw-border tw-border-[rgba(201,162,39,0.4)] tw-bg-transparent"></span>
                {{/if}}
            {{/each}}
        </span>
    </div>

    {{!-- Target preview --}}
    <div class="tw-flex tw-items-center tw-justify-between tw-gap-3 tw-p-3 tw-rounded-md tw-border tw-border-[rgba(201,162,39,0.25)] tw-bg-[rgba(0,0,0,0.25)] tw-mb-4">
        <span class="tw-text-[#9a9a8a] tw-text-sm tw-uppercase tw-tracking-[0.08em]">
            {{localize "WH40K.Fear.Target"}}
        </span>
        <span class="tw-font-display tw-font-bold tw-text-xl tw-tabular-nums {{#if fearRatingHigh}}tw-text-red-600{{else}}tw-text-gold{{/if}}">{{target}}</span>
    </div>

    {{!-- Action buttons --}}
    <div class="tw-flex tw-gap-2.5 tw-mt-5 tw-pt-5 tw-border-t tw-border-[rgba(201,162,39,0.2)]">
        <button type="button"
                data-action="rollTest"
                {{#if isNoOp}}disabled{{/if}}
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-5 tw-py-3 tw-border-none tw-rounded-md tw-font-ui tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-cursor-pointer tw-bg-gradient-to-br tw-from-gold tw-to-[#8b6914] dh2e:tw-from-bronze tw-text-[#0a0a0f] tw-shadow-[0_4px_12px_rgba(201,162,39,0.3)]">
            <i class="fas fa-dice-d20"></i> {{localize "WH40K.Fear.DialogTitle"}}
        </button>
        <button type="button"
                data-action="cancel"
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-5 tw-py-3 tw-border tw-border-[rgba(255,255,255,0.15)] tw-rounded-md tw-font-ui tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-cursor-pointer tw-bg-[rgba(255,255,255,0.05)] tw-text-[rgba(255,255,255,0.7)]">
            <i class="fas fa-times"></i> {{localize "WH40K.Daemonhost.Cancel"}}
        </button>
    </div>

</div>
