{{! Rogue Trader Force Field Prompt }}
<div class="dialog-content">
    <form class="tw-relative tw-font-ui tw-text-[#e8e4d9] tw-p-5" autocomplete="off">
        {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs}}
            <div class="tw-flex tw-items-center tw-gap-[14px] tw-mb-4 tw-pb-[14px] tw-border-b tw-border-[rgba(255,255,255,0.08)]">
                <img class="tw-w-12 tw-h-12 tw-flex-shrink-0 tw-rounded tw-object-cover tw-border tw-border-[rgba(201,162,39,0.3)]" alt="{{this.actor.name}}" src="{{this.actor.img}}" />
                <div class="tw-flex-1 tw-min-w-0">
                    <h2 class="tw-font-display tw-text-[1.1rem] tw-font-semibold tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-uppercase tw-tracking-wider tw-m-0 tw-truncate">Force Field</h2>
                    <div class="tw-text-[0.9rem] tw-text-[color:var(--wh40k-text-secondary)] tw-mt-1 tw-truncate">{{this.forceField.name}}</div>
                </div>
            </div>

            {{> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Character"  value=this.actor.name}}
            {{> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Quality"    value=this.forceField.system.protectionRating}}
            {{> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Activated"  value=this.forceField.system.activated}}
            {{> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Overloaded" value=this.forceField.system.overloaded last=true}}
        {{/systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs}}

        {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs title="Protection" marginClass=""}}
            {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Rating"}}
                <input class="tw-px-3.5 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-min-w-[80px] tw-text-right tw-w-20" type="number" data-dtype="Number" name="protectionRating" value="{{this.protectionRating}}" />
            {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
            {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Overload" last=true}}
                <input class="tw-px-3.5 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-min-w-[80px] tw-text-right tw-w-20" type="number" data-dtype="Number" name="overloadRating" value="{{this.overloadRating}}" />
            {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
        {{/systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs}}
    </form>
</div>

{{! Dialog Buttons }}
<div class="dialog-buttons">
    <button class="dialog-button roll default" data-button="roll" id="roll-force-field">
        <span class="material-icons">casino</span>
        Roll
    </button>
    <button class="dialog-button cancel" data-button="cancel" id="cancel-prompt">
        <span class="material-icons">close</span>
        Cancel
    </button>
</div>
