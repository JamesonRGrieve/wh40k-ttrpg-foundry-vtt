{{!-- Sister of Battle Elite Advance Dialog (GitHub #134) --}}
{{!-- GM confirms the advance; the three talents are listed below. --}}
<div class="tw-p-5 tw-bg-transparent tw-font-ui tw-text-[#e8e4d9]" data-wh40k-system="dh2">

    <div class="tw-mb-4 tw-text-center tw-text-[0.85rem] tw-text-[#9a9a8a] tw-italic">
        {{localize "WH40K.SisterOfBattle.Description"}}
    </div>

    {{!-- Prerequisites callout --}}
    <div class="tw-mb-4 tw-p-3 tw-rounded-md tw-border tw-border-[rgba(201,162,39,0.25)] dh2:tw-border-gold dh2:tw-bg-amber-900/30 tw-bg-[rgba(0,0,0,0.35)]">
        <div class="tw-text-[0.85rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-gold dh2:tw-text-gold tw-mb-2">
            {{localize "WH40K.SisterOfBattle.Prerequisites"}}
        </div>
        <ul class="tw-list-none tw-p-0 tw-m-0 tw-flex tw-flex-col tw-gap-1 tw-text-[0.85rem]">
            <li class="tw-text-[#e8e4d9]">{{localize "WH40K.SisterOfBattle.Prereqs.Fellowship"}}</li>
            <li class="tw-text-[#e8e4d9]">{{localize "WH40K.SisterOfBattle.Prereqs.Willpower"}}</li>
            <li class="tw-text-[#e8e4d9]">{{localize "WH40K.SisterOfBattle.Prereqs.Female"}}</li>
            <li class="tw-text-[#e8e4d9]">{{localize "WH40K.SisterOfBattle.Prereqs.Faith"}}</li>
        </ul>
    </div>

    {{!-- Grants header --}}
    <div class="tw-text-[0.85rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-gold dh2:tw-text-gold tw-mb-2">
        {{localize "WH40K.SisterOfBattle.GrantsHeader"}}
    </div>

    {{!-- Talent grant list --}}
    <div class="tw-grid tw-grid-cols-1 tw-gap-2.5 tw-mb-5">
        {{#each talents}}
            <div data-talent="{{this.id}}"
                 class="tw-flex tw-flex-col tw-gap-1 tw-p-3 tw-rounded-md tw-border-2 tw-border-[rgba(201,162,39,0.25)] dh2:tw-border-gold dh2:tw-bg-amber-900/30 tw-bg-[rgba(0,0,0,0.35)]">
                <div class="tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-gold dh2:tw-text-gold">
                    {{this.label}}
                </div>
                <div class="tw-text-[0.85rem] tw-text-[#e8e4d9]">
                    {{this.summary}}
                </div>
            </div>
        {{/each}}
    </div>

    {{!-- Action buttons --}}
    <div class="tw-flex tw-gap-2.5 tw-mt-5 tw-pt-5 tw-border-t tw-border-[rgba(201,162,39,0.2)]">
        <button type="button"
                data-action="apply"
                {{#unless canApply}}disabled{{/unless}}
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-5 tw-py-3 tw-border-none tw-rounded-md tw-font-ui tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-cursor-pointer tw-bg-gradient-to-br tw-from-gold tw-to-[#8b6914] dh2:tw-from-gold tw-text-[#0a0a0f] tw-shadow-[0_4px_12px_rgba(201,162,39,0.3)]">
            <i class="fas fa-cross"></i> {{localize "WH40K.SisterOfBattle.ApplyButton"}}
        </button>
        <button type="button"
                data-action="cancel"
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-5 tw-py-3 tw-border tw-border-[rgba(255,255,255,0.15)] tw-rounded-md tw-font-ui tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-cursor-pointer tw-bg-[rgba(255,255,255,0.05)] tw-text-[rgba(255,255,255,0.7)]">
            <i class="fas fa-times"></i> {{localize "WH40K.SisterOfBattle.Cancel"}}
        </button>
    </div>

</div>
