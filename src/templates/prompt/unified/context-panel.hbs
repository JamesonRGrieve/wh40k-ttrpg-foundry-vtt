{{!-- Unified Roll Dialog: Context Panel - delegates to sub-panels --}}
<div class="tw-border-t tw-border-[rgba(255,255,255,0.06)]" {{#unless hasContextPanel}}hidden{{/unless}}>
{{#if hasContextPanel}}
    <button type="button" class="tw-flex tw-items-center tw-w-full tw-px-5 tw-py-3 tw-bg-[rgba(0,0,0,0.15)] tw-border-0 tw-text-[#e8e4d9] tw-cursor-pointer tw-text-sm tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-transition-colors hover:tw-bg-[rgba(0,0,0,0.25)]" data-action="toggleContextSection">
        <span class="tw-flex-1 tw-text-left tw-flex tw-items-center tw-gap-2">
            {{#if isWeapon}}<i class="fas fa-crosshairs {{themeClassFor 'accent'}} tw-text-[0.9rem]"></i> Attack Options{{/if}}
            {{#if isPsychic}}<i class="fas fa-brain {{themeClassFor 'accent'}} tw-text-[0.9rem]"></i> Psychic Power{{/if}}
            {{#if isForceField}}<i class="fas fa-shield-alt {{themeClassFor 'accent'}} tw-text-[0.9rem]"></i> Force Field{{/if}}
            {{#if hasSkillPanel}}<i class="fas fa-dumbbell {{themeClassFor 'accent'}} tw-text-[0.9rem]"></i> {{localize "WH40K.UntrainedSkill.CharacteristicLabel"}}{{/if}}
            {{#if isAthletics}}{{#unless hasSkillPanel}}<i class="fas fa-mountain {{themeClassFor 'accent'}} tw-text-[0.9rem]"></i> {{localize "WH40K.Climbing.SurfaceLabel"}}{{/unless}}{{/if}}
        </span>
        <i class="fas {{#if contextExpanded}}fa-chevron-up{{else}}fa-chevron-down{{/if}} tw-text-[#6a6a6a] tw-text-xs"></i>
    </button>

    {{#if contextExpanded}}
        <div class="tw-px-5 tw-pt-3 tw-pb-4 tw-bg-[rgba(0,0,0,0.08)]">
            {{#if isWeapon}}
                {{> "systems/wh40k-rpg/templates/prompt/unified/panels/weapon-panel.hbs"}}
            {{/if}}
            {{#if isPsychic}}
                {{> "systems/wh40k-rpg/templates/prompt/unified/panels/psychic-panel.hbs"}}
            {{/if}}
            {{#if isForceField}}
                {{> "systems/wh40k-rpg/templates/prompt/unified/panels/force-field-panel.hbs"}}
            {{/if}}
            {{#if isAthletics}}
                <div class="wh40k-climb-surface-picker tw-mb-3">
                    <h4 class="tw-font-display tw-text-xs tw-font-semibold {{themeClassFor 'accent'}} tw-uppercase tw-tracking-[0.1em] tw-m-0 tw-mb-2">
                        {{localize "WH40K.Climbing.SurfaceLabel"}}
                    </h4>
                    <select class="wh40k-climb-surface-picker__select tw-py-2.5 tw-px-[14px] tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-md tw-text-[#e8e4d9] tw-text-base tw-font-medium tw-w-full tw-transition-all hover:tw-border-[rgba(255,255,255,0.15)] focus:tw-outline-none focus:tw-border-gold-raw focus:tw-shadow-[0_0_0_3px_rgba(201,162,39,0.2)] focus:tw-bg-[rgba(0,0,0,0.4)]"
                            name="climbSurface"
                            data-action="setClimbSurface">
                        {{#each climbSurfaceOptions as |opt|}}
                            <option value="{{opt.value}}" {{#if opt.isCurrent}}selected{{/if}}>{{opt.label}}</option>
                        {{/each}}
                    </select>
                    {{#if (eq climbSurface "sheer")}}
                        <div class="wh40k-climb-surface-picker__sheer-indicator tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-mt-2 tw-rounded-md tw-bg-blue-900/40 tw-text-blue-200 tw-border tw-border-blue-400/40 tw-text-[0.8rem]" title="{{localize "WH40K.Climbing.SheerTooltip"}}">
                            <i class="fas fa-icicles tw-text-blue-300"></i>
                            <span>{{localize "WH40K.Climbing.SheerTooltip"}}</span>
                        </div>
                    {{/if}}
                </div>
            {{/if}}
            {{#if hasSkillPanel}}
                {{#with skillPanel as |panel|}}
                    {{#if panel.altOptions.length}}
                        <div class="tw-mb-3 wh40k-skill-char-override">
                            <h4 class="tw-font-display tw-text-xs tw-font-semibold {{themeClassFor 'accent'}} tw-uppercase tw-tracking-[0.1em] tw-m-0 tw-mb-2">
                                {{localize "WH40K.UntrainedSkill.CharacteristicLabel"}}
                            </h4>
                            <select class="wh40k-skill-char-override__select tw-py-2.5 tw-px-[14px] tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-md tw-text-[#e8e4d9] tw-text-base tw-font-medium tw-w-full tw-transition-all hover:tw-border-[rgba(255,255,255,0.15)] focus:tw-outline-none focus:tw-border-gold-raw focus:tw-shadow-[0_0_0_3px_rgba(201,162,39,0.2)] focus:tw-bg-[rgba(0,0,0,0.4)]"
                                    name="characteristicOverride"
                                    data-action="setCharacteristicOverride">
                                {{#each panel.altOptions as |opt|}}
                                    <option value="{{opt.value}}" {{#if opt.isCurrent}}selected{{/if}}>{{opt.label}}</option>
                                {{/each}}
                            </select>
                        </div>
                    {{/if}}
                    {{#if panel.halved}}
                        <div class="wh40k-skill-char-override__halved tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-rounded-md tw-bg-amber-900/15 tw-border tw-border-amber-400/40 tw-text-[0.8rem] tw-text-amber-200 tw-mb-2" data-testid="skill-untrained-halved">
                            <i class="fas fa-percentage tw-text-amber-300"></i>
                            <span>{{localize "WH40K.UntrainedSkill.HalvedIndicator"}}</span>
                        </div>
                    {{/if}}
                    {{#if panel.untrainedAdvanced}}
                        <div class="wh40k-skill-char-override__blocked tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-rounded-md tw-bg-red-900/15 tw-border tw-border-red-400/40 tw-text-[0.8rem] tw-text-red-200" data-testid="skill-untrained-advanced">
                            <i class="fas fa-ban tw-text-red-300"></i>
                            <span>{{localize "WH40K.UntrainedSkill.UntrainedAdvancedBlocked"}}</span>
                        </div>
                    {{/if}}
                {{/with}}
            {{/if}}
        </div>
    {{/if}}
{{/if}}
</div>
