{{!-- Unified Roll Dialog: Modifiers Section --}}
<div class="tw-border-t tw-border-[rgba(255,255,255,0.06)] tw-py-2.5 tw-px-5" {{#if isForceField}}hidden{{/if}}>
{{#unless isForceField}}
    {{!-- Try-Again warning banner (#62) — soft advisory, never hard-blocks. --}}
    {{#if tryAgainAdvice}}
    <div class="wh40k-try-again-warning tw-flex tw-items-start tw-gap-2 tw-mb-2.5 tw-py-2 tw-px-3 tw-bg-yellow-900/30 tw-border tw-border-yellow-700/50 tw-rounded-md tw-text-[#fde68a]">
        <i class="fas fa-triangle-exclamation tw-text-yellow-400 tw-mt-0.5"></i>
        <div class="tw-flex tw-flex-col tw-gap-0.5 tw-min-w-0 tw-flex-1">
            <span class="tw-text-[0.78rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-yellow-300">{{localize "WH40K.TryingAgain.WarningTitle"}}</span>
            <span class="wh40k-try-again-warning__hint tw-text-[0.78rem] tw-leading-snug">
                {{#if tryAgainAdvice.blocksByConvention}}
                    {{localize "WH40K.TryingAgain.BlockedMessage"}}
                {{else}}
                    {{localize "WH40K.TryingAgain.CumulativeMessage"}}
                {{/if}}
            </span>
            {{#unless (eq tryAgainPenalty 0)}}
            <span class="wh40k-try-again-warning__penalty tw-text-[0.78rem] tw-font-bold tw-text-[#f87171]">
                {{localize "WH40K.TryingAgain.PenaltyLabel"}}: {{tryAgainPenaltyLabel}}
            </span>
            {{/unless}}
        </div>
    </div>
    {{/if}}

    {{!-- Test variant selector (#246): homebrew skill sub-tests (e.g. Visual / Auditory).
         Picking one gates which conditional modifiers apply. --}}
    {{#if hasSkillVariants}}
    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-mb-2.5">
        <span class="tw-text-[0.72rem] tw-text-[#9a9a8a] tw-uppercase tw-tracking-[0.05em] tw-font-medium">{{localize "WH40K.Roll.TestVariant"}}</span>
        <div class="tw-flex tw-flex-wrap tw-gap-1.5">
            {{#each skillVariants}}
            <button type="button"
                    class="tw-inline-flex tw-items-center tw-py-1 tw-px-2.5 tw-border tw-rounded-2xl tw-cursor-pointer tw-text-[0.78rem] tw-transition-all {{#if (eq name ../selectedSkillVariant)}}tw-bg-[rgba(201,162,39,0.15)] tw-border-[rgba(201,162,39,0.5)] tw-text-[#e8e4d9] tw-shadow-[0_0_8px_rgba(201,162,39,0.15)]{{else}}tw-bg-[rgba(0,0,0,0.25)] tw-border-[rgba(255,255,255,0.08)] tw-text-[#9a9a8a] hover:tw-bg-[rgba(201,162,39,0.08)] hover:tw-border-[rgba(201,162,39,0.3)] hover:tw-text-[#b8b8a8]{{/if}}"
                    data-action="selectSkillVariant" data-variant="{{name}}" data-tooltip="{{description}}">
                {{name}}
            </button>
            {{/each}}
        </div>
    </div>
    {{/if}}

    {{!-- Situational modifier pills from character talents/traits/conditions --}}
    {{#if hasSituationalModifiers}}
    <div class="tw-flex tw-flex-wrap tw-gap-1.5 tw-mb-2.5">
        {{#each situationalModifiers}}
        <button type="button"
                class="tw-inline-flex tw-items-center tw-gap-[5px] tw-py-1 tw-px-2.5 tw-border tw-rounded-2xl tw-cursor-pointer tw-text-[0.78rem] tw-transition-all [&>i]:tw-text-[0.7rem] [&>i]:tw-opacity-70 {{#if active}}tw-bg-[rgba(201,162,39,0.15)] tw-border-[rgba(201,162,39,0.5)] tw-text-[#e8e4d9] tw-shadow-[0_0_8px_rgba(201,162,39,0.15)] [&>i]:tw-opacity-100 [&>i]:tw-text-gold-raw{{else}}tw-bg-[rgba(0,0,0,0.25)] tw-border-[rgba(255,255,255,0.08)] tw-text-[#9a9a8a] hover:tw-bg-[rgba(201,162,39,0.08)] hover:tw-border-[rgba(201,162,39,0.3)] hover:tw-text-[#b8b8a8]{{/if}}"
                data-action="toggleSituational" data-toggle-key="{{toggleKey}}"
                data-tooltip="{{condition}}">
            {{#if icon}}<i class="{{icon}}"></i>{{/if}}
            <span class="tw-font-medium tw-max-w-[120px] tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap">{{source}}</span>
            <span class="tw-font-bold tw-text-sm {{#if (gt value 0)}}tw-text-[#4ade80]{{else}}tw-text-[#f87171]{{/if}}">
                {{valueLabel}}
            </span>
        </button>
        {{/each}}
    </div>
    {{/if}}

    {{!-- Assistants stepper (#60) — +10 per assistant up to cap (core.md §"Assistance"). --}}
    <div class="wh40k-assistance-stepper tw-flex tw-items-center tw-justify-center tw-gap-2 tw-mb-2"
         data-tooltip="{{localize "WH40K.Assistance.Tooltip"}}">
        <span class="tw-text-[0.78rem] tw-text-[#9a9a8a] tw-font-medium tw-uppercase tw-tracking-[0.05em]">{{localize "WH40K.Assistance.Label"}}</span>
        <div class="tw-flex tw-items-center tw-gap-0 tw-border tw-border-[rgba(255,255,255,0.1)] tw-rounded-md tw-overflow-hidden tw-bg-[rgba(0,0,0,0.2)]">
            <button type="button"
                    class="wh40k-assistance-stepper__minus tw-flex tw-items-center tw-justify-center tw-w-[28px] tw-h-[28px] tw-bg-[rgba(0,0,0,0.15)] tw-border-0 tw-text-[#c8c8b8] tw-cursor-pointer tw-text-[0.7rem] tw-transition-all hover:tw-bg-[rgba(255,255,255,0.08)] hover:tw-text-[#e8e4d9] active:tw-bg-[rgba(255,255,255,0.15)] disabled:tw-opacity-30 disabled:tw-cursor-not-allowed"
                    data-action="decrementAssistant"
                    data-tooltip="{{localize "WH40K.Assistance.MinusButton"}}"
                    aria-label="{{localize "WH40K.Assistance.MinusButton"}}"
                    {{#unless canDecrementAssistant}}disabled{{/unless}}>
                <i class="fas fa-minus"></i>
            </button>
            <span class="wh40k-assistance-stepper__count tw-min-w-[28px] tw-h-[28px] tw-flex tw-items-center tw-justify-center tw-px-2 tw-border-l tw-border-r tw-border-[rgba(255,255,255,0.06)] tw-text-[#e8e4d9] tw-text-sm tw-font-bold tw-tabular-nums">{{assistantCount}}</span>
            <button type="button"
                    class="wh40k-assistance-stepper__plus tw-flex tw-items-center tw-justify-center tw-w-[28px] tw-h-[28px] tw-bg-[rgba(0,0,0,0.15)] tw-border-0 tw-text-[#c8c8b8] tw-cursor-pointer tw-text-[0.7rem] tw-transition-all hover:tw-bg-[rgba(255,255,255,0.08)] hover:tw-text-[#e8e4d9] active:tw-bg-[rgba(255,255,255,0.15)] disabled:tw-opacity-30 disabled:tw-cursor-not-allowed"
                    data-action="incrementAssistant"
                    data-tooltip="{{localize "WH40K.Assistance.PlusButton"}}"
                    aria-label="{{localize "WH40K.Assistance.PlusButton"}}"
                    {{#unless canIncrementAssistant}}disabled{{/unless}}>
                <i class="fas fa-plus"></i>
            </button>
        </div>
        {{#if (gt assistanceBonus 0)}}
            <span class="wh40k-assistance-stepper__badge tw-inline-flex tw-items-center tw-px-2 tw-py-0.5 tw-rounded-full tw-text-xs tw-font-bold tw-bg-[rgba(74,222,128,0.15)] tw-border tw-border-[rgba(74,222,128,0.4)] tw-text-[#4ade80] tw-shadow-[0_0_8px_rgba(74,222,128,0.2)]">+{{assistanceBonus}}</span>
        {{else}}
            <span class="wh40k-assistance-stepper__badge tw-inline-flex tw-items-center tw-px-2 tw-py-0.5 tw-rounded-full tw-text-xs tw-font-medium tw-bg-[rgba(0,0,0,0.2)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-text-[#6a6a6a]">+0</span>
        {{/if}}
    </div>

    {{!-- Extended Test toggle (#59) — cumulative DoS toward a threshold. --}}
    <div class="wh40k-extended-test-controls tw-flex tw-items-center tw-justify-between tw-gap-2 tw-mb-2 tw-py-1.5 tw-px-2 tw-border tw-border-[rgba(99,102,241,0.25)] tw-rounded-md tw-bg-[rgba(99,102,241,0.06)]"
         data-tooltip="{{localize "WH40K.ExtendedTest.ToggleLabel"}}">
        <label class="wh40k-extended-test-controls__toggle tw-flex tw-items-center tw-gap-2 tw-cursor-pointer tw-text-[0.78rem] tw-text-[#c8c8b8] tw-uppercase tw-tracking-[0.05em] tw-font-medium">
            <input type="checkbox"
                   class="wh40k-extended-test-controls__checkbox tw-w-4 tw-h-4 tw-cursor-pointer tw-accent-indigo-500"
                   data-action="toggleExtended"
                   name="extended"
                   {{#if extended}}checked{{/if}} />
            <span>{{localize "WH40K.ExtendedTest.ToggleLabel"}}</span>
        </label>
        {{#if extended}}
        <div class="wh40k-extended-test-controls__threshold tw-flex tw-items-center tw-gap-1.5">
            <span class="tw-text-[0.72rem] tw-text-[#9a9a8a] tw-uppercase tw-tracking-[0.05em]">{{localize "WH40K.ExtendedTest.ThresholdLabel"}}</span>
            <input type="number"
                   min="1"
                   step="1"
                   class="wh40k-extended-test-controls__threshold-input tw-w-14 tw-py-1 tw-px-1.5 tw-bg-[rgba(0,0,0,0.25)] tw-border tw-border-[rgba(99,102,241,0.4)] tw-rounded tw-text-[#e0e7ff] tw-text-sm tw-text-center tw-font-bold tw-tabular-nums focus:tw-outline-none focus:tw-border-indigo-400 focus:tw-bg-[rgba(99,102,241,0.12)]"
                   value="{{extendedThreshold}}"
                   data-action="setExtendedThreshold"
                   name="extendedThreshold" />
        </div>
        {{/if}}
    </div>

    {{!-- Inline custom modifier: hidden until toggled --}}
    {{#if showCustomModifier}}
    <div class="tw-flex tw-items-center tw-justify-center tw-gap-2">
        <div class="tw-flex tw-items-center tw-gap-0 tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-md tw-overflow-hidden tw-bg-[rgba(0,0,0,0.2)]">
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-[30px] tw-h-[30px] tw-bg-[rgba(0,0,0,0.15)] tw-border-0 tw-text-gold-raw bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-text-[0.7rem] tw-transition-all hover:tw-bg-[rgba(201,162,39,0.15)] hover:tw-text-[#e8e4d9] active:tw-bg-[rgba(201,162,39,0.25)]" data-action="customModDown">
                <i class="fas fa-minus"></i>
            </button>
            <input type="number" id="unified-custom-modifier" class="tw-w-12 tw-py-1 tw-px-0.5 tw-bg-transparent tw-border-0 tw-border-l tw-border-r tw-border-[rgba(201,162,39,0.15)] tw-text-[#e8e4d9] tw-text-sm tw-text-center tw-font-bold tw-[appearance:textfield] [&::-webkit-outer-spin-button]:tw-[appearance:none] [&::-webkit-inner-spin-button]:tw-[appearance:none] focus:tw-outline-none focus:tw-bg-[rgba(201,162,39,0.08)]"
                   value="{{customMod}}" placeholder="0" />
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-[30px] tw-h-[30px] tw-bg-[rgba(0,0,0,0.15)] tw-border-0 tw-text-gold-raw bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-text-[0.7rem] tw-transition-all hover:tw-bg-[rgba(201,162,39,0.15)] hover:tw-text-[#e8e4d9] active:tw-bg-[rgba(201,162,39,0.25)]" data-action="customModUp">
                <i class="fas fa-plus"></i>
            </button>
        </div>
        <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-6 tw-h-6 tw-bg-transparent tw-border-0 tw-text-[#6a6a6a] tw-cursor-pointer tw-text-[0.7rem] tw-rounded-full tw-transition-all hover:tw-text-[#f87171] hover:tw-bg-[rgba(248,113,113,0.1)]" data-action="toggleCustomModifier">
            <i class="fas fa-times"></i>
        </button>
    </div>
    {{else}}
    <button type="button" class="tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-w-full tw-py-1.5 tw-bg-transparent tw-border tw-border-dashed tw-border-[rgba(201,162,39,0.15)] tw-rounded-md tw-text-[rgba(201,162,39,0.5)] tw-text-[0.78rem] tw-cursor-pointer tw-transition-all hover:tw-border-[rgba(201,162,39,0.4)] hover:tw-text-gold-raw hover:tw-bg-[rgba(201,162,39,0.05)]" data-action="toggleCustomModifier">
        <i class="fas fa-plus-circle"></i> Custom Modifier
    </button>
    {{/if}}
{{/unless}}
</div>
