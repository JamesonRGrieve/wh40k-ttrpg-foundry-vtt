{{!-- Only War Logistics Test dialog (#154). --}}
{{!-- GM/player selects Table 6-2 axes + craftsmanship, then rolls 1d100 vs target. --}}
<div class="tw-p-5 tw-bg-transparent tw-font-ui tw-text-[#e8e4d9]" data-wh40k-system="ow">

    <div class="tw-mb-3 tw-text-center tw-text-[0.85rem] tw-text-amber-300 tw-italic">
        {{localize "WH40K.OW.Logistics.Test.Title"}}
    </div>

    {{!-- Base + persistent rating context (read-only readouts from actor) --}}
    <div class="tw-mb-3 tw-flex tw-justify-between tw-items-center tw-px-3 tw-py-2 tw-rounded-md tw-border tw-border-[rgba(217,119,6,0.25)] tw-bg-[rgba(0,0,0,0.25)]">
        <span class="tw-text-sm tw-uppercase tw-tracking-[0.06em] tw-text-amber-100">
            {{localize "WH40K.OW.Logistics.BaseRatingLabel"}}
        </span>
        <span class="tw-font-bold tw-tabular-nums tw-text-amber-100" data-base-rating>{{baseRating}}</span>
    </div>

    {{!-- Axis: Troop Count --}}
    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-mb-3">
        <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-amber-200">
            {{localize "WH40K.OW.Logistics.Modifier.TroopCount"}}
        </label>
        <div class="tw-grid tw-grid-cols-4 tw-gap-1.5" data-axis="troopCount">
            {{#each troopCountOptions}}
                <button type="button"
                        data-action="owSetAxis"
                        data-axis="troopCount"
                        data-value="{{this.id}}"
                        data-selected="{{#if this.selected}}on{{else}}off{{/if}}"
                        class="tw-px-2 tw-py-1.5 tw-text-xs tw-uppercase tw-tracking-[0.05em] tw-rounded-sm tw-border tw-cursor-pointer {{#if this.selected}}tw-border-amber-400 tw-bg-[rgba(217,119,6,0.2)] tw-text-amber-100{{else}}tw-border-[rgba(217,119,6,0.25)] tw-bg-[rgba(0,0,0,0.25)] tw-text-amber-300{{/if}}">
                    {{localize this.labelKey}}
                </button>
            {{/each}}
        </div>
    </div>

    {{!-- Axis: Time in Front --}}
    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-mb-3">
        <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-amber-200">
            {{localize "WH40K.OW.Logistics.Modifier.TimeInFront"}}
        </label>
        <div class="tw-grid tw-grid-cols-4 tw-gap-1.5" data-axis="timeInFront">
            {{#each timeInFrontOptions}}
                <button type="button"
                        data-action="owSetAxis"
                        data-axis="timeInFront"
                        data-value="{{this.id}}"
                        data-selected="{{#if this.selected}}on{{else}}off{{/if}}"
                        class="tw-px-2 tw-py-1.5 tw-text-xs tw-uppercase tw-tracking-[0.05em] tw-rounded-sm tw-border tw-cursor-pointer {{#if this.selected}}tw-border-amber-400 tw-bg-[rgba(217,119,6,0.2)] tw-text-amber-100{{else}}tw-border-[rgba(217,119,6,0.25)] tw-bg-[rgba(0,0,0,0.25)] tw-text-amber-300{{/if}}">
                    {{localize this.labelKey}}
                </button>
            {{/each}}
        </div>
    </div>

    {{!-- Axis: Front Activity --}}
    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-mb-3">
        <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-amber-200">
            {{localize "WH40K.OW.Logistics.Modifier.FrontActive"}}
        </label>
        <div class="tw-grid tw-grid-cols-3 tw-gap-1.5" data-axis="frontActive">
            {{#each frontActiveOptions}}
                <button type="button"
                        data-action="owSetAxis"
                        data-axis="frontActive"
                        data-value="{{this.id}}"
                        data-selected="{{#if this.selected}}on{{else}}off{{/if}}"
                        class="tw-px-2 tw-py-1.5 tw-text-xs tw-uppercase tw-tracking-[0.05em] tw-rounded-sm tw-border tw-cursor-pointer {{#if this.selected}}tw-border-amber-400 tw-bg-[rgba(217,119,6,0.2)] tw-text-amber-100{{else}}tw-border-[rgba(217,119,6,0.25)] tw-bg-[rgba(0,0,0,0.25)] tw-text-amber-300{{/if}}">
                    {{localize this.labelKey}}
                </button>
            {{/each}}
        </div>
    </div>

    {{!-- Axis: War Conditions --}}
    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-mb-3">
        <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-amber-200">
            {{localize "WH40K.OW.Logistics.Modifier.WarCondition"}}
        </label>
        <div class="tw-grid tw-grid-cols-3 tw-gap-1.5" data-axis="warCondition">
            {{#each warConditionOptions}}
                <button type="button"
                        data-action="owSetAxis"
                        data-axis="warCondition"
                        data-value="{{this.id}}"
                        data-selected="{{#if this.selected}}on{{else}}off{{/if}}"
                        class="tw-px-2 tw-py-1.5 tw-text-xs tw-uppercase tw-tracking-[0.05em] tw-rounded-sm tw-border tw-cursor-pointer {{#if this.selected}}tw-border-amber-400 tw-bg-[rgba(217,119,6,0.2)] tw-text-amber-100{{else}}tw-border-[rgba(217,119,6,0.25)] tw-bg-[rgba(0,0,0,0.25)] tw-text-amber-300{{/if}}">
                    {{localize this.labelKey}}
                </button>
            {{/each}}
        </div>
    </div>

    {{!-- Craftsmanship picker --}}
    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-mb-3">
        <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-amber-200">
            {{localize "WH40K.OW.Logistics.CraftsmanshipLabel"}}
        </label>
        <div class="tw-grid tw-grid-cols-4 tw-gap-1.5" data-axis="craftsmanship">
            {{#each craftsmanshipOptions}}
                <button type="button"
                        data-action="owSetAxis"
                        data-axis="craftsmanship"
                        data-value="{{this.id}}"
                        data-selected="{{#if this.selected}}on{{else}}off{{/if}}"
                        class="tw-px-2 tw-py-1.5 tw-text-xs tw-uppercase tw-tracking-[0.05em] tw-rounded-sm tw-border tw-cursor-pointer {{#if this.selected}}tw-border-amber-400 tw-bg-[rgba(217,119,6,0.2)] tw-text-amber-100{{else}}tw-border-[rgba(217,119,6,0.25)] tw-bg-[rgba(0,0,0,0.25)] tw-text-amber-300{{/if}}">
                    {{localize this.labelKey}}
                </button>
            {{/each}}
        </div>
    </div>

    {{!-- Standard kit toggle --}}
    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-mb-4">
        <button type="button"
                data-action="owToggleStandardKit"
                data-toggle-state="{{#if standardKit}}on{{else}}off{{/if}}"
                class="tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-rounded-md tw-border tw-cursor-pointer {{#if standardKit}}tw-border-amber-400 tw-bg-[rgba(217,119,6,0.18)] tw-text-amber-200{{else}}tw-border-[rgba(217,119,6,0.25)] tw-bg-[rgba(0,0,0,0.25)] tw-text-amber-100{{/if}}">
            <span class="tw-text-sm tw-uppercase tw-tracking-[0.06em]">{{localize "WH40K.OW.Logistics.StandardKitToggle"}}</span>
            <i class="fas {{#if standardKit}}fa-check-square{{else}}fa-square{{/if}}"></i>
        </button>
    </div>

    {{!-- Live target preview --}}
    <div class="tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-mb-3 tw-rounded-md tw-border tw-border-amber-500 tw-bg-[rgba(217,119,6,0.18)]">
        <span class="tw-text-sm tw-uppercase tw-tracking-[0.06em] tw-text-amber-100">
            {{localize "WH40K.OW.Logistics.TargetPreview"}}
        </span>
        <span class="tw-font-bold tw-text-lg tw-tabular-nums tw-text-amber-100" data-target-preview>{{computedTarget}}</span>
    </div>

    {{!-- Action buttons --}}
    <div class="tw-flex tw-gap-2.5 tw-mt-4 tw-pt-4 tw-border-t tw-border-[rgba(217,119,6,0.25)]">
        <button type="button"
                data-action="owRollLogistics"
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-5 tw-py-3 tw-border-none tw-rounded-md tw-font-ui tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-cursor-pointer tw-bg-gradient-to-br tw-from-amber-600 tw-to-amber-900 tw-text-amber-50 tw-shadow-[0_4px_12px_rgba(217,119,6,0.35)]">
            <i class="fas fa-dice-d10"></i> {{localize "WH40K.OW.Logistics.RollButton"}}
        </button>
        <button type="button"
                data-action="owCancelLogistics"
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-5 tw-py-3 tw-border tw-border-[rgba(255,255,255,0.15)] tw-rounded-md tw-font-ui tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-cursor-pointer tw-bg-[rgba(255,255,255,0.05)] tw-text-[rgba(255,255,255,0.7)]">
            <i class="fas fa-times"></i> {{localize "WH40K.OW.Logistics.CancelButton"}}
        </button>
    </div>

</div>
