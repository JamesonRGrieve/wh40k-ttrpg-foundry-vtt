{{! Rogue Trader Damage Roll Prompt - Modern Design }}
<form class="wh40k-prompt wh40k-prompt--damage tw-relative tw-font-ui tw-text-[#e8e4d9] tw-p-5" autocomplete="off">
    <div class="wh40k-prompt__panel tw-relative tw-p-4 tw-mb-4 tw-border tw-border-[rgba(201,162,39,0.3)] tw-rounded-md tw-bg-gradient-to-br tw-from-[#14141c] tw-to-[#0d0d12] tw-shadow-[0_4px_20px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.03)]">
        <h3 class="wh40k-prompt__section-title tw-flex tw-items-center tw-gap-2 tw-font-display tw-text-[0.8rem] tw-font-semibold tw-text-[#d4af37] tw-uppercase tw-tracking-[0.12em] tw-m-0 tw-mb-3 tw-pb-2 tw-border-b tw-border-[rgba(255,255,255,0.08)]">{{name}} Damage</h3>

        {{#if psychicPower}}
            <div class="wh40k-prompt__field tw-grid tw-grid-cols-[1fr_auto] tw-gap-3 tw-items-center tw-py-2 tw-min-h-[40px] tw-border-b tw-border-[rgba(255,255,255,0.08)]">
                <span class="wh40k-prompt__label tw-text-[0.85rem] tw-font-medium tw-text-[#e8e4d9] tw-whitespace-nowrap">Psychic Rating</span>
                <input class="wh40k-prompt__input tw-px-3.5 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-min-w-[80px] tw-text-center tw-w-20" type="number" data-dtype="Number" id="pr" name="pr" value="{{pr}}" />
            </div>
        {{/if}}
        <div class="wh40k-prompt__field tw-grid tw-grid-cols-[1fr_auto] tw-gap-3 tw-items-center tw-py-2 tw-min-h-[40px] tw-border-b tw-border-[rgba(255,255,255,0.08)]">
            <span class="wh40k-prompt__label tw-text-[0.85rem] tw-font-medium tw-text-[#e8e4d9] tw-whitespace-nowrap">Damage Formula</span>
            <input class="wh40k-prompt__input tw-px-3.5 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-min-w-[120px]" type="text" id="damage" name="damage" value="{{damage}}" />
        </div>
        <div class="wh40k-prompt__field tw-grid tw-grid-cols-[1fr_auto] tw-gap-3 tw-items-center tw-py-2 tw-min-h-[40px] tw-border-b tw-border-[rgba(255,255,255,0.08)]">
            <span class="wh40k-prompt__label tw-text-[0.85rem] tw-font-medium tw-text-[#e8e4d9] tw-whitespace-nowrap">Damage Type</span>
            <select class="wh40k-prompt__select tw-w-full tw-min-h-[40px] tw-px-3 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-cursor-pointer tw-appearance-none tw-min-w-[140px]" id="damageType" name="damageType">
                {{selectOptions (arrayToObject dh.combat.damage_types) selected=damageType}}
            </select>
        </div>
        <div class="wh40k-prompt__field tw-grid tw-grid-cols-[1fr_auto] tw-gap-3 tw-items-center tw-py-2 tw-min-h-[40px]">
            <span class="wh40k-prompt__label tw-text-[0.85rem] tw-font-medium tw-text-[#e8e4d9] tw-whitespace-nowrap">Penetration</span>
            <input class="wh40k-prompt__input tw-px-3.5 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-min-w-[120px]" type="text" id="penetration" name="penetration" value="{{penetration}}" />
        </div>
    </div>
</form>