{{!-- Weapon Roll Prompt --}}
<div class="dialog-content">
    <form class="tw-relative tw-font-ui tw-text-[color:var(--wh40k-text-primary)] tw-p-5" autocomplete="off">
        {{!-- Weapon Select or Info --}}
        {{#if weaponSelect}}
            {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs title="Select Weapons"}}
                <div class="tw-flex tw-flex-col tw-gap-2">
                    {{#each weapons as |weapon|}}
                        <label class="tw-flex tw-items-center tw-gap-3 tw-cursor-pointer tw-rounded tw-p-3 tw-border tw-border-[rgba(255,255,255,0.08)] tw-bg-[rgba(0,0,0,0.25)] {{#if weapon.isSelected}}tw-border-gold tw-bg-[rgba(201,162,39,0.08)] tw-shadow-[0_0_20px_rgba(201,162,39,0.2)]{{/if}}">
                            <input class="weapon-select tw-flex-shrink-0"
                                type="checkbox"
                                data-dtype="Boolean"
                                {{checked weapon.isSelected}}
                                name="{{weapon.id}}" />
                            <img class="tw-w-10 tw-h-10 tw-flex-shrink-0 tw-rounded tw-object-cover" alt="{{weapon.name}}" src="{{weapon.img}}" />
                            <div class="tw-flex-1 tw-min-w-0">
                                <div class="tw-font-semibold tw-truncate">{{weapon.name}}</div>
                                {{#if weapon.items}}
                                    <div class="tw-text-[0.8rem] tw-truncate">
                                        {{#each weapon.items as |item|}}{{item.name}}{{#unless @last}}, {{/unless}}{{/each}}
                                    </div>
                                {{/if}}
                            </div>
                        </label>
                    {{/each}}
                </div>
            {{/systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs}}
        {{else}}
            {{!-- Weapon Header Panel --}}
            {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs}}
                <div class="tw-flex tw-items-center tw-gap-[14px] tw-mb-4 tw-pb-[14px] tw-border-b tw-border-[rgba(255,255,255,0.08)]">
                    <img class="tw-w-12 tw-h-12 tw-flex-shrink-0 tw-rounded tw-object-cover" alt="{{weapon.name}}" src="{{weapon.img}}" />
                    <div class="tw-flex-1 tw-min-w-0">
                        <h2 class="tw-font-display tw-text-[1.1rem] tw-font-semibold tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-uppercase tw-tracking-wider tw-m-0 tw-truncate">{{weapon.name}}</h2>
                        <div class="tw-text-[0.9rem] tw-text-[color:var(--wh40k-text-secondary)] tw-mt-1 tw-truncate">{{this.sourceActor.name}}</div>
                    </div>
                </div>

                {{!-- Target Display --}}
                <div class="tw-flex tw-items-center tw-justify-between tw-py-2">
                    <span class="tw-text-[0.85rem]">Target ({{baseChar}})</span>
                    <span class="tw-font-bold tw-text-[1.5rem] tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">{{baseTarget}}</span>
                    <span class="tw-text-[0.85rem]">%</span>
                </div>

                {{#if weapon.usesAmmo}}
                    {{> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Ammunition" value=ammoText}}
                {{/if}}
                {{#each weapon.items as |item|}}
                    {{#if item.isAttackSpecial}}
                        {{> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Special" value=item.name}}
                    {{/if}}
                {{/each}}
            {{/systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs}}

            {{!-- Attack Options Panel --}}
            {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs title="Attack Options"}}
                {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                    <span class="tw-text-[0.85rem] tw-font-medium">Attack Type{{#if weapon.usesAmmo}} <small>(max {{fireRate}} hits)</small>{{/if}}</span>
                    <select class="tw-w-full tw-min-h-[40px] tw-px-3 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-cursor-pointer tw-appearance-none tw-min-w-[140px]" name="action" id="action">
                        {{selectOptions actions selected=this.action}}
                    </select>
                {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                {{#if this.isCalledShot}}
                    {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Called Shot Location"}}
                        <select class="tw-w-full tw-min-h-[40px] tw-px-3 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-cursor-pointer tw-appearance-none tw-min-w-[140px]" name="calledShotLocation" id="calledShotLocation">
                            {{selectOptions locations selected=this.calledShotLocation}}
                        </select>
                    {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                {{/if}}
                {{#if this.isLasWeapon}}
                    {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Las Firing Mode"}}
                        <select class="tw-w-full tw-min-h-[40px] tw-px-3 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-cursor-pointer tw-appearance-none tw-min-w-[140px]" name="lasMode" id="lasMode">
                            {{selectOptions (arrayToObject lasModes) selected=this.lasMode}}
                        </select>
                    {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                {{/if}}
                {{#if this.hasEyeOfVengeanceAvailable}}
                    {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Use Eye of Vengeance" last=true}}
                        <input class="tw-cursor-pointer" data-dtype="Boolean" type="checkbox" name="eyeOfVengeance" {{checked this.eyeOfVengeance}} />
                    {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                {{/if}}
            {{/systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs}}

            {{!-- Modifiers Panel --}}
            {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs title="Modifiers" marginClass=""}}
                {{#with this.modifiers}}
                    {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Difficulty"}}
                        <select class="tw-w-full tw-min-h-[40px] tw-px-3 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-cursor-pointer tw-appearance-none tw-min-w-[140px]" data-dtype="Number" name="modifiers.difficulty">
                            {{selectOptions @root.difficulties selected=difficulty}}
                        </select>
                    {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                    {{#if @root.canAim}}
                        {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Aim"}}
                            <select class="tw-w-full tw-min-h-[40px] tw-px-3 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-cursor-pointer tw-appearance-none tw-min-w-[140px]" data-dtype="Number" name="modifiers.aim">
                                {{selectOptions @root.aims selected=aim}}
                            </select>
                        {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                    {{/if}}
                    {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Additional Modifier" last=true}}
                        <input class="tw-px-3.5 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-min-w-[80px] tw-text-right tw-w-20" type="number" data-dtype="Number" name="modifiers.modifier" value="{{modifier}}" />
                    {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                {{/with}}
                {{#if this.weapon.isRanged}}
                    <div class="tw-h-px tw-bg-gradient-to-r tw-from-transparent tw-via-[rgba(201,162,39,0.3)] tw-to-transparent tw-my-3"></div>
                    {{#> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Distance (m)"}}
                        <input class="tw-px-3.5 tw-py-2.5 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-md tw-text-[#e8e4d9] tw-text-[0.9rem] tw-font-medium tw-min-w-[80px] tw-text-right tw-w-20" type="number" data-dtype="Number" name="distance" id="distance" value="{{this.distance}}" />
                    {{/systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs}}
                    <div class="tw-flex tw-justify-between tw-items-center tw-pt-1">
                        <span class="tw-text-[0.85rem]">{{rangeName}}</span>
                        <span class="tw-text-[0.85rem] tw-font-semibold {{#if (gt rangeBonus 0)}}tw-text-[#4ade80]{{else if (lt rangeBonus 0)}}tw-text-[#f87171]{{else}}tw-text-[color:var(--wh40k-text-secondary)]{{/if}}">{{#if (gt rangeBonus 0)}}+{{/if}}{{rangeBonus}}</span>
                    </div>
                    {{#if this.rangeModifiedBy}}
                        <div class="tw-flex tw-items-center tw-gap-1 tw-mt-2 tw-text-[0.85rem] tw-p-2 tw-bg-[rgba(59,130,246,0.1)] tw-border-l-[3px] tw-border-l-[rgba(59,130,246,0.6)] tw-rounded-md tw-text-[rgba(147,197,253,0.9)]">
                            <i class="fas fa-info-circle"></i>
                            Range modifier affected by {{this.rangeModifiedBy}}
                        </div>
                    {{/if}}
                    {{#if this.isMeltaRange}}
                        <div class="tw-flex tw-items-center tw-gap-1 tw-mt-2 tw-text-[0.85rem] tw-p-2 tw-bg-[rgba(251,146,60,0.1)] tw-border-l-[3px] tw-border-l-[rgba(251,146,60,0.6)] tw-rounded-md tw-text-[rgba(254,215,170,0.9)]">
                            <i class="fas fa-fire tw-animate-melta-pulse"></i>
                            Melta: Double penetration at this range
                        </div>
                    {{/if}}
                {{/if}}
                {{#if this.modifiers.attack}}
                    <div class="tw-border-t tw-border-[rgba(255,255,255,0.08)]">
                        {{> systems/wh40k-rpg/templates/prompt/partial/prompt-row.hbs label="Weapon Attack Mod" value=modifiers.attack last=true}}
                    </div>
                {{/if}}
            {{/systems/wh40k-rpg/templates/prompt/partial/prompt-panel.hbs}}
        {{/if}}
    </form>
</div>

{{!-- Dialog Buttons --}}
<div class="dialog-buttons">
    <button class="dialog-button roll default" data-button="roll" id="attack-roll">
        <span class="material-icons">casino</span>
        Roll
    </button>
    <button class="dialog-button cancel" data-button="cancel" id="attack-cancel">
        <span class="material-icons">close</span>
        Cancel
    </button>
</div>
