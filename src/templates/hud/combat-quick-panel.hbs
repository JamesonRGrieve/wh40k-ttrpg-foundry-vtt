{{!-- Combat Quick Panel Template --}}
<div class="tw-flex tw-flex-col tw-gap-3 tw-p-3 data-[opacity=high]:tw-opacity-90 data-[opacity=medium]:tw-opacity-70 data-[opacity=low]:tw-opacity-50" data-opacity="{{opacityKey}}">

    {{!-- Header: Initiative --}}
    <div class="tw-bg-black/30 tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-rounded-[var(--wh40k-radius-md)] tw-p-2">
        <h3 class="tw-m-0 tw-mb-2 tw-text-[color:var(--wh40k-gold,var(--wh40k-color-gold))] tw-text-[0.9rem] tw-font-bold tw-uppercase"><i class="fas fa-bolt"></i> Initiative</h3>
        <div class="tw-flex tw-items-center tw-gap-2">
            {{#if initiative.rolled}}
                <span class="tw-font-bold tw-text-[color:var(--wh40k-bone,#e8dcc8)]">{{initiative.value}}</span>
                <button type="button" class="tw-bg-[var(--wh40k-iron,#3e3e3e)] tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-cursor-pointer tw-p-2 hover:tw-bg-[var(--wh40k-bronze,#cd7f32)] hover:tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))]" data-action="rollInitiative" data-tooltip="Re-roll">
                    <i class="fas fa-dice"></i>
                </button>
            {{else}}
                <button type="button" class="tw-flex-1 tw-bg-[var(--wh40k-iron,#3e3e3e)] tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-cursor-pointer tw-p-2 tw-font-bold hover:tw-bg-[var(--wh40k-bronze,#cd7f32)] hover:tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))]" data-action="rollInitiative">
                    <i class="fas fa-dice"></i> Roll Initiative
                </button>
            {{/if}}
        </div>
    </div>

    {{!-- Vitals --}}
    <div class="tw-bg-black/30 tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-rounded-[var(--wh40k-radius-md)] tw-p-2">
        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-1 vital-row wounds-row {{#if wounds.critical}}critical{{else if wounds.low}}low{{/if}}">
            <span class="tw-w-[60px] tw-text-[color:var(--wh40k-bone,#e8dcc8)]">HP:</span>
            <div class="tw-flex-1 tw-h-4 tw-bg-black/50 tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-rounded-[var(--wh40k-radius-sm)] tw-overflow-hidden">
                <div class="tw-h-full" style="width: {{wounds.percentage}}%; background: linear-gradient(90deg, #4caf50, #8bc34a)"></div>
            </div>
            <span class="tw-w-[50px] tw-text-right tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-font-bold">{{wounds.value}}/{{wounds.max}}</span>
        </div>

        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-1 vital-row fatigue-row {{#if fatigue.exhausted}}exhausted{{/if}}">
            <span class="tw-w-[60px] tw-text-[color:var(--wh40k-bone,#e8dcc8)]">Fatigue:</span>
            <div class="tw-flex-1 tw-h-4 tw-bg-black/50 tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-rounded-[var(--wh40k-radius-sm)] tw-overflow-hidden">
                <div class="tw-h-full" style="width: {{fatigue.percentage}}%; background: linear-gradient(90deg, #4caf50, #8bc34a)"></div>
            </div>
            <span class="tw-w-[50px] tw-text-right tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-font-bold">{{fatigue.value}}/{{fatigue.max}}</span>
        </div>
    </div>

    {{!-- Primary Weapon --}}
    <div class="tw-bg-black/30 tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-rounded-[var(--wh40k-radius-md)] tw-p-2">
        <h3 class="tw-m-0 tw-mb-2 tw-text-[color:var(--wh40k-gold,var(--wh40k-color-gold))] tw-text-[0.9rem] tw-font-bold tw-uppercase"><i class="fas fa-crosshairs"></i> Primary Weapon</h3>

        {{#if weapon.none}}
            <div class="tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-opacity-60">
                <i class="fas fa-exclamation-triangle"></i>
                No weapon equipped
            </div>
        {{else}}
            <div class="tw-flex tw-gap-2 tw-mb-2">
                <img src="{{weapon.img}}" alt="{{weapon.name}}" class="tw-w-10 tw-h-10 tw-border tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))] tw-rounded-[var(--wh40k-radius-sm)]" />
                <div class="tw-flex-1">
                    <div class="tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-font-bold">{{weapon.name}}</div>
                    <div class="tw-text-[0.85rem] tw-text-[color:var(--wh40k-gold,var(--wh40k-color-gold))]">
                        <span>{{weapon.damage}}</span>
                        <span>Pen {{weapon.penetration}}</span>
                    </div>
                </div>
            </div>

            {{!-- Rate of Fire Buttons --}}
            <div class="tw-flex tw-gap-2 tw-mb-2">
                {{#if weapon.rateOfFire.single}}
                    <button type="button" class="attack-btn standard-attack tw-flex-1 tw-p-2 tw-bg-[var(--wh40k-bronze,#cd7f32)] tw-border tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-font-bold tw-cursor-pointer hover:tw-bg-[var(--wh40k-gold,var(--wh40k-color-gold))]" data-action="standardAttack" data-tooltip="Standard Attack">
                        <i class="fas fa-bullseye"></i> Standard
                    </button>
                {{/if}}

                {{#if weapon.rateOfFire.semiAuto}}
                    <button type="button" class="attack-btn semi-auto-attack tw-flex-1 tw-p-2 tw-bg-[var(--wh40k-bronze,#cd7f32)] tw-border tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-font-bold tw-cursor-pointer hover:tw-bg-[var(--wh40k-gold,var(--wh40k-color-gold))]" data-action="semiAutoAttack" data-tooltip="Semi-Auto Burst">
                        <i class="fas fa-burst"></i> Semi
                    </button>
                {{/if}}

                {{#if weapon.rateOfFire.fullAuto}}
                    <button type="button" class="attack-btn full-auto-attack tw-flex-1 tw-p-2 tw-bg-[var(--wh40k-bronze,#cd7f32)] tw-border tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-font-bold tw-cursor-pointer hover:tw-bg-[var(--wh40k-gold,var(--wh40k-color-gold))]" data-action="fullAutoAttack" data-tooltip="Full Auto">
                        <i class="fas fa-fire"></i> Full
                    </button>
                {{/if}}
            </div>

            {{!-- Ammo Bar --}}
            {{#if weapon.clip}}
                <div class="tw-flex tw-items-center tw-gap-2 ammo-row {{#if weapon.ammo.low}}low{{/if}}">
                    <span class="tw-text-[color:var(--wh40k-bone,#e8dcc8)]">Ammo:</span>
                    <div class="tw-flex-1 tw-h-4 tw-bg-black/50 tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-rounded-[var(--wh40k-radius-sm)] tw-overflow-hidden">
                        <div class="tw-h-full" style="width: {{weapon.ammo.percentage}}%; background: linear-gradient(90deg, #4caf50, #8bc34a)"></div>
                    </div>
                    <span class="tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-font-bold">{{weapon.ammo.current}}/{{weapon.ammo.max}}</span>
                </div>
            {{/if}}
        {{/if}}
    </div>

    {{!-- Reactions --}}
    <div class="tw-bg-black/30 tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-rounded-[var(--wh40k-radius-md)] tw-p-2">
        <h3 class="tw-m-0 tw-mb-2 tw-text-[color:var(--wh40k-gold,var(--wh40k-color-gold))] tw-text-[0.9rem] tw-font-bold tw-uppercase"><i class="fas fa-shield-alt"></i> Reactions ({{reactions.remaining}})</h3>
        <div class="tw-flex tw-gap-2 tw-flex-wrap">
            <button type="button"
                    class="tw-flex-1 tw-p-2 tw-bg-[var(--wh40k-iron,#3e3e3e)] tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-cursor-pointer hover:not-disabled:tw-bg-[var(--wh40k-bronze,#cd7f32)] hover:not-disabled:tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))] disabled:tw-opacity-40 disabled:tw-cursor-not-allowed"
                    data-action="dodge"
                    {{#unless reactions.dodge.available}}disabled{{/unless}}
                    data-tooltip="{{reactions.dodge.label}}">
                <i class="fas fa-wind"></i> Dodge
                {{#if reactions.dodge.available}}
                    <span class="tw-text-[color:var(--wh40k-gold,var(--wh40k-color-gold))]">({{reactions.dodge.target}})</span>
                {{/if}}
            </button>

            <button type="button"
                    class="tw-flex-1 tw-p-2 tw-bg-[var(--wh40k-iron,#3e3e3e)] tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-cursor-pointer hover:not-disabled:tw-bg-[var(--wh40k-bronze,#cd7f32)] hover:not-disabled:tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))] disabled:tw-opacity-40 disabled:tw-cursor-not-allowed"
                    data-action="parry"
                    {{#unless reactions.parry.available}}disabled{{/unless}}
                    data-tooltip="{{reactions.parry.label}}">
                <i class="fas fa-hand-paper"></i> Parry
                {{#if reactions.parry.available}}
                    <span class="tw-text-[color:var(--wh40k-gold,var(--wh40k-color-gold))]">({{reactions.parry.target}})</span>
                {{/if}}
            </button>
        </div>
    </div>

    {{!-- Quick Actions --}}
    <div class="tw-bg-black/30 tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-rounded-[var(--wh40k-radius-md)] tw-p-2">
        <h3 class="tw-m-0 tw-mb-2 tw-text-[color:var(--wh40k-gold,var(--wh40k-color-gold))] tw-text-[0.9rem] tw-font-bold tw-uppercase"><i class="fas fa-bolt"></i> Quick Actions</h3>
        <div class="tw-flex tw-gap-2 tw-flex-wrap">
            {{#each actions}}
                <button type="button"
                        class="action-btn tw-flex-1 tw-p-2 tw-bg-[var(--wh40k-iron,#3e3e3e)] tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-cursor-pointer hover:not-disabled:tw-bg-[var(--wh40k-bronze,#cd7f32)] hover:not-disabled:tw-border-[color:var(--wh40k-gold,var(--wh40k-color-gold))] disabled:tw-opacity-40 disabled:tw-cursor-not-allowed"
                        data-action="{{this.action}}"
                        {{#if this.disabled}}disabled{{/if}}
                        data-tooltip="{{this.tooltip}}">
                    <i class="{{this.icon}}"></i>
                    {{this.label}}
                </button>
            {{/each}}
        </div>
    </div>

    {{!-- Footer: Opacity Toggle --}}
    <div class="tw-flex tw-justify-end">
        <button type="button" class="tw-bg-[var(--wh40k-iron,#3e3e3e)] tw-border tw-border-[var(--wh40k-bronze,#cd7f32)] tw-text-[color:var(--wh40k-bone,#e8dcc8)] tw-cursor-pointer tw-p-2 hover:tw-bg-[var(--wh40k-bronze,#cd7f32)]" data-action="toggleOpacity" data-tooltip="Toggle Opacity">
            <i class="fas fa-eye"></i>
        </button>
    </div>
</div>
