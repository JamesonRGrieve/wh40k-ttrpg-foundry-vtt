{{!-- Enhanced NPC Threat Scaler Dialog Template --}}
{{!-- Phase 5: Enhanced threat scaling dialog with improved UX --}}

<form class="wh40k-threat-scaler-form">

  <!-- Header Section -->
  <div class="wh40k-scaler-header">
    <div class="wh40k-scaler-npc-info">
      <img src="{{actor.img}}" class="wh40k-scaler-npc-portrait" alt="{{actor.name}}" />
      <div class="wh40k-scaler-npc-identity">
        <h3>{{actor.name}}</h3>
        <div class="wh40k-scaler-current-threat">
          Current Threat: <strong>{{currentThreat}}</strong>
          <span class="wh40k-threat-tier-badge" style="background: {{currentTier.color}}">{{currentTier.label}}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Threat Slider Section -->
  <div class="wh40k-scaler-slider-section">
    <label for="newThreatLevel">New Threat Level</label>

    <div class="wh40k-slider-container">
      <input type="range"
             id="newThreatLevel"
             name="newThreatLevel"
             class="wh40k-threat-slider"
             min="1"
             max="30"
             value="{{newThreat}}"
             data-action="updatePreview" />
      <div class="wh40k-slider-marks">
        <span class="wh40k-slider-mark" data-value="1" style="left: 0%">
          <span class="wh40k-mark-tick"></span>
          <span class="wh40k-mark-label">1<br/>Minor</span>
        </span>
        <span class="wh40k-slider-mark" data-value="10" style="left: 30%">
          <span class="wh40k-mark-tick"></span>
          <span class="wh40k-mark-label">10<br/>Standard</span>
        </span>
        <span class="wh40k-slider-mark" data-value="15" style="left: 47%">
          <span class="wh40k-mark-tick"></span>
          <span class="wh40k-mark-label">15<br/>Tough</span>
        </span>
        <span class="wh40k-slider-mark" data-value="20" style="left: 63%">
          <span class="wh40k-mark-tick"></span>
          <span class="wh40k-mark-label">20<br/>Elite</span>
        </span>
        <span class="wh40k-slider-mark" data-value="30" style="left: 100%">
          <span class="wh40k-mark-tick"></span>
          <span class="wh40k-mark-label">30<br/>Boss</span>
        </span>
      </div>
    </div>

    <div class="wh40k-slider-value-display">
      <div class="wh40k-new-threat-value">{{newThreat}}</div>
      <div class="wh40k-new-threat-tier" style="background: {{newTier.color}}">{{newTier.label}}</div>
    </div>

    <!-- Quick Presets -->
    <div class="wh40k-quick-presets">
      <button type="button" class="wh40k-preset-btn" data-action="adjustThreat" data-amount="-5">
        <i class="fas fa-minus"></i> 5
      </button>
      <button type="button" class="wh40k-preset-btn" data-action="adjustThreat" data-amount="-1">
        <i class="fas fa-minus"></i> 1
      </button>
      <button type="button" class="wh40k-preset-btn wh40k-preset-reset" data-action="resetThreat">
        <i class="fas fa-undo"></i> Reset
      </button>
      <button type="button" class="wh40k-preset-btn" data-action="adjustThreat" data-amount="1">
        <i class="fas fa-plus"></i> 1
      </button>
      <button type="button" class="wh40k-preset-btn" data-action="adjustThreat" data-amount="5">
        <i class="fas fa-plus"></i> 5
      </button>
    </div>
  </div>

  <!-- Scaling Options -->
  <div class="wh40k-scaler-options">
    <h4>Scaling Options</h4>
    <div class="wh40k-options-grid">
      <label class="wh40k-checkbox-label">
        <input type="checkbox" name="scaleCharacteristics" {{#if scaleCharacteristics}}checked{{/if}} />
        <span>Characteristics</span>
      </label>
      <label class="wh40k-checkbox-label">
        <input type="checkbox" name="scaleWounds" {{#if scaleWounds}}checked{{/if}} />
        <span>Wounds</span>
      </label>
      <label class="wh40k-checkbox-label">
        <input type="checkbox" name="scaleSkills" {{#if scaleSkills}}checked{{/if}} />
        <span>Skills</span>
      </label>
      <label class="wh40k-checkbox-label">
        <input type="checkbox" name="scaleWeapons" {{#if scaleWeapons}}checked{{/if}} />
        <span>Weapons</span>
      </label>
      <label class="wh40k-checkbox-label">
        <input type="checkbox" name="scaleArmour" {{#if scaleArmour}}checked{{/if}} />
        <span>Armour</span>
      </label>
    </div>
  </div>

  <!-- Preview Section -->
  <div class="wh40k-scaler-preview">
    <h4>Preview Changes</h4>

    {{#if (gt threatDifference 10)}}
    <div class="wh40k-warning-banner">
      <i class="fas fa-exclamation-triangle"></i>
      <span>Large threat change ({{threatDifference}} levels) - review carefully!</span>
    </div>
    {{/if}}

    <!-- Tabs for different preview sections -->
    <nav class="wh40k-preview-tabs">
      <button type="button" class="wh40k-preview-tab active" data-tab="characteristics">Characteristics</button>
      <button type="button" class="wh40k-preview-tab" data-tab="combat">Combat</button>
      <button type="button" class="wh40k-preview-tab" data-tab="skills">Skills</button>
    </nav>

    <!-- Characteristics Preview -->
    <div class="wh40k-preview-section active" data-section="characteristics">
      <table class="wh40k-comparison-table">
        <thead>
          <tr>
            <th>Stat</th>
            <th>Current</th>
            <th></th>
            <th>New</th>
            <th>Change</th>
          </tr>
        </thead>
        <tbody>
          {{#each characteristicChanges}}
          <tr>
            <td class="wh40k-stat-name">{{short}}</td>
            <td class="wh40k-stat-current">{{current}}</td>
            <td class="wh40k-stat-arrow"><i class="fas fa-arrow-right"></i></td>
            <td class="wh40k-stat-new {{#if (gt change 0)}}increased{{else if (lt change 0)}}decreased{{/if}}">{{new}}</td>
            <td class="wh40k-stat-change {{#if (gt change 0)}}positive{{else if (lt change 0)}}negative{{else}}neutral{{/if}}">
              {{#if (gt change 0)}}+{{/if}}{{change}}
              <span class="wh40k-change-percent">({{percentChange}}%)</span>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    <!-- Combat Preview -->
    <div class="wh40k-preview-section" data-section="combat">
      <div class="wh40k-combat-changes">
        <div class="wh40k-change-row">
          <span class="wh40k-change-label">Wounds:</span>
          <span class="wh40k-change-current">{{currentWounds}}</span>
          <i class="fas fa-arrow-right"></i>
          <span class="wh40k-change-new">{{newWounds}}</span>
          <span class="wh40k-change-diff {{#if (gt woundsChange 0)}}positive{{else if (lt woundsChange 0)}}negative{{/if}}">
            {{#if (gt woundsChange 0)}}+{{/if}}{{woundsChange}}
          </span>
        </div>
        <div class="wh40k-change-row">
          <span class="wh40k-change-label">Armour:</span>
          <span class="wh40k-change-current">{{currentArmour}}</span>
          <i class="fas fa-arrow-right"></i>
          <span class="wh40k-change-new">{{newArmour}}</span>
          <span class="wh40k-change-diff {{#if (gt armourChange 0)}}positive{{else if (lt armourChange 0)}}negative{{/if}}">
            {{#if (gt armourChange 0)}}+{{/if}}{{armourChange}}
          </span>
        </div>
      </div>
    </div>

    <!-- Skills Preview -->
    <div class="wh40k-preview-section" data-section="skills">
      <p class="wh40k-preview-note">Skill levels will be adjusted based on characteristic changes.</p>
    </div>
  </div>

  <!-- Footer Buttons -->
  <footer class="wh40k-scaler-footer">
    <button type="button" class="wh40k-btn-secondary" data-action="cancel">
      <i class="fas fa-times"></i> Cancel
    </button>
    <button type="submit" class="wh40k-btn-primary">
      <i class="fas fa-check"></i> Apply Scaling
    </button>
  </footer>

</form>
