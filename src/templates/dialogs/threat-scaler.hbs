{{!-- Enhanced NPC Threat Scaler Dialog Template --}}
{{!-- Phase 5: Enhanced threat scaling dialog with improved UX --}}

<form class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-lg)] tw-p-[var(--wh40k-space-md)] tw-max-h-[85vh] tw-overflow-y-auto">

  <!-- Header Section -->
  <div class="tw-border-b-2 tw-border-[var(--color-border-secondary)] tw-pb-[var(--wh40k-space-md)]">
    <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)]">
      <img src="{{actor.img}}" class="tw-w-20 tw-h-20 tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-border-[var(--color-border-secondary)] tw-object-cover" alt="{{actor.name}}" />
      <div>
        <h3 class="tw-m-0 tw-mb-1.5 tw-text-[1.4rem] tw-text-[color:var(--color-text-light-primary)]">{{actor.name}}</h3>
        <div class="tw-text-[0.9rem] tw-text-[color:var(--color-text-light-secondary)]">
          Current Threat: <strong class="tw-text-[color:var(--color-text-light-primary)] tw-text-[1.1rem]">{{currentThreat}}</strong>
          <span class="tw-inline-block tw-px-2 tw-py-0.5 tw-rounded-[var(--wh40k-radius-lg)] tw-text-[0.7rem] tw-uppercase tw-font-bold tw-text-white tw-ml-1.5 tw-tracking-[0.5px]" style="background: {{currentTier.color}}">{{currentTier.label}}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Threat Slider Section -->
  <div>
    <label class="tw-block tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--color-text-light-secondary)] tw-mb-2 tw-uppercase tw-tracking-[0.5px]" for="newThreatLevel">New Threat Level</label>

    <div class="tw-relative tw-pt-5 tw-pb-10">
      <input type="range"
             id="newThreatLevel"
             name="newThreatLevel"
             class="tw-w-full tw-h-3 tw-appearance-none tw-rounded-md tw-outline-none"
             style="background: linear-gradient(to right, #4caf50 0%, #4caf50 16.7%, #2196f3 16.7%, #2196f3 33.3%, #ff9800 33.3%, #ff9800 50%, #f44336 50%, #f44336 66.7%, #9c27b0 66.7%, #9c27b0 100%)"
             min="1"
             max="30"
             value="{{newThreat}}"
             data-action="updatePreview" />
      <div class="tw-absolute tw-top-0 tw-left-0 tw-right-0 tw-h-3 tw-pointer-events-none">
        <span class="tw-absolute tw-transform tw--translate-x-1/2 tw-flex tw-flex-col tw-items-center" data-value="1" style="left: 0%">
          <span class="tw-w-0.5 tw-h-4 tw-bg-white/50 tw-mb-1"></span>
          <span class="tw-text-[0.65rem] tw-text-[color:var(--color-text-light-secondary)] tw-text-center tw-whitespace-nowrap tw-font-semibold tw-uppercase tw-tracking-[0.3px]">1<br/>Minor</span>
        </span>
        <span class="tw-absolute tw-transform tw--translate-x-1/2 tw-flex tw-flex-col tw-items-center" data-value="10" style="left: 30%">
          <span class="tw-w-0.5 tw-h-4 tw-bg-white/50 tw-mb-1"></span>
          <span class="tw-text-[0.65rem] tw-text-[color:var(--color-text-light-secondary)] tw-text-center tw-whitespace-nowrap tw-font-semibold tw-uppercase tw-tracking-[0.3px]">10<br/>Standard</span>
        </span>
        <span class="tw-absolute tw-transform tw--translate-x-1/2 tw-flex tw-flex-col tw-items-center" data-value="15" style="left: 47%">
          <span class="tw-w-0.5 tw-h-4 tw-bg-white/50 tw-mb-1"></span>
          <span class="tw-text-[0.65rem] tw-text-[color:var(--color-text-light-secondary)] tw-text-center tw-whitespace-nowrap tw-font-semibold tw-uppercase tw-tracking-[0.3px]">15<br/>Tough</span>
        </span>
        <span class="tw-absolute tw-transform tw--translate-x-1/2 tw-flex tw-flex-col tw-items-center" data-value="20" style="left: 63%">
          <span class="tw-w-0.5 tw-h-4 tw-bg-white/50 tw-mb-1"></span>
          <span class="tw-text-[0.65rem] tw-text-[color:var(--color-text-light-secondary)] tw-text-center tw-whitespace-nowrap tw-font-semibold tw-uppercase tw-tracking-[0.3px]">20<br/>Elite</span>
        </span>
        <span class="tw-absolute tw-transform tw--translate-x-1/2 tw-flex tw-flex-col tw-items-center" data-value="30" style="left: 100%">
          <span class="tw-w-0.5 tw-h-4 tw-bg-white/50 tw-mb-1"></span>
          <span class="tw-text-[0.65rem] tw-text-[color:var(--color-text-light-secondary)] tw-text-center tw-whitespace-nowrap tw-font-semibold tw-uppercase tw-tracking-[0.3px]">30<br/>Boss</span>
        </span>
      </div>
    </div>

    <div class="tw-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-md)] tw-mt-[var(--wh40k-space-lg)]">
      <div class="tw-text-[3rem] tw-font-bold tw-text-[color:var(--color-text-light-primary)]">{{newThreat}}</div>
      <div class="tw-px-4 tw-py-1.5 tw-rounded-xl tw-text-[0.9rem] tw-uppercase tw-font-bold tw-text-white tw-tracking-[0.5px]" style="background: {{newTier.color}}">{{newTier.label}}</div>
    </div>

    <!-- Quick Presets -->
    <div class="tw-flex tw-gap-[var(--wh40k-space-sm)] tw-justify-center tw-mt-[var(--wh40k-space-md)]">
      <button type="button" class="tw-px-4 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--color-text-light-primary)] tw-cursor-pointer tw-text-[0.85rem] tw-font-semibold hover:tw-bg-[rgba(139,0,0,0.2)] hover:tw-border-[var(--wh40k-accent-gold)]" data-action="adjustThreat" data-amount="-5">
        <i class="fas fa-minus"></i> 5
      </button>
      <button type="button" class="tw-px-4 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--color-text-light-primary)] tw-cursor-pointer tw-text-[0.85rem] tw-font-semibold hover:tw-bg-[rgba(139,0,0,0.2)] hover:tw-border-[var(--wh40k-accent-gold)]" data-action="adjustThreat" data-amount="-1">
        <i class="fas fa-minus"></i> 1
      </button>
      <button type="button" class="tw-px-4 tw-py-2 tw-bg-[rgba(139,0,0,0.1)] tw-border tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure tw-rounded-[var(--wh40k-radius-md)] tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-text-[0.85rem] tw-font-semibold hover:tw-bg-[rgba(139,0,0,0.2)]" data-action="resetThreat">
        <i class="fas fa-undo"></i> Reset
      </button>
      <button type="button" class="tw-px-4 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--color-text-light-primary)] tw-cursor-pointer tw-text-[0.85rem] tw-font-semibold hover:tw-bg-[rgba(139,0,0,0.2)] hover:tw-border-[var(--wh40k-accent-gold)]" data-action="adjustThreat" data-amount="1">
        <i class="fas fa-plus"></i> 1
      </button>
      <button type="button" class="tw-px-4 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--color-text-light-primary)] tw-cursor-pointer tw-text-[0.85rem] tw-font-semibold hover:tw-bg-[rgba(139,0,0,0.2)] hover:tw-border-[var(--wh40k-accent-gold)]" data-action="adjustThreat" data-amount="5">
        <i class="fas fa-plus"></i> 5
      </button>
    </div>
  </div>

  <!-- Scaling Options -->
  <div>
    <h4 class="tw-m-0 tw-mb-[var(--wh40k-space-sm)] tw-text-[0.9rem] tw-uppercase tw-text-[color:var(--color-text-light-secondary)] tw-tracking-[0.5px]">Scaling Options</h4>
    <div class="tw-grid tw-grid-cols-[repeat(auto-fit,minmax(130px,1fr))] tw-gap-[var(--wh40k-space-sm)]">
      <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-px-3 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer hover:tw-bg-[rgba(139,0,0,0.1)] hover:tw-border-[var(--wh40k-accent-gold)]">
        <input type="checkbox" name="scaleCharacteristics" {{#if scaleCharacteristics}}checked{{/if}} class="tw-w-[18px] tw-h-[18px] tw-cursor-pointer" />
        <span class="tw-text-[0.85rem] tw-font-medium">Characteristics</span>
      </label>
      <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-px-3 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer hover:tw-bg-[rgba(139,0,0,0.1)] hover:tw-border-[var(--wh40k-accent-gold)]">
        <input type="checkbox" name="scaleWounds" {{#if scaleWounds}}checked{{/if}} class="tw-w-[18px] tw-h-[18px] tw-cursor-pointer" />
        <span class="tw-text-[0.85rem] tw-font-medium">Wounds</span>
      </label>
      <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-px-3 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer hover:tw-bg-[rgba(139,0,0,0.1)] hover:tw-border-[var(--wh40k-accent-gold)]">
        <input type="checkbox" name="scaleSkills" {{#if scaleSkills}}checked{{/if}} class="tw-w-[18px] tw-h-[18px] tw-cursor-pointer" />
        <span class="tw-text-[0.85rem] tw-font-medium">Skills</span>
      </label>
      <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-px-3 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer hover:tw-bg-[rgba(139,0,0,0.1)] hover:tw-border-[var(--wh40k-accent-gold)]">
        <input type="checkbox" name="scaleWeapons" {{#if scaleWeapons}}checked{{/if}} class="tw-w-[18px] tw-h-[18px] tw-cursor-pointer" />
        <span class="tw-text-[0.85rem] tw-font-medium">Weapons</span>
      </label>
      <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-px-3 tw-py-2 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer hover:tw-bg-[rgba(139,0,0,0.1)] hover:tw-border-[var(--wh40k-accent-gold)]">
        <input type="checkbox" name="scaleArmour" {{#if scaleArmour}}checked{{/if}} class="tw-w-[18px] tw-h-[18px] tw-cursor-pointer" />
        <span class="tw-text-[0.85rem] tw-font-medium">Armour</span>
      </label>
    </div>
  </div>

  <!-- Preview Section -->
  <div>
    <h4 class="tw-m-0 tw-mb-[var(--wh40k-space-md)] tw-text-[0.9rem] tw-uppercase tw-text-[color:var(--color-text-light-secondary)] tw-tracking-[0.5px]">Preview Changes</h4>

    {{#if (gt threatDifference 10)}}
    <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-bg-[rgba(255,152,0,0.2)] tw-border tw-border-[#ff9800] tw-rounded-[var(--wh40k-radius-md)] tw-text-[#ff9800] tw-font-semibold tw-mb-[var(--wh40k-space-md)]">
      <i class="fas fa-exclamation-triangle tw-text-[1.2rem]"></i>
      <span>Large threat change ({{threatDifference}} levels) - review carefully!</span>
    </div>
    {{/if}}

    <!-- Tabs for different preview sections -->
    <nav class="tw-flex tw-gap-[var(--wh40k-space-xs)] tw-border-b-2 tw-border-[var(--color-border-secondary)] tw-mb-[var(--wh40k-space-md)]">
      <button type="button" class="wh40k-preview-tab active tw-px-4 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-transparent tw-text-[color:var(--color-text-light-secondary)] tw-cursor-pointer tw-text-[0.85rem] tw-font-semibold tw-uppercase tw-mb-[-2px] hover:tw-text-[color:var(--color-text-light-primary)] [&.active]:tw-text-gold [&.active]:tw-border-b-gold bc:[&.active]:tw-text-crimson-light dh1e:[&.active]:tw-text-gold-raw-l5 dh2e:[&.active]:tw-text-gold-raw dw:[&.active]:tw-text-accent-combat ow:[&.active]:tw-text-brass-l20 rt:[&.active]:tw-text-gold im:[&.active]:tw-text-failure" data-tab="characteristics">Characteristics</button>
      <button type="button" class="wh40k-preview-tab tw-px-4 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-transparent tw-text-[color:var(--color-text-light-secondary)] tw-cursor-pointer tw-text-[0.85rem] tw-font-semibold tw-uppercase tw-mb-[-2px] hover:tw-text-[color:var(--color-text-light-primary)] [&.active]:tw-text-gold [&.active]:tw-border-b-gold bc:[&.active]:tw-text-crimson-light dh1e:[&.active]:tw-text-gold-raw-l5 dh2e:[&.active]:tw-text-gold-raw dw:[&.active]:tw-text-accent-combat ow:[&.active]:tw-text-brass-l20 rt:[&.active]:tw-text-gold im:[&.active]:tw-text-failure" data-tab="combat">Combat</button>
      <button type="button" class="wh40k-preview-tab tw-px-4 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-transparent tw-text-[color:var(--color-text-light-secondary)] tw-cursor-pointer tw-text-[0.85rem] tw-font-semibold tw-uppercase tw-mb-[-2px] hover:tw-text-[color:var(--color-text-light-primary)] [&.active]:tw-text-gold [&.active]:tw-border-b-gold bc:[&.active]:tw-text-crimson-light dh1e:[&.active]:tw-text-gold-raw-l5 dh2e:[&.active]:tw-text-gold-raw dw:[&.active]:tw-text-accent-combat ow:[&.active]:tw-text-brass-l20 rt:[&.active]:tw-text-gold im:[&.active]:tw-text-failure" data-tab="skills">Skills</button>
    </nav>

    <!-- Characteristics Preview -->
    <div class="wh40k-preview-section active tw-hidden [&.active]:tw-block" data-section="characteristics">
      <table class="tw-w-full tw-border-collapse tw-block tw-overflow-x-auto">
        <thead class="tw-bg-[var(--color-bg-tertiary)] tw-border-b-2 tw-border-[var(--color-border-secondary)] tw-table tw-w-full tw-table-fixed">
          <tr>
            <th class="tw-text-left tw-text-[0.75rem] tw-uppercase tw-font-semibold tw-text-[color:var(--color-text-light-secondary)] tw-p-2 tw-tracking-[0.5px]">Stat</th>
            <th class="tw-text-left tw-text-[0.75rem] tw-uppercase tw-font-semibold tw-text-[color:var(--color-text-light-secondary)] tw-p-2 tw-tracking-[0.5px]">Current</th>
            <th class="tw-text-left tw-text-[0.75rem] tw-uppercase tw-font-semibold tw-text-[color:var(--color-text-light-secondary)] tw-p-2 tw-tracking-[0.5px]"></th>
            <th class="tw-text-left tw-text-[0.75rem] tw-uppercase tw-font-semibold tw-text-[color:var(--color-text-light-secondary)] tw-p-2 tw-tracking-[0.5px]">New</th>
            <th class="tw-text-left tw-text-[0.75rem] tw-uppercase tw-font-semibold tw-text-[color:var(--color-text-light-secondary)] tw-p-2 tw-tracking-[0.5px]">Change</th>
          </tr>
        </thead>
        <tbody class="tw-block tw-max-h-[400px] tw-overflow-y-auto">
          {{#each characteristicChanges}}
          <tr class="tw-border-b tw-border-[var(--color-border-tertiary)] tw-table tw-w-full tw-table-fixed hover:tw-bg-[var(--color-bg-tertiary)]">
            <td class="tw-p-2 tw-text-[0.85rem] tw-font-bold tw-text-[color:var(--wh40k-accent-gold)]">{{short}}</td>
            <td class="tw-p-2 tw-text-[0.85rem] tw-text-[color:var(--color-text-light-secondary)]">{{current}}</td>
            <td class="tw-p-2 tw-text-[0.85rem] tw-text-center tw-text-[color:var(--color-text-light-secondary)]"><i class="fas fa-arrow-right"></i></td>
            <td class="tw-p-2 tw-text-[0.85rem] tw-font-bold {{#if (gt change 0)}}tw-text-[#4caf50]{{else if (lt change 0)}}tw-text-[#f44336]{{/if}}">{{new}}</td>
            <td class="tw-p-2 tw-text-[0.85rem] tw-font-bold tw-text-right {{#if (gt change 0)}}tw-text-[#4caf50]{{else if (lt change 0)}}tw-text-[#f44336]{{else}}tw-text-[color:var(--color-text-light-secondary)]{{/if}}">
              {{#if (gt change 0)}}+{{/if}}{{change}}
              <span class="tw-text-[0.75rem] tw-font-normal tw-ml-1">({{percentChange}}%)</span>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    <!-- Combat Preview -->
    <div class="wh40k-preview-section tw-hidden [&.active]:tw-block" data-section="combat">
      <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-md)]">
        <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)] tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--color-bg-tertiary)] tw-rounded-[var(--wh40k-radius-md)]">
          <span class="tw-font-semibold tw-text-[color:var(--color-text-light-secondary)] tw-min-w-[80px]">Wounds:</span>
          <span class="tw-font-bold tw-text-[color:var(--color-text-light-primary)]">{{currentWounds}}</span>
          <i class="fas fa-arrow-right tw-text-[color:var(--color-text-light-secondary)]"></i>
          <span class="tw-font-bold tw-text-[color:var(--color-text-light-primary)]">{{newWounds}}</span>
          <span class="tw-font-bold tw-ml-auto {{#if (gt woundsChange 0)}}tw-text-[#4caf50]{{else if (lt woundsChange 0)}}tw-text-[#f44336]{{/if}}">
            {{#if (gt woundsChange 0)}}+{{/if}}{{woundsChange}}
          </span>
        </div>
        <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)] tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--color-bg-tertiary)] tw-rounded-[var(--wh40k-radius-md)]">
          <span class="tw-font-semibold tw-text-[color:var(--color-text-light-secondary)] tw-min-w-[80px]">Armour:</span>
          <span class="tw-font-bold tw-text-[color:var(--color-text-light-primary)]">{{currentArmour}}</span>
          <i class="fas fa-arrow-right tw-text-[color:var(--color-text-light-secondary)]"></i>
          <span class="tw-font-bold tw-text-[color:var(--color-text-light-primary)]">{{newArmour}}</span>
          <span class="tw-font-bold tw-ml-auto {{#if (gt armourChange 0)}}tw-text-[#4caf50]{{else if (lt armourChange 0)}}tw-text-[#f44336]{{/if}}">
            {{#if (gt armourChange 0)}}+{{/if}}{{armourChange}}
          </span>
        </div>
      </div>
    </div>

    <!-- Skills Preview -->
    <div class="wh40k-preview-section tw-hidden [&.active]:tw-block" data-section="skills">
      <p class="tw-p-[var(--wh40k-space-md)] tw-bg-[var(--color-bg-tertiary)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--color-text-light-secondary)] tw-italic tw-text-center">Skill levels will be adjusted based on characteristic changes.</p>
    </div>
  </div>

  <!-- Footer Buttons -->
  <footer class="tw-flex tw-justify-end tw-gap-[var(--wh40k-space-sm)] tw-pt-[var(--wh40k-space-md)] tw-border-t-2 tw-border-[var(--color-border-secondary)] tw-flex-wrap">
    <button type="button" class="tw-flex tw-items-center tw-gap-1.5 tw-px-5 tw-py-2.5 tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.9rem] tw-font-semibold tw-cursor-pointer tw-flex-shrink-0 tw-bg-[var(--color-bg-tertiary)] tw-border tw-border-[var(--color-border-secondary)] tw-text-[color:var(--color-text-light-primary)] hover:tw-bg-[var(--color-bg-secondary)] hover:tw-border-[var(--color-border-highlight)]" data-action="cancel">
      <i class="fas fa-times"></i> Cancel
    </button>
    <button type="submit" class="tw-flex tw-items-center tw-gap-1.5 tw-px-5 tw-py-2.5 tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.9rem] tw-font-semibold tw-cursor-pointer tw-flex-shrink-0 tw-bg-[var(--wh40k-accent-gold)] tw-border tw-border-[var(--wh40k-accent-gold)] tw-text-black hover:tw-bg-[var(--wh40k-color-gold-light)] hover:tw-border-[var(--wh40k-color-gold-light)]">
      <i class="fas fa-check"></i> Apply Scaling
    </button>
  </footer>

</form>
