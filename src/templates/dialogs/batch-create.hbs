{{!-- Batch Create Dialog --}}
<div class="batch-create-content tw-flex tw-flex-col tw-gap-3">
  {{!-- Name Pattern --}}
  <div class="form-group">
    <label>{{localize "WH40K.NPC.BatchCreate.NamePattern"}}</label>
    <input type="text" name="namePattern" value="{{state.namePattern}}" placeholder="NPC {n}"/>
    <p class="hint">{{localize "WH40K.NPC.BatchCreate.NamePatternHint"}}</p>
  </div>

  {{!-- Count --}}
  <div class="form-group">
    <label>{{localize "WH40K.NPC.BatchCreate.Count"}}</label>
    <input type="number" name="count" value="{{state.count}}" min="1" max="100"/>
  </div>

  {{!-- Threat Level --}}
  <div class="form-group slider-group">
    <label>{{localize "WH40K.NPC.ThreatLevel"}}</label>
    <div class="slider-with-value tw-flex tw-items-center tw-gap-4">
      <input type="range" name="threatLevel" value="{{state.threatLevel}}" min="1" max="30" step="1"/>
      <span class="threat-value">{{state.threatLevel}}</span>
    </div>
    <p class="tier-label">{{tierName}}</p>
  </div>

  {{!-- Role & Type --}}
  <div class="form-group-row">
    <div class="form-group">
      <label>{{localize "WH40K.NPC.Role"}}</label>
      <select name="role">
        {{#each roles}}
        <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    </div>

    <div class="form-group">
      <label>{{localize "WH40K.NPC.Type"}}</label>
      <select name="type">
        {{#each types}}
        <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  {{!-- Equipment Preset --}}
  <div class="form-group">
    <label>{{localize "WH40K.NPC.EquipmentPreset"}}</label>
    <select name="preset">
      {{#each presets}}
      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}} - {{description}}</option>
      {{/each}}
    </select>
  </div>

  {{!-- Faction --}}
  <div class="form-group">
    <label>{{localize "WH40K.NPC.Faction"}}</label>
    <input type="text" name="faction" value="{{state.faction}}" placeholder="Optional"/>
  </div>

  {{!-- Folder --}}
  {{#if folders.length}}
  <div class="form-group">
    <label>{{localize "WH40K.NPC.BatchCreate.Folder"}}</label>
    <select name="folder">
      <option value="">{{localize "WH40K.NPC.BatchCreate.NoFolder"}}</option>
      {{#each folders}}
      <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
      {{/each}}
    </select>
  </div>
  {{/if}}

  {{!-- Options --}}
  <fieldset class="batch-options">
    <legend>{{localize "WH40K.NPC.BatchCreate.Options"}}</legend>
    
    <div class="form-group checkbox">
      <label>
        <input type="checkbox" name="isHorde" {{#if state.isHorde}}checked{{/if}}/>
        {{localize "WH40K.NPC.EnableHordeMode"}}
      </label>
    </div>

    <div class="form-group checkbox">
      <label>
        <input type="checkbox" name="randomize" {{#if state.randomize}}checked{{/if}}/>
        {{localize "WH40K.NPC.BatchCreate.RandomizeStats"}}
      </label>
    </div>

    {{#if state.randomize}}
    <div class="form-group indent">
      <label>{{localize "WH40K.NPC.BatchCreate.RandomizeAmount"}}</label>
      <div class="slider-with-value tw-flex tw-items-center tw-gap-4">
        <input type="range" name="randomizeAmount" value="{{state.randomizeAmount}}" min="5" max="30" step="5"/>
        <span>±{{state.randomizeAmount}}%</span>
      </div>
    </div>
    {{/if}}

    <div class="form-group checkbox">
      <label>
        <input type="checkbox" name="openSheets" {{#if state.openSheets}}checked{{/if}}/>
        {{localize "WH40K.NPC.BatchCreate.OpenSheets"}}
      </label>
      <p class="hint">{{localize "WH40K.NPC.BatchCreate.OpenSheetsHint"}}</p>
    </div>
  </fieldset>

  {{!-- Preview --}}
  <div class="batch-preview">
    <h4>{{localize "WH40K.NPC.Preview"}}</h4>
    <ul class="name-preview-list tw-flex tw-flex-wrap tw-gap-2">
      {{#each previewNames}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>

  {{!-- Buttons --}}
  <footer class="sheet-footer flexrow tw-pt-3 tw-gap-2">
    {{#each buttons}}
    <button type="{{type}}" {{#if action}}data-action="{{action}}"{{/if}} class="{{cssClass}}">
      <i class="{{icon}}"></i>
      {{localize label}}
    </button>
    {{/each}}
  </footer>
</div>
