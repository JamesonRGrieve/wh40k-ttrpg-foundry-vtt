{{! Confirmation Dialog Template }}
{{! ApplicationV2 replacement for Dialog.confirm() }}

<div class="confirmation-dialog-content">
    <div class="confirmation-message">
        {{{content}}}
    </div>

    <footer class="form-footer tw-flex tw-gap-2.5 tw-pt-4 tw-border-t tw-border-solid tw-border-amber-500/20">
        <button type="button" class="dialog-button cancel tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-p-3 tw-rounded-md tw-cursor-pointer" data-action="cancel">
            <i class="fas fa-times tw-text-sm"></i>
            {{cancelLabel}}
        </button>
        <button type="button" class="dialog-button confirm tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-p-3 tw-rounded-md tw-cursor-pointer" data-action="confirm" autofocus>
            <i class="fas fa-check tw-text-sm"></i>
            {{confirmLabel}}
        </button>
    </footer>
</div>