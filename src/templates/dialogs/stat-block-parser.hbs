{{!-- Stat Block Parser Dialog --}}
<div class="tw-flex tw-flex-col tw-gap-4 tw-h-full">
  {{!-- Input Section --}}
  <div class="tw-grow-0 tw-shrink-0">
    <div class="tw-flex tw-justify-between tw-items-center tw-mb-2">
      <label class="tw-font-bold tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">{{localize "WH40K.NPC.Import.PasteStatBlock"}}</label>
      <button type="button" data-action="clearInput"
              class="tw-p-1 tw-cursor-pointer tw-bg-transparent tw-border-0 tw-opacity-70 hover:tw-opacity-100"
              title="Clear">
        <i class="fa-solid fa-eraser"></i>
      </button>
    </div>
    <textarea name="rawInput" rows="12" placeholder="{{localize "WH40K.NPC.Import.Placeholder"}}"
              class="tw-w-full tw-min-h-[200px] tw-font-mono tw-text-sm tw-p-3 tw-border tw-border-solid tw-border-[var(--color-border-light-tertiary)] tw-rounded-md tw-bg-[var(--color-bg-option)] tw-resize-y focus:tw-outline-none focus:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))]">{{rawInput}}</textarea>
    <p class="tw-text-xs tw-mt-1 tw-text-[var(--color-text-light-6)]">{{localize "WH40K.NPC.Import.Hint"}}</p>
  </div>

  {{!-- Parse Button --}}
  <div class="tw-text-center">
    <button type="button" data-action="parse" class="secondary tw-px-8 tw-py-2">
      <i class="fa-solid fa-magnifying-glass"></i>
      {{localize "WH40K.NPC.Import.Parse"}}
    </button>
  </div>

  {{!-- Errors/Warnings/Info --}}
  {{#if hasErrors}}
  <div class="tw-p-3 tw-rounded-md tw-bg-red-500/15 tw-border tw-border-solid tw-border-red-500/40">
    <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-2 tw-text-red-500"><i class="fa-solid fa-circle-exclamation"></i> {{localize "WH40K.NPC.Import.Errors"}}</h4>
    <ul class="tw-m-0 tw-pl-6 tw-text-xs">
      {{#each errors}}
      <li class="tw-mb-1">{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{#if hasWarnings}}
  <div class="tw-p-3 tw-rounded-md tw-bg-orange-400/15 tw-border tw-border-solid tw-border-orange-400/40">
    <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-2 tw-text-orange-400"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "WH40K.NPC.Import.Warnings"}}</h4>
    <ul class="tw-m-0 tw-pl-6 tw-text-xs">
      {{#each warnings}}
      <li class="tw-mb-1">{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{#if hasInfo}}
  <div class="tw-p-3 tw-rounded-md">
    <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-2"><i class="fa-solid fa-circle-info"></i> {{localize "WH40K.NPC.Import.Info"}}</h4>
    <ul class="tw-m-0 tw-pl-6 tw-text-xs">
      {{#each info}}
      <li class="tw-mb-1">{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{!-- Preview Section --}}
  {{#if hasParsed}}
  <div class="tw-flex-1 tw-overflow-auto tw-p-6 tw-border tw-border-solid tw-border-[var(--color-border-tertiary)] tw-rounded-md tw-bg-[var(--wh40k-bg-translucent)] tw-shadow-inset tw-backdrop-blur-sm">
    <h3 class="tw-m-0 tw-mb-4 tw-pb-2 tw-border-b tw-border-solid tw-border-[var(--color-border-light-tertiary)] tw-font-heading tw-tracking-[0.02em]">{{localize "WH40K.NPC.Preview"}}</h3>

    <div class="tw-grid tw-gap-4 tw-grid-cols-[repeat(auto-fit,minmax(200px,1fr))]">
      {{!-- Basic Info --}}
      <div class="tw-p-4 tw-bg-[var(--wh40k-bg-paper-light)] tw-rounded-lg tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-shadow-sm">
        <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-1 tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-uppercase tw-tracking-[0.05em] [&>i]:tw-text-[0.7rem]"> {{localize "WH40K.NPC.Identity"}}</h4>
        <dl class="tw-m-0 tw-text-[0.85rem] [&_dt]:tw-font-bold [&_dt]:tw-text-[var(--color-text-light-6)]">
          <dt>{{localize "WH40K.NPC.Name"}}</dt>
          <dd class="tw-m-0 tw-mb-2">{{parsedData.name}}</dd>
          <dt>{{localize "WH40K.NPC.Type"}}</dt>
          <dd class="tw-m-0 tw-mb-2">{{parsedData.system.type}}</dd>
          <dt>{{localize "WH40K.NPC.ThreatLevel"}}</dt>
          <dd class="tw-m-0 tw-mb-2">{{parsedData.system.threatLevel}}</dd>
        </dl>
      </div>

      {{!-- Characteristics --}}
      <div class="tw-p-4 tw-bg-[var(--wh40k-bg-paper-light)] tw-rounded-lg tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-shadow-sm">
        <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-1 tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-uppercase tw-tracking-[0.05em] [&>i]:tw-text-[0.7rem]">{{localize "WH40K.Characteristics.Label"}}</h4>
        <div class="tw-grid tw-grid-cols-5 tw-gap-2">
          {{#each parsedData.system.characteristics as |char key|}}
          <div class="tw-text-center tw-p-1 tw-rounded-sm tw-bg-[var(--wh40k-bg-subtle)] tw-border tw-border-solid tw-border-[var(--wh40k-border-light)]">
            <span class="tw-block tw-text-xs tw-text-[var(--color-text-light-6)]">{{char.short}}</span>
            <span class="tw-font-bold tw-text-base">{{char.base}}</span>
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- Vitals --}}
      <div class="tw-p-4 tw-bg-[var(--wh40k-bg-paper-light)] tw-rounded-lg tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-shadow-sm" style="--wh40k-color-accent: var(--wh40k-accent-skills);">
        <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-1 tw-text-[var(--wh40k-color-accent)] tw-uppercase tw-tracking-[0.05em] [&>i]:tw-text-[0.7rem]">{{localize "WH40K.Vitals.Label"}}</h4>
        <dl class="tw-m-0 tw-text-[0.85rem] [&_dt]:tw-font-bold [&_dt]:tw-text-[var(--color-text-light-6)]">
          <dt>{{localize "WH40K.Wounds.Label"}}</dt>
          <dd class="tw-m-0 tw-mb-2">{{parsedData.system.wounds.max}}</dd>
          {{#if parsedData.system.armour}}
          <dt>{{localize "WH40K.Armour.Label"}}</dt>
          <dd class="tw-m-0 tw-mb-2">{{parsedData.system.armour.total}}</dd>
          {{/if}}
        </dl>
      </div>

      {{!-- Skills --}}
      {{#if parsedData}}
      <div class="tw-p-4 tw-bg-[var(--wh40k-bg-paper-light)] tw-rounded-lg tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-shadow-sm" style="--wh40k-color-accent: var(--wh40k-accent-talents);">
        <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-1 tw-text-[var(--wh40k-color-accent)] tw-uppercase tw-tracking-[0.05em] [&>i]:tw-text-[0.7rem] [&>i]:tw-text-[var(--wh40k-color-accent)]"><i class="fa-solid fa-list-check"></i> {{localize "WH40K.Skills"}}</h4>
        <ul class="tw-list-none tw-p-0 tw-m-0 tw-grid tw-gap-1">
          {{#if hasPreviewSkills}}
            {{#each previewSkills as |skill|}}
            <li class="tw-flex tw-items-center tw-gap-2 tw-p-2 tw-rounded-sm tw-text-sm tw-bg-[var(--wh40k-bg-overlay-medium)] tw-border tw-border-solid tw-border-[var(--color-border-light-tertiary)] tw-text-[var(--color-text-secondary)] [&>i]:tw-text-[var(--wh40k-color-accent)] [&>i]:tw-text-[0.65rem]"><i class="fa-solid fa-check"></i>{{skill.name}}</li>
            {{/each}}
          {{else}}
            <li class="tw-flex tw-justify-center tw-p-2 tw-rounded-sm tw-text-sm tw-italic tw-text-[var(--color-text-tertiary)] tw-bg-[var(--wh40k-bg-overlay-light)]">None</li>
          {{/if}}
        </ul>
      </div>
      {{/if}}

      {{!-- Talents --}}
      {{#if parsedData}}
      <div class="tw-p-4 tw-bg-[var(--wh40k-bg-paper-light)] tw-rounded-lg tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-shadow-sm" style="--wh40k-color-accent: var(--wh40k-accent-equipment);">
        <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-1 tw-text-[var(--wh40k-color-accent)] tw-uppercase tw-tracking-[0.05em] [&>i]:tw-text-[0.7rem] [&>i]:tw-text-[var(--wh40k-color-accent)]"><i class="fa-solid fa-star"></i> {{localize "WH40K.Talents"}}</h4>
        <ul class="tw-list-none tw-p-0 tw-m-0 tw-grid tw-gap-1">
          {{#if hasPreviewTalents}}
            {{#each previewTalents as |item|}}
            <li class="tw-flex tw-items-center tw-gap-2 tw-p-2 tw-rounded-sm tw-text-sm tw-bg-[var(--wh40k-bg-overlay-medium)] tw-border tw-border-solid tw-border-[var(--color-border-light-tertiary)] tw-text-[var(--color-text-secondary)] [&>i]:tw-text-[var(--wh40k-color-accent)] [&>i]:tw-text-[0.65rem]"><i class="fa-solid fa-bolt"></i>{{item.name}}</li>
            {{/each}}
          {{else}}
            <li class="tw-flex tw-justify-center tw-p-2 tw-rounded-sm tw-text-sm tw-italic tw-text-[var(--color-text-tertiary)] tw-bg-[var(--wh40k-bg-overlay-light)]">None</li>
          {{/if}}
        </ul>
      </div>
      {{/if}}

      {{!-- Traits --}}
      {{#if parsedData}}
      <div class="tw-p-4 tw-bg-[var(--wh40k-bg-paper-light)] tw-rounded-lg tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-shadow-sm" style="--wh40k-color-accent: var(--wh40k-accent-combat);">
        <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-1 tw-text-[var(--wh40k-color-accent)] tw-uppercase tw-tracking-[0.05em] [&>i]:tw-text-[0.7rem] [&>i]:tw-text-[var(--wh40k-color-accent)]"><i class="fa-solid fa-dna"></i> {{localize "WH40K.Traits"}}</h4>
        <ul class="tw-list-none tw-p-0 tw-m-0 tw-grid tw-gap-1">
          {{#if hasPreviewTraits}}
            {{#each previewTraits as |item|}}
            <li class="tw-flex tw-items-center tw-gap-2 tw-p-2 tw-rounded-sm tw-text-sm tw-bg-[var(--wh40k-bg-overlay-medium)] tw-border tw-border-solid tw-border-[var(--color-border-light-tertiary)] tw-text-[var(--color-text-secondary)] [&>i]:tw-text-[var(--wh40k-color-accent)] [&>i]:tw-text-[0.65rem]"><i class="fa-solid fa-shield"></i>{{item.name}}</li>
            {{/each}}
          {{else}}
            <li class="tw-flex tw-justify-center tw-p-2 tw-rounded-sm tw-text-sm tw-italic tw-text-[var(--color-text-tertiary)] tw-bg-[var(--wh40k-bg-overlay-light)]">None</li>
          {{/if}}
        </ul>
      </div>
      {{/if}}

      {{!-- Weapons --}}
      {{#if parsedData}}
      <div class="tw-p-4 tw-bg-[var(--wh40k-bg-paper-light)] tw-rounded-lg tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-shadow-sm">
        <h4 class="tw-m-0 tw-mb-2 tw-text-sm tw-flex tw-items-center tw-gap-1 tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-uppercase tw-tracking-[0.05em] [&>i]:tw-text-[0.7rem]"><i class="fa-solid fa-gun"></i> {{localize "WH40K.Weapons"}}</h4>
        <ul class="tw-list-none tw-p-0 tw-m-0 tw-grid tw-gap-1">
          {{#if hasPreviewWeapons}}
            {{#each previewWeapons as |weapon|}}
            <li class="tw-flex tw-items-center tw-gap-2 tw-p-2 tw-rounded-sm tw-text-sm tw-bg-[var(--wh40k-bg-overlay-medium)] tw-border tw-border-solid tw-border-[var(--color-border-light-tertiary)] tw-text-[var(--color-text-secondary)] [&>i]:tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))] [&>i]:tw-text-[0.65rem]"><i class="fa-solid fa-bullseye"></i>{{weapon.name}} ({{weapon.damage}}, Pen {{weapon.pen}})</li>
            {{/each}}
          {{else}}
            <li class="tw-flex tw-justify-center tw-p-2 tw-rounded-sm tw-text-sm tw-italic tw-text-[var(--color-text-tertiary)] tw-bg-[var(--wh40k-bg-overlay-light)]">None</li>
          {{/if}}
        </ul>
      </div>
      {{/if}}
    </div>
  </div>
  {{/if}}

  {{!-- Action Buttons --}}
  <footer class="tw-pt-4 tw-flex tw-gap-2 [&>button]:tw-grow">
    {{#each buttons}}
    <button type="{{type}}" {{#if action}}data-action="{{action}}"{{/if}} class="{{cssClass}}" {{#if disabled}}disabled{{/if}}>
      <i class="{{icon}}"></i>
      {{localize label}}
    </button>
    {{/each}}
  </footer>
</div>
