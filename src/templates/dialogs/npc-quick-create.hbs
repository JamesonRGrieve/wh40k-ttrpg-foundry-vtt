{{!-- NPC Quick Create Dialog Template --}}
{{!-- Phase 3: Quick NPC creation with auto-generated stats --}}

<div class="tw-flex tw-flex-col tw-gap-4 tw-p-2">
    {{!-- Header --}}
    <header class="tw-text-center tw-pb-3 tw-border-b tw-border-solid tw-border-[var(--color-border-light,#666)] tw-mb-2">
        <h2 class="tw-m-0 tw-mb-1 tw-text-xl tw-text-[var(--color-text-light-heading,#fff)] [&>i]:tw-mr-2 [&>i]:tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))]"><i class="fa-solid fa-user-plus"></i> {{localize "WH40K.NPC.QuickCreate"}}</h2>
        <p class="tw-m-0 tw-text-[0.85rem] tw-text-[var(--color-text-light-secondary,#aaa)] tw-italic">{{localize "WH40K.NPC.QuickCreateSubtitle"}}</p>
    </header>

    {{!-- Form Section --}}
    <section class="tw-flex tw-flex-col tw-gap-3">
        {{!-- Name Input --}}
        <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-font-medium [&>label]:tw-text-[0.85rem] [&>label]:tw-text-[var(--color-text-light-heading,#eee)] [&>input]:tw-w-full [&>input]:tw-p-2 [&>input]:tw-border [&>input]:tw-border-solid [&>input]:tw-border-[var(--color-border-light,#555)] [&>input]:tw-rounded-md [&>input]:tw-bg-[var(--color-bg-input,#222)] [&>input]:tw-text-[var(--color-text-light,#fff)] [&>input]:tw-text-base [&>input:focus]:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] [&>input:focus]:tw-outline-none">
            <label for="name">{{localize "WH40K.Name"}}</label>
            <input type="text" name="name" value="{{state.name}}" placeholder="Enter NPC name..." />
        </div>

        {{!-- Faction Input --}}
        <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-font-medium [&>label]:tw-text-[0.85rem] [&>label]:tw-text-[var(--color-text-light-heading,#eee)] [&>input]:tw-w-full [&>input]:tw-p-2 [&>input]:tw-border [&>input]:tw-border-solid [&>input]:tw-border-[var(--color-border-light,#555)] [&>input]:tw-rounded-md [&>input]:tw-bg-[var(--color-bg-input,#222)] [&>input]:tw-text-[var(--color-text-light,#fff)] [&>input]:tw-text-base [&>input:focus]:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] [&>input:focus]:tw-outline-none">
            <label for="faction">{{localize "WH40K.NPC.Faction"}}</label>
            <input type="text" name="faction" value="{{state.faction}}" placeholder="e.g., Ork, Imperial Guard, Chaos..." />
        </div>

        {{!-- Threat Level Slider --}}
        <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-font-medium [&>label]:tw-text-[0.85rem] [&>label]:tw-text-[var(--color-text-light-heading,#eee)]">
            <label for="threatLevel">{{localize "WH40K.NPC.ThreatLevel"}}</label>
            <div class="tw-flex tw-items-center tw-gap-3 [&>input[type=range]]:tw-flex-1 [&>input[type=range]]:tw-appearance-none [&>input[type=range]]:tw-h-2 [&>input[type=range]]:tw-bg-gradient-to-r [&>input[type=range]]:tw-from-[#2d5a27] [&>input[type=range]]:tw-via-[var(--wh40k-color-gold)] [&>input[type=range]]:tw-to-[#8b0000] [&>input[type=range]]:tw-rounded-md [&>input[type=range]]:tw-cursor-pointer">
                <input type="range" name="threatLevel" min="1" max="30" value="{{state.threatLevel}}" />
                <span class="tw-text-xl tw-font-bold tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-min-w-[2rem] tw-text-center">{{state.threatLevel}}</span>
            </div>
            <div class="tw-flex tw-items-center tw-gap-2 tw-mt-1 tw-text-[0.8rem]">
                <span class="tw-font-bold tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-px-1.5 tw-py-0.5 tw-bg-[rgba(201,162,39,0.2)] tw-rounded-sm">{{tierName}}</span>
                <span class="tw-text-[var(--color-text-light-secondary,#aaa)] tw-italic">{{tierDescription}}</span>
            </div>
        </div>

        {{!-- Three-Column Layout --}}
        <div class="tw-grid tw-grid-cols-3 tw-gap-3">
            {{!-- Role Select --}}
            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-font-medium [&>label]:tw-text-[0.85rem] [&>label]:tw-text-[var(--color-text-light-heading,#eee)] [&>select]:tw-w-full [&>select]:tw-p-2 [&>select]:tw-border [&>select]:tw-border-solid [&>select]:tw-border-[var(--color-border-light,#555)] [&>select]:tw-rounded-md [&>select]:tw-bg-[var(--color-bg-input,#222)] [&>select]:tw-text-[var(--color-text-light,#fff)] [&>select]:tw-text-base [&>select]:tw-cursor-pointer [&>select:focus]:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] [&>select:focus]:tw-outline-none">
                <label for="role">{{localize "WH40K.NPC.Role"}}</label>
                <select name="role">
                    {{#each roles}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
            </div>

            {{!-- Type Select --}}
            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-font-medium [&>label]:tw-text-[0.85rem] [&>label]:tw-text-[var(--color-text-light-heading,#eee)] [&>select]:tw-w-full [&>select]:tw-p-2 [&>select]:tw-border [&>select]:tw-border-solid [&>select]:tw-border-[var(--color-border-light,#555)] [&>select]:tw-rounded-md [&>select]:tw-bg-[var(--color-bg-input,#222)] [&>select]:tw-text-[var(--color-text-light,#fff)] [&>select]:tw-text-base [&>select]:tw-cursor-pointer [&>select:focus]:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] [&>select:focus]:tw-outline-none">
                <label for="type">{{localize "WH40K.NPC.Type"}}</label>
                <select name="type">
                    {{#each types}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
            </div>

            {{!-- Equipment Preset Select --}}
            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-font-medium [&>label]:tw-text-[0.85rem] [&>label]:tw-text-[var(--color-text-light-heading,#eee)] [&>select]:tw-w-full [&>select]:tw-p-2 [&>select]:tw-border [&>select]:tw-border-solid [&>select]:tw-border-[var(--color-border-light,#555)] [&>select]:tw-rounded-md [&>select]:tw-bg-[var(--color-bg-input,#222)] [&>select]:tw-text-[var(--color-text-light,#fff)] [&>select]:tw-text-base [&>select]:tw-cursor-pointer [&>select:focus]:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] [&>select:focus]:tw-outline-none">
                <label for="preset">{{localize "WH40K.NPC.EquipmentPreset"}}</label>
                <select name="preset">
                    {{#each presets}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
            </div>
        </div>

        {{!-- Horde Toggle --}}
        <div class="tw-flex-row tw-items-center tw-gap-2 [&>label]:tw-flex [&>label]:tw-items-center [&>label]:tw-gap-2 [&>label]:tw-cursor-pointer [&_input[type=checkbox]]:tw-w-4 [&_input[type=checkbox]]:tw-h-4 [&_input[type=checkbox]]:tw-cursor-pointer [&_span]:tw-font-normal">
            <label>
                <input type="checkbox" name="isHorde" {{#if state.isHorde}}checked{{/if}} />
                <span>{{localize "WH40K.NPC.EnableHordeMode"}}</span>
            </label>
            <p class="tw-mt-1 tw-mb-0 tw-ml-6 tw-text-[0.75rem] tw-text-[var(--color-text-light-secondary,#888)] tw-italic">{{localize "WH40K.NPC.HordeModeHint"}}</p>
        </div>
    </section>

    {{!-- Preview Section --}}
    <section class="tw-bg-[var(--color-bg-option,#1a1a1a)] tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-p-3">
        <h3 class="tw-m-0 tw-mb-3 tw-text-md tw-text-[var(--color-text-light-heading,#fff)] tw-border-b tw-border-solid tw-border-[var(--color-border-light,#444)] tw-pb-2 [&>i]:tw-mr-2 [&>i]:tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))]"><i class="fa-solid fa-eye"></i> {{localize "WH40K.NPC.Preview"}}</h3>

        {{!-- Characteristics Grid --}}
        <div class="tw-mb-3 last:tw-mb-0">
            <h4 class="tw-m-0 tw-mb-2 tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#ddd)] tw-uppercase tw-tracking-[0.05em]">{{localize "WH40K.Characteristics"}}</h4>
            <div class="tw-grid tw-grid-cols-5 tw-gap-2">
                {{#each preview.characteristics}}
                <div class="tw-flex tw-flex-col tw-items-center tw-p-1.5 tw-bg-[var(--color-bg-hover,#252525)] tw-border tw-border-solid tw-border-[var(--color-border-light,#444)] tw-rounded-md">
                    <span class="tw-font-bold tw-text-[0.75rem] tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))]">{{short}}</span>
                    <span class="tw-text-[1.1rem] tw-font-bold tw-text-[var(--color-text-light,#fff)]">{{value}}</span>
                    <span class="tw-text-[0.7rem] tw-text-[var(--color-text-light-secondary,#888)]">({{bonus}})</span>
                </div>
                {{/each}}
            </div>
        </div>

        {{!-- Stats Row --}}
        <div class="tw-mb-3 last:tw-mb-0 tw-flex tw-justify-around tw-gap-4 tw-p-2 tw-bg-[var(--color-bg-hover,#252525)] tw-rounded-md">
            <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                <span class="tw-text-[0.75rem] tw-text-[var(--color-text-light-secondary,#888)] tw-uppercase">{{localize "WH40K.Wounds"}}</span>
                <span class="tw-text-md tw-font-bold tw-text-[var(--color-text-light,#fff)]">{{preview.wounds}}</span>
            </div>
            <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                <span class="tw-text-[0.75rem] tw-text-[var(--color-text-light-secondary,#888)] tw-uppercase">{{localize "WH40K.Armour"}}</span>
                <span class="tw-text-md tw-font-bold tw-text-[var(--color-text-light,#fff)]">{{preview.armour}}</span>
            </div>
            <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                <span class="tw-text-[0.75rem] tw-text-[var(--color-text-light-secondary,#888)] tw-uppercase">{{localize "WH40K.Movement"}}</span>
                <span class="tw-text-md tw-font-bold tw-text-[var(--color-text-light,#fff)]">{{preview.movement.half}}/{{preview.movement.full}}/{{preview.movement.charge}}/{{preview.movement.run}}</span>
            </div>
        </div>

        {{!-- Skills Preview --}}
        {{#if preview.skills.length}}
        <div class="tw-mb-3 last:tw-mb-0">
            <h4 class="tw-m-0 tw-mb-2 tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#ddd)] tw-uppercase tw-tracking-[0.05em]">{{localize "WH40K.Skills"}}</h4>
            <div class="tw-flex tw-flex-wrap tw-gap-1">
                {{#each preview.skills}}
                <span class="tw-px-2 tw-py-0.5 tw-bg-[var(--color-bg-hover,#333)] tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-xl tw-text-[0.75rem] tw-text-[var(--color-text-light,#ddd)]">{{name}}{{#if level}} {{level}}{{/if}}</span>
                {{/each}}
            </div>
        </div>
        {{/if}}

        {{!-- Weapons Preview --}}
        {{#if preview.weapons.length}}
        <div class="tw-mb-3 last:tw-mb-0">
            <h4 class="tw-m-0 tw-mb-2 tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#ddd)] tw-uppercase tw-tracking-[0.05em]">{{localize "WH40K.Weapons"}}</h4>
            <div class="tw-flex tw-flex-col tw-gap-1">
                {{#each preview.weapons}}
                <div class="tw-flex tw-justify-between tw-px-2 tw-py-1 tw-bg-[var(--color-bg-hover,#252525)] tw-rounded-sm tw-text-base">
                    <span class="tw-font-medium tw-text-[var(--color-text-light,#fff)]">{{name}}</span>
                    <span class="tw-text-[var(--color-text-light-secondary,#aaa)]">{{damage}}, Pen {{pen}}</span>
                </div>
                {{/each}}
            </div>
        </div>
        {{/if}}
    </section>

    {{!-- Footer Buttons --}}
    <footer class="tw-flex tw-justify-end tw-gap-3 tw-pt-3 tw-border-t tw-border-solid tw-border-[var(--color-border-light,#555)]">
        {{#each buttons}}
        <button type="{{type}}" class="tw-flex tw-items-center tw-gap-2 tw-px-4 tw-py-2 tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-bg-[var(--color-bg-btn,#333)] tw-text-[var(--color-text-light,#fff)] tw-text-base tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--color-bg-btn-hover,#444)] hover:tw-border-[var(--color-border-highlight,#777)] [&>i]:tw-text-[0.85rem] {{#if (eq cssClass 'primary')}}!tw-bg-[var(--wh40k-color-accent,var(--wh40k-color-gold))] !tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] !tw-text-black hover:!tw-bg-[var(--wh40k-color-accent-hover,#ddb52f)]{{/if}}" {{#if action}}data-action="{{action}}"{{/if}}>
            <i class="{{icon}}"></i>
            {{localize label}}
        </button>
        {{/each}}
    </footer>
</div>
