{{!-- NPC Quick Create Dialog Template --}}
{{!-- Phase 3: Quick NPC creation with auto-generated stats --}}

<div class="tw-flex tw-flex-col tw-gap-4 tw-p-2">
    {{!-- Header --}}
    <header class="tw-text-center tw-pb-3 tw-border-b tw-border-solid tw-border-[var(--color-border-light,#666)] tw-mb-2">
        <h2 class="tw-m-0 tw-mb-1 tw-text-xl tw-text-[var(--color-text-light-heading,#fff)]"><i class="fa-solid fa-user-plus tw-mr-2 tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))]"></i> {{localize "WH40K.NPC.QuickCreate"}}</h2>
        <p class="tw-m-0 tw-text-[0.85rem] tw-text-[var(--color-text-light-secondary,#aaa)] tw-italic">{{localize "WH40K.NPC.QuickCreateSubtitle"}}</p>
    </header>

    {{!-- Form Section --}}
    <section class="tw-flex tw-flex-col tw-gap-3">
        {{!-- Name Input --}}
        <div class="tw-flex tw-flex-col tw-gap-1">
            <label for="name" class="tw-font-medium tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#eee)]">{{localize "WH40K.Name"}}</label>
            <input type="text" name="name" value="{{state.name}}" placeholder="Enter NPC name..." class="tw-w-full tw-p-2 tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-bg-[var(--color-bg-input,#222)] tw-text-[var(--color-text-light,#fff)] tw-text-base focus:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] focus:tw-outline-none" />
        </div>

        {{!-- Faction Input --}}
        <div class="tw-flex tw-flex-col tw-gap-1">
            <label for="faction" class="tw-font-medium tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#eee)]">{{localize "WH40K.NPC.Faction"}}</label>
            <input type="text" name="faction" value="{{state.faction}}" placeholder="e.g., Ork, Imperial Guard, Chaos..." class="tw-w-full tw-p-2 tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-bg-[var(--color-bg-input,#222)] tw-text-[var(--color-text-light,#fff)] tw-text-base focus:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] focus:tw-outline-none" />
        </div>

        {{!-- Threat Level Slider --}}
        <div class="tw-flex tw-flex-col tw-gap-1">
            <label for="threatLevel" class="tw-font-medium tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#eee)]">{{localize "WH40K.NPC.ThreatLevel"}}</label>
            <div class="tw-flex tw-items-center tw-gap-3">
                <input type="range" name="threatLevel" min="1" max="30" value="{{state.threatLevel}}" class="tw-flex-1 tw-appearance-none tw-h-2 tw-bg-gradient-to-r tw-from-[#2d5a27] tw-via-[var(--wh40k-color-gold)] tw-to-[#8b0000] tw-rounded-md tw-cursor-pointer" />
                <span class="tw-text-xl tw-font-bold tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-min-w-[2rem] tw-text-center">{{state.threatLevel}}</span>
            </div>
            <div class="tw-flex tw-items-center tw-gap-2 tw-mt-1 tw-text-[0.8rem]">
                <span class="tw-font-bold tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-px-1.5 tw-py-0.5 tw-bg-[rgba(201,162,39,0.2)] tw-rounded-sm">{{tierName}}</span>
                <span class="tw-text-[var(--color-text-light-secondary,#aaa)] tw-italic">{{tierDescription}}</span>
            </div>
        </div>

        {{!-- Three-Column Layout --}}
        <div class="tw-grid tw-grid-cols-3 tw-gap-3">
            {{!-- Role Select --}}
            <div class="tw-flex tw-flex-col tw-gap-1">
                <label for="role" class="tw-font-medium tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#eee)]">{{localize "WH40K.NPC.Role"}}</label>
                <select name="role" class="tw-w-full tw-p-2 tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-bg-[var(--color-bg-input,#222)] tw-text-[var(--color-text-light,#fff)] tw-text-base tw-cursor-pointer focus:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] focus:tw-outline-none">
                    {{#each roles}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
            </div>

            {{!-- Type Select --}}
            <div class="tw-flex tw-flex-col tw-gap-1">
                <label for="type" class="tw-font-medium tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#eee)]">{{localize "WH40K.NPC.Type"}}</label>
                <select name="type" class="tw-w-full tw-p-2 tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-bg-[var(--color-bg-input,#222)] tw-text-[var(--color-text-light,#fff)] tw-text-base tw-cursor-pointer focus:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] focus:tw-outline-none">
                    {{#each types}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
            </div>

            {{!-- Equipment Preset Select --}}
            <div class="tw-flex tw-flex-col tw-gap-1">
                <label for="preset" class="tw-font-medium tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#eee)]">{{localize "WH40K.NPC.EquipmentPreset"}}</label>
                <select name="preset" class="tw-w-full tw-p-2 tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-bg-[var(--color-bg-input,#222)] tw-text-[var(--color-text-light,#fff)] tw-text-base tw-cursor-pointer focus:tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] focus:tw-outline-none">
                    {{#each presets}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
            </div>
        </div>

        {{!-- Horde Toggle --}}
        <div class="tw-flex tw-flex-row tw-items-center tw-gap-2">
            <label class="tw-flex tw-items-center tw-gap-2 tw-cursor-pointer">
                <input type="checkbox" name="isHorde" {{#if state.isHorde}}checked{{/if}} class="tw-w-4 tw-h-4 tw-cursor-pointer" />
                <span class="tw-font-normal">{{localize "WH40K.NPC.EnableHordeMode"}}</span>
            </label>
            <p class="tw-mt-1 tw-mb-0 tw-ml-6 tw-text-[0.75rem] tw-text-[var(--color-text-light-secondary,#888)] tw-italic">{{localize "WH40K.NPC.HordeModeHint"}}</p>
        </div>
    </section>

    {{!-- Preview Section --}}
    <section class="tw-bg-[var(--color-bg-option,#1a1a1a)] tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-p-3">
        <h3 class="tw-m-0 tw-mb-3 tw-text-md tw-text-[var(--color-text-light-heading,#fff)] tw-border-b tw-border-solid tw-border-[var(--color-border-light,#444)] tw-pb-2"><i class="fa-solid fa-eye tw-mr-2 tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))]"></i> {{localize "WH40K.NPC.Preview"}}</h3>

        {{!-- Characteristics Grid --}}
        <div class="tw-mb-3 last:tw-mb-0">
            <h4 class="tw-m-0 tw-mb-2 tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#ddd)] tw-uppercase tw-tracking-[0.05em]">{{localize "WH40K.Characteristics"}}</h4>
            <div class="tw-grid tw-grid-cols-5 tw-gap-2">
                {{#each preview.characteristics}}
                <div class="tw-flex tw-flex-col tw-items-center tw-p-1.5 tw-bg-[var(--color-bg-hover,#252525)] tw-border tw-border-solid tw-border-[var(--color-border-light,#444)] tw-rounded-md">
                    <span class="tw-font-bold tw-text-[0.75rem] tw-text-[var(--wh40k-color-accent,var(--wh40k-color-gold))]">{{short}}</span>
                    <span class="tw-text-[1.1rem] tw-font-bold tw-text-[var(--color-text-light,#fff)]">{{value}}</span>
                    <span class="tw-text-[0.7rem] tw-text-[var(--color-text-light-secondary,#888)]">({{bonus}})</span>
                </div>
                {{/each}}
            </div>
        </div>

        {{!-- Stats Row --}}
        <div class="tw-mb-3 last:tw-mb-0 tw-flex tw-justify-around tw-gap-4 tw-p-2 tw-bg-[var(--color-bg-hover,#252525)] tw-rounded-md">
            <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                <span class="tw-text-[0.75rem] tw-text-[var(--color-text-light-secondary,#888)] tw-uppercase">{{localize "WH40K.Wounds"}}</span>
                <span class="tw-text-md tw-font-bold tw-text-[var(--color-text-light,#fff)]">{{preview.wounds}}</span>
            </div>
            <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                <span class="tw-text-[0.75rem] tw-text-[var(--color-text-light-secondary,#888)] tw-uppercase">{{localize "WH40K.Armour"}}</span>
                <span class="tw-text-md tw-font-bold tw-text-[var(--color-text-light,#fff)]">{{preview.armour}}</span>
            </div>
            <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                <span class="tw-text-[0.75rem] tw-text-[var(--color-text-light-secondary,#888)] tw-uppercase">{{localize "WH40K.Movement"}}</span>
                <span class="tw-text-md tw-font-bold tw-text-[var(--color-text-light,#fff)]">{{preview.movement.half}}/{{preview.movement.full}}/{{preview.movement.charge}}/{{preview.movement.run}}</span>
            </div>
        </div>

        {{!-- Skills Preview --}}
        {{#if preview.skills.length}}
        <div class="tw-mb-3 last:tw-mb-0">
            <h4 class="tw-m-0 tw-mb-2 tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#ddd)] tw-uppercase tw-tracking-[0.05em]">{{localize "WH40K.Skills"}}</h4>
            <div class="tw-flex tw-flex-wrap tw-gap-1">
                {{#each preview.skills}}
                <span class="tw-px-2 tw-py-0.5 tw-bg-[var(--color-bg-hover,#333)] tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-xl tw-text-[0.75rem] tw-text-[var(--color-text-light,#ddd)]">{{name}}{{#if level}} {{level}}{{/if}}</span>
                {{/each}}
            </div>
        </div>
        {{/if}}

        {{!-- Weapons Preview --}}
        {{#if preview.weapons.length}}
        <div class="tw-mb-3 last:tw-mb-0">
            <h4 class="tw-m-0 tw-mb-2 tw-text-[0.85rem] tw-text-[var(--color-text-light-heading,#ddd)] tw-uppercase tw-tracking-[0.05em]">{{localize "WH40K.Weapons"}}</h4>
            <div class="tw-flex tw-flex-col tw-gap-1">
                {{#each preview.weapons}}
                <div class="tw-flex tw-justify-between tw-px-2 tw-py-1 tw-bg-[var(--color-bg-hover,#252525)] tw-rounded-sm tw-text-base">
                    <span class="tw-font-medium tw-text-[var(--color-text-light,#fff)]">{{name}}</span>
                    <span class="tw-text-[var(--color-text-light-secondary,#aaa)]">{{damage}}, Pen {{pen}}</span>
                </div>
                {{/each}}
            </div>
        </div>
        {{/if}}
    </section>

    {{!-- Footer Buttons --}}
    <footer class="tw-flex tw-justify-end tw-gap-3 tw-pt-3 tw-border-t tw-border-solid tw-border-[var(--color-border-light,#555)]">
        {{#each buttons}}
        <button type="{{type}}" class="tw-flex tw-items-center tw-gap-2 tw-px-4 tw-py-2 tw-border tw-border-solid tw-border-[var(--color-border-light,#555)] tw-rounded-md tw-bg-[var(--color-bg-btn,#333)] tw-text-[var(--color-text-light,#fff)] tw-text-base tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--color-bg-btn-hover,#444)] hover:tw-border-[var(--color-border-highlight,#777)] {{#if (eq cssClass 'primary')}}tw-bg-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-border-[var(--wh40k-color-accent,var(--wh40k-color-gold))] tw-text-black hover:tw-bg-[var(--wh40k-color-accent-hover,#ddb52f)]{{/if}}" {{#if action}}data-action="{{action}}"{{/if}}>
            <i class="{{icon}} tw-text-[0.85rem]"></i>
            {{localize label}}
        </button>
        {{/each}}
    </footer>
</div>
