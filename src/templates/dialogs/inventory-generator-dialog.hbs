<div class="tw-flex tw-flex-col tw-h-full tw-text-[color:var(--color-text-light-primary,#f0f0f0)]" data-wh40k-system="{{gameSystem}}">

    <header class="tw-px-4 tw-py-3 tw-bg-[rgba(0,0,0,0.3)] tw-border-b-2 tw-border-[var(--color-border-dark,#444)]">
        <h1 class="tw-m-0 tw-text-xl tw-font-semibold tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
            <i class="fa-solid fa-boxes-stacked tw-mr-2"></i>{{localize "WH40K.InventoryGenerator.Heading" actor=actorName}}
        </h1>
        <p class="tw-m-0 tw-mt-1 tw-text-xs tw-text-[color:var(--color-text-light-secondary,#999)]">{{localize "WH40K.InventoryGenerator.Hint"}}</p>
    </header>

    {{#if poolEmpty}}
    <div class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-p-8">
        <p class="tw-text-sm tw-italic tw-text-[color:var(--color-text-light-secondary,#999)]">{{localize "WH40K.InventoryGenerator.PoolEmpty"}}</p>
    </div>
    {{else}}

    <nav class="wh40k-tabs tw-flex tw-gap-1 tw-px-3 tw-pt-2 tw-bg-[rgba(0,0,0,0.2)] tw-border-b tw-border-[var(--color-border-dark,#444)]" data-group="primary">
        <button type="button" data-action="switchTab" data-tab="generate"
            class="tw-flex tw-items-center tw-gap-1.5 tw-px-4 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-solid tw-text-sm tw-font-medium tw-cursor-pointer tw-transition-colors {{#if onGenerateTab}}tw-text-gold tw-border-gold dh2:tw-text-gold-raw dh2:tw-border-gold-raw rt:tw-text-gold rt:tw-border-gold im:tw-text-failure im:tw-border-failure{{else}}tw-text-[color:var(--color-text-light-secondary,#999)] tw-border-transparent{{/if}}">
            <i class="fa-solid fa-dice"></i>{{localize "WH40K.InventoryGenerator.TabGenerate"}}
        </button>
        <button type="button" data-action="switchTab" data-tab="browse"
            class="tw-flex tw-items-center tw-gap-1.5 tw-px-4 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-solid tw-text-sm tw-font-medium tw-cursor-pointer tw-transition-colors {{#if onBrowseTab}}tw-text-gold tw-border-gold dh2:tw-text-gold-raw dh2:tw-border-gold-raw rt:tw-text-gold rt:tw-border-gold im:tw-text-failure im:tw-border-failure{{else}}tw-text-[color:var(--color-text-light-secondary,#999)] tw-border-transparent{{/if}}">
            <i class="fa-solid fa-magnifying-glass"></i>{{localize "WH40K.InventoryGenerator.TabBrowse"}}
        </button>
    </nav>

    <div class="wh40k-tab-content tw-flex tw-flex-1 tw-gap-3 tw-p-3 tw-overflow-hidden">

        {{!-- ── Left: active tab ── --}}
        <section class="tw-flex tw-flex-col tw-flex-1 tw-min-w-0 tw-overflow-hidden">

            {{#if onGenerateTab}}
            <div class="tw-flex tw-flex-col tw-gap-3">
                <label class="tw-flex tw-flex-col tw-gap-1 tw-text-xs tw-uppercase tw-tracking-wide tw-text-[color:var(--color-text-light-secondary,#999)]">
                    {{localize "WH40K.InventoryGenerator.ProfileLabel"}}
                    <select name="profile" class="tw-p-2 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[var(--color-border-dark,#444)] tw-rounded tw-text-sm tw-text-[color:var(--color-text-light-primary,#f0f0f0)] tw-normal-case">
                        <option value="" {{#unless profile}}selected{{/unless}}>{{localize "WH40K.InventoryGenerator.ProfileAny"}}</option>
                        {{#each profiles}}
                        <option value="{{this}}" {{#if (eq ../profile this)}}selected{{/if}}>{{this}}</option>
                        {{/each}}
                    </select>
                </label>

                <label class="tw-flex tw-flex-col tw-gap-1 tw-text-xs tw-uppercase tw-tracking-wide tw-text-[color:var(--color-text-light-secondary,#999)]">
                    {{localize "WH40K.InventoryGenerator.CountLabel"}}
                    <input type="number" name="count" min="1" max="100" value="{{count}}"
                        class="tw-p-2 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[var(--color-border-dark,#444)] tw-rounded tw-text-sm tw-text-[color:var(--color-text-light-primary,#f0f0f0)]">
                </label>

                <div class="tw-flex tw-gap-2">
                    <button type="button" data-action="generate"
                        class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-rounded tw-border-0 tw-text-sm tw-font-semibold tw-text-white tw-cursor-pointer tw-bg-[var(--color-cool-2,#2c5f8a)] hover:tw-bg-[var(--color-cool-3,#3a7bb0)]">
                        <i class="fa-solid fa-dice"></i>{{localize "WH40K.InventoryGenerator.Generate"}}
                    </button>
                    <button type="button" data-action="reroll"
                        class="tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-rounded tw-border tw-border-[var(--color-border-dark,#444)] tw-text-sm tw-text-[color:var(--color-text-light-secondary,#bbb)] tw-cursor-pointer tw-bg-transparent hover:tw-bg-[rgba(255,255,255,0.06)]">
                        <i class="fa-solid fa-rotate"></i>{{localize "WH40K.InventoryGenerator.Reroll"}}
                    </button>
                </div>
                <p class="tw-m-0 tw-text-xs tw-italic tw-text-[color:var(--color-text-light-secondary,#888)]">{{localize "WH40K.InventoryGenerator.GenerateHelp"}}</p>
            </div>
            {{/if}}

            {{#if onBrowseTab}}
            <div class="tw-flex tw-flex-col tw-flex-1 tw-min-h-0 tw-gap-2">
                <input type="text" name="browseSearch" value="{{browseSearch}}" placeholder="{{localize "WH40K.InventoryGenerator.SearchPlaceholder"}}"
                    class="tw-p-2 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[var(--color-border-dark,#444)] tw-rounded tw-text-sm tw-text-[color:var(--color-text-light-primary,#f0f0f0)]">
                <div class="tw-flex-1 tw-overflow-y-auto tw-border tw-border-[var(--color-border-dark,#444)] tw-rounded tw-bg-[rgba(0,0,0,0.2)]">
                    {{#each browseRows}}
                    <div class="tw-flex tw-items-center tw-gap-2 tw-px-2 tw-py-1.5 tw-border-b tw-border-[rgba(255,255,255,0.06)]">
                        <img src="{{this.img}}" alt="" class="tw-w-7 tw-h-7 tw-rounded tw-flex-shrink-0 tw-object-cover">
                        <div class="tw-flex tw-flex-col tw-min-w-0 tw-flex-1">
                            <span class="tw-text-sm tw-truncate">{{this.name}}</span>
                            <span class="tw-text-[0.7rem] tw-text-[color:var(--color-text-light-secondary,#888)] tw-truncate">{{this.type}} · {{this.availability}}</span>
                        </div>
                        <button type="button" data-action="stage" data-uuid="{{this.uuid}}"
                            class="tw-flex-shrink-0 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--color-border-dark,#444)] tw-text-xs tw-text-[color:var(--color-text-light-secondary,#bbb)] tw-cursor-pointer tw-bg-transparent hover:tw-bg-[rgba(255,255,255,0.08)]">
                            <i class="fa-solid fa-plus"></i> {{localize "WH40K.InventoryGenerator.Stage"}}
                        </button>
                    </div>
                    {{else}}
                    <p class="tw-p-4 tw-text-sm tw-italic tw-text-center tw-text-[color:var(--color-text-light-secondary,#888)]">{{localize "WH40K.InventoryGenerator.BrowseEmpty"}}</p>
                    {{/each}}
                </div>
                {{#if browseTruncated}}
                <p class="tw-m-0 tw-text-xs tw-italic tw-text-[color:var(--color-text-light-secondary,#888)]">{{localize "WH40K.InventoryGenerator.BrowseTruncated"}}</p>
                {{/if}}
            </div>
            {{/if}}

        </section>

        {{!-- ── Right: shared staging list ── --}}
        <section class="tw-flex tw-flex-col tw-w-[280px] tw-flex-shrink-0 tw-min-h-0 tw-border tw-border-[var(--color-border-dark,#444)] tw-rounded tw-bg-[rgba(0,0,0,0.2)]">
            <div class="tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-border-b tw-border-[var(--color-border-dark,#444)]">
                <span class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide">{{localize "WH40K.InventoryGenerator.Staged"}} ({{stagedCount}})</span>
                <button type="button" data-action="clearStaged"
                    class="tw-text-xs tw-text-[color:var(--color-text-light-secondary,#999)] tw-bg-transparent tw-border-0 tw-cursor-pointer hover:tw-text-[color:var(--color-warm-2,#d08770)]">
                    {{localize "WH40K.InventoryGenerator.ClearStaged"}}
                </button>
            </div>
            <div class="tw-flex-1 tw-overflow-y-auto">
                {{#each staged}}
                <div class="tw-flex tw-items-center tw-gap-2 tw-px-2 tw-py-1.5 tw-border-b tw-border-[rgba(255,255,255,0.06)]">
                    <img src="{{this.img}}" alt="" class="tw-w-6 tw-h-6 tw-rounded tw-flex-shrink-0 tw-object-cover">
                    <div class="tw-flex tw-flex-col tw-min-w-0 tw-flex-1">
                        <span class="tw-text-sm tw-truncate">{{this.name}}</span>
                        <span class="tw-text-[0.7rem] tw-text-[color:var(--color-text-light-secondary,#888)] tw-truncate">{{this.type}}</span>
                    </div>
                    <button type="button" data-action="unstage" data-uuid="{{this.uuid}}" data-tooltip="{{localize "WH40K.InventoryGenerator.Unstage"}}"
                        class="tw-flex-shrink-0 tw-bg-transparent tw-border-0 tw-text-[color:var(--color-text-light-secondary,#888)] tw-cursor-pointer hover:tw-text-[color:var(--color-warm-2,#d08770)]">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                {{else}}
                <p class="tw-p-4 tw-text-sm tw-italic tw-text-center tw-text-[color:var(--color-text-light-secondary,#888)]">{{localize "WH40K.InventoryGenerator.StagedEmpty"}}</p>
                {{/each}}
            </div>
        </section>

    </div>

    <footer class="tw-flex tw-justify-end tw-gap-2 tw-px-4 tw-py-3 tw-border-t tw-border-[var(--color-border-dark,#444)] tw-bg-[rgba(0,0,0,0.3)]">
        <button type="button" data-action="cancel"
            class="tw-px-4 tw-py-2 tw-rounded tw-border tw-border-[var(--color-border-dark,#444)] tw-text-sm tw-text-[color:var(--color-text-light-secondary,#bbb)] tw-cursor-pointer tw-bg-transparent hover:tw-bg-[rgba(255,255,255,0.06)]">
            {{localize "WH40K.InventoryGenerator.Cancel"}}
        </button>
        <button type="button" data-action="apply" {{#unless stagedCount}}disabled{{/unless}}
            class="tw-px-4 tw-py-2 tw-rounded tw-border-0 tw-text-sm tw-font-semibold tw-text-white tw-cursor-pointer tw-bg-[var(--color-cool-2,#2c5f8a)] hover:tw-bg-[var(--color-cool-3,#3a7bb0)] disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
            <i class="fa-solid fa-check tw-mr-1"></i>{{localize "WH40K.InventoryGenerator.Apply"}}
        </button>
    </footer>

    {{/if}}
</div>
