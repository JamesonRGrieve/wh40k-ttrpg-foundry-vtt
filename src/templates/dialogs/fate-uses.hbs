{{!-- Fate Uses reference dialog — read-only listing of canonical Fate Point uses. --}}
<div class="wh40k-fate-uses tw-p-3 tw-flex tw-flex-col tw-gap-2" data-wh40k-system="{{gameSystem}}">
    <p class="tw-text-[0.85rem] tw-leading-snug tw-m-0 tw-text-[color:var(--color-text-secondary)]">
        {{localize "WH40K.FateUses.Intro"}}
    </p>

    <ul class="tw-list-none tw-p-0 tw-m-0 tw-flex tw-flex-col tw-gap-1.5">
        {{#each uses as |use|}}
            <li class="wh40k-fate-uses__entry tw-flex tw-gap-2 tw-items-start tw-p-2 tw-rounded tw-border tw-border-solid tw-border-[color:var(--color-border-light)] tw-bg-[rgba(0,0,0,0.10)]
                       {{#if use.burn}}tw-border-l-4 tw-border-l-crimson bc:tw-border-l-crimson-light dh1e:tw-border-l-gold-raw dh2e:tw-border-l-crimson dw:tw-border-l-accent-combat ow:tw-border-l-brass-l20 rt:tw-border-l-gold im:tw-border-l-failure{{/if}}">
                {{#if use.icon}}
                    <i class="fas {{use.icon}} tw-text-[1.1rem] tw-mt-[2px] tw-text-[var(--wh40k-accent-gold)] bc:tw-text-crimson-light dh1e:tw-text-gold-raw dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                {{/if}}
                <div class="tw-flex tw-flex-col tw-gap-0.5 tw-flex-1">
                    <strong class="tw-text-[0.85rem] tw-font-bold tw-text-[color:var(--wh40k-text-medium)] tw-uppercase tw-tracking-[0.03em]">
                        {{localize use.label}}{{#if use.burn}} <span class="tw-text-[0.7rem] tw-font-normal tw-normal-case tw-tracking-normal tw-text-crimson">({{localize "WH40K.FateUses.BurnTag"}})</span>{{/if}}
                    </strong>
                    <span class="tw-text-[0.78rem] tw-leading-snug tw-m-0 tw-text-[color:var(--color-text-primary)]">
                        {{localize use.description}}
                    </span>
                </div>
            </li>
        {{/each}}
    </ul>

    {{#if bonusAttributes.length}}
        <div class="tw-mt-2 tw-pt-2 tw-border-t tw-border-solid tw-border-[color:var(--color-border-light)]">
            <strong class="tw-text-[0.85rem] tw-font-bold tw-text-[color:var(--wh40k-text-medium)] tw-uppercase tw-tracking-[0.03em]">
                {{localize "WH40K.FateUses.BonusAttributesTitle"}}
            </strong>
            <ul class="tw-list-disc tw-pl-4 tw-mt-1 tw-text-[0.78rem] tw-leading-snug">
                {{#each bonusAttributes as |attr|}}
                    <li><strong>{{attr.name}}:</strong> {{attr.summary}}</li>
                {{/each}}
            </ul>
        </div>
    {{/if}}

    <p class="tw-mt-1 tw-text-[0.7rem] tw-italic tw-text-[color:var(--color-text-tertiary)] tw-m-0">
        {{localize "WH40K.FateUses.Footer"}}
    </p>
</div>
