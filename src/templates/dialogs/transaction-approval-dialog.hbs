<div class="tw-flex tw-flex-col tw-gap-4 tw-p-4">
    <p class="tw-text-sm tw-text-slate-100">{{summary}}</p>

    <div class="wh40k-panel">
        <div class="wh40k-panel-header">
            <span class="wh40k-panel-title">
                <i class="fa-solid fa-receipt"></i>
                {{localize "WH40K.Trade.Approval.Adjustments"}}
            </span>
        </div>
        <div class="wh40k-panel-body tw-grid tw-gap-2 tw-text-sm tw-text-slate-100">
            <p><strong>{{localize "WH40K.Trade.Approval.Mode"}}:</strong> {{modeLabel}}</p>
            <p><strong>{{localize "WH40K.Trade.Approval.BaseCost"}}:</strong> {{quote.baseCost}} {{quote.resourceLabel}}</p>
            {{#if hasAdjustments}}
                <ul class="tw-my-1 tw-list-disc tw-pl-5 tw-text-slate-200">
                    {{#each adjustments}}
                        <li>{{label}}: {{#if positive}}+{{/if}}{{value}}</li>
                    {{/each}}
                </ul>
            {{else}}
                <p class="tw-text-slate-300">{{localize "WH40K.Trade.Approval.NoAdjustments"}}</p>
            {{/if}}
            <p><strong>{{localize "WH40K.Trade.Approval.FinalCost"}}:</strong> {{quote.finalCost}} {{quote.resourceLabel}}</p>
            {{#if quote.influenceBurn}}
                <p>{{localize "WH40K.Trade.Approval.InfluenceBurn" count=quote.influenceBurn}}</p>
            {{/if}}
        </div>
    </div>

    <div class="tw-grid tw-gap-2">
        <label for="transaction-gm-modifier" class="tw-text-sm tw-font-semibold tw-text-slate-100">
            {{localize "WH40K.Trade.Approval.GMModifierLabel"}}
        </label>
        <input
            id="transaction-gm-modifier"
            type="number"
            step="5"
            name="gmModifierPercent"
            value="{{gmModifierPercent}}"
            class="tw-rounded-md tw-border tw-border-slate-600 tw-bg-slate-950 tw-px-3 tw-py-2 tw-text-sm tw-text-slate-100"
        />
        <p class="tw-text-xs tw-text-slate-400">{{localize "WH40K.Trade.Approval.GMModifierHint"}}</p>
        <p class="tw-text-sm tw-text-slate-100">
            <strong>{{localize "WH40K.Trade.Approval.FinalCost"}}:</strong> ~{{estimatedFinal}} {{quote.resourceLabel}}
        </p>
    </div>

    <footer class="tw-flex tw-justify-end tw-gap-2">
        <button
            type="button"
            class="tw-inline-flex tw-items-center tw-gap-2 tw-rounded-md tw-border tw-border-slate-600 tw-px-4 tw-py-2 tw-font-semibold tw-text-slate-200 hover:tw-bg-slate-800"
            data-action="reject"
        >
            <i class="fa-solid fa-xmark"></i>
            <span>{{localize "WH40K.Trade.Approval.Reject"}}</span>
        </button>
        <button
            type="button"
            class="tw-inline-flex tw-items-center tw-gap-2 tw-rounded-md tw-bg-amber-600 tw-px-4 tw-py-2 tw-font-semibold tw-text-slate-950 hover:tw-bg-amber-500"
            data-action="approve"
        >
            <i class="fa-solid fa-check"></i>
            <span>{{localize "WH40K.Trade.Approval.Approve"}}</span>
        </button>
    </footer>
</div>
