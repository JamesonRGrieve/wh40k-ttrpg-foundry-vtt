{{!-- Effect Creation Dialog Template --}}
<form class="tw-flex tw-flex-col tw-gap-4 tw-p-3">

    {{!-- Category Selection Tabs --}}
    <div class="tw-grid tw-grid-cols-5 tw-gap-1 tw-p-2 tw-bg-black/30 tw-rounded-lg tw-border tw-border-solid tw-border-[var(--wh40k-accent-gold)]/20">
        <button type="button"
                class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-1.5 tw-p-2 tw-bg-white/5 tw-border tw-border-solid tw-border-white/10 tw-rounded-md tw-text-white/70 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all hover:tw-bg-white/10 hover:tw-border-[var(--wh40k-accent-gold)]/50 hover:tw-text-[var(--wh40k-accent-gold)] hover:-tw-translate-y-0.5 data-[active=true]:tw-bg-gradient-to-br data-[active=true]:tw-from-[var(--wh40k-accent-gold)]/30 data-[active=true]:tw-to-[var(--wh40k-accent-gold)]/20 data-[active=true]:tw-border-[var(--wh40k-accent-gold)] data-[active=true]:tw-text-[var(--wh40k-accent-gold)] data-[active=true]:tw-shadow-[0_0_12px_var(--wh40k-accent-gold)] [&>i]:tw-text-xl [&>span]:tw-leading-none"
                data-active="{{#if (eq selectedCategory 'condition')}}true{{else}}false{{/if}}"
                data-action="selectCategory"
                data-category="condition">
            <i class="fas fa-person-circle-exclamation"></i>
            <span>Conditions</span>
        </button>
        <button type="button"
                class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-1.5 tw-p-2 tw-bg-white/5 tw-border tw-border-solid tw-border-white/10 tw-rounded-md tw-text-white/70 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all hover:tw-bg-white/10 hover:tw-border-[var(--wh40k-accent-gold)]/50 hover:tw-text-[var(--wh40k-accent-gold)] hover:-tw-translate-y-0.5 data-[active=true]:tw-bg-gradient-to-br data-[active=true]:tw-from-[var(--wh40k-accent-gold)]/30 data-[active=true]:tw-to-[var(--wh40k-accent-gold)]/20 data-[active=true]:tw-border-[var(--wh40k-accent-gold)] data-[active=true]:tw-text-[var(--wh40k-accent-gold)] data-[active=true]:tw-shadow-[0_0_12px_var(--wh40k-accent-gold)] [&>i]:tw-text-xl [&>span]:tw-leading-none"
                data-active="{{#if (eq selectedCategory 'characteristic')}}true{{else}}false{{/if}}"
                data-action="selectCategory"
                data-category="characteristic">
            <i class="fas fa-shield-halved"></i>
            <span>Characteristics</span>
        </button>
        <button type="button"
                class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-1.5 tw-p-2 tw-bg-white/5 tw-border tw-border-solid tw-border-white/10 tw-rounded-md tw-text-white/70 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all hover:tw-bg-white/10 hover:tw-border-[var(--wh40k-accent-gold)]/50 hover:tw-text-[var(--wh40k-accent-gold)] hover:-tw-translate-y-0.5 data-[active=true]:tw-bg-gradient-to-br data-[active=true]:tw-from-[var(--wh40k-accent-gold)]/30 data-[active=true]:tw-to-[var(--wh40k-accent-gold)]/20 data-[active=true]:tw-border-[var(--wh40k-accent-gold)] data-[active=true]:tw-text-[var(--wh40k-accent-gold)] data-[active=true]:tw-shadow-[0_0_12px_var(--wh40k-accent-gold)] [&>i]:tw-text-xl [&>span]:tw-leading-none"
                data-active="{{#if (eq selectedCategory 'skill')}}true{{else}}false{{/if}}"
                data-action="selectCategory"
                data-category="skill">
            <i class="fas fa-users-gear"></i>
            <span>Skills</span>
        </button>
        <button type="button"
                class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-1.5 tw-p-2 tw-bg-white/5 tw-border tw-border-solid tw-border-white/10 tw-rounded-md tw-text-white/70 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all hover:tw-bg-white/10 hover:tw-border-[var(--wh40k-accent-gold)]/50 hover:tw-text-[var(--wh40k-accent-gold)] hover:-tw-translate-y-0.5 data-[active=true]:tw-bg-gradient-to-br data-[active=true]:tw-from-[var(--wh40k-accent-gold)]/30 data-[active=true]:tw-to-[var(--wh40k-accent-gold)]/20 data-[active=true]:tw-border-[var(--wh40k-accent-gold)] data-[active=true]:tw-text-[var(--wh40k-accent-gold)] data-[active=true]:tw-shadow-[0_0_12px_var(--wh40k-accent-gold)] [&>i]:tw-text-xl [&>span]:tw-leading-none"
                data-active="{{#if (eq selectedCategory 'combat')}}true{{else}}false{{/if}}"
                data-action="selectCategory"
                data-category="combat">
            <i class="fas fa-swords"></i>
            <span>Combat</span>
        </button>
        <button type="button"
                class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-1.5 tw-p-2 tw-bg-white/5 tw-border tw-border-solid tw-border-white/10 tw-rounded-md tw-text-white/70 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all hover:tw-bg-white/10 hover:tw-border-[var(--wh40k-accent-gold)]/50 hover:tw-text-[var(--wh40k-accent-gold)] hover:-tw-translate-y-0.5 data-[active=true]:tw-bg-gradient-to-br data-[active=true]:tw-from-[var(--wh40k-accent-gold)]/30 data-[active=true]:tw-to-[var(--wh40k-accent-gold)]/20 data-[active=true]:tw-border-[var(--wh40k-accent-gold)] data-[active=true]:tw-text-[var(--wh40k-accent-gold)] data-[active=true]:tw-shadow-[0_0_12px_var(--wh40k-accent-gold)] [&>i]:tw-text-xl [&>span]:tw-leading-none"
                data-active="{{#if (eq selectedCategory 'custom')}}true{{else}}false{{/if}}"
                data-action="selectCategory"
                data-category="custom">
            <i class="fas fa-wand-sparkles"></i>
            <span>Custom</span>
        </button>
    </div>

    {{!-- Hidden field to track effect type --}}
    <input type="hidden" name="effectType" value="{{selectedCategory}}" />

    {{!-- Condition Selection Grid --}}
    {{#if (eq selectedCategory 'condition')}}
        <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3 tw-bg-black/20 tw-border tw-border-solid tw-border-white/10 tw-rounded-lg">
            <div class="tw-flex tw-items-center tw-gap-2 tw-pb-2 tw-border-b-2 tw-border-solid tw-border-[var(--wh40k-accent-gold)]/30 tw-text-md tw-font-bold tw-uppercase tw-tracking-[0.1em] tw-text-[var(--wh40k-accent-gold)] [&>i]:tw-text-[1.1rem]">
                <i class="fas fa-bolt"></i>
                <span>Quick Apply Condition</span>
            </div>
            <div class="tw-grid tw-grid-cols-3 tw-gap-2 tw-mt-2">
                {{#each conditions as |condition|}}
                    <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-1 tw-p-3 tw-bg-black/30 tw-border-2 tw-border-solid tw-rounded-lg tw-cursor-pointer tw-transition-all hover:-tw-translate-y-0.5 {{#if (eq condition.nature 'harmful')}}tw-border-red-500/30 hover:tw-bg-red-500/15 hover:tw-border-[var(--wh40k-accent-red)] hover:tw-shadow-[0_4px_16px_rgba(231,76,60,0.3)] [&>.condition-icon]:tw-text-[var(--wh40k-accent-red)]{{else if (eq condition.nature 'beneficial')}}tw-border-green-500/30 hover:tw-bg-green-500/15 hover:tw-border-[var(--wh40k-accent-green-bright)] hover:tw-shadow-[0_4px_16px_rgba(46,204,113,0.3)] [&>.condition-icon]:tw-text-[var(--wh40k-accent-green-bright)]{{else}}tw-border-transparent{{/if}}"
                         data-action="selectCondition"
                         data-condition-id="{{condition.id}}">
                        <i class="{{condition.icon}} condition-icon tw-text-3xl"></i>
                        <span class="tw-text-white/90 tw-text-[0.85rem] tw-font-semibold tw-text-center">{{condition.name}}</span>
                    </div>
                {{/each}}
            </div>
            <input type="hidden" name="conditionId" />

            {{!-- Optional duration for conditions --}}
            <div class="tw-mt-3 tw-pt-3 tw-border-t tw-border-solid tw-border-white/10 tw-flex tw-flex-col tw-gap-1">
                <label class="tw-flex tw-items-center tw-gap-1 tw-text-white/80 tw-text-[0.85rem] tw-font-semibold [&>i]:tw-text-[var(--wh40k-accent-gold)]">
                    <i class="far fa-clock"></i> Duration (Rounds)
                </label>
                <input type="number"
                       name="duration.rounds"
                       min="0"
                       placeholder="Leave blank for permanent"
                       class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)] placeholder:tw-text-white/40" />
                <span class="tw-text-white/50 tw-text-xs tw-italic tw-mt-0.5">Leave blank for permanent effect</span>
            </div>
        </div>
    {{/if}}

    {{!-- Characteristic Modifier --}}
    {{#if (eq selectedCategory 'characteristic')}}
        <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3 tw-bg-black/20 tw-border tw-border-solid tw-border-white/10 tw-rounded-lg">
            <div class="tw-flex tw-items-center tw-gap-2 tw-pb-2 tw-border-b-2 tw-border-solid tw-border-[var(--wh40k-accent-gold)]/30 tw-text-md tw-font-bold tw-uppercase tw-tracking-[0.1em] tw-text-[var(--wh40k-accent-gold)] [&>i]:tw-text-[1.1rem]">
                <i class="fas fa-chart-line"></i>
                <span>Modify Characteristic</span>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="characteristic">Characteristic</label>
                <select name="characteristic" id="characteristic" class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)]">
                    <option value="">-- Select Characteristic --</option>
                    {{#each characteristics as |char|}}
                        <option value="{{char.id}}">{{char.label}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="modifierValue">Modifier</label>
                <div class="tw-flex tw-items-stretch [&>input]:tw-flex-1 [&>input]:tw-rounded-r-none [&>input]:tw-border-r-0">
                    <input type="number"
                           name="modifierValue"
                           id="modifierValue"
                           class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)] placeholder:tw-text-white/40"
                           placeholder="+10 or -20"
                           step="5" />
                    <span class="tw-flex tw-items-center tw-justify-center tw-px-3 tw-bg-black/30 tw-border tw-border-solid tw-border-white/20 tw-border-l-0 tw-rounded-r-md tw-text-[var(--wh40k-accent-gold)]">
                        <i class="fas fa-plus-minus"></i>
                    </span>
                </div>
                <span class="tw-text-white/50 tw-text-xs tw-italic tw-mt-0.5">Positive for bonus, negative for penalty</span>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="charDuration">Duration (Rounds)</label>
                <input type="number"
                       name="duration.rounds"
                       id="charDuration"
                       min="0"
                       placeholder="Leave blank for permanent"
                       class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)] placeholder:tw-text-white/40" />
            </div>
        </div>
    {{/if}}

    {{!-- Skill Modifier --}}
    {{#if (eq selectedCategory 'skill')}}
        <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3 tw-bg-black/20 tw-border tw-border-solid tw-border-white/10 tw-rounded-lg">
            <div class="tw-flex tw-items-center tw-gap-2 tw-pb-2 tw-border-b-2 tw-border-solid tw-border-[var(--wh40k-accent-gold)]/30 tw-text-md tw-font-bold tw-uppercase tw-tracking-[0.1em] tw-text-[var(--wh40k-accent-gold)] [&>i]:tw-text-[1.1rem]">
                <i class="fas fa-user-graduate"></i>
                <span>Modify Skill</span>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="skill">Skill</label>
                <select name="skill" id="skill" class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)]">
                    <option value="">-- Select Skill --</option>
                    {{#each skills as |skill|}}
                        <option value="{{skill.id}}">{{skill.label}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="skillModifier">Modifier</label>
                <div class="tw-flex tw-items-stretch [&>input]:tw-flex-1 [&>input]:tw-rounded-r-none [&>input]:tw-border-r-0">
                    <input type="number"
                           name="modifierValue"
                           id="skillModifier"
                           class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)] placeholder:tw-text-white/40"
                           placeholder="+10 or -20"
                           step="5" />
                    <span class="tw-flex tw-items-center tw-justify-center tw-px-3 tw-bg-black/30 tw-border tw-border-solid tw-border-white/20 tw-border-l-0 tw-rounded-r-md tw-text-[var(--wh40k-accent-gold)]">
                        <i class="fas fa-plus-minus"></i>
                    </span>
                </div>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="skillDuration">Duration (Rounds)</label>
                <input type="number"
                       name="duration.rounds"
                       id="skillDuration"
                       min="0"
                       placeholder="Leave blank for permanent"
                       class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)] placeholder:tw-text-white/40" />
            </div>
        </div>
    {{/if}}

    {{!-- Combat Modifier --}}
    {{#if (eq selectedCategory 'combat')}}
        <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3 tw-bg-black/20 tw-border tw-border-solid tw-border-white/10 tw-rounded-lg">
            <div class="tw-flex tw-items-center tw-gap-2 tw-pb-2 tw-border-b-2 tw-border-solid tw-border-[var(--wh40k-accent-gold)]/30 tw-text-md tw-font-bold tw-uppercase tw-tracking-[0.1em] tw-text-[var(--wh40k-accent-gold)] [&>i]:tw-text-[1.1rem]">
                <i class="fas fa-crosshairs"></i>
                <span>Modify Combat Stats</span>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="combatType">Combat Stat</label>
                <select name="combatType" id="combatType" class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)]">
                    <option value="">-- Select Combat Stat --</option>
                    {{#each combatTypes as |type|}}
                        <option value="{{type.id}}">{{type.label}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="combatModifier">Modifier</label>
                <div class="tw-flex tw-items-stretch [&>input]:tw-flex-1 [&>input]:tw-rounded-r-none [&>input]:tw-border-r-0">
                    <input type="number"
                           name="modifierValue"
                           id="combatModifier"
                           class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)] placeholder:tw-text-white/40"
                           placeholder="+5 or -10"
                           step="5" />
                    <span class="tw-flex tw-items-center tw-justify-center tw-px-3 tw-bg-black/30 tw-border tw-border-solid tw-border-white/20 tw-border-l-0 tw-rounded-r-md tw-text-[var(--wh40k-accent-gold)]">
                        <i class="fas fa-plus-minus"></i>
                    </span>
                </div>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="combatDuration">Duration (Rounds)</label>
                <input type="number"
                       name="duration.rounds"
                       id="combatDuration"
                       min="0"
                       placeholder="Leave blank for permanent"
                       class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)] placeholder:tw-text-white/40" />
            </div>
        </div>
    {{/if}}

    {{!-- Custom Effect --}}
    {{#if (eq selectedCategory 'custom')}}
        <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3 tw-bg-black/20 tw-border tw-border-solid tw-border-white/10 tw-rounded-lg">
            <div class="tw-flex tw-items-center tw-gap-2 tw-pb-2 tw-border-b-2 tw-border-solid tw-border-[var(--wh40k-accent-gold)]/30 tw-text-md tw-font-bold tw-uppercase tw-tracking-[0.1em] tw-text-[var(--wh40k-accent-gold)] [&>i]:tw-text-[1.1rem]">
                <i class="fas fa-pen-fancy"></i>
                <span>Create Custom Effect</span>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1 [&>label]:tw-text-white/90 [&>label]:tw-text-[0.85rem] [&>label]:tw-font-semibold [&>label]:tw-uppercase [&>label]:tw-tracking-[0.05em]">
                <label for="customName">Effect Name</label>
                <input type="text"
                       name="customName"
                       id="customName"
                       class="tw-p-2 tw-bg-black/50 tw-border tw-border-solid tw-border-white/20 tw-rounded-md tw-text-white/90 tw-text-base tw-transition-all focus:tw-outline-none focus:tw-border-[var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_8px_var(--wh40k-accent-gold)] placeholder:tw-text-white/40"
                       placeholder="Enter effect name..."
                       required />
                <span class="tw-text-white/50 tw-text-xs tw-italic tw-mt-0.5">A blank effect sheet will open for advanced configuration</span>
            </div>

            <div class="tw-flex tw-gap-2 tw-p-3 tw-bg-blue-500/10 tw-border tw-border-solid tw-border-blue-500/30 tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-info)] tw-rounded-md [&>i]:tw-shrink-0 [&>i]:tw-text-[var(--wh40k-accent-info)] [&>i]:tw-text-[1.1rem] [&>i]:tw-mt-0.5 [&>p]:tw-m-0 [&>p]:tw-text-white/80 [&>p]:tw-text-[0.85rem] [&>p]:tw-leading-[1.5]">
                <i class="fas fa-info-circle"></i>
                <p>This will create an empty effect that you can configure manually. Use the effect sheet to add changes, duration, and other properties.</p>
            </div>
        </div>
    {{/if}}

    {{!-- Dialog Buttons --}}
    <footer class="tw-flex tw-justify-end tw-gap-2 tw-p-3 tw-mt-4 tw-bg-black/30 tw-border-t tw-border-solid tw-border-[var(--wh40k-accent-gold)]/30 tw-rounded-b-lg">
        <button type="submit"
                class="tw-flex tw-items-center tw-gap-1 tw-px-4 tw-py-2 tw-rounded-md tw-text-[0.85rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all hover:-tw-translate-y-px tw-bg-gradient-to-br tw-from-[var(--wh40k-accent-gold)] tw-to-[var(--wh40k-accent-gold)]/80 tw-text-[#0a0a0f] tw-border tw-border-solid tw-border-[var(--wh40k-accent-gold)] hover:tw-shadow-[0_4px_12px_var(--wh40k-accent-gold)] [&>i]:tw-text-[0.9rem]">
            <i class="fas fa-check"></i>
            Create Effect
        </button>
        <button type="button"
