{{!-- Advancement Dialog Template --}}
<div class="tw-flex tw-flex-col tw-h-full tw-gap-0 tw-font-[var(--wh40k-font-ui)]" data-wh40k-system="{{_gameSystemId}}">

  {{!-- Header with XP Display (sticky so totals stay visible while content scrolls — #22) --}}
  <header class="tw-sticky tw-top-0 tw-z-20 tw-bg-[var(--color-bg-secondary)] tw-shrink-0">
    <div>
      <div>
        <div style="width: {{xp.usedPercent}}%">
          <span class="tw-pointer-events-none tw-absolute tw-inset-0 tw-animate-xp-shimmer tw-bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent)]"></span>
        </div>
      </div>
      <div>
        <span class="bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat im:tw-text-failure ow:tw-text-brass-l20 rt:tw-text-gold">
          <i class="fas fa-bolt"></i>
          <strong>{{xp.available}}</strong> {{localize "WH40K.Advancement.XPAvailable"}}
        </span>
        <span>
          ({{xp.used}} / {{xp.total}} {{localize "WH40K.Advancement.XPUsed"}})
        </span>
      </div>
    </div>
  </header>

  {{!-- No Career Selected - Blocked State --}}
  {{#unless hasCareer}}
  <div class="tw-animate-[fadeIn_250ms_ease]">
    <div>
      <i class="fas fa-route"></i>
    </div>
    <h3>{{localize "WH40K.Advancement.NoCareerTitle"}}</h3>
    <p>{{localize "WH40K.Advancement.NoCareerMessage"}}</p>
    <div>
      <i class="fas fa-info-circle"></i>
      <span>{{localize "WH40K.Advancement.NoCareerHint"}}</span>
    </div>
  </div>
  {{else}}

  {{!-- Tab Navigation (sticky alongside the header so the tab bar stays anchored) --}}
  <nav class="tw-sticky tw-top-[var(--wh40k-adv-header-h,4rem)] tw-z-10 tw-bg-[var(--color-bg-secondary)] tw-shrink-0">
    {{#each tabs}}
    <button
      class="{{#if this.active}}active{{/if}}"
      data-action="switchTab"
      data-tab="{{this.id}}"
      type="button"
    >
      <i class="fas {{this.icon}}"></i>
      <span>{{localize this.label}}</span>
    </button>
    {{/each}}
  </nav>

  {{!-- Content Area — scrollable so options below the window edge are reachable (#22). The
       PARTS.scrollable selector targets .wh40k-adv__content; this class also lets the parent
       flex container claim remaining height via tw-flex-1 tw-min-h-0. --}}
  <div class="wh40k-adv__content tw-flex-1 tw-min-h-0 tw-overflow-y-auto">

    {{!-- Characteristics Tab --}}
    {{#if (eq activeTab "characteristics")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      <div>
        {{#each characteristics}}
        <div class="{{#if this.recentlyPurchased}}tw-animate-purchasePulse{{/if}}">

          <div>
            <span>{{this.abbreviation}}</span>
            <span>{{this.currentValue}}</span>
          </div>

          <div>{{this.label}}</div>

          {{#if this.aptitudeMatch}}
          <div data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
            {{#each this.aptitudeMatch.matched}}<span></span>{{/each}}
            {{#each this.aptitudeMatch.unmatched}}<span></span>{{/each}}
          </div>
          {{/if}}

          {{!-- Tier Progress Dots --}}
          <div>
            {{#each this.tiers}}
            <div
              class="{{#if this.current}}tw-animate-currentPulse{{/if}}"
              title="{{this.label}}"
            ></div>
            {{/each}}
          </div>

          {{!-- Purchase Button or Status --}}
          {{#if this.isMaxed}}
          <div>
            <i class="fas fa-crown"></i>
            {{localize "WH40K.Advancement.Maxed"}}
          </div>
          {{else if this.canPurchase}}
          <button
            data-action="purchaseCharacteristic"
            data-characteristic="{{this.key}}"
            type="button"
          >
            <span>{{this.nextTierLabel}}</span>
            <span>{{this.nextCost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span>{{this.nextCost}} XP</span>
          </div>
          {{/if}}

        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- Skills Tab --}}
    {{#if (eq activeTab "skills")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      {{#if skills.length}}
      <div>
        {{#each skills}}
        <div class="{{#if this.recentlyPurchased}}tw-animate-purchasePulse{{/if}}">
          <div>
            <span>{{this.displayName}}</span>
            <a
               data-action="openCompendiumItem"
               data-name="{{this.displayName}}"
               data-type="skill"
               title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.aptitudeMatch}}
            <span data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
              {{#each this.aptitudeMatch.matched}}<span></span>{{/each}}
              {{#each this.aptitudeMatch.unmatched}}<span></span>{{/each}}
            </span>
            {{/if}}
            {{#if this.owned}}
            <span class="tw-text-[0.7rem] tw-py-[0.15rem] tw-px-[0.4rem] tw-rounded-[3px] tw-inline-flex tw-items-center tw-gap-1 tw-w-fit tw-bg-[rgba(45,80,22,0.3)] tw-text-[#7cb342]">
              <i class="fas fa-check"></i> {{localize "WH40K.Advancement.Owned"}}
            </span>
            {{/if}}
          </div>

          {{#if this.blocked}}
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-[color:var(--color-text-secondary)] tw-cursor-help [&_i]:tw-text-[color:var(--wh40k-color-warning)]" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
            <i class="fas fa-lock"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <div>
            <i class="fas fa-check-circle"></i>
          </div>
          {{else if this.canPurchase}}
          <button
            class="tw-py-[0.4rem] tw-px-[0.8rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="skill"
            type="button"
          >
            <span>{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div>
        <i class="fas fa-book"></i>
        <p>{{localize "WH40K.Advancement.NoSkillsAvailable"}}</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Talents Tab --}}
    {{#if (eq activeTab "talents")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      {{#if talents.length}}
      <div>
        {{#each talents}}
        <div class="{{#if this.recentlyPurchased}}tw-animate-purchasePulse{{/if}}">
          <div>
            <span title="Tier {{this.tier}}">T{{this.tier}}</span>
            <span>{{this.displayName}}</span>
            <a
               data-action="openCompendiumItem"
               data-name="{{this.name}}"
               data-type="talent"
               title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.aptitudeMatch}}
            <span data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
              {{#each this.aptitudeMatch.matched}}<span></span>{{/each}}
              {{#each this.aptitudeMatch.unmatched}}<span></span>{{/each}}
            </span>
            {{/if}}
            {{#if this.owned}}
            <span class="tw-text-[0.7rem] tw-py-[0.15rem] tw-px-[0.4rem] tw-rounded-[3px] tw-inline-flex tw-items-center tw-gap-1 tw-w-fit tw-bg-[rgba(45,80,22,0.3)] tw-text-[#7cb342]">
              <i class="fas fa-check"></i> {{localize "WH40K.Advancement.Owned"}}
            </span>
            {{/if}}
            {{#if this.blocked}}
            <span title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
              <i class="fas fa-exclamation-triangle"></i>
              {{localize "WH40K.Advancement.RequiresPrereq"}}
            </span>
            {{/if}}
          </div>

          {{#if this.blocked}}
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-[color:var(--color-text-secondary)] tw-cursor-help [&_i]:tw-text-[color:var(--wh40k-color-warning)]" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
            <i class="fas fa-lock"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <div>
            <i class="fas fa-check-circle"></i>
          </div>
          {{else if this.canPurchase}}
          <button
            class="tw-py-[0.4rem] tw-px-[0.8rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="talent"
            type="button"
          >
            <span>{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div>
        <i class="fas fa-star"></i>
        <p>{{localize "WH40K.Advancement.NoTalentsAvailable"}}</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Psychic Powers Tab (psykers only) --}}
    {{#if (eq activeTab "psychic")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      {{#if psychic}}
      <div>
        <div>
          <i class="fas fa-brain"></i>
          <span>Psy Rating</span>
          <span>{{psychic.psyAdvance.currentRating}}</span>
        </div>
        {{#if psychic.psyAdvance.maxed}}
        <span><i class="fas fa-crown"></i> Maximum</span>
        {{else if psychic.psyAdvance.canPurchase}}
        <button class="tw-py-[0.4rem] tw-px-[0.8rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]" data-action="purchasePsyRating" type="button">
          <span>Advance to {{psychic.psyAdvance.nextRating}}</span>
          <span>{{psychic.psyAdvance.cost}} XP</span>
        </button>
        {{else}}
        <div>
          <i class="fas fa-coins"></i>
          <span>Advance to {{psychic.psyAdvance.nextRating}} — {{psychic.psyAdvance.cost}} XP</span>
        </div>
        {{/if}}
      </div>

      {{#if psychic.chips.length}}
      <div>
        <nav>
          {{#each psychic.chips as |chip|}}
          <button type="button"
                  class="{{#if chip.active}}active{{/if}}"
                  data-action="switchDiscipline"
                  data-discipline="{{chip.key}}"
                  title="{{chip.accessible}} accessible / {{chip.count}} total">
            <span>{{chip.label}}</span>
            <span>{{chip.accessible}}/{{chip.count}}</span>
          </button>
          {{/each}}
        </nav>
        {{#if psychic.hasBlocked}}
        <button type="button"
                class="{{#if psychic.availableOnly}}active{{/if}}"
                data-action="toggleAvailableOnly"
                title="Show only powers at or below your Psy Rating">
          <i class="fas {{#if psychic.availableOnly}}fa-check-square{{else}}fa-square{{/if}}"></i>
          Available to me
        </button>
        {{/if}}
      </div>
      {{/if}}

      {{#each psychic.disciplines as |discipline|}}
      <h4>{{discipline.label}}</h4>
      <div>
        {{#each discipline.items}}
        <div>
          <div>
            <span title="Psy Rating {{this.prCost}}">PR{{this.prCost}}</span>
            <span>{{this.displayName}}</span>
            <a
               data-action="openCompendiumItem"
               data-name="{{this.name}}"
               data-type="psychicPower"
               title="View in Compendium">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.owned}}
            <span class="tw-text-[0.7rem] tw-py-[0.15rem] tw-px-[0.4rem] tw-rounded-[3px] tw-inline-flex tw-items-center tw-gap-1 tw-w-fit tw-bg-[rgba(45,80,22,0.3)] tw-text-[#7cb342]">
              <i class="fas fa-check"></i> Owned
            </span>
            {{/if}}
            {{#if this.blocked}}
            <span title="{{#each this.prereqDisplay}}{{this}}{{/each}}">
              <i class="fas fa-exclamation-triangle"></i>
              Requires PR {{this.prCost}}
            </span>
            {{/if}}
          </div>
          {{#if this.blocked}}
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-[color:var(--color-text-secondary)] tw-cursor-help [&_i]:tw-text-[color:var(--wh40k-color-warning)]">
            <i class="fas fa-lock"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <div><i class="fas fa-check-circle"></i></div>
          {{else if this.canPurchase}}
          <button class="tw-py-[0.4rem] tw-px-[0.8rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="psychic-power"
            type="button">
            <span>{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div>
            <i class="fas fa-coins"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/each}}

      {{#unless psychic.disciplines.length}}
      <div>
        <i class="fas fa-filter"></i>
        <p>No powers match the current filter.</p>
      </div>
      {{/unless}}
      {{else}}
      <div>
        <i class="fas fa-brain"></i>
        <p>No psychic powers available. Take the Psyker elite advance to unlock.</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Traits Tab --}}
    {{#if (eq activeTab "traits")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      {{#if traits.owned.length}}
      <h4>Current Traits</h4>
      <div>
        {{#each traits.owned}}
        <div>
          <div>
            <span>{{this.name}}</span>
            <span class="tw-text-[0.7rem] tw-py-[0.15rem] tw-px-[0.4rem] tw-rounded-[3px] tw-inline-flex tw-items-center tw-gap-1 tw-w-fit">
              <i class="fas fa-seedling"></i> {{this.source}}
            </span>
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if traits.elites.length}}
      <h4>Elite Advances</h4>
      <p class="tw-text-xs tw-opacity-70 tw-mb-2 tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
        Elite advances are fundamental character changes that grant new traits, talents, and unlocks. Requires GM approval in play.
      </p>
      <div>
        {{#each traits.elites}}
        <div>
          <div>
            <span>{{this.name}}</span>
            <a
               data-action="openCompendiumItem"
               data-name="{{this.name}}"
               data-type="originPath"
               title="View in Compendium">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.owned}}
            <span class="tw-text-[0.7rem] tw-py-[0.15rem] tw-px-[0.4rem] tw-rounded-[3px] tw-inline-flex tw-items-center tw-gap-1 tw-w-fit tw-bg-[rgba(45,80,22,0.3)] tw-text-[#7cb342]">
              <i class="fas fa-check"></i> Taken
            </span>
            {{/if}}
          </div>
          {{#if this.owned}}
          <div><i class="fas fa-check-circle"></i></div>
          {{else if this.canPurchase}}
          <button class="tw-py-[0.4rem] tw-px-[0.8rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="elite"
            type="button">
            <span>{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div>
            <i class="fas fa-coins"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#unless (or traits.owned.length traits.elites.length)}}
      <div>
        <i class="fas fa-dna"></i>
        <p>No traits yet. Traits are granted by home world, background, or elite advances — they can't be bought directly with XP.</p>
      </div>
      {{/unless}}
    </div>
    {{/if}}

  </div>
  {{/unless}}
</div>
