{{!-- Advancement Dialog Template --}}
<div class="wh40k-adv">
  
  {{!-- Header with XP Display --}}
  <header class="wh40k-adv__header">
    <div class="wh40k-adv__xp-display">
      <div class="wh40k-adv__xp-bar">
        <div class="wh40k-adv__xp-fill" style="width: {{xp.usedPercent}}%"></div>
      </div>
      <div class="wh40k-adv__xp-info">
        <span class="wh40k-adv__xp-available">
          <i class="fas fa-bolt"></i>
          <strong>{{xp.available}}</strong> {{localize "WH40K.Advancement.XPAvailable"}}
        </span>
        <span class="wh40k-adv__xp-total">
          ({{xp.used}} / {{xp.total}} {{localize "WH40K.Advancement.XPUsed"}})
        </span>
      </div>
    </div>
  </header>

  {{!-- No Career Selected - Blocked State --}}
  {{#unless hasCareer}}
  <div class="wh40k-adv__blocked-state">
    <div class="wh40k-adv__blocked-icon">
      <i class="fas fa-route"></i>
    </div>
    <h3 class="wh40k-adv__blocked-title">{{localize "WH40K.Advancement.NoCareerTitle"}}</h3>
    <p class="wh40k-adv__blocked-message">{{localize "WH40K.Advancement.NoCareerMessage"}}</p>
    <div class="wh40k-adv__blocked-hint">
      <i class="fas fa-info-circle"></i>
      <span>{{localize "WH40K.Advancement.NoCareerHint"}}</span>
    </div>
  </div>
  {{else}}

  {{!-- Tab Navigation --}}
  <nav class="wh40k-adv__tabs">
    {{#each tabs}}
    <button 
      class="wh40k-adv__tab {{#if this.active}}wh40k-adv__tab--active{{/if}}"
      data-action="switchTab"
      data-tab="{{this.id}}"
      type="button"
    >
      <i class="fas {{this.icon}}"></i>
      <span>{{localize this.label}}</span>
    </button>
    {{/each}}
  </nav>

  {{!-- Content Area --}}
  <div class="wh40k-adv__content">

    {{!-- Characteristics Tab --}}
    {{#if (eq activeTab "characteristics")}}
    <div class="wh40k-adv__panel wh40k-adv__panel--characteristics">
      <div class="wh40k-adv__char-grid">
        {{#each characteristics}}
        <div class="wh40k-adv__char-card {{#if this.recentlyPurchased}}wh40k-adv__char-card--purchased{{/if}} {{#if this.isMaxed}}wh40k-adv__char-card--maxed{{/if}}">
          
          <div class="wh40k-adv__char-header">
            <span class="wh40k-adv__char-abbr">{{this.abbreviation}}</span>
            <span class="wh40k-adv__char-value">{{this.currentValue}}</span>
          </div>
          
          <div class="wh40k-adv__char-name">{{this.label}}</div>
          
          {{!-- Tier Progress Dots --}}
          <div class="wh40k-adv__char-tiers">
            {{#each this.tiers}}
            <div 
              class="wh40k-adv__tier-dot {{#if this.purchased}}wh40k-adv__tier-dot--purchased{{/if}} {{#if this.current}}wh40k-adv__tier-dot--current{{/if}}"
              title="{{this.label}}"
            ></div>
            {{/each}}
          </div>

          {{!-- Purchase Button or Status --}}
          {{#if this.isMaxed}}
          <div class="wh40k-adv__char-status wh40k-adv__char-status--maxed">
            <i class="fas fa-crown"></i>
            {{localize "WH40K.Advancement.Maxed"}}
          </div>
          {{else if this.canPurchase}}
          <button 
            class="wh40k-adv__char-btn"
            data-action="purchaseCharacteristic"
            data-characteristic="{{this.key}}"
            type="button"
          >
            <span class="wh40k-adv__char-tier-label">{{this.nextTierLabel}}</span>
            <span class="wh40k-adv__char-cost">{{this.nextCost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="wh40k-adv__char-status wh40k-adv__char-status--cant-afford" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span class="wh40k-adv__char-cost wh40k-adv__char-cost--expensive">{{this.nextCost}} XP</span>
          </div>
          {{/if}}

        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- Skills Tab --}}
    {{#if (eq activeTab "skills")}}
    <div class="wh40k-adv__panel wh40k-adv__panel--skills">
      {{#if skills.length}}
      <div class="wh40k-adv__advance-list">
        {{#each skills}}
        <div class="wh40k-adv__advance-card 
          {{#if this.owned}}wh40k-adv__advance-card--owned{{/if}}
          {{#if this.blocked}}wh40k-adv__advance-card--blocked{{/if}}
          {{#if this.cantAfford}}wh40k-adv__advance-card--cant-afford{{/if}}
          {{#if this.recentlyPurchased}}wh40k-adv__advance-card--purchased{{/if}}"
        >
          <div class="wh40k-adv__advance-info">
            <span class="wh40k-adv__advance-name">{{this.displayName}}</span>
            <a class="wh40k-adv__advance-link" 
               data-action="openCompendiumItem" 
               data-name="{{this.displayName}}" 
               data-type="skill"
               title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.owned}}
            <span class="wh40k-adv__advance-badge wh40k-adv__advance-badge--owned">
              <i class="fas fa-check"></i> {{localize "WH40K.Advancement.Owned"}}
            </span>
            {{/if}}
          </div>
          
          {{#if this.blocked}}
          <div class="wh40k-adv__advance-blocked" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
            <i class="fas fa-lock"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <div class="wh40k-adv__advance-status">
            <i class="fas fa-check-circle"></i>
          </div>
          {{else if this.canPurchase}}
          <button 
            class="wh40k-adv__advance-btn"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="skill"
            type="button"
          >
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="wh40k-adv__advance-status wh40k-adv__advance-status--cant-afford" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="wh40k-adv__empty">
        <i class="fas fa-book"></i>
        <p>{{localize "WH40K.Advancement.NoSkillsAvailable"}}</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Talents Tab --}}
    {{#if (eq activeTab "talents")}}
    <div class="wh40k-adv__panel wh40k-adv__panel--talents">
      {{#if talents.length}}
      <div class="wh40k-adv__advance-list">
        {{#each talents}}
        <div class="wh40k-adv__advance-card 
          {{#if this.owned}}wh40k-adv__advance-card--owned{{/if}}
          {{#if this.blocked}}wh40k-adv__advance-card--blocked{{/if}}
          {{#if this.cantAfford}}wh40k-adv__advance-card--cant-afford{{/if}}
          {{#if this.recentlyPurchased}}wh40k-adv__advance-card--purchased{{/if}}"
        >
          <div class="wh40k-adv__advance-info">
            <span class="wh40k-adv__advance-name">{{this.displayName}}</span>
            <a class="wh40k-adv__advance-link" 
               data-action="openCompendiumItem" 
               data-name="{{this.displayName}}" 
               data-type="talent"
               title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.owned}}
            <span class="wh40k-adv__advance-badge wh40k-adv__advance-badge--owned">
              <i class="fas fa-check"></i> {{localize "WH40K.Advancement.Owned"}}
            </span>
            {{/if}}
            {{#if this.blocked}}
            <span class="wh40k-adv__advance-prereq" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
              <i class="fas fa-exclamation-triangle"></i>
              {{localize "WH40K.Advancement.RequiresPrereq"}}
            </span>
            {{/if}}
          </div>
          
          {{#if this.blocked}}
          <div class="wh40k-adv__advance-blocked" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
            <i class="fas fa-lock"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <div class="wh40k-adv__advance-status">
            <i class="fas fa-check-circle"></i>
          </div>
          {{else if this.canPurchase}}
          <button 
            class="wh40k-adv__advance-btn"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="talent"
            type="button"
          >
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="wh40k-adv__advance-status wh40k-adv__advance-status--cant-afford" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="wh40k-adv__empty">
        <i class="fas fa-star"></i>
        <p>{{localize "WH40K.Advancement.NoTalentsAvailable"}}</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

  </div>
  {{/unless}}
</div>
