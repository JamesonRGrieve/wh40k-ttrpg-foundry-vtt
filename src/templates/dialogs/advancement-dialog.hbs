{{!-- Advancement Dialog Template --}}
<div class="tw-flex tw-flex-col tw-h-full tw-gap-0 tw-font-[var(--wh40k-font-ui)]" data-wh40k-system="{{_gameSystemId}}">

  {{!-- Header with XP Display (sticky so totals stay visible while content scrolls — #22) --}}
  <header class="tw-sticky tw-top-0 tw-z-20 tw-bg-[var(--color-bg-secondary)] tw-shrink-0">
    <div>
      <div>
        <div style="width: {{xp.usedPercent}}%">
          <span class="tw-pointer-events-none tw-absolute tw-inset-0 tw-animate-xp-shimmer tw-bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent)]"></span>
        </div>
      </div>
      <div>
        <span class="bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat im:tw-text-failure ow:tw-text-brass-l20 rt:tw-text-gold">
          <i class="fas fa-bolt"></i>
          <strong>{{xp.available}}</strong> {{localize "WH40K.Advancement.XPAvailable"}}
        </span>
        <span>
          ({{xp.used}} / {{xp.total}} {{localize "WH40K.Advancement.XPUsed"}})
        </span>
      </div>
    </div>
  </header>

  {{!-- No Career Selected - Blocked State --}}
  {{#unless hasCareer}}
  <div class="tw-animate-[fadeIn_250ms_ease]">
    <div>
      <i class="fas fa-route"></i>
    </div>
    <h3>{{localize "WH40K.Advancement.NoCareerTitle"}}</h3>
    <p>{{localize "WH40K.Advancement.NoCareerMessage"}}</p>
    <div>
      <i class="fas fa-info-circle"></i>
      <span>{{localize "WH40K.Advancement.NoCareerHint"}}</span>
    </div>
  </div>
  {{else}}

  {{!-- Tab Navigation (sticky alongside the header so the tab bar stays anchored) --}}
  <nav class="tw-sticky tw-top-[var(--wh40k-adv-header-h,4rem)] tw-z-10 tw-shrink-0 tw-flex tw-items-stretch tw-gap-0.5 tw-bg-[var(--color-bg-secondary)] tw-border-b tw-border-[var(--wh40k-border-color)] tw-px-1 tw-py-1 tw-overflow-x-auto">
    {{#each tabs}}
    <button
      class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-3 tw-py-1.5 tw-rounded tw-text-[0.75rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-whitespace-nowrap tw-cursor-pointer tw-transition-all tw-shrink-0
             {{#if this.active}}tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.25),rgba(139,112,21,0.35))] tw-border tw-border-[var(--wh40k-color-gold)] tw-text-[color:var(--wh40k-color-gold-light)]{{else}}tw-bg-transparent tw-border tw-border-transparent tw-text-[color:var(--color-text-secondary)] hover:tw-bg-[rgba(0,0,0,0.15)] hover:tw-text-[color:var(--wh40k-color-gold-light)]{{/if}}"
      data-action="switchTab"
      data-tab="{{this.id}}"
      type="button"
    >
      <i class="fas {{this.icon}}"></i>
      <span>{{localize this.label}}</span>
    </button>
    {{/each}}
  </nav>

  {{!-- Content Area — scrollable so options below the window edge are reachable (#22). The
       PARTS.scrollable selector targets .wh40k-adv__content; this class also lets the parent
       flex container claim remaining height via tw-flex-1 tw-min-h-0. --}}
  <div class="wh40k-adv__content tw-flex-1 tw-min-h-0 tw-overflow-y-auto">

    {{!-- Characteristics Tab --}}
    {{#if (eq activeTab "characteristics")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      <div class="tw-flex tw-flex-col tw-gap-1">
        {{#each characteristics}}
        <div class="tw-flex tw-items-center tw-gap-3 tw-py-1.5 tw-px-2.5 tw-rounded-md tw-bg-[var(--color-bg-option,rgba(0,0,0,0.03))] tw-border tw-border-[var(--wh40k-border-color-light)] {{#if this.recentlyPurchased}}tw-animate-purchasePulse{{/if}}">
          <div class="tw-flex tw-items-baseline tw-gap-1.5 tw-min-w-[3.5rem]">
            <span class="tw-text-[0.65rem] tw-font-mono tw-uppercase tw-text-[color:var(--color-text-tertiary)]">{{this.abbreviation}}</span>
            <span class="tw-font-display tw-text-[1.05rem] tw-font-bold tw-leading-none tw-text-[color:var(--wh40k-color-gold-light)]">{{this.currentValue}}</span>
          </div>

          <div class="tw-font-semibold tw-flex-1 tw-min-w-0 tw-truncate">{{this.label}}</div>

          {{#if this.aptitudeMatch}}
          <div class="tw-flex tw-items-center tw-gap-0.5" data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
            {{#each this.aptitudeMatch.matched}}<span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-[var(--wh40k-color-gold)]"></span>{{/each}}
            {{#each this.aptitudeMatch.unmatched}}<span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-[rgba(0,0,0,0.25)]"></span>{{/each}}
          </div>
          {{/if}}

          {{!-- Tier Progress Dots --}}
          <div class="tw-flex tw-items-center tw-gap-1">
            {{#each this.tiers}}
            <div
              class="tw-w-2 tw-h-2 tw-rounded-full {{#if this.purchased}}tw-bg-[var(--wh40k-color-gold)]{{else if this.current}}tw-bg-[var(--wh40k-color-gold-light)] tw-animate-currentPulse{{else}}tw-bg-[rgba(0,0,0,0.2)] tw-border tw-border-[var(--wh40k-border-color-light)]{{/if}}"
              title="{{this.label}}"
            ></div>
            {{/each}}
          </div>

          {{!-- Purchase Button or Status --}}
          {{#if this.isMaxed}}
          <span class="tw-inline-flex tw-items-center tw-gap-1.5 tw-py-1 tw-px-2 tw-rounded tw-bg-[rgba(201,162,39,0.15)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em]">
            <i class="fas fa-crown"></i>
            {{localize "WH40K.Advancement.Maxed"}}
          </span>
          {{else if this.canPurchase}}
          <button
            class="tw-inline-flex tw-items-center tw-gap-2 tw-py-[0.3rem] tw-px-[0.6rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.72rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
            data-action="purchaseCharacteristic"
            data-characteristic="{{this.key}}"
            type="button"
          >
            <span>+{{this.nextTierLabel}}</span>
            <span class="tw-py-[0.1rem] tw-px-[0.4rem] tw-rounded tw-bg-[rgba(0,0,0,0.25)] tw-text-[0.65rem]">{{this.nextCost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="tw-inline-flex tw-items-center tw-gap-1 tw-text-[color:var(--color-text-tertiary)] tw-text-[0.7rem]" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span>{{this.nextCost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- Skills Tab --}}
    {{#if (eq activeTab "skills")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      {{#if skills.length}}
      <div class="tw-flex tw-flex-col tw-gap-1">
        {{#each skills}}
        <div class="tw-flex tw-items-center tw-justify-between tw-gap-2 tw-py-1 tw-px-2.5 tw-rounded-md {{#if this.owned}}tw-bg-[rgba(45,80,22,0.18)] tw-border tw-border-[rgba(124,179,66,0.4)]{{else if this.blocked}}tw-bg-[rgba(0,0,0,0.08)] tw-opacity-70{{else}}tw-bg-[var(--color-bg-option,rgba(0,0,0,0.03))] tw-border tw-border-[var(--wh40k-border-color-light)]{{/if}} {{#if this.recentlyPurchased}}tw-animate-purchasePulse{{/if}}">
          <div class="tw-flex tw-items-center tw-gap-2 tw-min-w-0 tw-flex-1">
            {{#if this.currentLabel}}
            <span class="tw-text-[0.6rem] tw-font-mono tw-uppercase tw-tracking-wider tw-py-[0.1rem] tw-px-[0.3rem] tw-rounded tw-bg-[rgba(0,0,0,0.2)] tw-text-[color:var(--color-text-tertiary)]" title="Current rank">{{this.currentLabel}}</span>
            {{/if}}
            <span class="tw-font-semibold tw-truncate">{{this.displayName}}</span>
            <a class="tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-color-gold)]"
               data-action="openCompendiumItem"
               data-name="{{this.name}}"
               data-type="skill"
               title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
              <i class="fas fa-external-link-alt tw-text-[0.7rem]"></i>
            </a>
            {{#if this.aptitudeMatch}}
            <span class="tw-flex tw-items-center tw-gap-0.5" data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
              {{#each this.aptitudeMatch.matched}}<span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-[var(--wh40k-color-gold)]"></span>{{/each}}
              {{#each this.aptitudeMatch.unmatched}}<span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-[rgba(0,0,0,0.25)]"></span>{{/each}}
            </span>
            {{/if}}
            {{#if this.owned}}
            <span class="tw-text-[0.65rem] tw-py-[0.1rem] tw-px-[0.4rem] tw-rounded tw-inline-flex tw-items-center tw-gap-1 tw-bg-[rgba(45,80,22,0.3)] tw-text-[#7cb342]"><i class="fas fa-check"></i> Mastered</span>
            {{/if}}
          </div>
          {{#if this.blocked}}
          <div class="tw-flex tw-items-center tw-gap-1 tw-text-[color:var(--wh40k-color-warning)] tw-text-[0.7rem] tw-cursor-help" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
            <i class="fas fa-lock"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <i class="fas fa-check-circle tw-text-[#7cb342]"></i>
          {{else if this.canPurchase}}
          <button
            class="tw-inline-flex tw-items-center tw-gap-1.5 tw-py-[0.3rem] tw-px-[0.6rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.72rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="skill"
            type="button"
          >
            <i class="fas fa-arrow-up tw-text-[0.65rem]"></i>
            <span>{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="tw-inline-flex tw-items-center tw-gap-1 tw-text-[color:var(--color-text-tertiary)] tw-text-[0.7rem]" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="tw-flex tw-flex-col tw-items-center tw-gap-2 tw-py-8 tw-px-4 tw-text-center tw-text-[color:var(--color-text-tertiary)]">
        <i class="fas fa-book tw-text-[1.5rem] tw-opacity-50"></i>
        <p class="tw-text-[0.85rem] tw-m-0">{{localize "WH40K.Advancement.NoSkillsAvailable"}}</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Talents Tab — grouped by tier (aptitude systems); falls back to flat list for career systems --}}
    {{#if (eq activeTab "talents")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      {{#if talents.length}}
      {{#if talentsByTier.length}}
      <div class="tw-flex tw-flex-col tw-gap-3">
        {{#each talentsByTier as |group|}}
        <section class="tw-pl-3 tw-border-l-2 {{#if group.unlocked}}tw-border-[var(--wh40k-color-gold)]{{else}}tw-border-[var(--wh40k-color-warning)] tw-opacity-80{{/if}}">
          <header class="tw-flex tw-items-center tw-gap-2 tw-text-[0.7rem] tw-uppercase tw-font-bold tw-tracking-[0.08em] tw-text-[color:var(--color-text-secondary)] tw-mb-1.5">
            <i class="fas {{#if group.unlocked}}fa-circle-check tw-text-[color:var(--wh40k-color-gold-light)]{{else}}fa-lock tw-text-[color:var(--wh40k-color-warning)]{{/if}}"></i>
            <span>Tier {{group.tier}}</span>
            {{#unless group.unlocked}}
            <span class="tw-text-[0.65rem] tw-font-normal tw-normal-case tw-tracking-normal tw-text-[color:var(--wh40k-color-warning)]">— Own a Tier {{group.prevTier}} talent to unlock</span>
            {{/unless}}
            <span class="tw-ml-auto tw-text-[0.65rem]">{{group.items.length}} talent{{#unless (eq group.items.length 1)}}s{{/unless}}</span>
          </header>
          <div class="tw-flex tw-flex-col tw-gap-1">
            {{#each group.items}}
            <div class="tw-flex tw-items-center tw-justify-between tw-gap-2 tw-py-1 tw-px-2.5 tw-rounded-md {{#if this.blocked}}tw-bg-[rgba(0,0,0,0.08)] tw-opacity-70{{else}}tw-bg-[var(--color-bg-option,rgba(0,0,0,0.03))] tw-border tw-border-[var(--wh40k-border-color-light)]{{/if}} {{#if this.recentlyPurchased}}tw-animate-purchasePulse{{/if}}">
              <div class="tw-flex tw-items-center tw-gap-2 tw-min-w-0 tw-flex-1">
                <span class="tw-text-[0.6rem] tw-font-mono tw-py-[0.1rem] tw-px-[0.3rem] tw-rounded tw-bg-[rgba(0,0,0,0.2)] tw-text-[color:var(--color-text-tertiary)]" title="Tier {{this.tier}}">T{{this.tier}}</span>
                <span class="tw-font-semibold tw-truncate">{{this.displayName}}</span>
                <a class="tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-color-gold)]"
                   data-action="openCompendiumItem"
                   data-name="{{this.name}}"
                   data-type="talent"
                   title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
                  <i class="fas fa-external-link-alt tw-text-[0.7rem]"></i>
                </a>
                {{#if this.aptitudeMatch}}
                <span class="tw-flex tw-items-center tw-gap-0.5" data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
                  {{#each this.aptitudeMatch.matched}}<span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-[var(--wh40k-color-gold)]"></span>{{/each}}
                  {{#each this.aptitudeMatch.unmatched}}<span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-[rgba(0,0,0,0.25)]"></span>{{/each}}
                </span>
                {{/if}}
              </div>
              {{#if this.blocked}}
              <div class="tw-flex tw-items-center tw-gap-1 tw-text-[color:var(--wh40k-color-warning)] tw-text-[0.7rem] tw-cursor-help" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
                <i class="fas fa-lock"></i>
                <span>{{this.cost}} XP</span>
              </div>
              {{else if this.canPurchase}}
              <button
                class="tw-inline-flex tw-items-center tw-gap-1.5 tw-py-[0.3rem] tw-px-[0.6rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.72rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
                data-action="purchaseAdvance"
                data-index="{{this.index}}"
                data-type="talent"
                type="button"
              >
                <span>{{this.cost}} XP</span>
              </button>
              {{else if this.cantAfford}}
              <div class="tw-inline-flex tw-items-center tw-gap-1 tw-text-[color:var(--color-text-tertiary)] tw-text-[0.7rem]" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
                <i class="fas fa-coins"></i>
                <span>{{this.cost}} XP</span>
              </div>
              {{/if}}
            </div>
            {{/each}}
            {{#unless group.items.length}}
            <div class="tw-text-[0.75rem] tw-text-[color:var(--color-text-tertiary)] tw-italic tw-py-1">No talents available in this tier.</div>
            {{/unless}}
          </div>
        </section>
        {{/each}}
      </div>
      {{else}}
      {{!-- Career-based systems: flat list (no tier grouping) --}}
      <div class="tw-flex tw-flex-col tw-gap-1">
        {{#each talents}}
        <div class="tw-flex tw-items-center tw-justify-between tw-gap-2 tw-py-1 tw-px-2.5 tw-rounded-md {{#if this.owned}}tw-bg-[rgba(45,80,22,0.18)] tw-border tw-border-[rgba(124,179,66,0.4)]{{else if this.blocked}}tw-bg-[rgba(0,0,0,0.08)] tw-opacity-70{{else}}tw-bg-[var(--color-bg-option,rgba(0,0,0,0.03))] tw-border tw-border-[var(--wh40k-border-color-light)]{{/if}} {{#if this.recentlyPurchased}}tw-animate-purchasePulse{{/if}}">
          <div class="tw-flex tw-items-center tw-gap-2 tw-min-w-0 tw-flex-1">
            <span class="tw-font-semibold tw-truncate">{{this.displayName}}</span>
            <a class="tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-color-gold)]"
               data-action="openCompendiumItem"
               data-name="{{this.name}}"
               data-type="talent"
               title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
              <i class="fas fa-external-link-alt tw-text-[0.7rem]"></i>
            </a>
            {{#if this.owned}}
            <span class="tw-text-[0.65rem] tw-py-[0.1rem] tw-px-[0.4rem] tw-rounded tw-inline-flex tw-items-center tw-gap-1 tw-bg-[rgba(45,80,22,0.3)] tw-text-[#7cb342]"><i class="fas fa-check"></i> Owned</span>
            {{/if}}
          </div>
          {{#if this.blocked}}
          <div class="tw-flex tw-items-center tw-gap-1 tw-text-[color:var(--wh40k-color-warning)] tw-text-[0.7rem] tw-cursor-help" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
            <i class="fas fa-lock"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <i class="fas fa-check-circle tw-text-[#7cb342]"></i>
          {{else if this.canPurchase}}
          <button
            class="tw-inline-flex tw-items-center tw-gap-1.5 tw-py-[0.3rem] tw-px-[0.6rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.72rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="talent"
            type="button"
          >
            <span>{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="tw-inline-flex tw-items-center tw-gap-1 tw-text-[color:var(--color-text-tertiary)] tw-text-[0.7rem]" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span>{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}
      {{else}}
      <div class="tw-flex tw-flex-col tw-items-center tw-gap-2 tw-py-8 tw-px-4 tw-text-center tw-text-[color:var(--color-text-tertiary)]">
        <i class="fas fa-star tw-text-[1.5rem] tw-opacity-50"></i>
        <p class="tw-text-[0.85rem] tw-m-0">{{localize "WH40K.Advancement.NoTalentsAvailable"}}</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Psychic Powers Tab (psykers only) --}}
    {{#if (eq activeTab "psychic")}}
    <div class="tw-animate-[fadeIn_250ms_ease]">
      {{#if psychic}}
      {{!-- Psy Rating header card --}}
      <div class="tw-flex tw-items-center tw-justify-between tw-gap-3 tw-mb-3 tw-px-3 tw-py-2 tw-rounded-md tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.08),rgba(0,0,0,0.15))] tw-border tw-border-[var(--wh40k-border-color)]">
        <div class="tw-flex tw-items-center tw-gap-2">
          <i class="fas fa-brain tw-text-[color:var(--wh40k-color-gold)]"></i>
          <span class="tw-text-[0.75rem] tw-uppercase tw-tracking-[0.1em] tw-text-[color:var(--color-text-secondary)]">Psy Rating</span>
          <span class="tw-font-display tw-text-[1.4rem] tw-font-bold tw-leading-none tw-text-[color:var(--wh40k-color-gold-light)]">{{psychic.psyAdvance.currentRating}}</span>
        </div>
        {{#if psychic.psyAdvance.maxed}}
        <span class="tw-inline-flex tw-items-center tw-gap-1.5 tw-py-1 tw-px-2 tw-rounded tw-bg-[rgba(201,162,39,0.15)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.75rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em]">
          <i class="fas fa-crown"></i> Maximum
        </span>
        {{else if psychic.psyAdvance.canPurchase}}
        <button class="tw-inline-flex tw-items-center tw-gap-2 tw-py-[0.4rem] tw-px-[0.8rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]" data-action="purchasePsyRating" type="button">
          <span>Advance to {{psychic.psyAdvance.nextRating}}</span>
          <span class="tw-py-[0.1rem] tw-px-[0.4rem] tw-rounded tw-bg-[rgba(0,0,0,0.25)] tw-text-[0.7rem]">{{psychic.psyAdvance.cost}} XP</span>
        </button>
        {{else}}
        <div class="tw-inline-flex tw-items-center tw-gap-1.5 tw-text-[color:var(--color-text-tertiary)] tw-text-[0.75rem]">
          <i class="fas fa-coins"></i>
          <span>Advance to {{psychic.psyAdvance.nextRating}} — {{psychic.psyAdvance.cost}} XP</span>
        </div>
        {{/if}}
      </div>

      {{!-- Discipline filter chips + "available only" toggle --}}
      {{#if psychic.chips.length}}
      <div class="tw-flex tw-items-center tw-flex-wrap tw-gap-2 tw-mb-3">
        <nav class="tw-flex tw-flex-wrap tw-gap-1.5 tw-flex-1">
          {{#each psychic.chips as |chip|}}
          <button type="button"
                  class="tw-inline-flex tw-items-center tw-gap-1.5 tw-py-1 tw-px-2.5 tw-rounded-full tw-text-[0.72rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all
                         {{#if chip.active}}tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.3),rgba(139,112,21,0.4))] tw-border tw-border-[var(--wh40k-color-gold)] tw-text-[color:var(--wh40k-color-gold-light)]{{else}}tw-bg-[rgba(0,0,0,0.15)] tw-border tw-border-[var(--wh40k-border-color)] tw-text-[color:var(--color-text-secondary)] hover:tw-border-[var(--wh40k-color-gold-dark)] hover:tw-text-[color:var(--wh40k-color-gold-light)]{{/if}}"
                  data-action="switchDiscipline"
                  data-discipline="{{chip.key}}"
                  title="{{chip.accessible}} accessible / {{chip.count}} total">
            <span>{{chip.label}}</span>
            <span class="tw-py-[0.1rem] tw-px-[0.4rem] tw-rounded-full tw-bg-[rgba(0,0,0,0.3)] tw-text-[0.65rem] tw-font-mono tw-tracking-normal">{{chip.accessible}}/{{chip.count}}</span>
          </button>
          {{/each}}
        </nav>
        {{#if psychic.hasBlocked}}
        <button type="button"
                class="tw-inline-flex tw-items-center tw-gap-1.5 tw-py-1 tw-px-2.5 tw-rounded tw-text-[0.72rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all
                       {{#if psychic.availableOnly}}tw-bg-[rgba(201,162,39,0.2)] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-text-[color:var(--wh40k-color-gold-light)]{{else}}tw-bg-[rgba(0,0,0,0.15)] tw-border tw-border-[var(--wh40k-border-color)] tw-text-[color:var(--color-text-secondary)] hover:tw-border-[var(--wh40k-color-gold-dark)]{{/if}}"
                data-action="toggleAvailableOnly"
                title="Show only powers at or below your Psy Rating">
          <i class="fas {{#if psychic.availableOnly}}fa-check-square{{else}}fa-square{{/if}}"></i>
          <span>Available</span>
        </button>
        {{/if}}
      </div>
      {{/if}}

      {{!-- PROTOTYPE: tier-grouped power tree. Each discipline lists its powers grouped by
           Psy Rating tier (PR 1 → PR N). Tiers above the actor's current PR show as
           "blocked" rows; lower tiers as accessible. The flat `discipline.items` array is
           still available for callers that prefer the old layout. --}}
      {{#each psychic.disciplines as |discipline|}}
      <h4 class="tw-mt-3 tw-mb-1 tw-text-[color:var(--wh40k-color-gold)] tw-font-display tw-uppercase tw-tracking-[0.1em] tw-border-b tw-border-[var(--wh40k-border-color)]">{{discipline.label}}</h4>
      <div class="tw-flex tw-flex-col tw-gap-2">
        {{#each discipline.tiers as |tier|}}
        <section class="tw-pl-3 tw-border-l-2 {{#if tier.accessible}}tw-border-[var(--wh40k-color-gold)]{{else}}tw-border-[var(--wh40k-color-warning)] tw-opacity-70{{/if}}">
          <header class="tw-flex tw-items-center tw-gap-2 tw-text-[0.7rem] tw-uppercase tw-font-bold tw-tracking-[0.08em] tw-text-[color:var(--color-text-secondary)] tw-mb-1">
            <i class="fas {{#if tier.accessible}}fa-circle-check tw-text-[color:var(--wh40k-color-gold-light)]{{else}}fa-lock tw-text-[color:var(--wh40k-color-warning)]{{/if}}"></i>
            <span>{{tier.label}}</span>
            <span class="tw-ml-auto tw-text-[0.65rem]">{{tier.items.length}} power{{#unless (eq tier.items.length 1)}}s{{/unless}}</span>
          </header>
          <div class="tw-flex tw-flex-col tw-gap-1">
            {{#each tier.items}}
            <div class="tw-flex tw-flex-col tw-gap-0.5 tw-py-1 tw-px-2 tw-rounded-md {{#if this.owned}}tw-bg-[rgba(45,80,22,0.18)] tw-border tw-border-[rgba(124,179,66,0.4)]{{else if this.blocked}}tw-bg-[rgba(0,0,0,0.08)] tw-opacity-70{{else}}tw-bg-[var(--color-bg-option,rgba(0,0,0,0.03))] tw-border tw-border-[var(--wh40k-border-color-light)]{{/if}}">
              <div class="tw-flex tw-items-center tw-justify-between tw-gap-2">
                <div class="tw-flex tw-items-center tw-gap-2 tw-min-w-0 tw-flex-1">
                  <span class="tw-text-[0.65rem] tw-font-mono tw-text-[color:var(--color-text-tertiary)]" title="Psy Rating {{this.prCost}}">PR{{this.prCost}}</span>
                  <span class="tw-font-semibold tw-truncate">{{this.displayName}}</span>
                  <a class="tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-color-gold)]"
                     data-action="openCompendiumItem"
                     data-name="{{this.name}}"
                     data-type="psychicPower"
                     title="View in Compendium">
                    <i class="fas fa-external-link-alt tw-text-[0.7rem]"></i>
                  </a>
                  {{#if this.owned}}
                  <span class="tw-text-[0.65rem] tw-py-[0.1rem] tw-px-[0.4rem] tw-rounded-[3px] tw-inline-flex tw-items-center tw-gap-1 tw-bg-[rgba(45,80,22,0.3)] tw-text-[#7cb342]"><i class="fas fa-check"></i> Owned</span>
                  {{/if}}
                </div>
                {{#if this.blocked}}
                <div class="tw-flex tw-items-center tw-gap-1 tw-text-[color:var(--wh40k-color-warning)] tw-text-[0.7rem] tw-cursor-help" title="Prerequisites not met">
                  <i class="fas fa-lock"></i>
                  <span>{{this.cost}} XP</span>
                </div>
                {{else if this.owned}}
                <i class="fas fa-check-circle tw-text-[#7cb342]"></i>
                {{else if this.canPurchase}}
                <button class="tw-py-[0.3rem] tw-px-[0.6rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.75rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
                  data-action="purchaseAdvance"
                  data-index="{{this.index}}"
                  data-type="psychic-power"
                  type="button">
                  <span>{{this.cost}} XP</span>
                </button>
                {{else if this.cantAfford}}
                <div class="tw-flex tw-items-center tw-gap-1 tw-text-[color:var(--color-text-tertiary)] tw-text-[0.7rem]">
                  <i class="fas fa-coins"></i>
                  <span>{{this.cost}} XP</span>
                </div>
                {{/if}}
              </div>
              {{#if this.prereqDisplay.length}}
              <div class="tw-flex tw-items-center tw-gap-1 tw-pl-[2.6rem] tw-text-[0.65rem] tw-text-[color:var(--wh40k-color-warning)] tw-opacity-80">
                <i class="fas fa-link tw-text-[0.6rem]"></i>
                <span class="tw-font-semibold tw-uppercase tw-tracking-[0.05em]">Requires:</span>
                <span>{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</span>
              </div>
              {{/if}}
            </div>
            {{/each}}
          </div>
        </section>
        {{/each}}
      </div>
      {{/each}}

      {{#unless psychic.disciplines.length}}
      <div class="tw-flex tw-flex-col tw-items-center tw-gap-2 tw-py-8 tw-px-4 tw-text-center tw-text-[color:var(--color-text-tertiary)]">
        <i class="fas fa-filter tw-text-[1.5rem] tw-opacity-50"></i>
        <p class="tw-text-[0.85rem] tw-m-0">No powers match the current filter.</p>
      </div>
      {{/unless}}
      {{else}}
      <div class="tw-flex tw-flex-col tw-items-center tw-gap-2 tw-py-8 tw-px-4 tw-text-center tw-text-[color:var(--color-text-tertiary)]">
        <i class="fas fa-brain tw-text-[2rem] tw-opacity-40"></i>
        <p class="tw-text-[0.9rem] tw-m-0 tw-max-w-[28rem]">No psychic powers available. Take the Psyker elite advance from the <strong class="tw-text-[color:var(--wh40k-color-gold)]">Traits</strong> tab to unlock.</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Traits Tab --}}
    {{#if (eq activeTab "traits")}}
    <div class="tw-animate-[fadeIn_250ms_ease] tw-flex tw-flex-col tw-gap-4">
      {{#if traits.owned.length}}
      <section>
        <h4 class="tw-mt-0 tw-mb-1.5 tw-text-[color:var(--wh40k-color-gold)] tw-font-display tw-uppercase tw-tracking-[0.1em] tw-text-[0.85rem] tw-border-b tw-border-[var(--wh40k-border-color)] tw-pb-1">Current Traits</h4>
        <div class="tw-flex tw-flex-col tw-gap-1">
          {{#each traits.owned}}
          <div class="tw-flex tw-items-center tw-justify-between tw-gap-2 tw-py-1 tw-px-2.5 tw-rounded-md tw-bg-[rgba(45,80,22,0.18)] tw-border tw-border-[rgba(124,179,66,0.4)]">
            <span class="tw-font-semibold tw-truncate">{{this.name}}</span>
            <span class="tw-text-[0.65rem] tw-py-[0.1rem] tw-px-[0.4rem] tw-rounded tw-inline-flex tw-items-center tw-gap-1 tw-bg-[rgba(0,0,0,0.2)] tw-text-[color:var(--color-text-tertiary)]">
              <i class="fas fa-seedling"></i> {{this.source}}
            </span>
          </div>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if traits.elites.length}}
      <section>
        <h4 class="tw-mt-0 tw-mb-1 tw-text-[color:var(--wh40k-color-gold)] tw-font-display tw-uppercase tw-tracking-[0.1em] tw-text-[0.85rem] tw-border-b tw-border-[var(--wh40k-border-color)] tw-pb-1">Elite Advances</h4>
        <p class="tw-text-[0.72rem] tw-opacity-70 tw-mb-2 tw-mt-1.5 tw-text-[color:var(--color-text-secondary)]">
          Elite advances are fundamental character changes that grant new traits, talents, and unlocks. Requires GM approval in play.
        </p>
        <div class="tw-flex tw-flex-col tw-gap-1">
          {{#each traits.elites}}
          <div class="tw-flex tw-items-center tw-justify-between tw-gap-2 tw-py-1.5 tw-px-2.5 tw-rounded-md {{#if this.owned}}tw-bg-[rgba(45,80,22,0.18)] tw-border tw-border-[rgba(124,179,66,0.4)]{{else}}tw-bg-[var(--color-bg-option,rgba(0,0,0,0.03))] tw-border tw-border-[var(--wh40k-border-color-light)]{{/if}}">
            <div class="tw-flex tw-items-center tw-gap-2 tw-min-w-0 tw-flex-1">
              <i class="fas fa-star tw-text-[color:var(--wh40k-color-gold)] tw-text-[0.7rem]"></i>
              <span class="tw-font-semibold tw-truncate">{{this.name}}</span>
              <a class="tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-color-gold)]"
                 data-action="openCompendiumItem"
                 data-name="{{this.name}}"
                 data-type="originPath"
                 title="View in Compendium">
                <i class="fas fa-external-link-alt tw-text-[0.7rem]"></i>
              </a>
              {{#if this.owned}}
              <span class="tw-text-[0.65rem] tw-py-[0.1rem] tw-px-[0.4rem] tw-rounded tw-inline-flex tw-items-center tw-gap-1 tw-bg-[rgba(45,80,22,0.3)] tw-text-[#7cb342]">
                <i class="fas fa-check"></i> Taken
              </span>
              {{/if}}
            </div>
            {{#if this.owned}}
            <i class="fas fa-check-circle tw-text-[#7cb342]"></i>
            {{else if this.canPurchase}}
            <button class="tw-inline-flex tw-items-center tw-gap-1.5 tw-py-[0.3rem] tw-px-[0.6rem] tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.2),rgba(139,112,21,0.3))] tw-border tw-border-[var(--wh40k-color-gold-dark)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-color-gold-light)] tw-text-[0.72rem] tw-font-semibold tw-cursor-pointer hover:tw-bg-[linear-gradient(135deg,rgba(201,162,39,0.35),rgba(139,112,21,0.45))] hover:tw-border-[var(--wh40k-color-gold)] hover:tw-scale-105 active:tw-scale-[0.98]"
              data-action="purchaseAdvance"
              data-index="{{this.index}}"
              data-type="elite"
              type="button">
              <span>{{this.cost}} XP</span>
            </button>
            {{else if this.cantAfford}}
            <div class="tw-inline-flex tw-items-center tw-gap-1 tw-text-[color:var(--color-text-tertiary)] tw-text-[0.7rem]">
              <i class="fas fa-coins"></i>
              <span>{{this.cost}} XP</span>
            </div>
            {{/if}}
          </div>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#unless (or traits.owned.length traits.elites.length)}}
      <div class="tw-flex tw-flex-col tw-items-center tw-gap-2 tw-py-8 tw-px-4 tw-text-center tw-text-[color:var(--color-text-tertiary)]">
        <i class="fas fa-dna tw-text-[1.5rem] tw-opacity-50"></i>
        <p class="tw-text-[0.85rem] tw-m-0 tw-max-w-[28rem]">No traits yet. Traits are granted by home world, background, or elite advances — they can't be bought directly with XP.</p>
      </div>
      {{/unless}}
    </div>
    {{/if}}

  </div>
  {{/unless}}
</div>
