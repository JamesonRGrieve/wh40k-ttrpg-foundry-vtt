{{!-- Advancement Dialog Template --}}
<div class="wh40k-adv">
  
  {{!-- Header with XP Display --}}
  <header class="wh40k-adv__header">
    <div class="wh40k-adv__xp-display">
      <div class="wh40k-adv__xp-bar">
        <div class="wh40k-adv__xp-fill" style="width: {{xp.usedPercent}}%"></div>
      </div>
      <div class="wh40k-adv__xp-info">
        <span class="wh40k-adv__xp-available">
          <i class="fas fa-bolt"></i>
          <strong>{{xp.available}}</strong> {{localize "WH40K.Advancement.XPAvailable"}}
        </span>
        <span class="wh40k-adv__xp-total">
          ({{xp.used}} / {{xp.total}} {{localize "WH40K.Advancement.XPUsed"}})
        </span>
      </div>
    </div>
  </header>

  {{!-- No Career Selected - Blocked State --}}
  {{#unless hasCareer}}
  <div class="wh40k-adv__blocked-state">
    <div class="wh40k-adv__blocked-icon">
      <i class="fas fa-route"></i>
    </div>
    <h3 class="wh40k-adv__blocked-title">{{localize "WH40K.Advancement.NoCareerTitle"}}</h3>
    <p class="wh40k-adv__blocked-message">{{localize "WH40K.Advancement.NoCareerMessage"}}</p>
    <div class="wh40k-adv__blocked-hint">
      <i class="fas fa-info-circle"></i>
      <span>{{localize "WH40K.Advancement.NoCareerHint"}}</span>
    </div>
  </div>
  {{else}}

  {{!-- Tab Navigation --}}
  <nav class="wh40k-adv__tabs">
    {{#each tabs}}
    <button 
      class="wh40k-adv__tab {{#if this.active}}wh40k-adv__tab--active{{/if}}"
      data-action="switchTab"
      data-tab="{{this.id}}"
      type="button"
    >
      <i class="fas {{this.icon}}"></i>
      <span>{{localize this.label}}</span>
    </button>
    {{/each}}
  </nav>

  {{!-- Content Area --}}
  <div class="wh40k-adv__content">

    {{!-- Characteristics Tab --}}
    {{#if (eq activeTab "characteristics")}}
    <div class="wh40k-adv__panel wh40k-adv__panel--characteristics">
      <div class="wh40k-adv__char-grid">
        {{#each characteristics}}
        <div class="wh40k-adv__char-card {{#if this.recentlyPurchased}}wh40k-adv__char-card--purchased{{/if}} {{#if this.isMaxed}}wh40k-adv__char-card--maxed{{/if}}">
          
          <div class="wh40k-adv__char-header">
            <span class="wh40k-adv__char-abbr">{{this.abbreviation}}</span>
            <span class="wh40k-adv__char-value">{{this.currentValue}}</span>
          </div>
          
          <div class="wh40k-adv__char-name">{{this.label}}</div>

          {{#if this.aptitudeMatch}}
          <div class="wh40k-adv__apt-dots" data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
            {{#each this.aptitudeMatch.matched}}<span class="wh40k-adv__apt-dot wh40k-adv__apt-dot--matched"></span>{{/each}}
            {{#each this.aptitudeMatch.unmatched}}<span class="wh40k-adv__apt-dot"></span>{{/each}}
          </div>
          {{/if}}

          {{!-- Tier Progress Dots --}}
          <div class="wh40k-adv__char-tiers">
            {{#each this.tiers}}
            <div 
              class="wh40k-adv__tier-dot {{#if this.purchased}}wh40k-adv__tier-dot--purchased{{/if}} {{#if this.current}}wh40k-adv__tier-dot--current{{/if}}"
              title="{{this.label}}"
            ></div>
            {{/each}}
          </div>

          {{!-- Purchase Button or Status --}}
          {{#if this.isMaxed}}
          <div class="wh40k-adv__char-status wh40k-adv__char-status--maxed">
            <i class="fas fa-crown"></i>
            {{localize "WH40K.Advancement.Maxed"}}
          </div>
          {{else if this.canPurchase}}
          <button 
            class="wh40k-adv__char-btn"
            data-action="purchaseCharacteristic"
            data-characteristic="{{this.key}}"
            type="button"
          >
            <span class="wh40k-adv__char-tier-label">{{this.nextTierLabel}}</span>
            <span class="wh40k-adv__char-cost">{{this.nextCost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="wh40k-adv__char-status wh40k-adv__char-status--cant-afford" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span class="wh40k-adv__char-cost wh40k-adv__char-cost--expensive">{{this.nextCost}} XP</span>
          </div>
          {{/if}}

        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- Skills Tab --}}
    {{#if (eq activeTab "skills")}}
    <div class="wh40k-adv__panel wh40k-adv__panel--skills">
      {{#if skills.length}}
      <div class="wh40k-adv__advance-list">
        {{#each skills}}
        <div class="wh40k-adv__advance-card 
          {{#if this.owned}}wh40k-adv__advance-card--owned{{/if}}
          {{#if this.blocked}}wh40k-adv__advance-card--blocked{{/if}}
          {{#if this.cantAfford}}wh40k-adv__advance-card--cant-afford{{/if}}
          {{#if this.recentlyPurchased}}wh40k-adv__advance-card--purchased{{/if}}"
        >
          <div class="wh40k-adv__advance-info">
            <span class="wh40k-adv__advance-name">{{this.displayName}}</span>
            <a class="wh40k-adv__advance-link"
               data-action="openCompendiumItem"
               data-name="{{this.displayName}}"
               data-type="skill"
               title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.aptitudeMatch}}
            <span class="wh40k-adv__apt-dots" data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
              {{#each this.aptitudeMatch.matched}}<span class="wh40k-adv__apt-dot wh40k-adv__apt-dot--matched"></span>{{/each}}
              {{#each this.aptitudeMatch.unmatched}}<span class="wh40k-adv__apt-dot"></span>{{/each}}
            </span>
            {{/if}}
            {{#if this.owned}}
            <span class="wh40k-adv__advance-badge wh40k-adv__advance-badge--owned">
              <i class="fas fa-check"></i> {{localize "WH40K.Advancement.Owned"}}
            </span>
            {{/if}}
          </div>

          {{#if this.blocked}}
          <div class="wh40k-adv__advance-blocked" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
            <i class="fas fa-lock"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <div class="wh40k-adv__advance-status">
            <i class="fas fa-check-circle"></i>
          </div>
          {{else if this.canPurchase}}
          <button
            class="wh40k-adv__advance-btn"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="skill"
            type="button"
          >
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="wh40k-adv__advance-status wh40k-adv__advance-status--cant-afford" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="wh40k-adv__empty">
        <i class="fas fa-book"></i>
        <p>{{localize "WH40K.Advancement.NoSkillsAvailable"}}</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Talents Tab --}}
    {{#if (eq activeTab "talents")}}
    <div class="wh40k-adv__panel wh40k-adv__panel--talents">
      {{#if talents.length}}
      <div class="wh40k-adv__advance-list">
        {{#each talents}}
        <div class="wh40k-adv__advance-card 
          {{#if this.owned}}wh40k-adv__advance-card--owned{{/if}}
          {{#if this.blocked}}wh40k-adv__advance-card--blocked{{/if}}
          {{#if this.cantAfford}}wh40k-adv__advance-card--cant-afford{{/if}}
          {{#if this.recentlyPurchased}}wh40k-adv__advance-card--purchased{{/if}}"
        >
          <div class="wh40k-adv__advance-info">
            <span class="wh40k-adv__advance-tier-badge" title="Tier {{this.tier}}">T{{this.tier}}</span>
            <span class="wh40k-adv__advance-name">{{this.displayName}}</span>
            <a class="wh40k-adv__advance-link"
               data-action="openCompendiumItem"
               data-name="{{this.name}}"
               data-type="talent"
               title="{{localize 'WH40K.Advancement.ViewInCompendium'}}">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.aptitudeMatch}}
            <span class="wh40k-adv__apt-dots" data-tooltip="Aptitudes: {{#each this.aptitudeMatch.all}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} — Matched {{this.aptitudeMatch.matches}}/{{this.aptitudeMatch.all.length}}">
              {{#each this.aptitudeMatch.matched}}<span class="wh40k-adv__apt-dot wh40k-adv__apt-dot--matched"></span>{{/each}}
              {{#each this.aptitudeMatch.unmatched}}<span class="wh40k-adv__apt-dot"></span>{{/each}}
            </span>
            {{/if}}
            {{#if this.owned}}
            <span class="wh40k-adv__advance-badge wh40k-adv__advance-badge--owned">
              <i class="fas fa-check"></i> {{localize "WH40K.Advancement.Owned"}}
            </span>
            {{/if}}
            {{#if this.blocked}}
            <span class="wh40k-adv__advance-prereq" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
              <i class="fas fa-exclamation-triangle"></i>
              {{localize "WH40K.Advancement.RequiresPrereq"}}
            </span>
            {{/if}}
          </div>
          
          {{#if this.blocked}}
          <div class="wh40k-adv__advance-blocked" title="{{#each this.prereqDisplay}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}">
            <i class="fas fa-lock"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <div class="wh40k-adv__advance-status">
            <i class="fas fa-check-circle"></i>
          </div>
          {{else if this.canPurchase}}
          <button 
            class="wh40k-adv__advance-btn"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="talent"
            type="button"
          >
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="wh40k-adv__advance-status wh40k-adv__advance-status--cant-afford" title="{{localize 'WH40K.Advancement.CannotAfford'}}">
            <i class="fas fa-coins"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="wh40k-adv__empty">
        <i class="fas fa-star"></i>
        <p>{{localize "WH40K.Advancement.NoTalentsAvailable"}}</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Psychic Powers Tab (psykers only) --}}
    {{#if (eq activeTab "psychic")}}
    <div class="wh40k-adv__panel wh40k-adv__panel--psychic">
      {{#if psychic}}
      <div class="wh40k-adv__psy-rating-card">
        <div class="wh40k-adv__psy-rating-info">
          <i class="fas fa-brain"></i>
          <span class="wh40k-adv__psy-rating-label">Psy Rating</span>
          <span class="wh40k-adv__psy-rating-value">{{psychic.psyAdvance.currentRating}}</span>
        </div>
        {{#if psychic.psyAdvance.maxed}}
        <span class="wh40k-adv__psy-rating-maxed"><i class="fas fa-crown"></i> Maximum</span>
        {{else if psychic.psyAdvance.canPurchase}}
        <button class="wh40k-adv__advance-btn" data-action="purchasePsyRating" type="button">
          <span>Advance to {{psychic.psyAdvance.nextRating}}</span>
          <span class="wh40k-adv__advance-cost">{{psychic.psyAdvance.cost}} XP</span>
        </button>
        {{else}}
        <div class="wh40k-adv__advance-status wh40k-adv__advance-status--cant-afford">
          <i class="fas fa-coins"></i>
          <span>Advance to {{psychic.psyAdvance.nextRating}} — {{psychic.psyAdvance.cost}} XP</span>
        </div>
        {{/if}}
      </div>

      {{#if psychic.chips.length}}
      <div class="wh40k-adv__psy-controls">
        <nav class="wh40k-adv__psy-chips">
          {{#each psychic.chips as |chip|}}
          <button type="button"
                  class="wh40k-adv__psy-chip {{#if chip.active}}wh40k-adv__psy-chip--active{{/if}}"
                  data-action="switchDiscipline"
                  data-discipline="{{chip.key}}"
                  title="{{chip.accessible}} accessible / {{chip.count}} total">
            <span class="wh40k-adv__psy-chip-label">{{chip.label}}</span>
            <span class="wh40k-adv__psy-chip-count">{{chip.accessible}}/{{chip.count}}</span>
          </button>
          {{/each}}
        </nav>
        {{#if psychic.hasBlocked}}
        <button type="button"
                class="wh40k-adv__psy-filter {{#if psychic.availableOnly}}wh40k-adv__psy-filter--active{{/if}}"
                data-action="toggleAvailableOnly"
                title="Show only powers at or below your Psy Rating">
          <i class="fas {{#if psychic.availableOnly}}fa-check-square{{else}}fa-square{{/if}}"></i>
          Available to me
        </button>
        {{/if}}
      </div>
      {{/if}}

      {{#each psychic.disciplines as |discipline|}}
      <h4 class="wh40k-adv__psy-disc-header">{{discipline.label}}</h4>
      <div class="wh40k-adv__advance-list">
        {{#each discipline.items}}
        <div class="wh40k-adv__advance-card
          {{#if this.owned}}wh40k-adv__advance-card--owned{{/if}}
          {{#if this.blocked}}wh40k-adv__advance-card--blocked{{/if}}
          {{#if this.cantAfford}}wh40k-adv__advance-card--cant-afford{{/if}}"
        >
          <div class="wh40k-adv__advance-info">
            <span class="wh40k-adv__advance-tier-badge" title="Psy Rating {{this.prCost}}">PR{{this.prCost}}</span>
            <span class="wh40k-adv__advance-name">{{this.displayName}}</span>
            <a class="wh40k-adv__advance-link"
               data-action="openCompendiumItem"
               data-name="{{this.name}}"
               data-type="psychicPower"
               title="View in Compendium">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.owned}}
            <span class="wh40k-adv__advance-badge wh40k-adv__advance-badge--owned">
              <i class="fas fa-check"></i> Owned
            </span>
            {{/if}}
            {{#if this.blocked}}
            <span class="wh40k-adv__advance-prereq" title="{{#each this.prereqDisplay}}{{this}}{{/each}}">
              <i class="fas fa-exclamation-triangle"></i>
              Requires PR {{this.prCost}}
            </span>
            {{/if}}
          </div>
          {{#if this.blocked}}
          <div class="wh40k-adv__advance-blocked">
            <i class="fas fa-lock"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{else if this.owned}}
          <div class="wh40k-adv__advance-status"><i class="fas fa-check-circle"></i></div>
          {{else if this.canPurchase}}
          <button class="wh40k-adv__advance-btn"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="psychic-power"
            type="button">
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="wh40k-adv__advance-status wh40k-adv__advance-status--cant-afford">
            <i class="fas fa-coins"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/each}}

      {{#unless psychic.disciplines.length}}
      <div class="wh40k-adv__empty">
        <i class="fas fa-filter"></i>
        <p>No powers match the current filter.</p>
      </div>
      {{/unless}}
      {{else}}
      <div class="wh40k-adv__empty">
        <i class="fas fa-brain"></i>
        <p>No psychic powers available. Take the Psyker elite advance to unlock.</p>
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Traits Tab --}}
    {{#if (eq activeTab "traits")}}
    <div class="wh40k-adv__panel wh40k-adv__panel--traits">
      {{#if traits.owned.length}}
      <h4 class="wh40k-adv__psy-disc-header">Current Traits</h4>
      <div class="wh40k-adv__advance-list">
        {{#each traits.owned}}
        <div class="wh40k-adv__advance-card wh40k-adv__advance-card--owned">
          <div class="wh40k-adv__advance-info">
            <span class="wh40k-adv__advance-name">{{this.name}}</span>
            <span class="wh40k-adv__advance-badge">
              <i class="fas fa-seedling"></i> {{this.source}}
            </span>
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if traits.elites.length}}
      <h4 class="wh40k-adv__psy-disc-header">Elite Advances</h4>
      <p class="notes tw-text-xs tw-opacity-70 tw-mb-2">
        Elite advances are fundamental character changes that grant new traits, talents, and unlocks. Requires GM approval in play.
      </p>
      <div class="wh40k-adv__advance-list">
        {{#each traits.elites}}
        <div class="wh40k-adv__advance-card
          {{#if this.owned}}wh40k-adv__advance-card--owned{{/if}}
          {{#if this.cantAfford}}wh40k-adv__advance-card--cant-afford{{/if}}"
        >
          <div class="wh40k-adv__advance-info">
            <span class="wh40k-adv__advance-name">{{this.name}}</span>
            <a class="wh40k-adv__advance-link"
               data-action="openCompendiumItem"
               data-name="{{this.name}}"
               data-type="originPath"
               title="View in Compendium">
              <i class="fas fa-external-link-alt"></i>
            </a>
            {{#if this.owned}}
            <span class="wh40k-adv__advance-badge wh40k-adv__advance-badge--owned">
              <i class="fas fa-check"></i> Taken
            </span>
            {{/if}}
          </div>
          {{#if this.owned}}
          <div class="wh40k-adv__advance-status"><i class="fas fa-check-circle"></i></div>
          {{else if this.canPurchase}}
          <button class="wh40k-adv__advance-btn"
            data-action="purchaseAdvance"
            data-index="{{this.index}}"
            data-type="elite"
            type="button">
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </button>
          {{else if this.cantAfford}}
          <div class="wh40k-adv__advance-status wh40k-adv__advance-status--cant-afford">
            <i class="fas fa-coins"></i>
            <span class="wh40k-adv__advance-cost">{{this.cost}} XP</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#unless (or traits.owned.length traits.elites.length)}}
      <div class="wh40k-adv__empty">
        <i class="fas fa-dna"></i>
        <p>No traits yet. Traits are granted by home world, background, or elite advances — they can't be bought directly with XP.</p>
      </div>
      {{/unless}}
    </div>
    {{/if}}

  </div>
  {{/unless}}
</div>
