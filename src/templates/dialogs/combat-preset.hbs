{{!-- Combat Preset Dialog Template --}}
<form class="wh40k-combat-preset-dialog tw-flex tw-flex-col tw-gap-4 tw-p-4">
  
  {{!-- Save Mode --}}
  {{#if (eq mode "save")}}
    <section class="wh40k-panel wh40k-panel--save-preset">
      <header class="wh40k-panel-header tw-flex tw-items-center tw-gap-2 tw-pb-2">
        <i class="fa-solid fa-save"></i>
        <h3>Save Combat Preset</h3>
      </header>
      <div class="wh40k-panel-body tw-p-4">
        {{#if npc}}
          <div class="wh40k-npc-preview tw-flex tw-items-center tw-gap-4 tw-p-4 tw-mb-6">
            <img src="{{npc.img}}" alt="{{npc.name}}" class="wh40k-token-image" />
            <div class="wh40k-npc-info tw-flex-1">
              <h4>{{npc.name}}</h4>
              <div class="wh40k-npc-stats tw-flex tw-gap-2">
                <span class="wh40k-badge">Threat {{npc.threatLevel}}</span>
                <span class="wh40k-badge">{{npc.type}}</span>
                <span class="wh40k-badge">{{npc.role}}</span>
              </div>
            </div>
          </div>

          <div class="wh40k-form-group tw-mb-4">
            <label class="wh40k-label">Preset Name *</label>
            <input 
              type="text" 
              name="presetName" 
              class="wh40k-input" 
              placeholder="e.g., Elite Guard, Chaos Cultist, Xenos Warrior"
              required
            />
          </div>

          <div class="wh40k-form-group tw-mb-4">
            <label class="wh40k-label">Description</label>
            <textarea 
              name="presetDescription" 
              class="wh40k-input" 
              rows="3"
              placeholder="Optional description of this preset..."
            ></textarea>
          </div>

          <div class="wh40k-form-actions tw-flex tw-justify-end tw-pt-4">
            <button 
              type="button" 
              class="wh40k-btn wh40k-btn--primary" 
              data-action="saveNew"
            >
              <i class="fa-solid fa-save"></i> Save Preset
            </button>
          </div>
        {{/if}}
      </div>
    </section>
  {{/if}}

  {{!-- Load Mode --}}
  {{#if (eq mode "load")}}
    <section class="wh40k-panel wh40k-panel--load-preset">
      <header class="wh40k-panel-header tw-flex tw-items-center tw-gap-2 tw-pb-2">
        <i class="fa-solid fa-download"></i>
        <h3>Load Combat Preset</h3>
      </header>
      <div class="wh40k-panel-body tw-p-4">
        {{#if npc}}
          <div class="wh40k-npc-preview tw-flex tw-items-center tw-gap-4 tw-p-4 tw-mb-6">
            <img src="{{npc.img}}" alt="{{npc.name}}" class="wh40k-token-image" />
            <div class="wh40k-npc-info tw-flex-1">
              <h4>{{npc.name}}</h4>
              <p class="wh40k-warning">Loading a preset will overwrite this NPC's stats.</p>
            </div>
          </div>
        {{/if}}

        {{#if hasPresets}}
          <div class="wh40k-preset-list tw-flex tw-flex-col tw-gap-2 tw-mb-4">
            {{#each presets}}
              <div 
                class="wh40k-preset-item {{#if this.selected}}wh40k-preset-item--selected{{/if}}" 
                data-action="selectPreset"
                data-preset-id="{{this.id}}"
              >
                <div class="wh40k-preset-header tw-flex tw-justify-between tw-items-center tw-mb-2">
                  <h5 class="wh40k-preset-name">{{this.name}}</h5>
                  <span class="wh40k-preset-date">{{this.createdDate}}</span>
                </div>
                {{#if this.description}}
                  <p class="wh40k-preset-description tw-mb-2">{{this.description}}</p>
                {{/if}}
                <div class="wh40k-preset-stats tw-flex tw-gap-2 tw-flex-wrap">
                  <span class="wh40k-badge wh40k-badge--small">Threat {{this.threatLevel}}</span>
                  <span class="wh40k-badge wh40k-badge--small">{{this.type}}</span>
                  {{#if this.faction}}<span class="wh40k-badge wh40k-badge--small">{{this.faction}}</span>{{/if}}
                </div>
              </div>
            {{/each}}
          </div>

          <div class="wh40k-form-actions tw-flex tw-justify-end tw-pt-4">
            <button 
              type="button" 
              class="wh40k-btn wh40k-btn--primary" 
              data-action="loadSelected"
              {{#unless selectedPreset}}disabled{{/unless}}
            >
              <i class="fa-solid fa-download"></i> Load Selected
            </button>
          </div>
        {{else}}
          <p class="wh40k-empty-message tw-text-center tw-p-10">
            <i class="fa-solid fa-info-circle"></i>
            No presets saved yet. Create one from an NPC sheet.
          </p>
        {{/if}}
      </div>
    </section>
  {{/if}}

  {{!-- Library Mode --}}
  {{#if (eq mode "library")}}
    <section class="wh40k-panel wh40k-panel--preset-library">
      <header class="wh40k-panel-header tw-flex tw-items-center tw-p-4">
        <h3 class="tw-flex-1">Preset Library</h3>
        <i class="fa-solid fa-bookmark"></i>
        <button 
          type="button" 
          class="wh40k-btn wh40k-btn--icon" 
          data-action="importPreset"
          data-tooltip="Import Preset from JSON"
        >
          <i class="fa-solid fa-file-import"></i>
        </button>
      </header>
      <div class="wh40k-panel-body tw-p-4">
        {{#if hasPresets}}
          <div class="wh40k-preset-library-list tw-flex tw-flex-col tw-gap-4">
            {{#each presets}}
              <div class="wh40k-preset-library-item tw-flex tw-gap-4 tw-p-4">
                <div class="wh40k-preset-content tw-flex-1">
                  <div class="wh40k-preset-header tw-flex tw-justify-between tw-items-center tw-mb-2">
                    <h5 class="wh40k-preset-name">{{this.name}}</h5>
                    <span class="wh40k-preset-date">{{this.createdDate}}</span>
                  </div>
                  {{#if this.description}}
                    <p class="wh40k-preset-description tw-mb-2">{{this.description}}</p>
                  {{/if}}
                  <div class="wh40k-preset-stats tw-flex tw-gap-2 tw-flex-wrap">
                    <span class="wh40k-badge wh40k-badge--small">Threat {{this.threatLevel}}</span>
                    <span class="wh40k-badge wh40k-badge--small">{{this.type}}</span>
                    {{#if this.role}}<span class="wh40k-badge wh40k-badge--small">{{this.role}}</span>{{/if}}
                    {{#if this.faction}}<span class="wh40k-badge wh40k-badge--small">{{this.faction}}</span>{{/if}}
                  </div>
                </div>
                <div class="wh40k-preset-actions tw-flex tw-gap-2 tw-items-start">
                  <button 
                    type="button" 
                    class="wh40k-btn wh40k-btn--icon" 
                    data-action="exportPreset"
                    data-preset-id="{{this.id}}"
                    data-tooltip="Export as JSON"
                  >
                    <i class="fa-solid fa-file-export"></i>
                  </button>
                  <button 
                    type="button" 
                    class="wh40k-btn wh40k-btn--icon wh40k-btn--danger" 
                    data-action="deletePreset"
                    data-preset-id="{{this.id}}"
                    data-tooltip="Delete Preset"
                  >
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </div>
              </div>
            {{/each}}
          </div>
        {{else}}
          <p class="wh40k-empty-message tw-text-center tw-p-10">
            <i class="fa-solid fa-info-circle"></i>
            No presets saved yet. Create one from an NPC sheet.
          </p>
        {{/if}}
      </div>
    </section>
  {{/if}}

</form>
