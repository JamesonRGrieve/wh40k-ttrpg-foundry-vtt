            <input type="text" name="grants.skills.{{@index}}.specialization" value="{{this.specialization}}" placeholder="Specialization (optional)" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <select name="grants.skills.{{@index}}.level" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none">
              {{#each ../trainingLevelOptions}}
              <option value="{{this.value}}" {{#if (eq this.value ../this.level)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold" data-action="addItem" data-category="grants" data-type="skills">
          <i class="fa-solid fa-plus"></i> Add Granted Skill
        </button>
      </div>

      {{!-- Granted Talents --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-star"></i>
          Granted Talents
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="grants" data-type="talents">
          {{#each grants.talents}}
          <div class="tw-grid tw-grid-cols-[1fr_1fr_1fr_32px] tw-gap-2 tw-items-center tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm">
            <input type="text" name="grants.talents.{{@index}}.name" value="{{this.name}}" placeholder="Talent name" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <input type="text" name="grants.talents.{{@index}}.specialization" value="{{this.specialization}}" placeholder="Specialization (optional)" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <input type="text" name="grants.talents.{{@index}}.uuid" value="{{this.uuid}}" placeholder="UUID (optional)" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold" data-action="addItem" data-category="grants" data-type="talents">
          <i class="fa-solid fa-plus"></i> Add Granted Talent
        </button>
      </div>

      {{!-- Granted Traits --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-dna"></i>
          Granted Traits
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="grants" data-type="traits">
          {{#each grants.traits}}
          <div class="tw-grid tw-grid-cols-[1fr_80px_1fr_32px] tw-gap-2 tw-items-center tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm">
            <input type="text" name="grants.traits.{{@index}}.name" value="{{this.name}}" placeholder="Trait name" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <input type="number" name="grants.traits.{{@index}}.level" value="{{this.level}}" placeholder="Level (optional)" class="tw-w-[70px] tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-text-center tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <input type="text" name="grants.traits.{{@index}}.uuid" value="{{this.uuid}}" placeholder="UUID (optional)" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold" data-action="addItem" data-category="grants" data-type="traits">
          <i class="fa-solid fa-plus"></i> Add Granted Trait
        </button>
      </div>

      {{!-- Special Abilities --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-bolt-lightning"></i>
          Special Abilities
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="grants" data-type="specialAbilities">
          {{#each grants.specialAbilities}}
          <div class="tw-flex tw-flex-col tw-gap-2 tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm">
            <input type="text" name="grants.specialAbilities.{{@index}}.name" value="{{this.name}}" placeholder="Ability name" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <textarea name="grants.specialAbilities.{{@index}}.description" rows="2" class="tw-w-full tw-px-3 tw-py-2 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] tw-resize-y tw-min-h-[50px] focus:tw-border-gold focus:tw-outline-none" placeholder="Description">{{this.description}}</textarea>
            <button type="button" class="tw-self-end tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold" data-action="addItem" data-category="grants" data-type="specialAbilities">
          <i class="fa-solid fa-plus"></i> Add Special Ability
