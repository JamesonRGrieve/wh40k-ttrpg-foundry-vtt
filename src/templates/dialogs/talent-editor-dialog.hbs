      </div>
    </div>

  </div>{{!-- content area --}}

  {{!-- Footer with Submit --}}
  <footer class="tw-flex tw-justify-end tw-gap-3 tw-p-3 tw-bg-gradient-to-b tw-from-transparent tw-to-black/20 tw-border-t-2 tw-border-solid tw-border-[var(--color-border-secondary)] tw-shrink-0">
    <button type="submit" class="tw-inline-flex tw-items-center tw-gap-2 tw-px-6 tw-py-3 tw-bg-gradient-to-b tw-from-gold/15 tw-to-gold/10 tw-border tw-border-solid tw-border-gold/40 tw-rounded-md tw-text-gold tw-font-heading tw-text-[0.9rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all tw-shadow-[0_2px_8px_rgba(0,0,0,0.3)] hover:tw-from-gold/25 hover:tw-to-gold/15 hover:tw-border-gold hover:tw-text-gold-light hover:tw-shadow-[0_0_16px_rgba(201,162,39,0.3)] hover:-tw-translate-y-px active:tw-translate-y-0 active:tw-shadow-[0_0_8px_rgba(201,162,39,0.2)]">
      <i class="fa-solid fa-check"></i>
      Save Changes
    </button>
  </footer>
</div>
