{{!--
  Talent Editor Dialog Template
  Comprehensive editor for complex talent fields (modifiers, grants, prerequisites, situational)
--}}
<div class="tw-flex tw-flex-col tw-h-full tw-bg-[var(--color-bg-primary)] tw-font-body">

  {{!-- Section Tabs --}}
  <nav class="tw-flex tw-px-3 tw-bg-[var(--color-bg-secondary)] tw-border-b-2 tw-border-solid tw-border-[var(--color-border-secondary)] tw-shrink-0">
    <button type="button" class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-[3px] tw-border-solid tw-border-transparent tw-text-[var(--color-text-secondary)] tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-text-[var(--color-text-primary)] hover:tw-bg-gold/5 [&>i]:tw-text-[0.95em] {{#if sections.prerequisites}}!tw-text-gold !tw-border-b-gold !tw-bg-gold/10{{/if}}"
            data-action="switchSection" data-section="prerequisites">
      <i class="fa-solid fa-lock"></i>
      <span>Prerequisites</span>
    </button>
    <button type="button" class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-[3px] tw-border-solid tw-border-transparent tw-text-[var(--color-text-secondary)] tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-text-[var(--color-text-primary)] hover:tw-bg-gold/5 [&>i]:tw-text-[0.95em] {{#if sections.modifiers}}!tw-text-gold !tw-border-b-gold !tw-bg-gold/10{{/if}}"
            data-action="switchSection" data-section="modifiers">
      <i class="fa-solid fa-chart-line"></i>
      <span>Modifiers</span>
    </button>
    <button type="button" class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-[3px] tw-border-solid tw-border-transparent tw-text-[var(--color-text-secondary)] tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-text-[var(--color-text-primary)] hover:tw-bg-gold/5 [&>i]:tw-text-[0.95em] {{#if sections.situational}}!tw-text-gold !tw-border-b-gold !tw-bg-gold/10{{/if}}"
            data-action="switchSection" data-section="situational">
      <i class="fa-solid fa-clock-rotate-left"></i>
      <span>Situational</span>
    </button>
    <button type="button" class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-bg-transparent tw-border-0 tw-border-b-[3px] tw-border-solid tw-border-transparent tw-text-[var(--color-text-secondary)] tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-text-[var(--color-text-primary)] hover:tw-bg-gold/5 [&>i]:tw-text-[0.95em] {{#if sections.grants}}!tw-text-gold !tw-border-b-gold !tw-bg-gold/10{{/if}}"
            data-action="switchSection" data-section="grants">
      <i class="fa-solid fa-gift"></i>
      <span>Grants</span>
    </button>
  </nav>

  {{!-- Content Area --}}
  <div class="tw-flex-1 tw-overflow-y-auto tw-p-3">

    {{!-- Reusable wrapper styles --}}
    {{!-- field-group: tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md tw-transition-all hover:tw-bg-black/20 hover:tw-border-[var(--wh40k-accent-talents)]/30 last:tw-mb-0 --}}
    {{!-- field-label: tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em] [&>i]:tw-text-[0.9em] [&>i]:tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] --}}
    {{!-- list-row: tw-grid tw-grid-cols-[1fr_80px_32px] tw-gap-2 tw-items-center tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-transition-all hover:tw-bg-black/35 hover:tw-border-[var(--wh40k-accent-talents)]/30 [&_input]:tw-px-2.5 [&_input]:tw-py-1.5 [&_input]:tw-text-[0.85rem] [&_input]:tw-bg-black/40 [&_input]:tw-border [&_input]:tw-border-solid [&_input]:tw-border-[var(--color-border-light)] [&_input]:tw-rounded-sm [&_input]:tw-text-[var(--color-text-primary)] focus:[&_input]:tw-border-gold focus:[&_input]:tw-outline-none [&_input[type=number]]:tw-w-[70px] [&_input[type=number]]:tw-text-center [&_select]:tw-px-2.5 [&_select]:tw-py-1.5 [&_select]:tw-text-[0.85rem] [&_select]:tw-bg-black/40 [&_select]:tw-border [&_select]:tw-border-solid [&_select]:tw-border-[var(--color-border-light)] [&_select]:tw-rounded-sm [&_select]:tw-text-[var(--color-text-primary)] focus:[&_select]:tw-border-gold focus:[&_select]:tw-outline-none --}}

    {{!-- ═══════════════════════════════════════════════════════════════════
         PREREQUISITES SECTION
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="{{#unless sections.prerequisites}}tw-hidden{{/unless}}" data-section="prerequisites">
      <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4 tw-pb-3 tw-border-b-2 tw-border-solid tw-border-[var(--color-border-secondary)] [&>i]:tw-text-lg [&>i]:tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] [&>h3]:tw-flex-1 [&>h3]:tw-flex [&>h3]:tw-items-center [&>h3]:tw-gap-2 [&>h3]:tw-m-0 [&>h3]:tw-font-heading [&>h3]:tw-text-lg [&>h3]:tw-font-bold [&>h3]:tw-text-gold [&>h3]:tw-uppercase [&>h3]:tw-tracking-[0.05em]">
        <i class="fa-solid fa-lock"></i>
        <h3>Prerequisites</h3>
        <p class="tw-w-full tw-m-0 tw-pl-[calc(1.2rem+0.5rem)] tw-text-[0.82rem] tw-italic tw-text-[var(--color-text-tertiary)] tw-leading-[1.4]">Define requirements that must be met before this talent can be taken.</p>
      </div>

      {{!-- Text Prerequisites --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-font"></i>
          Text Prerequisites
        </label>
        <textarea name="prerequisites.text" rows="2" class="tw-w-full tw-px-3 tw-py-2 tw-text-sm tw-bg-black/30 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] tw-resize-y tw-min-h-[50px] focus:tw-border-gold focus:tw-outline-none"
                  placeholder="Freeform text prerequisites (e.g., 'Must be a member of the Adeptus Mechanicus')">{{prerequisites.text}}</textarea>
      </div>

      {{!-- Characteristic Prerequisites --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-dumbbell"></i>
          Characteristic Requirements
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="prerequisites" data-type="characteristics">
          {{#each prerequisites.characteristics}}
          <div class="tw-grid tw-grid-cols-[1fr_80px_32px] tw-gap-2 tw-items-center tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm">
            <select name="prerequisites.characteristics.{{@index}}.key" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none">
              <option value="">-- Select --</option>
              {{#each ../characteristicOptions}}
              <option value="{{this.value}}" {{#if (eq this.value ../this.key)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
            <input type="number" name="prerequisites.characteristics.{{@index}}.value" value="{{this.value}}" min="0" placeholder="Min value" class="tw-w-[70px] tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-text-center tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson hover:tw-shadow-[0_0_8px_rgba(139,0,0,0.3)] [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold hover:tw-shadow-[0_0_10px_rgba(201,162,39,0.15)] [&>i]:tw-text-[0.85em]" data-action="addItem" data-category="prerequisites" data-type="characteristics">
          <i class="fa-solid fa-plus"></i> Add Characteristic Requirement
        </button>
      </div>

      {{!-- Skill Prerequisites --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-graduation-cap"></i>
          Skill Requirements
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="prerequisites" data-type="skills">
          {{#each prerequisites.skills}}
          <div class="tw-grid tw-grid-cols-[1fr_32px] tw-gap-2 tw-items-center tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm">
            <input type="text" name="prerequisites.skills.{{@index}}.name" value="{{this.name}}" placeholder="Skill name (e.g., Dodge, Parry)" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold" data-action="addItem" data-category="prerequisites" data-type="skills">
          <i class="fa-solid fa-plus"></i> Add Skill Requirement
        </button>
      </div>

      {{!-- Talent Prerequisites --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-star"></i>
          Talent Requirements
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="prerequisites" data-type="talents">
          {{#each prerequisites.talents}}
          <div class="tw-grid tw-grid-cols-[1fr_32px] tw-gap-2 tw-items-center tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm">
            <input type="text" name="prerequisites.talents.{{@index}}.name" value="{{this.name}}" placeholder="Talent name" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold" data-action="addItem" data-category="prerequisites" data-type="talents">
          <i class="fa-solid fa-plus"></i> Add Talent Requirement
        </button>
      </div>
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         MODIFIERS SECTION
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="{{#unless sections.modifiers}}tw-hidden{{/unless}}" data-section="modifiers">
      <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4 tw-pb-3 tw-border-b-2 tw-border-solid tw-border-[var(--color-border-secondary)] [&>i]:tw-text-lg [&>i]:tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] [&>h3]:tw-flex-1 [&>h3]:tw-flex [&>h3]:tw-items-center [&>h3]:tw-gap-2 [&>h3]:tw-m-0 [&>h3]:tw-font-heading [&>h3]:tw-text-lg [&>h3]:tw-font-bold [&>h3]:tw-text-gold [&>h3]:tw-uppercase [&>h3]:tw-tracking-[0.05em]">
        <i class="fa-solid fa-chart-line"></i>
        <h3>Permanent Modifiers</h3>
        <p class="tw-w-full tw-m-0 tw-pl-[calc(1.2rem+0.5rem)] tw-text-[0.82rem] tw-italic tw-text-[var(--color-text-tertiary)] tw-leading-[1.4]">Modifiers automatically applied while this talent is possessed.</p>
      </div>

      {{!-- Characteristic Modifiers --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-dumbbell"></i>
          Characteristic Modifiers
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="modifiers" data-type="characteristics">
          {{#each modifiers.characteristics}}
          <div class="tw-grid tw-grid-cols-[1fr_80px_32px] tw-gap-2 tw-items-center tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm">
            <select name="modifiers.characteristics.{{@index}}.key" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none">
              <option value="">-- Select --</option>
              {{#each ../characteristicOptions}}
              <option value="{{this.value}}" {{#if (eq this.value ../this.key)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
            <input type="number" name="modifiers.characteristics.{{@index}}.value" value="{{this.value}}" placeholder="+/-" class="tw-w-[70px] tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-text-center tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold" data-action="addItem" data-category="modifiers" data-type="characteristics">
          <i class="fa-solid fa-plus"></i> Add Characteristic Modifier
        </button>
      </div>

      {{!-- Skill Modifiers --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-graduation-cap"></i>
          Skill Modifiers
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="modifiers" data-type="skills">
          {{#each modifiers.skills}}
          <div class="tw-grid tw-grid-cols-[1fr_80px_32px] tw-gap-2 tw-items-center tw-px-3 tw-py-2 tw-bg-black/25 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm">
            <select name="modifiers.skills.{{@index}}.key" class="tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none">
              <option value="">-- Select --</option>
              {{#each ../skillOptions}}
              <option value="{{this.value}}" {{#if (eq this.value ../this.key)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
            <input type="number" name="modifiers.skills.{{@index}}.value" value="{{this.value}}" placeholder="+/-" class="tw-w-[70px] tw-px-2.5 tw-py-1.5 tw-text-[0.85rem] tw-text-center tw-bg-black/40 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-sm tw-text-[var(--color-text-primary)] focus:tw-border-gold focus:tw-outline-none" />
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-bg-crimson/15 tw-border tw-border-solid tw-border-crimson/40 tw-rounded-sm tw-text-crimson-light tw-cursor-pointer tw-transition-all hover:tw-bg-crimson/30 hover:tw-border-crimson [&>i]:tw-text-[0.8rem]" data-action="removeItem"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="tw-inline-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-accent-talents)]/10 tw-border tw-border-dashed tw-border-[var(--wh40k-accent-talents)]/30 tw-rounded-sm tw-text-[color-mix(in_srgb,var(--wh40k-accent-talents),white_15%)] tw-font-heading tw-text-[0.82rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-accent-talents)]/20 hover:tw-border-solid hover:tw-border-gold hover:tw-text-gold" data-action="addItem" data-category="modifiers" data-type="skills">
          <i class="fa-solid fa-plus"></i> Add Skill Modifier
        </button>
      </div>

      {{!-- Combat Modifiers --}}
      <div class="tw-mb-4 tw-p-3 tw-bg-black/15 tw-border tw-border-solid tw-border-[var(--color-border-light)] tw-rounded-md last:tw-mb-0">
        <label class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2 tw-font-heading tw-text-[0.82rem] tw-font-bold tw-text-gold tw-uppercase tw-tracking-[0.06em]">
          <i class="fa-solid fa-swords"></i>
          Combat Modifiers
        </label>
        <div class="tw-flex tw-flex-col tw-gap-2 tw-mt-2" data-category="modifiers" data-type="combat">
          {{#each modifiers.combat}}
