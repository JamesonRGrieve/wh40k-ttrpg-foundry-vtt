{{!-- Acquisition Dialog Template — RT Profit Factor + Scale (Table 9-35) --}}
<div class="tw-flex tw-flex-col tw-gap-4">

    {{!-- Header: Profit Factor --}}
    <div class="tw-flex tw-justify-between tw-items-center tw-pb-3 tw-border-b-2 tw-border-solid tw-border-bronze [&>h2]:tw-m-0 [&>h2]:tw-text-gold">
        <h2><i class="fas fa-coins"></i> {{localize "WH40K.AcquisitionScale.Header"}}</h2>
        <div>
            <span>{{localize "WH40K.AcquisitionScale.CurrentPF"}}</span>
            <span class="tw-text-xl tw-font-bold tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">{{profitFactor.current}}</span>
        </div>
    </div>

    {{!-- Item Being Acquired --}}
    {{#if item}}
    <div class="tw-flex tw-gap-3 tw-p-3 tw-bg-black/30 tw-border tw-border-solid tw-border-bronze tw-rounded-md">
        <img src="{{item.img}}" alt="{{item.name}}" class="tw-w-12 tw-h-12 tw-border tw-border-solid tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure" />
        <div>
            <div class="tw-font-bold">{{item.name}}</div>
            <div>
                <span>{{item.availability}}</span>
                <span>{{item.craftsmanship}}</span>
            </div>
        </div>
    </div>
    {{/if}}

    {{!-- Availability selector --}}
    <div class="[&>h3]:tw-m-0 [&>h3]:tw-mb-2 [&>h3]:tw-text-gold [&>h3]:tw-text-base">
        <h3>{{localize "WH40K.AcquisitionScale.AvailabilityHeader"}}</h3>
        <div class="tw-flex tw-flex-wrap tw-gap-1" data-acq-group="availability">
            {{#each availabilityChoices}}
            <button type="button"
                    data-action="selectAvailability"
                    data-availability="{{this.key}}"
                    class="tw-px-2 tw-py-1 tw-text-xs tw-border tw-border-solid tw-border-bronze tw-rounded-sm tw-cursor-pointer {{#if this.selected}}tw-bg-gold tw-text-black{{else}}tw-bg-[var(--color-bg-option,#222)] tw-text-[var(--wh40k-text-primary,#e8e4d9)]{{/if}}">
                {{localize this.labelKey}} {{#if (gt this.value 0)}}+{{/if}}{{this.value}}
            </button>
            {{/each}}
        </div>
    </div>

    {{!-- Craftsmanship selector --}}
    <div class="[&>h3]:tw-m-0 [&>h3]:tw-mb-2 [&>h3]:tw-text-gold [&>h3]:tw-text-base">
        <h3>{{localize "WH40K.AcquisitionScale.CraftsmanshipHeader"}}</h3>
        <div class="tw-flex tw-flex-wrap tw-gap-1" data-acq-group="craftsmanship">
            {{#each craftsmanshipChoices}}
            <button type="button"
                    data-action="selectCraftsmanship"
                    data-craftsmanship="{{this.key}}"
                    class="tw-px-2 tw-py-1 tw-text-xs tw-border tw-border-solid tw-border-bronze tw-rounded-sm tw-cursor-pointer {{#if this.selected}}tw-bg-gold tw-text-black{{else}}tw-bg-[var(--color-bg-option,#222)] tw-text-[var(--wh40k-text-primary,#e8e4d9)]{{/if}}">
                {{localize this.labelKey}} {{#if (gt this.value 0)}}+{{/if}}{{this.value}}
            </button>
            {{/each}}
        </div>
    </div>

    {{!-- Scale selector (new — Table 9-35 Scale column) --}}
    <div class="[&>h3]:tw-m-0 [&>h3]:tw-mb-2 [&>h3]:tw-text-gold [&>h3]:tw-text-base">
        <h3>{{localize "WH40K.AcquisitionScale.ScaleHeader"}}</h3>
        <div class="tw-flex tw-flex-wrap tw-gap-1" data-acq-group="scale">
            {{#each scaleChoices}}
            <button type="button"
                    data-action="selectScale"
                    data-scale="{{this.key}}"
                    class="tw-px-2 tw-py-1 tw-text-xs tw-border tw-border-solid tw-border-bronze tw-rounded-sm tw-cursor-pointer {{#if this.selected}}tw-bg-gold tw-text-black{{else}}tw-bg-[var(--color-bg-option,#222)] tw-text-[var(--wh40k-text-primary,#e8e4d9)]{{/if}}">
                {{localize this.labelKey}} {{#if (gt this.value 0)}}+{{/if}}{{this.value}}
            </button>
            {{/each}}
        </div>
    </div>

    {{!-- Common Modifiers --}}
    <div class="[&>h3]:tw-m-0 [&>h3]:tw-mb-2 [&>h3]:tw-text-gold [&>h3]:tw-text-base">
        <h3>{{localize "WH40K.AcquisitionScale.AdditionalHeader"}}</h3>
        {{#each commonModifiers}}
        <label class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-gap-2 [&_.positive]:tw-text-[#4caf50] [&_.negative]:tw-text-[#f44336]">
            <input type="checkbox"
                   data-action="toggleModifier"
                   data-modifier="{{this.key}}"
                   {{#if this.selected}}checked{{/if}} />
            <span class="tw-flex-1">{{localize this.label}}</span>
            <span class="{{#if (gt this.value 0)}}positive{{else}}negative{{/if}}">
                {{#if (gt this.value 0)}}+{{/if}}{{this.value}}
            </span>
        </label>
        {{/each}}
    </div>

    {{!-- Custom Modifier --}}
    <div>
        <label class="tw-flex tw-items-center tw-gap-2">
            <span>{{localize "WH40K.AcquisitionScale.CustomModifier"}}</span>
            <input type="number" name="customModifier" value="{{customModifier}}" placeholder="±0" class="tw-flex-1 tw-px-2 tw-py-1 tw-rounded-sm tw-border tw-border-solid tw-border-[var(--color-border-light-tertiary)] tw-bg-[var(--color-bg-option)]" />
        </label>
    </div>

    {{!-- Summary --}}
    <div class="tw-p-3 tw-bg-[rgba(212,175,55,0.1)] tw-border-2 tw-border-solid tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure tw-rounded-md">
        <div class="tw-flex tw-justify-between">
            <span>{{localize "WH40K.AcquisitionScale.BasePF"}}</span>
            <span>{{profitFactor.current}}</span>
        </div>
        <div class="tw-flex tw-justify-between [&_.positive]:tw-text-[#4caf50] [&_.negative]:tw-text-[#f44336]">
            <span>{{localize "WH40K.AcquisitionScale.TotalModifiers"}}</span>
            <span class="{{#if (gt totalModifier 0)}}positive{{else if (lt totalModifier 0)}}negative{{/if}}">
                {{#if (gt totalModifier 0)}}+{{/if}}{{totalModifier}}
            </span>
        </div>
        <div class="tw-flex tw-justify-between tw-text-lg tw-font-bold tw-pt-2 tw-border-t tw-border-solid tw-border-bronze">
            <span>{{localize "WH40K.AcquisitionScale.FinalTarget"}}</span>
            <span class="tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-text-xl">{{finalTarget}}</span>
        </div>
        {{#if autoSuccess}}
        <div data-acq-banner="auto-success" class="tw-mt-2 tw-p-2 tw-bg-[rgba(76,175,80,0.2)] tw-border tw-border-solid tw-border-[#4caf50] tw-rounded-sm tw-text-[#4caf50] tw-font-bold tw-text-center tw-uppercase tw-tracking-wide">
            <i class="fas fa-check-circle"></i> {{localize "WH40K.AcquisitionScale.AutoSuccessBanner"}}
        </div>
        {{/if}}
        {{#if autoFail}}
        <div data-acq-banner="auto-fail" class="tw-mt-2 tw-p-2 tw-bg-[rgba(244,67,54,0.2)] tw-border tw-border-solid tw-border-[#f44336] tw-rounded-sm tw-text-[#f44336] tw-font-bold tw-text-center tw-uppercase tw-tracking-wide">
            <i class="fas fa-times-circle"></i> {{localize "WH40K.AcquisitionScale.AutoFailBanner"}}
        </div>
        {{/if}}
    </div>

    {{!-- Actions --}}
    <div class="tw-flex tw-gap-2 [&>button]:tw-flex-1 [&>button]:tw-p-3 [&>button]:tw-font-bold [&>button]:tw-cursor-pointer">
        <button type="button" class="tw-bg-gold tw-text-black tw-border-2 tw-border-solid tw-border-bronze" data-action="roll">
            <i class="fas fa-dice-d20"></i> {{localize "WH40K.AcquisitionScale.RollButton"}}
        </button>
        <button type="button" class="tw-bg-[var(--color-bg-btn,#333)] tw-text-[var(--wh40k-text-primary,#e8e4d9)] tw-border-2 tw-border-solid tw-border-bronze" data-action="close">
            <i class="fas fa-times"></i> {{localize "WH40K.AcquisitionScale.CancelButton"}}
        </button>
    </div>

    {{!-- Recent Acquisitions --}}
    {{#if recentAcquisitions}}
    <div class="[&>h4]:tw-m-0 [&>h4]:tw-mb-2 [&>h4]:tw-text-gold [&>h4]:tw-text-base">
        <h4>{{localize "WH40K.AcquisitionScale.RecentHeader"}}</h4>
        <ul class="tw-m-0 tw-p-0 tw-list-none tw-flex tw-flex-col tw-gap-1">
            {{#each recentAcquisitions}}
            <li class="tw-flex tw-justify-between tw-px-2 tw-py-1 tw-rounded-sm {{#if this.success}}tw-bg-[rgba(76,175,80,0.15)] tw-text-[#4caf50]{{else}}tw-bg-[rgba(244,67,54,0.15)] tw-text-[#f44336]{{/if}}">
                <span>{{this.item.name}}</span>
                <span>{{this.roll}}/{{this.target}}</span>
            </li>
            {{/each}}
        </ul>
    </div>
    {{/if}}
</div>
