{{!-- Player → NPC trade interface. Two-column transfer layout modelled on the
      ship-inventory backpack-split panel: source stock on the left, the
      purchase / quote pane on the right. --}}
<div class="wh40k-panel wh40k-trade-dialog tw-overflow-hidden">
    <div class="wh40k-panel-header">
        <div class="tw-flex tw-items-center tw-gap-3">
            <span class="wh40k-panel-title tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
                <i class="fas fa-handshake"></i> {{localize "WH40K.Trade.DialogTitle"}}
            </span>
        </div>
        {{#if hasSources}}
            <div class="tw-flex tw-items-center tw-gap-2">
                <label for="transaction-source" class="tw-text-[0.7rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-secondary)]">Source</label>
                <select id="transaction-source" name="sourceId" class="tw-rounded-md tw-border tw-border-slate-600 tw-bg-slate-950 tw-px-3 tw-py-1.5 tw-text-sm tw-text-slate-100">
                    {{#each sources}}
                        <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}} ({{modeLabel}})</option>
                    {{/each}}
                </select>
            </div>
        {{/if}}
    </div>

    {{#if hasSources}}
        <div class="wh40k-panel-body tw-flex tw-gap-3">
            {{!-- LEFT: source stock --}}
            <div class="wh40k-trade-stock tw-flex tw-flex-col tw-flex-1 tw-min-w-0">
                <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2 tw-pb-1 tw-border-b tw-border-[var(--wh40k-border-light)] tw-text-[0.75rem] tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-secondary)]">
                    <i class="fas fa-store"></i>
                    <span>{{selectedSource.name}}</span>
                    <span class="tw-ml-auto tw-rounded-full tw-bg-[var(--wh40k-bg-input)] tw-px-1.5 tw-py-0.5 tw-text-[0.65rem] tw-font-bold">{{items.length}}</span>
                </div>
                <div class="tw-flex-1 tw-overflow-y-auto" style="max-height: 420px;">
                    {{#if items.length}}
                        <table class="tw-w-full tw-text-[0.78rem] tw-border-collapse">
                            <thead>
                                <tr>
                                    <th class="tw-w-7 tw-p-1 tw-border-b tw-border-[rgba(255,255,255,0.1)]"></th>
                                    <th class="tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Item</th>
                                    <th class="tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Type</th>
                                    <th class="tw-p-1 tw-text-right tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Qty</th>
                                    <th class="tw-p-1 tw-text-right tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Cost</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each items as |item|}}
                                    <tr class="wh40k-trade-row tw-cursor-pointer tw-border-b tw-border-[rgba(255,255,255,0.04)] hover:tw-bg-[rgba(255,255,255,0.05)] tw-transition-colors {{#if item.selected}}tw-bg-amber-500/10{{/if}}"
                                        data-action="selectItem"
                                        data-item-id="{{item.id}}"
                                        data-disable-drag="true"
                                        draggable="false">
                                        <td class="tw-p-1 tw-align-middle tw-text-center">
                                            {{#if item.selected}}<i class="fas fa-circle-check tw-text-amber-400"></i>{{else}}<i class="far fa-circle tw-text-[color:var(--wh40k-text-muted)]"></i>{{/if}}
                                        </td>
                                        <td class="tw-p-1 tw-align-middle">
                                            <div class="tw-flex tw-items-center tw-gap-2">
                                                {{#if item.img}}<img src="{{item.img}}" alt="{{item.name}}" class="tw-w-[22px] tw-h-[22px] tw-object-cover tw-rounded" />{{/if}}
                                                <span class="tw-font-semibold tw-text-slate-100 tw-max-w-[160px] tw-truncate">{{item.name}}</span>
                                            </div>
                                        </td>
                                        <td class="tw-p-1 tw-align-middle tw-text-[color:var(--wh40k-text-muted)] tw-capitalize">{{item.type}}</td>
                                        <td class="tw-p-1 tw-align-middle tw-text-right tw-text-slate-200">{{item.quantity}}</td>
                                        <td class="tw-p-1 tw-align-middle tw-text-right tw-text-slate-200">{{item.cost}}</td>
                                    </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    {{else}}
                        <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-center tw-opacity-70">
                            <i class="fas fa-box-open tw-text-[2rem] tw-mb-2 tw-opacity-50"></i>
                            <p class="tw-italic tw-text-sm tw-m-0">No inventory is available from this source.</p>
                        </div>
                    {{/if}}
                </div>
            </div>

            {{!-- DIVIDER --}}
            <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-2 tw-py-2">
                <div class="tw-flex-1 tw-w-px tw-bg-[var(--wh40k-border-light)]"></div>
                <span class="tw-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-full tw-bg-[var(--wh40k-bg-paper)] tw-border tw-border-[var(--wh40k-border-light)] tw-text-[color:var(--wh40k-text-secondary)]">
                    <i class="fas fa-right-long tw-text-[0.85rem]"></i>
                </span>
                <div class="tw-flex-1 tw-w-px tw-bg-[var(--wh40k-border-light)]"></div>
            </div>

            {{!-- RIGHT: purchase / quote pane --}}
            <div class="wh40k-trade-cart tw-flex tw-flex-col tw-flex-1 tw-min-w-0">
                <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2 tw-pb-1 tw-border-b tw-border-[var(--wh40k-border-light)] tw-text-[0.75rem] tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-secondary)]">
                    <i class="fas fa-receipt"></i>
                    <span>Purchase</span>
                </div>

                {{#if selectedItem}}
                    <div class="tw-flex tw-flex-col tw-gap-3">
                        <div class="tw-grid tw-gap-4 md:tw-grid-cols-2">
                            <div class="tw-grid tw-gap-1">
                                <label for="transaction-quantity" class="tw-text-xs tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-secondary)]">Quantity</label>
                                <input id="transaction-quantity" type="number" min="1" name="quantity" value="{{quantity}}" class="tw-rounded-md tw-border tw-border-slate-600 tw-bg-slate-950 tw-px-3 tw-py-2 tw-text-sm tw-text-slate-100" />
                            </div>
                            {{#if quote.allowInfluenceBurn}}
                                <div class="tw-grid tw-gap-1">
                                    <label for="transaction-influence" class="tw-text-xs tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-secondary)]">Burn Influence</label>
                                    <input id="transaction-influence" type="number" min="0" name="influenceBurn" value="{{influenceBurn}}" class="tw-rounded-md tw-border tw-border-slate-600 tw-bg-slate-950 tw-px-3 tw-py-2 tw-text-sm tw-text-slate-100" />
                                </div>
                            {{/if}}
                        </div>
                        {{#if quote.allowInfluenceBurn}}
                            <p class="tw-text-xs tw-text-slate-400">Influence only decreases if the GM approves and the barter completes.</p>
                        {{/if}}

                        {{#if quote}}
                            <div class="wh40k-panel tw-overflow-hidden">
                                <div class="wh40k-panel-body tw-grid tw-gap-2 tw-text-sm tw-text-slate-100">
                                    <p><strong>Mode:</strong> {{#if isBarter}}{{localize "WH40K.Trade.Approval.ModeBarter"}}{{else}}{{localize "WH40K.Trade.Approval.ModeRequisition"}}{{/if}}</p>
                                    <p><strong>{{localize "WH40K.Trade.Approval.BaseCost"}}:</strong> {{quote.baseCost}} {{quote.resourceLabel}}</p>
                                    {{#if quote.dispositionAttitude}}
                                        <p class="tw-text-slate-300">{{localize "WH40K.Trade.Adjust.Disposition" attitude=quote.dispositionAttitude}}</p>
                                    {{/if}}
                                    {{#if quote.adjustments.length}}
                                        <ul class="tw-my-1 tw-list-disc tw-pl-5 tw-text-slate-200">
                                            {{#each quote.adjustments}}
                                                <li>{{label}}: {{#if (gte value 0)}}+{{/if}}{{value}}</li>
                                            {{/each}}
                                        </ul>
                                    {{/if}}
                                    <p><strong>{{localize "WH40K.Trade.Approval.FinalCost"}}:</strong> {{quote.finalCost}} {{quote.resourceLabel}}</p>
                                    <p><strong>Available:</strong> {{quote.availableResource}} {{quote.resourceLabel}}</p>
                                    <p><strong>Remaining after transaction:</strong> {{quote.remainingResource}} {{quote.resourceLabel}}</p>
                                    {{#if quote.allowInfluenceBurn}}
                                        <p><strong>Remaining Influence:</strong> {{quote.remainingInfluence}}</p>
                                    {{/if}}
                                    {{#unless quote.stockAvailable}}
                                        <p class="tw-mt-1 tw-text-amber-300">The selected quantity is not currently available.</p>
                                    {{/unless}}
                                    {{#unless quote.canAfford}}
                                        <p class="tw-mt-1 tw-text-amber-300">The buyer cannot currently afford this transaction.</p>
                                    {{/unless}}
                                </div>
                            </div>
                        {{/if}}

                        <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-gap-2 tw-rounded-md tw-bg-amber-600 tw-px-4 tw-py-2 tw-font-semibold tw-text-slate-950 hover:tw-bg-amber-500" data-action="requestApproval">
                            <i class="fa-solid fa-paper-plane"></i>
                            <span>Send To GM For Approval</span>
                        </button>
                    </div>
                {{else}}
                    <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-center tw-opacity-70">
                        <i class="fas fa-hand-pointer tw-text-[2rem] tw-mb-2 tw-opacity-50"></i>
                        <p class="tw-italic tw-text-sm tw-m-0">Select an item from the source stock to price it.</p>
                    </div>
                {{/if}}
            </div>
        </div>
    {{else}}
        <div class="wh40k-panel-body">
            <p class="tw-text-sm tw-text-slate-300">No barter or requisition sources are configured for this player.</p>
        </div>
    {{/if}}
</div>
