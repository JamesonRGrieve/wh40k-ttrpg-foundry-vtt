{{!-- Craft Sheet Header (terracraft / aircraft / watercraft). Composes the
     shared `header-base` partial in horizontal variant; the body supplies the
     craft identity, the locomotion discriminator + faction meta row, and a
     quick-stats cluster (Integrity / Front Armour / Size). --}}

{{#> systems/wh40k-rpg/templates/actor/partial/header-base.hbs
    variant="horizontal"
    cardClass="tw-grid tw-grid-cols-[auto_1fr_auto] tw-gap-4 tw-p-4"}}
    <div class="tw-contents">
        {{!-- Identity: name input above portrait --}}
        <div class="tw-w-44 tw-shrink-0 tw-flex tw-flex-col tw-gap-2">
            {{> systems/wh40k-rpg/templates/actor/partial/actor-identity.hbs nameLabelKey="WH40K.Vehicle.Name" portraitWidthClass="tw-w-44"}}
        </div>

        {{!-- Meta: locomotion + faction --}}
        <div class="tw-flex tw-flex-1">
            <div class="tw-flex tw-gap-4 tw-flex-wrap">
                {{!-- Locomotion (propulsion adjective) --}}
                <div class="tw-flex tw-flex-col tw-gap-0.5">
                    <label class="tw-text-[0.7rem] tw-uppercase tw-text-[var(--wh40k-text-muted,#888)]">{{localize "WH40K.Vehicle.Locomotion"}}</label>
                    <select name="system.locomotion" class="tw-bg-[var(--wh40k-input-bg,rgba(0,0,0,0.3))] tw-border tw-border-[var(--wh40k-border-color,#444)] tw-text-[var(--wh40k-text-dark,#f0f0f0)] tw-px-2 tw-py-1 tw-rounded-sm tw-text-[0.85rem] focus:tw-border-gold focus:tw-outline-none">
                        <optgroup label="{{localize "WH40K.Vehicle.LocomotionGroup.Land"}}">
                            <option value="wheeled" {{#if (eq system.locomotion "wheeled")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Wheeled"}}</option>
                            <option value="tracked" {{#if (eq system.locomotion "tracked")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Tracked"}}</option>
                            <option value="walker" {{#if (eq system.locomotion "walker")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Walker"}}</option>
                            <option value="hover" {{#if (eq system.locomotion "hover")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Hover"}}</option>
                        </optgroup>
                        <optgroup label="{{localize "WH40K.Vehicle.LocomotionGroup.Air"}}">
                            <option value="flyer" {{#if (eq system.locomotion "flyer")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Flyer"}}</option>
                            <option value="skimmer" {{#if (eq system.locomotion "skimmer")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Skimmer"}}</option>
                            <option value="vtol" {{#if (eq system.locomotion "vtol")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Vtol"}}</option>
                        </optgroup>
                        <optgroup label="{{localize "WH40K.Vehicle.LocomotionGroup.Water"}}">
                            <option value="hull" {{#if (eq system.locomotion "hull")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Hull"}}</option>
                            <option value="submersible" {{#if (eq system.locomotion "submersible")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Submersible"}}</option>
                            <option value="hydrofoil" {{#if (eq system.locomotion "hydrofoil")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Hydrofoil"}}</option>
                        </optgroup>
                        <optgroup label="{{localize "WH40K.Vehicle.LocomotionGroup.Void"}}">
                            <option value="voidship" {{#if (eq system.locomotion "voidship")}}selected{{/if}}>{{localize "WH40K.Vehicle.LocomotionType.Voidship"}}</option>
                        </optgroup>
                    </select>
                </div>

                {{!-- Faction --}}
                <div class="tw-flex tw-flex-col tw-gap-0.5 tw-flex-1 tw-min-w-[150px]">
                    <label class="tw-text-[0.7rem] tw-uppercase tw-text-[var(--wh40k-text-muted,#888)]">{{localize "WH40K.NPC.Faction"}}</label>
                    <input type="text"
                           name="system.faction"
                           value="{{source.faction}}"
                           placeholder="{{localize 'WH40K.Vehicle.FactionPlaceholder'}}"
                           class="tw-bg-[var(--wh40k-input-bg,rgba(0,0,0,0.3))] tw-border tw-border-[var(--wh40k-border-color,#444)] tw-text-[var(--wh40k-text-dark,#f0f0f0)] tw-px-2 tw-py-1 tw-rounded-sm tw-text-[0.85rem] focus:tw-border-gold focus:tw-outline-none" />
                </div>
            </div>
        </div>

        {{!-- Quick Stats --}}
        <div class="tw-flex tw-flex-col tw-gap-2 tw-border-l tw-border-l-gold bc:tw-border-l-crimson-light dh1:tw-border-l-gold-raw-l5 dh2:tw-border-l-gold-raw dw:tw-border-l-accent-combat ow:tw-border-l-brass-l20 rt:tw-border-l-gold im:tw-border-l-failure tw-pl-4">
            {{> systems/wh40k-rpg/templates/actor/partial/stat-box.hbs
                label=(localize "WH40K.Vehicle.Integrity")
                boxBaseClass="tw-flex tw-flex-col tw-items-center tw-p-2 tw-bg-[var(--wh40k-input-bg,rgba(0,0,0,0.3))] tw-border tw-border-[var(--wh40k-border-color,#444)] tw-rounded-md tw-min-w-[70px]"
                labelBaseClass="tw-text-[0.65rem] tw-uppercase tw-text-[var(--wh40k-text-muted,#888)]"
                valuesBaseClass="tw-flex tw-items-center tw-gap-0.5"
                inputBaseClass="tw-w-[45px] tw-text-center tw-text-[1.1rem] tw-font-bold tw-bg-transparent tw-border-0 tw-text-[var(--wh40k-text-dark,#f0f0f0)] focus:tw-outline focus:tw-outline-1 focus:tw-outline-gold"
                sepBaseClass="tw-text-[1rem] tw-text-[var(--wh40k-text-muted,#888)]"
                boxClass="wh40k-craft-integrity"
                valueName="system.integrity.value"
                value=source.integrity.value
                maxName="system.integrity.max"
                max=source.integrity.max
                min="0"
                minMax="0"}}

            {{> systems/wh40k-rpg/templates/actor/partial/stat-box.hbs
                label=(localize "WH40K.Vehicle.ArmourFront")
                boxBaseClass="tw-flex tw-flex-col tw-items-center tw-p-2 tw-bg-[var(--wh40k-input-bg,rgba(0,0,0,0.3))] tw-border tw-border-[var(--wh40k-border-color,#444)] tw-rounded-md tw-min-w-[70px]"
                labelBaseClass="tw-text-[0.65rem] tw-uppercase tw-text-[var(--wh40k-text-muted,#888)]"
                inputBaseClass="tw-w-[45px] tw-text-center tw-text-[1.1rem] tw-font-bold tw-bg-transparent tw-border-0 tw-text-[var(--wh40k-text-dark,#f0f0f0)] focus:tw-outline focus:tw-outline-1 focus:tw-outline-gold"
                boxClass="wh40k-craft-armour"
                valueName="system.armour.front.value"
                value=source.armour.front.value
                min="0"}}

            {{> systems/wh40k-rpg/templates/actor/partial/stat-box.hbs
                label=(localize "WH40K.Vehicle.Size")
                boxBaseClass="tw-flex tw-flex-col tw-items-center tw-p-2 tw-bg-[var(--wh40k-input-bg,rgba(0,0,0,0.3))] tw-border tw-border-[var(--wh40k-border-color,#444)] tw-rounded-md tw-min-w-[70px]"
                labelBaseClass="tw-text-[0.65rem] tw-uppercase tw-text-[var(--wh40k-text-muted,#888)]"
                inputBaseClass="tw-w-[45px] tw-text-center tw-text-[1.1rem] tw-font-bold tw-bg-transparent tw-border-0 tw-text-[var(--wh40k-text-dark,#f0f0f0)] focus:tw-outline focus:tw-outline-1 focus:tw-outline-gold"
                boxClass="wh40k-craft-size"
                valueName="system.size"
                value=source.size
                min="1"
                maxAttr="10"}}
        </div>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/header-base.hbs}}
