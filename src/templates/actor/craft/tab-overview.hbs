{{!-- Craft Overview Tab (terracraft / aircraft / watercraft). Aircraft adds an
     altitude/ceiling block via {{#if isAircraft}}. --}}
<section class="tab {{#if tab.active}}active{{/if}} {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
    <div class="tw-flex tw-flex-col tw-gap-4">

        {{!-- Craft Stats Grid --}}
        <div class="tw-bg-[rgba(40,35,30,0.7)] tw-border tw-border-[#444] tw-rounded-[6px] tw-p-4 tw-mb-4">
            <h3 class="tw-text-[1.1rem] tw-font-bold tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-mb-2 tw-flex tw-items-center tw-gap-2">
                <i class="fas fa-tachometer-alt tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                {{localize "WH40K.Vehicle.Statistics"}}
            </h3>
            <div class="tw-grid tw-grid-cols-[repeat(auto-fit,minmax(150px,1fr))] tw-gap-4">
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">{{localize "WH40K.Vehicle.SpeedCruising"}}</label>
                    <input type="number" name="system.speed.cruising" value="{{craftStats.speed.cruising}}" min="0" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">{{localize "WH40K.Vehicle.SpeedTactical"}}</label>
                    <input type="number" name="system.speed.tactical" value="{{craftStats.speed.tactical}}" min="0" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">{{localize "WH40K.Vehicle.Manoeuverability"}}</label>
                    <input type="number" name="system.manoeuverability" value="{{craftStats.manoeuverability}}" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">{{localize "WH40K.Vehicle.Passengers"}}</label>
                    <input type="number" name="system.passengers" value="{{craftStats.passengers}}" min="0" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">{{localize "WH40K.Vehicle.CarryingCapacity"}}</label>
                    <input type="number" name="system.carryingCapacity" value="{{craftStats.carryingCapacity}}" min="0" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">{{localize "WH40K.Vehicle.Size"}}</label>
                    <input type="number" name="system.size" value="{{craftStats.size}}" min="1" max="10" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
            </div>

            {{!-- Aircraft-only: altitude tier + service ceiling --}}
            {{#if isAircraft}}
            <div class="tw-grid tw-grid-cols-[repeat(auto-fit,minmax(150px,1fr))] tw-gap-4 tw-mt-4 tw-pt-4 tw-border-t tw-border-[#444]">
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">{{localize "WH40K.Vehicle.Altitude"}}</label>
                    <select name="system.altitude" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]">
                        <option value="ground" {{#if (eq craftStats.altitude "ground")}}selected{{/if}}>{{localize "WH40K.Vehicle.AltitudeTier.Ground"}}</option>
                        <option value="low" {{#if (eq craftStats.altitude "low")}}selected{{/if}}>{{localize "WH40K.Vehicle.AltitudeTier.Low"}}</option>
                        <option value="high" {{#if (eq craftStats.altitude "high")}}selected{{/if}}>{{localize "WH40K.Vehicle.AltitudeTier.High"}}</option>
                        <option value="orbital" {{#if (eq craftStats.altitude "orbital")}}selected{{/if}}>{{localize "WH40K.Vehicle.AltitudeTier.Orbital"}}</option>
                    </select>
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">{{localize "WH40K.Vehicle.Ceiling"}}</label>
                    <input type="number" name="system.ceiling" value="{{craftStats.ceiling}}" min="0" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
            </div>
            {{/if}}
        </div>

        {{!-- Description --}}
        <div class="tw-bg-[rgba(40,35,30,0.7)] tw-border tw-border-[#444] tw-rounded-[6px] tw-p-4 tw-mb-4">
            <h3 class="tw-text-[1.1rem] tw-font-bold tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-mb-2 tw-flex tw-items-center tw-gap-2">
                <i class="fas fa-file-alt tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                {{localize "WH40K.Vehicle.Description"}}
            </h3>
            <div class="editor-content" data-edit="system.description">
                {{{system.description}}}
            </div>
        </div>

    </div>
</section>
