{{!-- Craft Notes Tab (terracraft / aircraft / watercraft). --}}
<section class="tab {{#if tab.active}}active{{/if}} {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
    <div class="tw-flex tw-flex-col tw-gap-4">

        {{!-- Special Rules --}}
        {{#> systems/wh40k-rpg/templates/actor/partial/craft-section.hbs icon="fa-scroll" titleKey="WH40K.Vehicle.SpecialRules"}}
            <div class="editor-content" data-edit="system.specialRules">
                {{{system.specialRules}}}
            </div>
        {{/systems/wh40k-rpg/templates/actor/partial/craft-section.hbs}}

        {{!-- Source Reference --}}
        {{#> systems/wh40k-rpg/templates/actor/partial/craft-section.hbs icon="fa-book" titleKey="WH40K.Vehicle.Source"}}
            <input type="text"
                   name="system.source"
                   value="{{source.source}}"
                   placeholder="{{localize 'WH40K.Vehicle.SourcePlaceholder'}}"
                   class="tw-w-full tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
        {{/systems/wh40k-rpg/templates/actor/partial/craft-section.hbs}}

    </div>
</section>
