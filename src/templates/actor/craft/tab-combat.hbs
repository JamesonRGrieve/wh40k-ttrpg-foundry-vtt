{{!-- Craft Combat Tab (terracraft / aircraft / watercraft). --}}
<section class="tab {{#if tab.active}}active{{/if}} {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
    <div class="tw-flex tw-flex-col tw-gap-4">

        {{!-- Creature profile — animate craft only (daemon-engines / walkers / Dreadnoughts). --}}
        {{#if characteristics}}
        {{#> systems/wh40k-rpg/templates/actor/partial/craft-section.hbs icon="fa-dharmachakra" titleKey="WH40K.Characteristics"}}
            <div class="tw-grid tw-grid-cols-3 sm:tw-grid-cols-5 lg:tw-grid-cols-9 tw-gap-2">
                {{#each characteristics}}
                <div class="tw-flex tw-flex-col tw-items-center tw-gap-1 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-rounded-[3px] tw-p-2">
                    <button type="button" class="tw-text-[0.75rem] tw-uppercase tw-text-[#aaa] hover:tw-text-gold tw-bg-transparent tw-border-0 tw-cursor-pointer" data-action="rollCharacteristic" data-characteristic="{{@key}}" title="{{this.label}}">{{this.short}}</button>
                    <input type="number" name="system.characteristics.{{@key}}.base" value="{{this.base}}" class="tw-w-full tw-text-center tw-bg-transparent tw-border-0 tw-text-[1.1rem] tw-font-bold tw-text-[#f0f0f0]" />
                    <span class="tw-text-[0.7rem] tw-text-[#888]">{{localize "WH40K.Skills.Bonus"}} {{this.bonus}}</span>
                </div>
                {{/each}}
            </div>
        {{/systems/wh40k-rpg/templates/actor/partial/craft-section.hbs}}

        {{#if profileAbilities.length}}
        {{#> systems/wh40k-rpg/templates/actor/partial/craft-section.hbs icon="fa-scroll" titleKey="WH40K.Abilities"}}
            <div class="tw-flex tw-flex-wrap tw-gap-2">
                {{#each profileAbilities}}
                <span class="tw-px-3 tw-py-1 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-rounded-[3px] tw-text-[0.85rem] tw-cursor-pointer hover:tw-text-gold" data-action="itemEdit" data-item-id="{{this._id}}">{{this.name}}</span>
                {{/each}}
            </div>
        {{/systems/wh40k-rpg/templates/actor/partial/craft-section.hbs}}
        {{/if}}
        {{/if}}

        {{!-- Directional Armour --}}
        {{#> systems/wh40k-rpg/templates/actor/partial/craft-section.hbs icon="fa-shield-alt" titleKey="WH40K.Vehicle.Armour"}}
            <div class="tw-grid tw-grid-cols-3 tw-gap-4">
                {{> systems/wh40k-rpg/templates/actor/partial/craft-field.hbs labelKey="WH40K.Vehicle.ArmourFront" name="system.armour.front.value" value=craftStats.armour.front min="0"}}
                {{> systems/wh40k-rpg/templates/actor/partial/craft-field.hbs labelKey="WH40K.Vehicle.ArmourSide" name="system.armour.side.value" value=craftStats.armour.side min="0"}}
                {{> systems/wh40k-rpg/templates/actor/partial/craft-field.hbs labelKey="WH40K.Vehicle.ArmourRear" name="system.armour.rear.value" value=craftStats.armour.rear min="0"}}
            </div>
        {{/systems/wh40k-rpg/templates/actor/partial/craft-section.hbs}}

        {{!-- Weapons List --}}
        {{#> systems/wh40k-rpg/templates/actor/partial/craft-section.hbs icon="fa-crosshairs" titleKey="WH40K.Vehicle.Weapons"}}
            <div class="tw-flex tw-flex-col tw-gap-2">
                {{#each weapons}}
                <div class="tw-flex tw-justify-between tw-items-center tw-px-3 tw-py-3 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-rounded-[3px] tw-transition-all" data-item-id="{{this._id}}">
                    <div class="tw-font-bold tw-cursor-pointer hover:tw-text-gold" data-action="rollWeapon" data-item-id="{{this._id}}">
                        {{this.name}}
                    </div>
                    <div class="tw-flex tw-gap-4 tw-text-[0.85rem] tw-text-[#888]">
                        <span>{{this.system.damage}}</span>
                        <span>{{this.system.range}}m</span>
                    </div>
                </div>
                {{else}}
                <div class="tw-py-8 tw-text-center tw-text-[#888] tw-italic">{{localize "WH40K.Vehicle.NoWeapons"}}</div>
                {{/each}}
            </div>
        {{/systems/wh40k-rpg/templates/actor/partial/craft-section.hbs}}

        {{!-- Traits --}}
        {{#> systems/wh40k-rpg/templates/actor/partial/craft-section.hbs icon="fa-bolt" titleKey="WH40K.Vehicle.Traits"}}
            <div class="tw-flex tw-flex-col tw-gap-3">
                {{#each vehicleTraits}}
                <div class="tw-px-3 tw-py-3 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-rounded-[3px]">
                    <strong class="tw-text-gold {{themeClassFor 'accent'}}">{{this.name}}</strong>
                    {{#if this.system.description}}
                    <p class="tw-mt-2 tw-text-[0.85rem] tw-text-[#888]">{{{this.system.description}}}</p>
                    {{/if}}
                </div>
                {{else}}
                <div class="tw-py-8 tw-text-center tw-text-[#888] tw-italic">{{localize "WH40K.Vehicle.NoTraits"}}</div>
                {{/each}}
            </div>
        {{/systems/wh40k-rpg/templates/actor/partial/craft-section.hbs}}

    </div>
</section>
