{{!-- Acolyte Sheet Header Part --}}
{{!-- Two-column layout: Left (portrait + bio) | Right (characteristics HUD V1 Enhanced) --}}
<div class="wh40k-header wh40k-grid-col-6 wh40k-panel wh40k-character-header">
    <div class="wh40k-header__info wh40k-header-grid">
        <div class="wh40k-header-left">
            <div class="wh40k-header-topline">
                <div class="wh40k-header__logo wh40k-portrait-container">
                    <img class="wh40k-header__logo-image wh40k-portrait" src="{{actor.img}}" data-action="editImage" data-edit="img" alt="{{actor.name}}" title="{{actor.name}}" />
                </div>
                <div class="wh40k-header-info">
                    <div class="wh40k-header-row wh40k-name-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Name"}}</span>
                        <input class="wh40k-header-input wh40k-name-input" name="name" type="text" value="{{actor.name}}" />
                    </div>
                    <div class="wh40k-header-row wh40k-player-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Player"}}</span>
                        <input class="wh40k-header-input wh40k-player-input" name="system.bio.playerName" type="text" value="{{source.bio.playerName}}" placeholder="Player Name" />
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">{{localize "WH40K.OriginPath.HomeWorld"}}</span>
                        <input class="wh40k-header-input" name="system.originPath.homeWorld" type="text" value="{{source.originPath.homeWorld}}" placeholder="Home World" />
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">{{localize "WH40K.OriginPath.Career"}}</span>
                        <input class="wh40k-header-input" name="system.originPath.career" type="text" value="{{source.originPath.career}}" placeholder="Career" />
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Rank"}}</span>
                        <input class="wh40k-header-input wh40k-rank-input" name="system.rogueTrader.rank" type="text" value="{{source.rogueTrader.rank}}" placeholder="Rank" />
                    </div>
                </div>
            </div>
        </div>
        <div class="wh40k-header-right">
            <div class="wh40k-hud-stack">
                {{!-- Characteristics HUD V1 Enhanced --}}
                <div class="wh40k-characteristics-hud">
                    {{#each actor.characteristics as |characteristic name|}}
                        {{#unless (eq name "influence")}}
                        <div class="wh40k-char-hud-item {{#if (gt this.modifier 0)}}wh40k-char-buffed{{/if}}{{#if (lt this.modifier 0)}}wh40k-char-debuffed{{/if}}"
                             data-advance="{{this.advance}}"
                             style="--advance-progress: {{divide this.advance 5}};">
                            <button
                                class="wh40k-char-hud-name roll-characteristic actor-drag"
                                type="button"
                                data-action="roll"
                                data-roll-type="characteristic"
                                data-roll-target="{{name}}"
                                data-item-type="characteristic"
                                data-item-id="{{name}}"
                                data-characteristic="{{name}}"
                                title="{{this.label}}"
                            >{{this.short}}</button>
                            <div class="wh40k-char-hud-circle" title="{{this.label}}">
                                <span class="wh40k-char-hud-mod">{{this.bonus}}</span>
                                <span class="wh40k-char-hud-mod-label">MOD</span>
                            </div>
                            <div class="wh40k-char-hud-base">Total {{this.total}}</div>
<!--                            <label class="wh40k-char-hud-toggle" data-action="toggleSection" data-toggle="charhud_{{name}}" title="Edit {{this.label}}">-->
<!--                                <span class="wh40k-char-hud-toggle-icon">v</span>-->
<!--                            </label>-->
<!--                            <div class="wh40k-char-hud-details charhud_{{name}}">-->
<!--                                <label class="wh40k-char-hud-field">-->
<!--                                    <span class="wh40k-char-hud-field-label">Base</span>-->
<!--                                    <input type="number" name="system.characteristics.{{name}}.base" data-dtype="Number" value="{{this.base}}" />-->
<!--                                </label>-->
<!--                                <label class="wh40k-char-hud-field">-->
<!--                                    <span class="wh40k-char-hud-field-label">Advances</span>-->
<!--                                    <select name="system.characteristics.{{name}}.advance">-->
<!--                                        {{option "0" this.advance "None"}}-->
<!--                                        {{option "1" this.advance "Simple"}}-->
<!--                                        {{option "2" this.advance "Intermediate"}}-->
<!--                                        {{option "3" this.advance "Trained"}}-->
<!--                                        {{option "4" this.advance "Proficient"}}-->
<!--                                        {{option "5" this.advance "Expert"}}-->
<!--                                    </select>-->
<!--                                </label>-->
<!--                                <label class="wh40k-char-hud-field">-->
<!--                                    <span class="wh40k-char-hud-field-label">Unnatural</span>-->
<!--                                    <select name="system.characteristics.{{name}}.unnatural" class="wh40k-unnatural-select" data-dtype="Number">-->
<!--                                        <option value="0" {{#if (eq this.unnatural 0)}}selected{{/if}}>—</option>-->
<!--                                        <option value="2" {{#if (eq this.unnatural 2)}}selected{{/if}}>×2</option>-->
<!--                                        <option value="3" {{#if (eq this.unnatural 3)}}selected{{/if}}>×3</option>-->
<!--                                        <option value="4" {{#if (eq this.unnatural 4)}}selected{{/if}}>×4</option>-->
<!--                                    </select>-->
<!--                                </label>-->
<!--                            </div>-->
                        </div>
                        {{/unless}}
                    {{/each}}
                </div>
            </div>
        </div>
    </div>
</div>
