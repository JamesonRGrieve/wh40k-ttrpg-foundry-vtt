{{!--
    Vital quick-controls — minus button / current/max display / plus button.
    Used by every vital panel and (separately) by dashboard compact rows.

    Required hash params:
        field        — full schema path (e.g. "system.wounds.value")
        current      — current resolved value
        cssPrefix    — class prefix (e.g. "wh40k-wounds")  generates "{{prefix}}-btn", "{{prefix}}-current", etc.
        wrapperClass — outer flex container utilities (e.g. "tw-flex tw-items-center tw-justify-between")

    Optional hash params:
        max         — resolved max (renders /max display when provided)
        maxLabel    — string override for max ("100" for corruption/insanity, "{{system.wounds.max}}" otherwise)
        decTitle    — title attr for minus button (default "Reduce")
        incTitle    — title attr for plus button (default "Increase")
        minValue    — data-min for decrement (default 0)
        maxValue    — data-max for increment (when set)
        showCalculator — boolean; when true, render the showStatBreakdown button next to value
        statKey     — passed to showStatBreakdown action (when showCalculator is true)
        valueWrapperClass — additional classes on the value display (text-xl, etc.)
        currentAnimateClass — animation utility to add to the current-value span (e.g. "tw-animate-pulse-scale")
--}}
{{!-- Button + value styling is inline; the wh40k-{prefix}-btn / -current / -minus / -plus
     class names are kept as DOM hooks (animations mixin and vital-partials tests query
     them) but no longer carry CSS — the typography & sizing live as tw-* utilities here.
     Original sizes were 28px (fate) / 36px (wounds); 32px is a shared compromise. --}}
<div class="{{wrapperClass}}">
    <button type="button"
            class="{{cssPrefix}}-btn {{cssPrefix}}-minus tw-w-8 tw-h-8 tw-p-0 tw-flex tw-items-center tw-justify-center tw-rounded-md tw-border tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-bg-[var(--wh40k-btn-bg)] tw-text-[var(--wh40k-text-medium)] tw-cursor-pointer hover:tw-bg-[var(--wh40k-btn-bg-hover)] hover:tw-border-[var(--wh40k-border-color)] tw-transition-colors"
            data-action="decrement"
            data-field="{{field}}"
            data-min="{{#if minValue}}{{minValue}}{{else}}0{{/if}}"
            title="{{#if decTitle}}{{decTitle}}{{else}}Reduce{{/if}}">
        <i class="fas fa-minus"></i>
    </button>

    <div class="{{cssPrefix}}-value tw-flex tw-items-baseline tw-gap-1 tw-font-alt tw-text-2xl tw-font-bold tw-leading-none tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure {{valueWrapperClass}}">
        <span class="{{cssPrefix}}-current {{currentAnimateClass}}">{{current}}</span>
        {{#if maxLabel}}
        <span class="{{cssPrefix}}-sep tw-text-base tw-opacity-60">/</span>
        <span class="{{cssPrefix}}-max tw-text-base tw-opacity-80">{{maxLabel}}</span>
        {{/if}}
        {{#if showCalculator}}
        {{> systems/wh40k-rpg/templates/actor/partial/stat-breakdown-button.hbs
            statKey=statKey
            extraClass="tw-ml-1"}}
        {{/if}}
    </div>

    <button type="button"
            class="{{cssPrefix}}-btn {{cssPrefix}}-plus tw-w-8 tw-h-8 tw-p-0 tw-flex tw-items-center tw-justify-center tw-rounded-md tw-border tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-bg-[var(--wh40k-btn-bg)] tw-text-[var(--wh40k-text-medium)] tw-cursor-pointer hover:tw-bg-[var(--wh40k-btn-bg-hover)] hover:tw-border-[var(--wh40k-border-color)] tw-transition-colors"
            data-action="increment"
            data-field="{{field}}"
            {{#if maxValue}}data-max="{{maxValue}}"{{/if}}
            title="{{#if incTitle}}{{incTitle}}{{else}}Increase{{/if}}">
        <i class="fas fa-plus"></i>
    </button>
</div>
