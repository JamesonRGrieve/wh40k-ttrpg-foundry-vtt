{{!--
    Vital progress bar with optional threshold markers.

    Required hash params:
        cssPrefix      — class prefix (e.g. "wh40k-wounds")
        percent        — numeric 0..100, or pre-resolved %

    Optional hash params:
        containerClass — extra classes on the outer bar container (positioning, gap, etc.)
        barClass       — extra classes on the inner bar track (height, bg, rounded, etc.).
                         REQUIRED for visible output — the legacy CSS rule was deleted in
                         the panel port and not replaced with a default; passing nothing
                         renders an unstyled 0-height div.
        cssVarName     — CSS variable for inline-style percent (e.g. "wounds-percent")
        fillExtraClass — extra utility classes for the fill (gradients, height, etc.).
                         Same REQUIRED note as barClass.
        thresholds     — array of { at, label, title } objects
        showPercentText— "right" | "below" | falsy. When truthy, render a percent span as a sibling (class: {cssPrefix}-percent).
        percentText    — override text (e.g. "{{value}} / {{max}}" for fatigue's progress text variant)
        percentTextClass — extra utilities on the percent text span
--}}
<div class="{{cssPrefix}}-bar-container {{containerClass}}">
    {{!-- Both `.wh40k-{prefix}-bar` and `.wh40k-{prefix}-bar-fill` are JS hooks
         (enhanced-animations-mixin.ts queries them and sets `--{cssVar}`); the
         legacy CSS that gave them visual styling was deleted in the panel port,
         so consumers MUST pass `barClass` to shape the track and `fillExtraClass`
         to shape the fill. The fill width is set inline so it works whether or
         not the surrounding cascade resolves the CSS var. --}}
    <div class="{{cssPrefix}}-bar {{barClass}}"
         data-percent="{{percent}}"
         style="--{{#if cssVarName}}{{cssVarName}}{{else}}{{cssPrefix}}-percent{{/if}}: {{percent}}%">
        <div class="{{cssPrefix}}-bar-fill {{fillExtraClass}}" style="width: {{percent}}%"></div>

        {{#each thresholds}}
        <div class="wh40k-threshold-marker tw-absolute tw-top-[-2px] tw-h-4 tw-flex tw-flex-col tw-items-center tw-pointer-events-none tw-z-[2]" style="left: {{this.at}}%;" title="{{this.title}}">
            <span class="tw-w-0.5 tw-h-full tw-bg-[var(--wh40k-border-accent)] tw-rounded-[1px] tw-bg-gold bc:tw-bg-crimson-light dh1e:tw-bg-gold-raw-l5 dh2e:tw-bg-gold-raw dw:tw-bg-accent-combat ow:tw-bg-brass-l20 rt:tw-bg-gold im:tw-bg-failure"></span>
            <span class="tw-absolute tw-top-[-18px] tw-text-[9px] tw-font-semibold tw-text-[var(--wh40k-text-muted)] tw-bg-[var(--wh40k-panel-bg-solid)] tw-px-[3px] tw-py-px tw-rounded-sm tw-border tw-border-[var(--wh40k-border-color-light)]">{{this.label}}</span>
        </div>
        {{/each}}
    </div>
    {{#if showPercentText}}
    <span class="{{cssPrefix}}-percent {{percentTextClass}}">{{#if percentText}}{{percentText}}{{else}}{{percent}}%{{/if}}</span>
    {{/if}}
</div>
