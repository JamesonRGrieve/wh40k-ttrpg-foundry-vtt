{{!--
    Vital pip row — dashboard row with leading icon + label and a body
    slot that holds a `pip-tracker-row` (or any pip-style cluster) plus
    any trailing affordance (penalty badge, restore button, etc.).
    Sibling to `vital-inline-row.hbs`, which renders dec/value/inc
    numeric controls instead of pip clusters.

    Block-partial usage:
        {{#> systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs
              icon="fa-bolt" label="Fatigue"}}
            {{> systems/wh40k-rpg/templates/actor/partial/pip-tracker-row …}}
            <span class="wh40k-vital-penalty">−10</span>
        {{/systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs}}

    Required hash params:
        icon        — Font Awesome class on the leading icon (e.g. "fa-heart")
        label       — display text for the row label

    Optional hash params:
        rowClass    — extra utility classes appended to the row container
                      (e.g. "wh40k-vital-critical-row").
--}}
<div class="wh40k-vital-row tw-flex tw-items-center tw-gap-1.5 tw-py-0.5 tw-border-l-2 tw-border-l-gold bc:tw-border-l-crimson-light dh1e:tw-border-l-gold-raw-l5 dh2e:tw-border-l-gold-raw dw:tw-border-l-accent-combat ow:tw-border-l-brass-l20 rt:tw-border-l-gold im:tw-border-l-failure tw-pl-1{{#if rowClass}} {{rowClass}}{{/if}}">
    <span class="wh40k-vital-icon"><i class="fas {{icon}}"></i></span>
    <span class="wh40k-vital-label">{{label}}</span>
    {{> @partial-block}}
</div>
