{{!--
    item-table-row.hbs — single row inside `item-table.hbs`. Renders a
    settings-toggle (or no-toggle) cell, a name cell (optionally an
    expand-toggle into a description body), arbitrary stat cells, and a
    per-row action toolbar. The block-content slot is the expandable
    description (only emitted when `nameToggleId` or `expandable` is truthy).

    Block-partial usage:
        (#>) systems/wh40k-rpg/templates/actor/partial/item-table-row.hbs
            item=item
            dragType="weapon"
            editAction="itemEdit"
            cells=(array
                (object value=item.system.class)
                (object value=item.system.type)
                (object value=item.system.equipped))
            actions=(array
                (object action="itemRoll" iconKey="fa:dice-d20" titleKey="WH40K.Common.Roll")
                (object action="itemDamage" iconKey="fa:bolt" titleKey="WH40K.Weapon.RollDamage")
                (object action="itemDelete" iconKey="fa:trash" titleKey="WH40K.Common.Delete"))
            nameToggleId=(concat 'description_' item.id)
            ... expandable description body ...
        (/) systems/wh40k-rpg/templates/actor/partial/item-table-row.hbs

    Hash arguments:
        item             — { id, name, img? } (required).
        dragType         — value emitted on data-item-type. When set, the row
                           also gets `item-drag` class for drop-zone wiring.
        nameToggleId     — when set, the name cell becomes a trait-toggle that
                           expands the description body. Pass e.g.
                           `(concat 'description_' item.id)` to match the
                           legacy `isExpanded` / `hideIfNot` flag id.
        showImg          — bool. If true, the name cell renders the item image
                           inline before the name (used by ship/vehicle panels
                           that don't have an expand toggle).
        editAction       — data-action for the leading settings cell. Pass
                           false to suppress the leading settings cell entirely
                           (used by panels that wrap the name itself in the
                           edit-button — e.g. ship-weapons, vehicle-weapons).
        editIconKey      — icon registry key for the edit cell
                           (default 'fa:cog').
        editTitleKey     — i18n key for the edit button title.
        cells            — array of {value, cellClass?, isHtml?, title?} stat
                           cells. `isHtml: true` triple-stashes the value
                           through `{{{...}}}` so e.g. enriched HTML survives.
        actions          — array of {action, iconKey, titleKey?, title?,
                           dataAttrs?, hoverClass?} action-toolbar buttons.
                           Each action's `data-item-id` defaults to `item.id`.
        rowClass         — extra classes appended to the row element.

    Theming: the row hover background uses inline per-system variants so each
    game system tints its hover highlight distinctly without a helper.
--}}
<div class="table-row tw-border-b dh2e:tw-border-bronze/20 rt:tw-border-amber-700/20 im:tw-border-crimson/20 {{#if dragType}}item-drag {{/if}}dh2e:hover:tw-bg-bronze/5 rt:hover:tw-bg-amber-700/5 im:hover:tw-bg-crimson/5{{#if rowClass}} {{rowClass}}{{/if}}" data-item-id="{{item.id}}"{{#if dragType}} data-item-type="{{dragType}}"{{/if}}>
    {{#unless (eq editAction false)}}
        <div class="table-cell--settingstoggle">
            <label class="wh40k-control-button item-edit" data-action="{{#if editAction}}{{editAction}}{{else}}itemEdit{{/if}}" data-item-id="{{item.id}}"{{#if editTitleKey}} title="{{localize editTitleKey}}" aria-label="{{localize editTitleKey}}"{{/if}}>
                <span class="wh40k-control-button__span">{{iconSvg (defaultVal editIconKey 'fa:cog') class="tw-w-3.5 tw-h-3.5"}}</span>
            </label>
        </div>
    {{/unless}}
    <div class="table-cell--left">
        {{#if nameToggleId}}
            {{> systems/wh40k-rpg/templates/actor/partial/trait-toggle.hbs toggle=nameToggleId text=item.name}}
        {{else if showImg}}
            <button class="item-name wh40k-item-button" data-action="{{#if editAction}}{{editAction}}{{else}}itemEdit{{/if}}" data-item-id="{{item.id}}" type="button">
                {{#if item.img}}<img class="wh40k-item-img" src="{{item.img}}" alt="{{item.name}}" />{{/if}}
                {{item.name}}
            </button>
        {{else}}
            <span class="display">{{item.name}}</span>
        {{/if}}
    </div>
    {{#each cells as |cell|}}
        <div class="{{#if cell.cellClass}}{{cell.cellClass}}{{else}}table-cell{{/if}}"{{#if cell.title}} title="{{cell.title}}"{{/if}}>
            {{#if cell.isHtml}}{{{cell.value}}}{{else}}<span class="display">{{cell.value}}</span>{{/if}}
        </div>
    {{/each}}
    {{#if actions.length}}
        <div class="table-cell--last">
            {{#each actions as |btn|}}
                <label class="wh40k-control-button {{#if btn.hoverClass}}{{btn.hoverClass}}{{/if}}" data-action="{{btn.action}}" data-item-id="{{../item.id}}"{{#if btn.titleKey}} title="{{localize btn.titleKey}}" aria-label="{{localize btn.titleKey}}"{{else if btn.title}} title="{{btn.title}}"{{/if}}{{#if btn.dataAttrs}} {{{btn.dataAttrs}}}{{/if}}>
                    <span class="wh40k-control-button__span">{{iconSvg btn.iconKey class="tw-w-3.5 tw-h-3.5"}}</span>
                </label>
            {{/each}}
        </div>
    {{/if}}
    {{#if nameToggleId}}
        <div class="table-cell--description description_{{item.id}}" {{hideIfNot (isExpanded nameToggleId)}}>
            {{> @partial-block}}
        </div>
    {{/if}}
</div>
