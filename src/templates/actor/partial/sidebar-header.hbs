{{!-- Shared sidebar character-sheet header content. Renders inside the
     wh40k-sidebar PARTS container; per-system header files wrap this in
     a flex column and append their own bio rows after it.

     Order: name input above portrait → portrait (with origin-builder
     button) → divination display (italic, when set) → origin path
     bubbles 2-col grid (when steps exist).

     Mirrors the DH2 NPC layout in header-dh.hbs and works for both PC
     and NPC actors via the universal `actor.name`, `originPathSteps`,
     `originPathComplete`, and `system.originPath.divination` context. --}}

<div class="wh40k-header-name-line tw-flex tw-w-full tw-items-center tw-gap-2">
    <input class="wh40k-header-input wh40k-name-input tw-min-w-0 tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[1.05rem] tw-font-bold tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]" name="name" type="text" value="{{actor.name}}" />
</div>

<div class="wh40k-portrait-container tw-relative tw-aspect-[11/15] tw-w-full tw-max-w-[160px] tw-cursor-pointer tw-overflow-hidden tw-rounded-md tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-shadow-[0_2px_8px_var(--wh40k-shadow-medium,rgba(0,0,0,0.2))] tw-transition-all hover:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] hover:tw-shadow-[0_0_8px_rgba(212,175,55,0.5)]">
    <i class="fa-solid fa-dice-d20 wh40k-origin-builder-btn tw-absolute tw-text-2xl tw-top-2 tw-left-2 tw-z-10 tw-cursor-pointer tw-opacity-60 tw-transition-all hover:tw-opacity-100 hover:tw-drop-shadow-[0_0_8px_rgba(212,175,55,0.9)] {{#unless originPathComplete}}pulse{{/unless}}"
       data-action="openOriginPathBuilder"
       data-tooltip="{{localize 'WH40K.Utility.SetupOriginPath'}}"></i>
    <img class="wh40k-portrait tw-h-full tw-w-full tw-object-cover tw-bg-[rgba(0,0,0,0.25)]" src="{{actor.img}}" data-action="editImage" data-edit="img" alt="{{actor.name}}" title="{{actor.name}}" />
</div>

{{#if system.originPath.divination}}
<p class="wh40k-divination tw-italic tw-opacity-60 tw-m-0 tw-text-center tw-text-xs tw-leading-snug">{{system.originPath.divination}}</p>
{{/if}}

{{#if originPathSteps.length}}
<div class="wh40k-npc-origin-grid tw-flex tw-w-full tw-flex-wrap tw-justify-center tw-gap-1.5">
    {{#each originPathSteps as |step|}}
    <div class="tw-flex tw-h-12 tw-w-12 tw-items-center tw-justify-center tw-overflow-hidden tw-rounded-full tw-border tw-border-solid tw-bg-[rgba(0,0,0,0.2)] tw-transition-all {{#if step.item}}tw-border-gold tw-cursor-pointer hover:tw-border-[#f0d060] hover:tw-shadow-[0_0_8px_rgba(212,175,55,0.5)]{{else}}tw-border-[var(--wh40k-border-color,#4a3728)] tw-opacity-40 tw-cursor-default{{/if}}"
         {{#if step.item}}data-action="itemEdit" data-item-id="{{step.item._id}}"{{/if}}
         {{#if step.tooltipData}}data-wh40k-tooltip="generic" data-wh40k-tooltip-data="{{step.tooltipData}}"{{else}}data-tooltip="{{step.label}}"{{/if}}>
        {{#if step.item}}
            <img src="{{step.item.img}}" alt="{{step.item.name}}" class="tw-h-full tw-w-full tw-object-cover" />
        {{else}}
            <i class="fas {{step.icon}} tw-text-base tw-text-[var(--wh40k-text-muted)]"></i>
        {{/if}}
    </div>
    {{/each}}
</div>
{{/if}}
