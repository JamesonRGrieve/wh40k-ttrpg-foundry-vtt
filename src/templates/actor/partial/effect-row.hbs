{{!--
    effect-row.hbs — canonical row partial for ActiveEffect display surfaces.

    Hash params (passed via `{{> effect-row effect=… compact=…}}`):
      effect       — { id, label, name?, icon, disabled, sourceName?,
                       duration?: {label}, changes?: [{label, value}] }
                     `label` is preferred; `name` is accepted as a fallback.
      compact      — bool. Compact lays out as a single dense line.
      expanded     — bool. When true, show the changes list (full only).
      editable     — bool (default-truthy: omit to render edit + delete).
      toggleAction — action name for enable/disable. default 'effectToggle'.
      editAction   — action name for edit. Falsy to omit edit button entirely.
                     Default 'effectEdit'.
      deleteAction — action name for delete. default 'effectDelete'.
      showDuration — bool. Show duration label if present (full only).

    The partial does not own panel chrome — it renders one row that consumers
    wrap in their own list / panel container.
--}}
{{#if compact}}
{{!-- Compact variant: single dense line --}}
<div class="tw-flex tw-items-center tw-gap-[6px] tw-px-[6px] tw-py-1 tw-rounded-sm tw-border-l-2 tw-border-l-[var(--wh40k-accent-gold)] tw-transition-all {{#if effect.disabled}}tw-opacity-50 tw-border-l-[var(--wh40k-text-muted)]{{/if}}"
     data-effect-id="{{effect.id}}"
     title="{{#if effect.label}}{{effect.label}}{{else}}{{effect.name}}{{/if}}{{#if effect.sourceName}} (from {{effect.sourceName}}){{/if}}">
    <img src="{{effect.icon}}"
         class="tw-w-[18px] tw-h-[18px] tw-rounded-sm tw-object-cover tw-shrink-0 tw-border tw-border-black/10 {{#if effect.disabled}}tw-grayscale{{/if}}"
         alt="" />
    <span class="tw-flex-1 tw-text-[0.75rem] tw-font-medium tw-text-[color:var(--color-text-primary)] tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis tw-leading-tight {{#if effect.disabled}}tw-line-through tw-text-[color:var(--wh40k-text-muted)]{{/if}}">{{#if effect.label}}{{effect.label}}{{else}}{{effect.name}}{{/if}}</span>
    <div class="tw-flex tw-gap-[2px] tw-ml-auto">
        <button type="button"
                class="tw-w-[18px] tw-h-[18px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[color:var(--wh40k-text-muted)] tw-cursor-pointer tw-rounded-sm tw-transition-all hover:tw-bg-white/10 hover:tw-text-[color:var(--wh40k-accent-gold)]"
                data-action="{{#if toggleAction}}{{toggleAction}}{{else}}effectToggle{{/if}}"
                data-effect-id="{{effect.id}}"
                title="{{#if effect.disabled}}{{localize 'WH40K.Effects.Enable'}}{{else}}{{localize 'WH40K.Effects.Disable'}}{{/if}}">
            <i class="fas {{#if effect.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}} tw-text-[0.7rem]"></i>
        </button>
        <button type="button"
                class="tw-w-[18px] tw-h-[18px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[color:var(--wh40k-text-muted)] tw-cursor-pointer tw-rounded-sm tw-transition-all hover:tw-bg-white/10 hover:tw-text-[color:var(--wh40k-accent-combat)]"
                data-action="{{#if deleteAction}}{{deleteAction}}{{else}}effectDelete{{/if}}"
                data-effect-id="{{effect.id}}"
                title="{{localize 'WH40K.Effects.Delete'}}">
            <i class="fas fa-times tw-text-[0.7rem]"></i>
        </button>
    </div>
</div>
{{else}}
{{!-- Full variant: card with icon, info, toolbar, optional changes list --}}
<div class="wh40k-effect-card tw-flex tw-flex-col tw-gap-2 tw-p-2 tw-bg-black/5 tw-border tw-border-solid tw-border-black/10 tw-rounded-sm {{#if effect.disabled}}wh40k-effect-disabled tw-opacity-50{{/if}}" data-effect-id="{{effect.id}}">
    <div class="wh40k-effect-card-header tw-flex tw-items-center tw-gap-2">
        <img src="{{effect.icon}}"
             class="wh40k-effect-icon tw-w-9 tw-h-9 tw-shrink-0"
             alt="{{#if effect.label}}{{effect.label}}{{else}}{{effect.name}}{{/if}}" />

        <div class="wh40k-effect-info tw-flex-1 tw-min-w-0">
            <div class="wh40k-effect-name tw-font-semibold tw-truncate tw-mb-0.5">{{#if effect.label}}{{effect.label}}{{else}}{{effect.name}}{{/if}}</div>
            {{#if effect.sourceName}}
                <div class="wh40k-effect-source tw-flex tw-items-center tw-gap-1 tw-text-xs tw-text-gray-500">
                    <i class="fas fa-link"></i> {{effect.sourceName}}
                </div>
            {{/if}}
            {{#if showDuration}}
                {{#if effect.duration.label}}
                    <div class="tw-text-xs tw-text-gray-500 tw-flex tw-items-center tw-gap-1">
                        <i class="fas fa-clock"></i> {{effect.duration.label}}
                    </div>
                {{/if}}
            {{/if}}
        </div>

        <div class="wh40k-effect-controls tw-flex tw-items-center tw-gap-1 tw-shrink-0">
            <button type="button"
                    class="wh40k-effect-btn wh40k-effect-toggle tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-cursor-pointer tw-bg-transparent tw-border-none tw-rounded-sm hover:tw-bg-black/5"
                    data-action="{{#if toggleAction}}{{toggleAction}}{{else}}effectToggle{{/if}}"
                    data-effect-id="{{effect.id}}"
                    title="{{#if effect.disabled}}{{localize 'WH40K.Effects.Enable'}}{{else}}{{localize 'WH40K.Effects.Disable'}}{{/if}}">
                <i class="fas {{#if effect.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
            </button>

            {{#unless (eq editable false)}}
                {{#unless (eq editAction "")}}
                    <button type="button"
                            class="wh40k-effect-btn wh40k-effect-edit tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-cursor-pointer tw-bg-transparent tw-border-none tw-rounded-sm hover:tw-bg-black/5"
                            data-action="{{#if editAction}}{{editAction}}{{else}}effectEdit{{/if}}"
                            data-effect-id="{{effect.id}}"
                            title="{{localize 'WH40K.Effects.Edit'}}">
                        <i class="fas fa-edit"></i>
                    </button>
                {{/unless}}

                <button type="button"
                        class="wh40k-effect-btn wh40k-effect-delete tw-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-cursor-pointer tw-bg-transparent tw-border-none tw-rounded-sm tw-text-failure hover:tw-bg-failure/10"
                        data-action="{{#if deleteAction}}{{deleteAction}}{{else}}effectDelete{{/if}}"
                        data-effect-id="{{effect.id}}"
                        title="{{localize 'WH40K.Effects.Delete'}}">
                    <i class="fas fa-trash"></i>
                </button>
            {{/unless}}
        </div>
    </div>

    {{#if expanded}}
        {{#if effect.changes.length}}
            <div class="wh40k-effect-changes tw-flex tw-flex-col tw-gap-1 tw-pt-2 tw-border-t tw-border-black/5">
                {{#each effect.changes as |change|}}
                    <div class="wh40k-effect-change tw-flex tw-items-center tw-justify-between tw-gap-2 tw-py-0.5 tw-px-2 tw-text-xs">
                        <span class="wh40k-change-label tw-text-gray-700">{{change.label}}</span>
                        <span class="wh40k-change-value tw-font-mono tw-font-semibold dh2e:tw-text-bronze rt:tw-text-amber-700 im:tw-text-crimson">{{change.value}}</span>
                    </div>
                {{/each}}
            </div>
        {{/if}}
    {{/if}}
</div>
{{/if}}
