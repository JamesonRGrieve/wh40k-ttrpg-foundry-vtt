{{!-- Shared sheet-header scaffold (block partial).

     The outer wrapper provides:
       * the standard `wh40k-header wh40k-panel` classes plus an optional
         component-specific class via `cardClass`
       * per-system Tailwind border variants (dh2e/rt/bc/dw/ow/im/dh1e)
         so every consuming header keeps the theme-ratchet count up
       * a `data-wh40k-system` attribute when `gameSystem` is supplied
         (makes per-system variants on inner content fire even when the
         partial is rendered outside a sheet root)

     Variants (selected via the `variant` hash param):
       * "sidebar" (default) — vertical column layout used by character
         headers. Body content (passed through the partial-block slot)
         is wrapped in an inner column flex container. Typical usage:
         pass `sidebar-header.hbs` + `sidebar-fields-panel.hbs`.
       * "horizontal" — horizontal layout. The wrapper renders the
         partial-block slot directly (no inner column wrapper);
         consumers supply their own structure (typically
         actor-identity + meta + quick-stats).

     Hash params:
       cardClass        extra classes on the outer wrapper.
       variant          "sidebar" | "horizontal" (default "sidebar")
       gameSystem       active system id; surfaces `data-wh40k-system`
                        on the wrapper so per-system variants on inner
                        elements fire.
       innerClass       classes on the inner flex container (sidebar
                        variant only).
       headerTag        outer element tag name (default "div"; pass
                        "header" for semantic markup).
--}}
{{#if (eq variant "horizontal")}}
<div class="wh40k-header wh40k-panel{{#if cardClass}} {{cardClass}}{{/if}} tw-flex tw-flex-none tw-shrink-0 tw-border-b tw-border-solid tw-border-[var(--color-border-secondary,#444)] dh2e:tw-border-bronze rt:tw-border-accent-dynasty bc:tw-border-crimson dw:tw-border-bronze ow:tw-border-brass im:tw-border-crimson-light dh1e:tw-border-gold-raw"{{#if gameSystem}} data-wh40k-system="{{gameSystem}}"{{/if}}>
    {{> @partial-block}}
</div>
{{else}}
<div class="wh40k-header wh40k-panel{{#if cardClass}} {{cardClass}}{{/if}} tw-flex tw-flex-none tw-flex-col tw-gap-3 tw-px-3 tw-py-3 tw-min-w-0 tw-m-0 tw-border-r-0 tw-border-b tw-border-solid tw-border-[var(--color-border-secondary,#444)] dh2e:tw-border-bronze rt:tw-border-accent-dynasty bc:tw-border-crimson dw:tw-border-bronze ow:tw-border-brass im:tw-border-crimson-light dh1e:tw-border-gold-raw tw-rounded-none"{{#if gameSystem}} data-wh40k-system="{{gameSystem}}"{{/if}}>
    <div class="{{#if innerClass}}{{innerClass}}{{else}}tw-flex tw-flex-col tw-items-center tw-gap-3{{/if}}">
        {{> @partial-block}}
    </div>
</div>
{{/if}}
