{{!--
    Dashboard zone — outer column with a header bar (icon + title) and a
    content panel. Used by the simple zones in `tab-overview.hbs`. Block
    partial: body content is supplied through the partial-block slot.

    For zones with a non-trivial header (SVG ring, action-button row), build
    the zone inline rather than forcing this partial to grow new slots.

    Required hash params:
        title        — header text
        icon         — Font Awesome class (e.g. "fa-heartbeat"); rendered as
                       `<i class="fas {{icon}}">`

    Optional hash params:
        zoneClass    — extra utility classes on the outer zone div (e.g. an
                       accent left-border like `tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-combat)]`)
        contentClass — override the default content-pad utilities. Defaults to
                       `tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1`
--}}
<div class="tw-flex tw-flex-col tw-overflow-hidden tw-bg-[var(--color-bg-secondary)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px]{{#if zoneClass}} {{zoneClass}}{{/if}}">
    <div class="tw-flex tw-items-center tw-gap-1.5 tw-py-1.5 tw-px-2.5 tw-bg-[var(--color-bg-tertiary)] tw-border-b tw-border-solid tw-border-[var(--color-border-secondary)] tw-text-xs tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)] tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
        <i class="fas {{icon}}"></i>
        <span>{{title}}</span>
    </div>
    <div class="{{#if contentClass}}{{contentClass}}{{else}}tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1{{/if}}">
        {{> @partial-block}}
    </div>
</div>
