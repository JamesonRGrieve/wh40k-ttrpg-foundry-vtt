{{!--
    Shared tab-nav strip — replaces the duplicated <nav>{{#each tabs}}<a/>{{/each}}</nav>
    pattern across player / vehicle / future actor sheets.

    Required hash params:
        tabs       — array of tab descriptors. Each entry should have:
                       { tab? | id, label, group, cssClass?, active?, icon? }
                     Both `tab` and `id` are accepted as the data-tab key (player passes
                     `tab`, vehicle passes `id` — the partial reads whichever exists).

    Optional hash params:
        navClass   — additional classes on the <nav> wrapper.
        itemClass  — additional classes on each tab anchor element.
        dataGroup  — overrides the data-group attr (default "primary").
        withLabelWrap — when true, wraps each anchor in a label with class wh40k-navigation__item.
                        Used by the older vehicle/starship chrome.

    Usage:
        {{> systems/wh40k-rpg/templates/actor/partial/tab-strip.hbs
            tabs=tabs
            navClass="!tw-flex !tw-flex-col !tw-gap-1 !tw-m-0 !tw-p-2 ..."
            itemClass="wh40k-nav-item tw-flex tw-w-full tw-items-center ..."}}
--}}
<nav class="tabs wh40k-navigation tw-flex tw-flex-col tw-flex-nowrap tw-items-stretch tw-gap-[2px] tw-py-[10px] tw-px-[8px] tw-bg-[linear-gradient(180deg,rgba(74,55,40,0.08),rgba(74,55,40,0.03))] tw-border-r tw-border-r-[rgba(74,55,40,0.15)] dh2e:tw-border-r-bronze rt:tw-border-r-accent-dynasty bc:tw-border-r-crimson dw:tw-border-r-bronze ow:tw-border-r-brass im:tw-border-r-crimson-light dh1e:tw-border-r-gold-raw tw-border-b-0 tw-rounded-lg tw-[perspective:800px] tw-sticky tw-top-[12px] tw-self-start {{navClass}}" data-group="{{#if dataGroup}}{{dataGroup}}{{else}}primary{{/if}}">
    {{#each tabs}}
    {{#if ../withLabelWrap}}
    <label class="wh40k-navigation__item wh40k-nav-item">
        <a class="wh40k-nav-item tw-flex tw-items-center tw-cursor-pointer {{../itemClass}} {{cssClass}} {{#if active}}active{{/if}}"
           data-action="tab"
           data-group="{{#if group}}{{group}}{{else}}primary{{/if}}"
           data-tab="{{#if tab}}{{tab}}{{else}}{{id}}{{/if}}"
           data-tooltip="{{label}}">
            {{#if icon}}<span class="tw-text-[12px] tw-leading-none tw-mr-1 material-icons">{{icon}}</span>{{/if}}
            {{label}}
        </a>
    </label>
    {{else}}
    <a class="wh40k-nav-item tw-flex tw-items-center tw-cursor-pointer {{../itemClass}} {{cssClass}} {{#if active}}active{{/if}}"
       data-action="tab"
       data-group="{{#if group}}{{group}}{{else}}primary{{/if}}"
       data-tab="{{#if tab}}{{tab}}{{else}}{{id}}{{/if}}"
       data-tooltip="{{label}}">
        {{#if icon}}<span class="tw-text-[12px] tw-leading-none tw-mr-1 material-icons">{{icon}}</span>{{/if}}
        {{label}}
    </a>
    {{/if}}
    {{/each}}
</nav>
