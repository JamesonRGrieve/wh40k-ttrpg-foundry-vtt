{{!--
    Vital quick-adjust button row — four buttons: -5 / -1 / +1 / +5.
    Used by corruption and insanity panels. The deltas and button styling are fixed
    (matching the existing markup); each caller passes its own field path and wrapper class.

    Required hash params:
        field        — schema path ("system.corruption")
        wrapperClass — outer container classes (e.g. "wh40k-corruption-quick-set tw-flex tw-gap-1 tw-mt-2")

    Optional hash params:
        minValue  — data-min for negative deltas (default 0)
        maxValue  — data-max for positive deltas (default 100)
--}}
<div class="{{wrapperClass}}">
    <button type="button"
            class="tw-p-2 tw-bg-[var(--wh40k-panel-bg-solid)] tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color)] tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure tw-rounded-md tw-text-[0.85rem] tw-font-bold tw-text-[var(--wh40k-text-medium)] tw-cursor-pointer tw-transition-all tw-font-alt tw-text-[var(--wh40k-success-secondary)] hover:tw-bg-[var(--wh40k-success-bg)] hover:tw-border-[var(--wh40k-success-primary)] hover:tw-text-[var(--wh40k-success-primary)] hover:-tw-translate-y-px hover:tw-shadow-[0_2px_4px_var(--wh40k-shadow-soft)] active:tw-translate-y-0 active:tw-shadow-[inset_0_2px_4px_var(--wh40k-shadow-medium)]"
            data-action="adjustStat"
            data-field="{{field}}"
            data-delta="-5"
            data-min="{{#if minValue}}{{minValue}}{{else}}0{{/if}}"
            title="Decrease by 5">
        -5
    </button>
    <button type="button"
            class="tw-p-2 tw-bg-[var(--wh40k-panel-bg-solid)] tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color)] tw-rounded-md tw-text-[0.85rem] tw-font-bold tw-text-[var(--wh40k-text-medium)] tw-cursor-pointer tw-transition-all tw-font-alt tw-text-[var(--wh40k-success-secondary)] hover:tw-bg-[var(--wh40k-success-bg)] hover:tw-border-[var(--wh40k-success-primary)] hover:tw-text-[var(--wh40k-success-primary)] hover:-tw-translate-y-px hover:tw-shadow-[0_2px_4px_var(--wh40k-shadow-soft)] active:tw-translate-y-0 active:tw-shadow-[inset_0_2px_4px_var(--wh40k-shadow-medium)]"
            data-action="adjustStat"
            data-field="{{field}}"
            data-delta="-1"
            data-min="{{#if minValue}}{{minValue}}{{else}}0{{/if}}"
            title="Decrease by 1">
        -1
    </button>
    <button type="button"
            class="tw-p-2 tw-bg-[var(--wh40k-panel-bg-solid)] tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color)] tw-rounded-md tw-text-[0.85rem] tw-font-bold tw-text-[var(--wh40k-text-medium)] tw-cursor-pointer tw-transition-all tw-font-alt tw-text-[var(--wh40k-corruption-primary)] hover:tw-bg-[var(--wh40k-corruption-bg)] hover:tw-border-[var(--wh40k-corruption-primary)] hover:tw-text-[var(--wh40k-corruption-primary)] hover:-tw-translate-y-px hover:tw-shadow-[0_2px_4px_var(--wh40k-shadow-soft)] active:tw-translate-y-0 active:tw-shadow-[inset_0_2px_4px_var(--wh40k-shadow-medium)]"
            data-action="adjustStat"
            data-field="{{field}}"
            data-delta="1"
            data-max="{{#if maxValue}}{{maxValue}}{{else}}100{{/if}}"
            title="Increase by 1">
        +1
    </button>
    <button type="button"
            class="tw-p-2 tw-bg-[var(--wh40k-panel-bg-solid)] tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color)] tw-rounded-md tw-text-[0.85rem] tw-font-bold tw-text-[var(--wh40k-text-medium)] tw-cursor-pointer tw-transition-all tw-font-alt tw-text-[var(--wh40k-corruption-primary)] hover:tw-bg-[var(--wh40k-corruption-bg)] hover:tw-border-[var(--wh40k-corruption-primary)] hover:tw-text-[var(--wh40k-corruption-primary)] hover:-tw-translate-y-px hover:tw-shadow-[0_2px_4px_var(--wh40k-shadow-soft)] active:tw-translate-y-0 active:tw-shadow-[inset_0_2px_4px_var(--wh40k-shadow-medium)]"
            data-action="adjustStat"
            data-field="{{field}}"
            data-delta="5"
            data-max="{{#if maxValue}}{{maxValue}}{{else}}100{{/if}}"
            title="Increase by 5">
        +5
    </button>
</div>
