{{!--
    Vital inline row — compact row used in the dashboard Vitals zone of tab-overview.

    Renders the dashboard's specific markup shape (icon + label + dec/value/inc cluster),
    using the dashboard's existing class names (wh40k-vital-row, wh40k-vital-btn, wh40k-vital-value,
    wh40k-mental-* variants) so JS data-action / data-field selectors and monolith CSS rules continue
    to match. This is intentionally NOT a wrapper around vital-quick-controls.hbs — that partial uses
    a cssPrefix API which generates {{prefix}}-btn / {{prefix}}-current / {{prefix}}-max class shapes
    that don't match the dashboard rows (single wh40k-vital-value span containing "current/max" with
    a stateClass for warning/critical decoration).

    Required hash params:
        icon        — Font Awesome class on the leading icon (e.g. "fa-heart")
        label       — display text for the row label
        field       — schema field path used by data-field on inc/dec buttons (e.g. "system.wounds.value")
        current     — current resolved value rendered in the value span

    Optional hash params:
        max         — max value; when truthy renders "/{{max}}" after current
        min         — data-min on decrement button (default 0)
        maxAttr     — data-max on increment button (when set; renders the attribute)
        stateClass  — extra class appended to the value span (e.g. "wh40k-critical", "wh40k-warning",
                      or a corruption/insanity degree class). Leading space added automatically.
        tooltip     — data-tooltip value on the row (used for hover hints)
        decTitle    — title attr on minus button (default "−1")
        incTitle    — title attr on plus button (default "+1")
        rowClass    — extra classes appended to wh40k-vital-row (e.g. "wh40k-mental-row")
        labelGroupClass — wrapper class for icon+label group (default flex inline group). Set to
                      "wh40k-mental-label-group" for mental rows.
        iconClass   — class on the icon span (default "wh40k-vital-icon"; mental rows use
                      "wh40k-mental-icon")
        labelClass  — class on the label span (default "wh40k-vital-label"; mental rows use
                      "wh40k-mental-label")
        valueClass  — class on the value span (default "wh40k-vital-value"; mental rows use
                      "wh40k-mental-value")
        controlsExtraClass — extra classes appended to the controls flex container (e.g. "tw-ml-auto")
        penaltyText — when truthy, renders <span class="wh40k-vital-penalty">{{penaltyText}}</span>
                      after the controls cluster
        degreeText  — when truthy, renders <span class="wh40k-mental-degree {{stateClass}}">…</span>
                      AFTER the controls (used by mental rows; stateClass holds the degree class).
                      When degreeText is set, stateClass is NOT applied to valueClass.

    NOTE: This is a regular (non-block) partial. Rows that need extra content after the controls
    (e.g. the Fate row's restoreFate button) should remain inline rather than use this partial.
--}}
<div class="wh40k-vital-row tw-flex tw-items-center tw-gap-1.5 tw-py-0.5 tw-border-l-2 tw-border-l-gold bc:tw-border-l-crimson-light dh1e:tw-border-l-gold-raw-l5 dh2e:tw-border-l-gold-raw dw:tw-border-l-accent-combat ow:tw-border-l-brass-l20 rt:tw-border-l-gold im:tw-border-l-failure tw-pl-1{{#if rowClass}} {{rowClass}}{{/if}}"{{#if tooltip}} data-tooltip="{{tooltip}}"{{/if}}>
    {{#if labelGroupClass}}
    <span class="{{labelGroupClass}}">
        <span class="{{#if iconClass}}{{iconClass}}{{else}}wh40k-vital-icon{{/if}}"><i class="fas {{icon}}"></i></span>
        <span class="{{#if labelClass}}{{labelClass}}{{else}}wh40k-vital-label{{/if}}">{{label}}</span>
    </span>
    {{else}}
    <span class="{{#if iconClass}}{{iconClass}}{{else}}wh40k-vital-icon{{/if}}"><i class="fas {{icon}}"></i></span>
    <span class="{{#if labelClass}}{{labelClass}}{{else}}wh40k-vital-label{{/if}}">{{label}}</span>
    {{/if}}
    <div class="wh40k-vital-controls tw-flex tw-items-center tw-gap-1{{#unless degreeText}} tw-ml-auto{{/unless}}{{#if controlsExtraClass}} {{controlsExtraClass}}{{/if}}">
        <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="{{field}}" data-min="{{#if min}}{{min}}{{else}}0{{/if}}" title="{{#if decTitle}}{{decTitle}}{{else}}−1{{/if}}">
            <i class="fas fa-minus"></i>
        </button>
        <span class="{{#if valueClass}}{{valueClass}}{{else}}wh40k-vital-value{{/if}}{{#unless degreeText}}{{#if stateClass}} {{stateClass}}{{/if}}{{/unless}}">
            {{current}}{{#if max}}/{{max}}{{/if}}
        </span>
        <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="{{field}}"{{#if maxAttr}} data-max="{{maxAttr}}"{{/if}} title="{{#if incTitle}}{{incTitle}}{{else}}+1{{/if}}">
            <i class="fas fa-plus"></i>
        </button>
    </div>
    {{#if penaltyText}}
    <span class="wh40k-vital-penalty">{{penaltyText}}</span>
    {{/if}}
    {{#if degreeText}}
    <span class="wh40k-mental-degree{{#if stateClass}} {{stateClass}}{{/if}}">{{degreeText}}</span>
    {{/if}}
</div>
