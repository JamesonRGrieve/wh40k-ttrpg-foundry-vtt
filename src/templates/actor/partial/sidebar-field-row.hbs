<div class="wh40k-header-row {{field.rowClass}} tw-flex tw-min-w-0 tw-items-baseline tw-gap-2">
    <span class="wh40k-header-label tw-min-w-[60px] tw-shrink-0 tw-text-[0.75rem] tw-font-bold tw-uppercase tw-text-[var(--wh40k-text-medium,#666)]">
        {{#if field.icon}}<i class="{{field.icon}}"></i> {{/if}}{{field.label}}
    </span>
    {{#if (eq field.type "select")}}
    <select
        class="wh40k-header-input tw-min-w-0 tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]"
        name="{{field.name}}"
    >
        {{selectOptions field.options selected=field.value}}
    </select>
    {{else}}
    <input
        class="wh40k-header-input {{field.inputClass}} tw-min-w-0 tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[var(--wh40k-text-dark,#333)] focus:tw-outline-none"
        name="{{field.name}}"
        type="{{field.type}}"
        value="{{field.value}}"
        placeholder="{{field.placeholder}}"
        {{#if field.min}}min="{{field.min}}"{{/if}}
        {{#if field.max}}max="{{field.max}}"{{/if}}
        {{#if field.borderColor}}style="border-color: {{field.borderColor}};"{{else}}style="border-color: var(--wh40k-border-color,#4a3728);"{{/if}}
    />
    {{/if}}
    {{#if field.valueLabel}}
    <span class="wh40k-header-value {{field.valueClass}} tw-min-w-0 tw-whitespace-nowrap tw-text-xs" {{#if field.valueColor}}style="color: {{field.valueColor}};"{{/if}}>
        {{field.valueLabel}}
    </span>
    {{/if}}
</div>
