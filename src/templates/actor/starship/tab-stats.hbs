{{!-- Starship Stats Tab --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    <div class="wh40k-panel spacer wh40k-grid-col-3 wh40k-grid-row-1">
        <h1 class="wh40k-panel-header">{{localize "WH40K.Starship.Combat.Header"}}</h1>
        <div class="wh40k-ship-initiative-box">
            <button type="button" class="wh40k-initiative-btn" data-action="rollInitiative" title="{{localize 'WH40K.Starship.Combat.RollInitiative'}}">
                <span class="material-icons">radar</span>
                <span class="wh40k-init-label">{{localize "WH40K.Starship.Combat.Initiative"}}</span>
            </button>
            <span class="wh40k-detection-bonus" title="{{localize 'WH40K.Starship.Combat.DetectionBonus'}}">+{{system.detectionBonus}}</span>
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Combat.Speed"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.speed" value="{{source.speed}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Combat.Manoeuvrability"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.manoeuvrability" value="{{source.manoeuvrability}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Combat.Detection"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.detection" value="{{source.detection}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Combat.Armour"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.armour" value="{{source.armour}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Combat.VoidShields"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.voidShields" value="{{source.voidShields}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Combat.TurretRating"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.turretRating" value="{{source.turretRating}}" />
        </div>
    </div>

    <div class="wh40k-panel spacer wh40k-grid-col-3 wh40k-grid-row-1">
        <h1 class="wh40k-panel-header">{{localize "WH40K.Starship.Resources.Header"}}</h1>
        
        {{!-- Power Status Indicator --}}
        <div class="wh40k-resource-status {{#if system.hasPowerShortage}}wh40k-shortage{{/if}}">
            <span class="wh40k-resource-icon material-icons">bolt</span>
            <span class="wh40k-resource-label">{{localize "WH40K.Starship.Resources.Power"}}</span>
            <span class="wh40k-resource-value {{#if system.hasPowerShortage}}wh40k-negative{{else}}wh40k-positive{{/if}}">
                {{system.power.available}}
            </span>
            <span class="wh40k-resource-detail">( {{system.power.used}} / {{system.power.total}} )</span>
        </div>
        
        {{!-- Space Status Indicator --}}
        <div class="wh40k-resource-status {{#if system.hasSpaceShortage}}wh40k-shortage{{/if}}">
            <span class="wh40k-resource-icon material-icons">warehouse</span>
            <span class="wh40k-resource-label">{{localize "WH40K.Starship.Resources.Space"}}</span>
            <span class="wh40k-resource-value {{#if system.hasSpaceShortage}}wh40k-negative{{else}}wh40k-positive{{/if}}">
                {{system.space.available}}
            </span>
            <span class="wh40k-resource-detail">( {{system.space.used}} / {{system.space.total}} )</span>
        </div>
        
        <div class="wh40k-resources-divider"></div>
        
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Resources.SpaceTotal"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.space.total" value="{{source.space.total}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Resources.SpaceUsed"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.space.used" value="{{source.space.used}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Resources.PowerTotal"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.power.total" value="{{source.power.total}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Resources.PowerUsed"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.power.used" value="{{source.power.used}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Resources.ShipPoints"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.shipPoints" value="{{source.shipPoints}}" />
        </div>
    </div>

    <div class="wh40k-panel spacer wh40k-grid-col-3 wh40k-grid-row-1">
        <h1 class="wh40k-panel-header">{{localize "WH40K.Starship.WeaponCapacity.Header"}}</h1>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.WeaponCapacity.Prow"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.weaponCapacity.prow" value="{{source.weaponCapacity.prow}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.WeaponCapacity.Dorsal"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.weaponCapacity.dorsal" value="{{source.weaponCapacity.dorsal}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.WeaponCapacity.Port"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.weaponCapacity.port" value="{{source.weaponCapacity.port}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.WeaponCapacity.Starboard"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.weaponCapacity.starboard" value="{{source.weaponCapacity.starboard}}" />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.WeaponCapacity.Keel"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.weaponCapacity.keel" value="{{source.weaponCapacity.keel}}" />
        </div>
    </div>

    <div class="wh40k-panel spacer wh40k-grid-col-3 wh40k-grid-row-1">
        <h1 class="wh40k-panel-header">{{localize "WH40K.Starship.Physical.Header"}}</h1>
        <div class="wh40k-field__wrapper wh40k-grid-col-3">
            <span class="wh40k-field__header">{{localize "WH40K.Starship.Physical.Dimensions"}}</span>
            <input type="text" class="wh40k-field__input" name="system.dimensions" value="{{source.dimensions}}" />
        </div>
    </div>
</section>
