{{!-- Vehicle Overview Tab --}}
<section class="tab {{#if tab.active}}active{{/if}} {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
    <div class="tw-flex tw-flex-col tw-gap-4">

        {{!-- Vehicle Stats Grid --}}
        <div class="tw-bg-[rgba(40,35,30,0.7)] tw-border tw-border-[#444] tw-rounded-[6px] tw-p-4 tw-mb-4">
            <h3 class="tw-text-[1.1rem] tw-font-bold tw-text-gold tw-mb-2 tw-flex tw-items-center tw-gap-2">
                <i class="fas fa-tachometer-alt tw-text-gold"></i>
                Vehicle Statistics
            </h3>
            <div class="tw-grid tw-grid-cols-[repeat(auto-fit,minmax(150px,1fr))] tw-gap-4">
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">Speed (Cruising)</label>
                    <input type="number" name="system.speed.cruising" value="{{vehicleStats.speed.cruising}}" min="0" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">Speed (Tactical)</label>
                    <input type="number" name="system.speed.tactical" value="{{vehicleStats.speed.tactical}}" min="0" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">Handling</label>
                    <input type="number" name="system.handling" value="{{vehicleStats.handling}}" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">Manoeuvrability</label>
                    <span class="tw-text-[1.2rem] tw-font-bold tw-text-[#f0f0f0] tw-p-2 tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-rounded-[3px] tw-text-center">{{vehicleStats.manoeuvrability}}</span>
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">Hull Points</label>
                    <input type="number" name="system.hull" value="{{vehicleStats.hull}}" min="0" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
                <div class="tw-flex tw-flex-col tw-gap-1 tw-col-span-2">
                    <label class="tw-text-[0.8rem] tw-text-[#888] tw-uppercase">Size</label>
                    <input type="number" name="system.size" value="{{vehicleStats.size}}" min="1" max="10" class="tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[#444] tw-text-[#f0f0f0] tw-p-2 tw-rounded-[3px]" />
                </div>
            </div>
        </div>

        {{!-- Description --}}
        <div class="tw-bg-[rgba(40,35,30,0.7)] tw-border tw-border-[#444] tw-rounded-[6px] tw-p-4 tw-mb-4">
            <h3 class="tw-text-[1.1rem] tw-font-bold tw-text-gold tw-mb-2 tw-flex tw-items-center tw-gap-2">
                <i class="fas fa-file-alt tw-text-gold"></i>
                Description
            </h3>
            <div class="editor-content" data-edit="system.description">
                {{{enrichHTML system.description}}}
            </div>
        </div>

    </div>
</section>
