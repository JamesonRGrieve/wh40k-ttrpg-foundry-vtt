{{!-- Vehicle Sheet Header --}}
<div class="wh40k-header wh40k-panel wh40k-vehicle-header">
    <div class="wh40k-header__info">
        {{!-- Identity: name input above portrait --}}
        <div class="wh40k-vehicle-identity tw-w-44 tw-shrink-0">
            {{> systems/wh40k-rpg/templates/actor/partial/actor-identity.hbs nameLabelKey="WH40K.Vehicle.Name" portraitWidthClass="tw-w-44"}}
        </div>

        {{!-- Meta: type + faction --}}
        <div class="wh40k-vehicle-meta">
            <div class="wh40k-vehicle-meta-row">
                {{!-- Type --}}
                <div class="wh40k-vehicle-field">
                    <label>{{localize "WH40K.Vehicle.Type"}}</label>
                    <select name="system.type" class="wh40k-vehicle-select">
                        <option value="vehicle" {{#if (eq system.type "vehicle")}}selected{{/if}}>Vehicle</option>
                        <option value="walker" {{#if (eq system.type "walker")}}selected{{/if}}>Walker</option>
                        <option value="flyer" {{#if (eq system.type "flyer")}}selected{{/if}}>Flyer</option>
                        <option value="skimmer" {{#if (eq system.type "skimmer")}}selected{{/if}}>Skimmer</option>
                    </select>
                </div>

                {{!-- Faction --}}
                <div class="wh40k-vehicle-field wh40k-vehicle-field--wide">
                    <label>{{localize "WH40K.NPC.Faction"}}</label>
                    <input type="text"
                           name="system.faction"
                           value="{{source.faction}}"
                           placeholder="e.g., Imperial Guard, Ork" />
                </div>
            </div>
        </div>

        {{!-- Quick Stats --}}
        <div class="wh40k-vehicle-quick-stats">
            {{!-- Structure --}}
            <div class="wh40k-vehicle-stat-box wh40k-vehicle-structure">
                <span class="wh40k-vehicle-stat-label">Structure</span>
                <div class="wh40k-vehicle-stat-values">
                    <input type="number"
                           class="wh40k-vehicle-stat-input"
                           name="system.wounds.value"
                           value="{{source.wounds.value}}"
                           min="0"
                           title="Current" />
                    <span class="wh40k-vehicle-stat-separator">/</span>
                    <input type="number"
                           class="wh40k-vehicle-stat-input"
                           name="system.wounds.max"
                           value="{{source.wounds.max}}"
                           min="1"
                           title="Max" />
                </div>
            </div>

            {{!-- Hull/Armour --}}
            <div class="wh40k-vehicle-stat-box wh40k-vehicle-armour">
                <span class="wh40k-vehicle-stat-label">Armour</span>
                <input type="number"
                       class="wh40k-vehicle-stat-input"
                       name="system.armour.total"
                       value="{{source.armour.total}}"
                       min="0" />
            </div>

            {{!-- Size --}}
            <div class="wh40k-vehicle-stat-box wh40k-vehicle-size">
                <span class="wh40k-vehicle-stat-label">Size</span>
                <input type="number"
                       class="wh40k-vehicle-stat-input"
                       name="system.size"
                       value="{{source.size}}"
                       min="1"
                       max="10" />
            </div>
        </div>
    </div>
</div>
