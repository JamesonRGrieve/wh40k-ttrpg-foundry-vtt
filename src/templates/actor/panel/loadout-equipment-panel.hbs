{{!-- Loadout Manager Equipment Panel --}}
{{!-- Modern equipment management with organized sections --}}

<div class="wh40k-equipment-loadout">
    {{!-- NEW: Split Backpack Panel (Personal & Ship Storage) --}}
    {{> systems/wh40k-rpg/templates/actor/panel/backpack-split-panel.hbs}}

    {{!-- Two Column Layout --}}
    <div class="wh40k-equipment-grid">
        {{!-- LEFT COLUMN: Armour & Protection --}}
        <div class="wh40k-equipment-col wh40k-equipment-protection">
            {{!-- Armour Body Diagram (already has panel wrapper) --}}
            {{> systems/wh40k-rpg/templates/actor/panel/armour-display-panel.hbs}}

            {{!-- Lifting Capacity --}}
            <div class="wh40k-panel wh40k-panel-lifting">
                <div class="wh40k-panel-header">
                    <span class="wh40k-panel-title"><i class="fas fa-dumbbell"></i> Lifting Capacity</span>
                </div>
                <div class="wh40k-panel-body">
                    <div class="wh40k-lifting-grid">
                        <div class="wh40k-lift-item">
                            <span class="wh40k-lift-label">Carry</span>
                            <span class="wh40k-lift-value">{{system.lifting.carry}} kg</span>
                        </div>
                        <div class="wh40k-lift-item">
                            <span class="wh40k-lift-label">Lift</span>
                            <span class="wh40k-lift-value">{{system.lifting.lift}} kg</span>
                        </div>
                        <div class="wh40k-lift-item">
                            <span class="wh40k-lift-label">Push</span>
                            <span class="wh40k-lift-value">{{system.lifting.push}} kg</span>
                        </div>
                    </div>
                </div>
            </div>

            {{!-- Backpack/Container Info --}}
            {{#if actor.backpack.hasBackpack}}
            <div class="wh40k-panel wh40k-panel-backpack">
                <div class="wh40k-panel-header">
                    <span class="wh40k-panel-title"><i class="fas fa-suitcase"></i> Backpack</span>
                </div>
                <div class="wh40k-panel-body">
                    <div class="wh40k-backpack-bar-wrapper">
                        <div class="wh40k-backpack-bar-container">
                            <div class="wh40k-backpack-bar-fill" style="width: {{backpackPercent}}%"></div>
                        </div>
                        <span class="wh40k-backpack-text">{{actor.encumbrance.backpack_value}} / {{actor.encumbrance.backpack_max}} kg</span>
                    </div>
                </div>
            </div>
            {{/if}}
        </div>

        {{!-- RIGHT COLUMN: Equipment Lists --}}
        <div class="wh40k-equipment-col wh40k-equipment-items">
            {{!-- Armour Items --}}
            <div class="wh40k-panel wh40k-panel-armour-list">
                <div class="wh40k-panel-header">
                    <span class="wh40k-panel-title"><i class="fas fa-shield-alt"></i> Armour</span>
                    <span class="wh40k-item-count">{{armourItems.length}}</span>
                </div>
                <div class="wh40k-panel-body">
                    {{#if armourItems.length}}
                    <div class="wh40k-equipment-table">
                        {{#each armourItems as |item|}}
                        <div class="wh40k-equip-row item-drag {{#if item.system.equipped}}wh40k-equip-equipped{{/if}}" data-item-id="{{item.id}}" data-item-type="armour">
                            <img class="wh40k-equip-icon" src="{{item.img}}" alt="{{item.name}}" />
                            <button type="button" class="wh40k-equip-name" data-action="itemEdit" data-item-id="{{item.id}}" title="{{item.name}}">{{item.name}}</button>
                            <span class="wh40k-equip-meta">{{item.system.type}}</span>
                            <span class="wh40k-equip-stat"><span class="wh40k-stat-l">AP:</span> <strong>{{item.system.ap}}</strong></span>
                            {{#if item.system.maxAP}}
                            <span class="wh40k-equip-stat"><span class="wh40k-stat-l">Max:</span> {{item.system.maxAP}}</span>
                            {{/if}}
                            {{#if item.system.weight}}
                            <span class="wh40k-equip-stat"><span class="wh40k-stat-l">Wt:</span> {{item.system.weight}}kg</span>
                            {{/if}}
                            <div class="wh40k-equip-actions">
                                <button type="button" class="wh40k-equip-btn wh40k-equip-toggle" data-action="toggleEquip" data-item-id="{{item.id}}" title="{{#if item.system.equipped}}Unequip{{else}}Equip{{/if}}">
                                    <i class="fas {{#if item.system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
                                </button>
                                <button type="button" class="wh40k-equip-btn" data-action="itemVocalize" data-item-id="{{item.id}}" title="Send to Chat">
                                    <i class="fas fa-comment"></i>
                                </button>
                                <button type="button" class="wh40k-equip-btn wh40k-equip-danger" data-action="itemDelete" data-item-id="{{item.id}}" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{!-- Armour Dropzone --}}
                    <div class="wh40k-dropzone-small" data-action="itemCreate" data-type="armour">
                        <i class="fas fa-plus-circle"></i>
                        <span>Drop armour here or click to create</span>
                    </div>
                </div>
            </div>

            {{!-- Force Fields --}}
            <div class="wh40k-panel wh40k-panel-forcefields">
                <div class="wh40k-panel-header">
                    <span class="wh40k-panel-title"><i class="fas fa-circle-notch"></i> Force Fields</span>
                    <span class="wh40k-item-count">{{forceFieldItems.length}}</span>
                </div>
                <div class="wh40k-panel-body">
                    {{#if forceFieldItems.length}}
                    <div class="wh40k-equipment-table">
                        {{#each forceFieldItems as |item|}}
                        <div class="wh40k-equip-row item-drag {{#if item.system.activated}}wh40k-equip-active{{/if}} {{#if item.system.overloaded}}wh40k-equip-overloaded{{/if}}" data-item-id="{{item.id}}" data-item-type="forceField">
                            <img class="wh40k-equip-icon" src="{{item.img}}" alt="{{item.name}}" />
                            <button type="button" class="wh40k-equip-name" data-action="itemEdit" data-item-id="{{item.id}}" title="{{item.name}}">{{item.name}}</button>
                            <span class="wh40k-equip-status">
                                {{#if item.system.overloaded}}
                                    <i class="fas fa-exclamation-triangle wh40k-status-danger"></i> OVERLOAD
                                {{else if item.system.activated}}
                                    <i class="fas fa-bolt wh40k-status-active"></i> ACTIVE
                                {{else}}
                                    <i class="fas fa-power-off wh40k-status-offline"></i> Offline
                                {{/if}}
                            </span>
                            <span class="wh40k-equip-stat"><span class="wh40k-stat-l">Rating:</span> <strong>{{item.system.protectionRating}}</strong></span>
                            <span class="wh40k-equip-stat"><span class="wh40k-stat-l">Overload:</span> {{item.system.overloadRoll}}</span>
                            <div class="wh40k-equip-actions">
                                {{#unless item.system.overloaded}}
                                <button type="button" class="wh40k-equip-btn wh40k-equip-toggle" data-action="toggleActivate" data-item-id="{{item.id}}" title="{{#if item.system.activated}}Deactivate{{else}}Activate{{/if}}">
                                    <i class="fas {{#if item.system.activated}}fa-bolt{{else}}fa-power-off{{/if}}"></i>
                                </button>
                                {{/unless}}
                                <button type="button" class="wh40k-equip-btn" data-action="itemRoll" data-item-id="{{item.id}}" title="Roll Protection">
                                    <i class="fas fa-dice-d20"></i>
                                </button>
                                <button type="button" class="wh40k-equip-btn" data-action="itemVocalize" data-item-id="{{item.id}}" title="Send to Chat">
                                    <i class="fas fa-comment"></i>
                                </button>
                                <button type="button" class="wh40k-equip-btn wh40k-equip-danger" data-action="itemDelete" data-item-id="{{item.id}}" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{!-- Force Field Dropzone --}}
                    <div class="wh40k-dropzone-small" data-action="itemCreate" data-type="forceField">
                        <i class="fas fa-plus-circle"></i>
                        <span>Drop force field here or click to create</span>
                    </div>
                </div>
            </div>

            {{!-- Cybernetics --}}
            <div class="wh40k-panel wh40k-panel-cybernetics">
                <div class="wh40k-panel-header">
                    <span class="wh40k-panel-title"><i class="fas fa-microchip"></i> Cybernetics</span>
                    <span class="wh40k-item-count">{{cyberneticItems.length}}</span>
                </div>
                <div class="wh40k-panel-body">
                    {{#if cyberneticItems.length}}
                    <div class="wh40k-equipment-table">
                        {{#each cyberneticItems as |item|}}
                        <div class="wh40k-equip-row item-drag {{#if item.system.equipped}}wh40k-equip-equipped{{/if}}" data-item-id="{{item.id}}" data-item-type="cybernetic">
                            <img class="wh40k-equip-icon" src="{{item.img}}" alt="{{item.name}}" />
                            <button type="button" class="wh40k-equip-name" data-action="itemEdit" data-item-id="{{item.id}}" title="{{item.name}}">{{item.name}}</button>
                            <span class="wh40k-equip-meta">{{item.system.location}}</span>
                            {{#if item.system.craftsmanship}}
                            <span class="wh40k-equip-stat"><span class="wh40k-stat-l">Quality:</span> {{item.system.craftsmanship}}</span>
                            {{/if}}
                            <div class="wh40k-equip-actions">
                                <button type="button" class="wh40k-equip-btn wh40k-equip-toggle" data-action="toggleEquip" data-item-id="{{item.id}}" title="{{#if item.system.equipped}}Uninstall{{else}}Install{{/if}}">
                                    <i class="fas {{#if item.system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
                                </button>
                                <button type="button" class="wh40k-equip-btn" data-action="itemVocalize" data-item-id="{{item.id}}" title="Send to Chat">
                                    <i class="fas fa-comment"></i>
                                </button>
                                <button type="button" class="wh40k-equip-btn wh40k-equip-danger" data-action="itemDelete" data-item-id="{{item.id}}" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{!-- Cybernetic Dropzone --}}
                    <div class="wh40k-dropzone-small" data-action="itemCreate" data-type="cybernetic">
                        <i class="fas fa-plus-circle"></i>
                        <span>Drop cybernetic here or click to create</span>
                    </div>
                </div>
            </div>

            {{!-- Gear --}}
            <div class="wh40k-panel wh40k-panel-gear">
                <div class="wh40k-panel-header">
                    <span class="wh40k-panel-title"><i class="fas fa-toolbox"></i> Gear</span>
                    <span class="wh40k-item-count">{{gearItems.length}}</span>
                </div>
                <div class="wh40k-panel-body">
                    {{#if gearItems.length}}
                    <div class="wh40k-equipment-table">
                        {{#each gearItems as |item|}}
                        <div class="wh40k-equip-row item-drag {{#if item.system.inBackpack}}wh40k-equip-stowed{{/if}}" data-item-id="{{item.id}}" data-item-type="gear">
                            <img class="wh40k-equip-icon" src="{{item.img}}" alt="{{item.name}}" />
                            <button type="button" class="wh40k-equip-name" data-action="itemEdit" data-item-id="{{item.id}}" title="{{item.name}}">{{item.name}}</button>
                            <span class="wh40k-equip-status">
                                {{#if item.system.inBackpack}}
                                    <i class="fas fa-suitcase"></i> Backpack
                                {{else}}
                                    <i class="fas fa-user"></i> Carried
                                {{/if}}
                            </span>
                            {{#if item.system.weight}}
                            <span class="wh40k-equip-stat"><span class="wh40k-stat-l">Wt:</span> {{item.system.weight}}kg</span>
                            {{/if}}
                            {{#if item.system.availability}}
                            <span class="wh40k-equip-stat"><span class="wh40k-stat-l">Avail:</span> {{item.system.availability}}</span>
                            {{/if}}
                            <div class="wh40k-equip-actions">
                                {{#if item.system.inBackpack}}
                                <button type="button" class="wh40k-equip-btn" data-action="unstowItem" data-item-id="{{item.id}}" title="Remove from Backpack">
                                    <i class="fas fa-box-open"></i>
                                </button>
                                {{else}}
                                <button type="button" class="wh40k-equip-btn" data-action="stowItem" data-item-id="{{item.id}}" title="Stow in Backpack">
                                    <i class="fas fa-archive"></i>
                                </button>
                                {{/if}}
                                <button type="button" class="wh40k-equip-btn" data-action="itemVocalize" data-item-id="{{item.id}}" title="Send to Chat">
                                    <i class="fas fa-comment"></i>
                                </button>
                                <button type="button" class="wh40k-equip-btn wh40k-equip-danger" data-action="itemDelete" data-item-id="{{item.id}}" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{!-- Gear Dropzone --}}
                    <div class="wh40k-dropzone-small" data-action="itemCreate" data-type="gear">
                        <i class="fas fa-plus-circle"></i>
                        <span>Drop gear here or click to create</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
