{{!-- Fatigue Panel — vital meter for fatigue levels with collapse threshold + rest/clear actions. --}}
{{#> systems/wh40k-rpg/templates/actor/partial/vital-panel-shell key="fatigue" label="Fatigue" icon="fa-bolt" actor=actor
    rootStateClass=(concat (iff (gt system.fatigue.value system.fatigue.max) "wh40k-unconscious") " " (iff (and (lte system.fatigue.value system.fatigue.max) (gt system.fatigue.value 0)) "wh40k-fatigued"))}}

    {{!-- Main Display: Current/Threshold with Quick Controls --}}
    <div class="tw-flex tw-flex-col tw-gap-1">
        {{> systems/wh40k-rpg/templates/actor/partial/vital-quick-controls
            wrapperClass="tw-flex tw-items-center tw-justify-between tw-mb-2"
            cssPrefix="wh40k-fatigue"
            field="system.fatigue.value"
            current=system.fatigue.value
            maxLabel=system.fatigue.max
            decTitle="Reduce Fatigue"
            incTitle="Increase Fatigue"}}

        {{> systems/wh40k-rpg/templates/actor/partial/vital-progress-bar
            cssPrefix="wh40k-fatigue"
            cssVarName="fatigue-percent"
            percent=(percent system.fatigue.value system.fatigue.max)
            containerClass="tw-relative tw-h-4 tw-bg-[rgba(0,0,0,0.3)] tw-rounded-md tw-overflow-hidden tw-mb-2"
            fillExtraClass="tw-h-full tw-bg-gradient-to-r tw-from-yellow-600 tw-to-crimson-dark"
            showPercentText="below"
            percentText=(concat system.fatigue.value " / " system.fatigue.max)
            percentTextClass="tw-text-xs tw-text-gray-400"
            thresholds=(array (object at=100 label="TB" title="Collapse Threshold"))}}
    </div>

    {{!-- Warning Messages --}}
    {{#if (gt system.fatigue.value system.fatigue.max)}}
    <div class="tw-text-crimson tw-flex tw-items-center tw-gap-2 tw-px-2 tw-py-1 tw-text-xs tw-font-bold tw-uppercase tw-tracking-wide tw-rounded tw-mt-1">
        <i class="{{concat 'fas fa-dizzy'}}"></i>
        <span>UNCONSCIOUS - Collapsed for {{sub 10 characteristics.toughness.bonus}} minutes!</span>
    </div>
    {{else if (gt system.fatigue.value 0)}}
    <div class="tw-text-warning tw-flex tw-items-center tw-gap-2 tw-px-2 tw-py-1 tw-text-xs tw-font-bold tw-uppercase tw-tracking-wide tw-rounded tw-mt-1">
        <i class="{{concat 'fas fa-exclamation-triangle'}}"></i>
        <span>FATIGUED - Suffer –10 penalty to all Tests</span>
    </div>
    {{/if}}

    {{!-- Quick Actions --}}
    <div class="tw-flex tw-gap-2 tw-mt-2">
        <button type="button"
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1 tw-bg-gray-700 tw-px-2 tw-py-1 tw-rounded-lg tw-border-2 tw-border-green-700/40 tw-text-success tw-text-xs tw-font-bold tw-cursor-pointer"
                data-action="decrement"
                data-field="system.fatigue.value"
                data-min="0"
                title="Rest to recover 1 fatigue">
            <i class="{{concat 'fas fa-bed'}}"></i>
            <span>Rest (-1)</span>
        </button>
        {{#if (gt system.fatigue.value 0)}}
        <button type="button"
                class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1 tw-bg-gray-700 tw-px-2 tw-py-1 tw-rounded-lg tw-border-2 tw-border-warning/40 tw-text-warning tw-text-xs tw-font-bold tw-cursor-pointer"
                data-action="clear-fatigue"
                title="Clear all fatigue (full rest)">
            <i class="{{concat 'fas fa-broom'}}"></i>
            <span>Clear All</span>
        </button>
        {{/if}}
    </div>

    {{!-- Edit Mode (Expandable) --}}
    <div class="tw-mt-2 tw-pt-2 tw-border-t tw-border-t-white/10" {{hideIfNot (isExpanded 'fatigue_details' actor)}}>

        {{!-- Current Fatigue Editor --}}
        <div class="tw-p-2 tw-bg-[rgba(0,0,0,0.1)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-lg tw-mb-1">
            <div class="tw-text-xs tw-font-bold tw-uppercase tw-tracking-widest tw-text-gray-400 tw-mb-1 tw-flex tw-items-center tw-gap-1">
                <i class="{{concat 'fas fa-cog'}}"></i> Edit Values
            </div>

            <div class="tw-grid tw-grid-cols-2 tw-gap-2 tw-mt-1">
                {{> systems/wh40k-rpg/templates/actor/partial/vital-edit-input
                    name="system.fatigue.max"
                    label="Threshold"
                    value=system.fatigue.max
                    labelClass="tw-text-xs tw-text-gray-400"
                    inputClass="tw-w-full tw-p-1 tw-rounded"
                    readonly=true
                    placeholder="Threshold"}}

                {{> systems/wh40k-rpg/templates/actor/partial/vital-edit-input
                    name="system.fatigue.value"
                    label="Current Fatigue"
                    value=system.fatigue.value
                    labelClass="tw-text-xs tw-text-gray-400"
                    inputClass="tw-w-full tw-p-1 tw-rounded"
                    placeholder="Current"}}
            </div>
        </div>

        {{!-- Info Section --}}
        <div class="tw-p-2 tw-bg-[rgba(0,0,0,0.1)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-lg tw-mt-4">
            <div class="tw-flex tw-gap-2 tw-p-2 tw-bg-[rgba(255,165,0,0.05)] tw-border-l-[3px] tw-border-l-warning/40 tw-rounded-md">
                <i class="{{concat 'fas fa-book'}} tw-text-gold tw-text-lg tw-mt-0.5 tw-shrink-0"></i>
                <div class="tw-flex tw-flex-col tw-gap-1 tw-text-xs tw-mt-1">
                    <strong>Fatigue Rules (Core)</strong>
                    <p><strong>Any Fatigue:</strong> –10 penalty to all Tests.</p>
                    <p><strong>Exceeds TB:</strong> Collapse unconscious for (10 – TB) minutes. Upon waking, fatigue resets to TB.</p>
                    <p><strong>Recovery:</strong> Each hour of rest removes 1 fatigue. Eight consecutive hours removes all fatigue.</p>
                </div>
            </div>
        </div>

    </div>
{{/systems/wh40k-rpg/templates/actor/partial/vital-panel-shell}}
