{{!-- Compact-but-readable Movement panel — size selector + 3 stat-grid sections (movement / leap+jump / lifting). --}}
{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label=(localize "WH40K.MOVEMENT.Label")
    icon="fa-running"
    rootClass="tw-col-auto"}}
    <div class="tw-flex tw-flex-col tw-gap-3">
        {{!-- Size Selector --}}
        <div class="tw-grid tw-grid-cols-2 tw-mb-2">
            <span class="tw-shrink-0">{{localize "WH40K.MOVEMENT.Size"}}</span>
            <select class="tw-grow" name="system.size">
                {{selectOptions dh.sizes selected=source.size labelAttr="label" valueAttr="@key"}}
            </select>
        </div>

        {{!-- Movement Rates (AB-based) --}}
        {{> systems/wh40k-rpg/templates/actor/partial/stat-grid-section
            heading=(localize "WH40K.MOVEMENT.Label")
            columns=4
            stats=(array
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Half")
                    value=actor.movement.half
                    unit="m"
                    action="setMovementMode"
                    attrs="data-movement-type=\"half\""
                    title=(localize "WH40K.MOVEMENT.Tooltip.Half"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Full")
                    value=actor.movement.full
                    unit="m"
                    action="setMovementMode"
                    attrs="data-movement-type=\"full\""
                    title=(localize "WH40K.MOVEMENT.Tooltip.Full"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Charge")
                    value=actor.movement.charge
                    unit="m"
                    action="setMovementMode"
                    attrs="data-movement-type=\"charge\""
                    title=(localize "WH40K.MOVEMENT.Tooltip.Charge"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Run")
                    value=actor.movement.run
                    unit="m"
                    action="setMovementMode"
                    attrs="data-movement-type=\"run\""
                    title=(localize "WH40K.MOVEMENT.Tooltip.Run")))}}

        {{!-- Leap & Jump (SB-based) --}}
        {{> systems/wh40k-rpg/templates/actor/partial/stat-grid-section
            heading=(localize "WH40K.MOVEMENT.Athletics")
            columns=4
            stats=(array
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.LeapVertical")
                    value=actor.movement.leapVertical
                    unit="m"
                    title=(localize "WH40K.MOVEMENT.Tooltip.LeapVertical"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.LeapHorizontal")
                    value=actor.movement.leapHorizontal
                    unit="m"
                    title=(localize "WH40K.MOVEMENT.Tooltip.LeapHorizontal"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Jump")
                    value=actor.movement.jump
                    unit="cm"
                    title=(localize "WH40K.MOVEMENT.Tooltip.Jump")))}}

        {{!-- Lifting Capacity (SB-based) --}}
        {{> systems/wh40k-rpg/templates/actor/partial/stat-grid-section
            heading=(localize "WH40K.MOVEMENT.CarryingCapacity")
            columns=4
            stats=(array
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Carry")
                    value=actor.lifting.carry
                    unit="kg"
                    title=(localize "WH40K.MOVEMENT.Tooltip.Carry"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Lift")
                    value=actor.lifting.lift
                    unit="kg"
                    title=(localize "WH40K.MOVEMENT.Tooltip.Lift"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Push")
                    value=actor.lifting.push
                    unit="kg"
                    title=(localize "WH40K.MOVEMENT.Tooltip.Push")))}}
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
