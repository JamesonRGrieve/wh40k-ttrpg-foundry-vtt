{{!-- Talents Panel — routed through the shared panel.hbs header so its heading
     matches the other Statistics-tab panels instead of a bare hand-rolled
     header (#238). --}}
{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label="Talents"
    icon="fa-star"
    count=talentsCount
    rootClass="wh40k-panel-talents-table tw-mt-0 tw-mb-0 tw-w-full tw-box-border tw-self-stretch"
    bodyClass="tw-flex tw-flex-col tw-gap-2 tw-w-full tw-box-border"}}
        {{#if talentsCount}}
        {{!-- Talents flow into 1–3 width-responsive columns (#267): auto-fit follows the
             panel width and collapses to a single column when the panel is narrow (e.g.
             while sharing the Statistics tab two-up with Traits), capping at three
             (gap-x = 0.75rem ⇒ 1.5rem subtracted at the 3-column breakpoint). Floor
             reduced to 10rem (down from 14rem) so columns reflow before text truncates —
             talent rows use tw-truncate on the name, so narrowing the floor lets the
             grid drop a column while entries still have a readable minimum. --}}
        <div class="tw-grid tw-gap-x-3 tw-gap-y-[2px] tw-items-start" style="grid-template-columns: repeat(auto-fit, minmax(max(10rem, calc((100% - 1.5rem) / 3)), 1fr));" data-drop-zone="talents" data-accepts="talent">
            {{#each talents as |talent|}}
            <div class="{{concat 'wh40k-tp_row'}} tw-group tw-relative tw-flex tw-items-center tw-rounded-md tw-min-h-[28px] tw-select-none tw-gap-[6px] tw-px-[6px] tw-py-[3px] tw-transition-colors" data-tooltip="{{talent.tooltipText}}">
                <img class="tw-shrink-0 tw-w-[22px] tw-h-[22px] tw-object-cover tw-rounded-[3px] tw-border tw-border-[var(--wh40k-border-color-light)]" src="{{talent.img}}" alt="{{talent.name}}" />

                <button type="button" class="tw-flex-1 tw-min-w-0 tw-text-left tw-cursor-pointer tw-truncate tw-font-semibold tw-bg-transparent tw-border-none tw-p-0 tw-m-0 tw-text-[0.78rem]" data-action="itemEdit" data-item-id="{{talent.id}}">
                    {{talent.fullName}}
                    {{#if talent.flags.wh40k-rpg.autoGranted}}
                    <i class="{{concat 'fas fa-gift'}}" style="margin-left:4px;font-size:0.6rem;color:var(--wh40k-color-gold);cursor:help" title="Granted by {{talent.flags.wh40k-rpg.grantedBy}}"></i>
                    {{/if}}
                </button>

                <div class="tw-flex tw-items-center tw-gap-1 tw-shrink-0 tw-text-[0.6rem]">
                    {{#if talent.system.tier}}<span class="tw-px-[4px] tw-py-[1px] tw-rounded-[3px] tw-font-bold tw-text-[0.55rem]" style="background:rgb(from var(--wh40k-accent-talents) r g b / 0.15);border:1px solid rgb(from var(--wh40k-accent-talents) r g b / 0.3);color:var(--wh40k-accent-talents)">T{{talent.system.tier}}</span>{{/if}}
                    <span><i class="{{concat 'fas'}} {{talentIcon talent.system.category}}" style="font-size:0.6rem"></i></span>
                    {{#if talent.system.stackable}}<span class="tw-font-bold" style="color:var(--wh40k-accent-talents)">×{{talent.system.rank}}</span>{{/if}}
                </div>

                <div class="tw-absolute tw-flex tw-items-center tw-opacity-0 tw-pointer-events-none group-hover:tw-opacity-100 group-hover:tw-pointer-events-auto focus-within:tw-opacity-100 focus-within:tw-pointer-events-auto" style="right:6px;top:50%;transform:translateY(-50%);gap:1px;padding:2px 4px;background:linear-gradient(90deg,transparent 0%,var(--wh40k-panel-bg-solid) 20%);border-radius:3px;transition:opacity var(--wh40k-transition-fast)">
                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-px-[5px] tw-py-[2px] tw-rounded-[3px] tw-text-[0.7rem] {{#if talent.isFavorite}}tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure{{/if}}"
                            data-action="toggleFavoriteTalent" data-item-id="{{talent.id}}"
                            title="{{#if talent.isFavorite}}{{localize "WH40K.Favourites.Unfavorite"}}{{else}}{{localize "WH40K.Favourites.Favorite"}}{{/if}}">
                        <i class="{{#if talent.isFavorite}}{{concat 'fas fa-star'}}{{else}}{{concat 'far fa-star'}}{{/if}}"></i>
                    </button>
                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-px-[5px] tw-py-[2px] tw-rounded-[3px] tw-text-[0.7rem]" data-action="itemVocalize" data-item-id="{{talent.id}}" title="Chat">
                        <i class="{{concat 'fas fa-comment'}}"></i>
                    </button>
                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-px-[5px] tw-py-[2px] tw-rounded-[3px] tw-text-[0.7rem]" data-action="itemDelete" data-item-id="{{talent.id}}" title="Delete">
                        <i class="{{concat 'fas fa-trash'}}"></i>
                    </button>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}

        {{!-- Drop-to-add zone is only shown when the world's freeform-creation
             setting is enabled (#396). By default talents must go through the
             advancement/XP flow; the dropzone invites mis-clicks when it appears
             unconditionally. --}}
        {{#if (isFreeformCreation)}}
        {{> systems/wh40k-rpg/templates/actor/partial/dropzone.hbs type="talent" iconClass="fa-star" hasItems=talentsCount label="Drop Talent to Add" compactLabel="Drop to add" clickToCreate=false}}
        {{/if}}
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
