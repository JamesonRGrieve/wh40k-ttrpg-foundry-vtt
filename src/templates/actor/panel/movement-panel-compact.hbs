{{! Modern Compact Movement Panel for Combat Tab }}
{{! Sleek, dense design with visual hierarchy }}

{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label="Movement"
    icon="fa-running"
    rootClass="wh40k-panel-movement-compact"}}
    <div class="tw-flex tw-flex-col tw-gap-[8px]">
        {{> systems/wh40k-rpg/templates/actor/partial/movement-stat-row.hbs
            label="Half" value=system.movement.half icon="fa-walking" fillPercent=25
            iconBgGrad="linear-gradient(135deg,rgba(from var(--wh40k-accent-green-bright,#4caf50) r g b/0.15) 0%,rgba(from var(--wh40k-accent-green-bright,#4caf50) r g b/0.05) 100%)"
            iconColor="var(--wh40k-accent-green,#388e3c)"}}

        {{> systems/wh40k-rpg/templates/actor/partial/movement-stat-row.hbs
            label="Full" value=system.movement.full icon="fa-shoe-prints" fillPercent=50
            iconBgGrad="linear-gradient(135deg,rgba(from var(--wh40k-accent-info,#3498db) r g b/0.15) 0%,rgba(from var(--wh40k-accent-info,#3498db) r g b/0.05) 100%)"
            iconColor="#2980b9"}}

        {{> systems/wh40k-rpg/templates/actor/partial/movement-stat-row.hbs
            label="Charge" value=system.movement.charge icon="fa-running" fillPercent=75
            iconBgGrad="linear-gradient(135deg,rgba(243,156,18,0.15) 0%,rgba(243,156,18,0.05) 100%)"
            iconColor="#e67e22"}}

        {{> systems/wh40k-rpg/templates/actor/partial/movement-stat-row.hbs
            label="Run" value=system.movement.run icon="fa-wind" fillPercent=100
            iconBgGrad="linear-gradient(135deg,rgba(from var(--wh40k-accent-red,#c0392b) r g b/0.15) 0%,rgba(from var(--wh40k-accent-red,#c0392b) r g b/0.05) 100%)"
            iconColor="#c0392b"}}
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
