{{! Modern Compact Movement Panel for Combat Tab }}
{{! Sleek, dense design with visual hierarchy }}

{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label="Movement"
    icon="fa-running"
    headerClass="tw-border-b-gold bc:tw-border-b-crimson-light dh1:tw-border-b-gold-raw-l5 dh2:tw-border-b-gold-raw dw:tw-border-b-accent-combat ow:tw-border-b-brass-l20 rt:tw-border-b-gold im:tw-border-b-failure"}}
    <div class="tw-flex tw-flex-col tw-gap-[8px]">
        {{> systems/wh40k-rpg/templates/actor/partial/movement-stat-row.hbs
            label="Half" value=system.movement.half icon="fa-walking" fillPercent=25
            action="vocalizeMovement" movementType="half"
            iconBgGrad="linear-gradient(135deg,rgba(from var(--wh40k-accent-green-bright,#4caf50) r g b/0.15) 0%,rgba(from var(--wh40k-accent-green-bright,#4caf50) r g b/0.05) 100%)"
            iconColor="var(--wh40k-accent-green,#388e3c)"}}

        {{> systems/wh40k-rpg/templates/actor/partial/movement-stat-row.hbs
            label="Full" value=system.movement.full icon="fa-shoe-prints" fillPercent=50
            action="vocalizeMovement" movementType="full"
            iconBgGrad="linear-gradient(135deg,rgba(from var(--wh40k-accent-info,#3498db) r g b/0.15) 0%,rgba(from var(--wh40k-accent-info,#3498db) r g b/0.05) 100%)"
            iconColor="#2980b9"}}

        {{> systems/wh40k-rpg/templates/actor/partial/movement-stat-row.hbs
            label="Charge" value=system.movement.charge icon="fa-running" fillPercent=75
            action="vocalizeMovement" movementType="charge"
            iconBgGrad="linear-gradient(135deg,rgba(243,156,18,0.15) 0%,rgba(243,156,18,0.05) 100%)"
            iconColor="#e67e22"}}

        {{> systems/wh40k-rpg/templates/actor/partial/movement-stat-row.hbs
            label="Run" value=system.movement.run icon="fa-wind" fillPercent=100
            action="vocalizeMovement" movementType="run"
            iconBgGrad="linear-gradient(135deg,rgba(from var(--wh40k-accent-red,#c0392b) r g b/0.15) 0%,rgba(from var(--wh40k-accent-red,#c0392b) r g b/0.05) 100%)"
            iconColor="#c0392b"}}
    </div>

    {{!-- Carrying Capacity (Lift / Push) — relocated here from the Overview Vitals card.
         Mirrors the carrying-capacity block in movement-panel-full, using the shared
         stat-grid-section partial. --}}
    {{> systems/wh40k-rpg/templates/actor/partial/stat-grid-section
        heading=(localize "WH40K.MOVEMENT.CarryingCapacity")
        headingIcon="fa-weight-hanging"
        columns=2
        sectionClass="tw-mt-2 tw-mb-0"
        stats=(array
            (object
                label=(localize "WH40K.MOVEMENT.Stat.Lift")
                value=system.lifting.lift
                unit="kg"
                icon="fa-dumbbell"
                title=(localize "WH40K.MOVEMENT.Tooltip.Lift"))
            (object
                label=(localize "WH40K.MOVEMENT.Stat.PushDrag")
                value=system.lifting.push
                unit="kg"
                icon="fa-cart-flatbed"
                title=(localize "WH40K.MOVEMENT.Tooltip.Push")))}}
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
