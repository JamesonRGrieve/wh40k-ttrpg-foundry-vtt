{{! Modern Compact Movement Panel for Combat Tab }}
{{! Sleek, dense design with visual hierarchy }}

{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label="Movement"
    icon="fa-running"
    rootClass="wh40k-panel-movement-compact"}}
    <div class="wh40k-movement-modern-compact">
        {{! Half Move }}
        <div class="wh40k-move-modern-cell wh40k-move-half">
            <div class="wh40k-move-modern-icon">
                <i class="fas fa-walking"></i>
            </div>
            <div class="wh40k-move-modern-content">
                <span class="wh40k-move-modern-label">Half</span>
                <span class="wh40k-move-modern-value">{{system.movement.half}}<span class="wh40k-move-unit">m</span></span>
            </div>
            <div class="wh40k-move-modern-bar" style="--move-percent: 25%;"></div>
        </div>

        {{! Full Move }}
        <div class="wh40k-move-modern-cell wh40k-move-full">
            <div class="wh40k-move-modern-icon">
                <i class="fas fa-shoe-prints"></i>
            </div>
            <div class="wh40k-move-modern-content">
                <span class="wh40k-move-modern-label">Full</span>
                <span class="wh40k-move-modern-value">{{system.movement.full}}<span class="wh40k-move-unit">m</span></span>
            </div>
            <div class="wh40k-move-modern-bar" style="--move-percent: 50%;"></div>
        </div>

        {{! Charge }}
        <div class="wh40k-move-modern-cell wh40k-move-charge">
            <div class="wh40k-move-modern-icon">
                <i class="fas fa-running"></i>
            </div>
            <div class="wh40k-move-modern-content">
                <span class="wh40k-move-modern-label">Charge</span>
                <span class="wh40k-move-modern-value">{{system.movement.charge}}<span class="wh40k-move-unit">m</span></span>
            </div>
            <div class="wh40k-move-modern-bar" style="--move-percent: 75%;"></div>
        </div>

        {{! Run }}
        <div class="wh40k-move-modern-cell wh40k-move-run">
            <div class="wh40k-move-modern-icon">
                <i class="fas fa-wind"></i>
            </div>
            <div class="wh40k-move-modern-content">
                <span class="wh40k-move-modern-label">Run</span>
                <span class="wh40k-move-modern-value">{{system.movement.run}}<span class="wh40k-move-unit">m</span></span>
            </div>
            <div class="wh40k-move-modern-bar" style="--move-percent: 100%;"></div>
        </div>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
