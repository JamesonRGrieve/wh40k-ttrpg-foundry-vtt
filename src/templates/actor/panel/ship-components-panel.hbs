{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs label=(localize "WH40K.Starship.Components.Header") rootClass="tw-col-span-6 tw-row-span-2" bodyClass="tw-p-0"}}
    {{#> systems/wh40k-rpg/templates/actor/partial/item-table.hbs
        addAction="itemCreate"
        addType="shipComponent"
        addTitleKey="WH40K.Common.AddShipComponent"
        headers=(array
            (object cellClass="table-cell--span2" labelKey="WH40K.Starship.Components.Name")
            (object labelKey="WH40K.Starship.Components.Type")
            (object labelKey="WH40K.Starship.Components.Power")
            (object labelKey="WH40K.Starship.Components.Space")
            (object labelKey="WH40K.Starship.Components.SP"))}}
        {{#each actor.items as |item|}}
            {{#if item.isShipComponent}}
                {{#> systems/wh40k-rpg/templates/actor/partial/item-table-row.hbs
                    item=item
                    showImg=true
                    editAction=false
                    cells=(array
                        (object value=item.system.componentTypeLabel cellClass="table-cell" title=item.system.componentTypeLabel)
                        (object value=item.system.powerDisplay cellClass=(concat "table-cell " (iff (gt item.system.power.generated 0) "tw-text-success tw-font-semibold" (iff (gt item.system.power.used 0) "tw-text-crimson" ""))))
                        (object value=item.system.space)
                        (object value=item.system.shipPoints))
                    actions=(array
                        (object action="itemEdit" iconKey="fa:cog" titleKey="WH40K.Common.Settings")
                        (object action="itemDelete" iconKey="fa:trash" titleKey="WH40K.Common.Delete"))}}
                {{/systems/wh40k-rpg/templates/actor/partial/item-table-row.hbs}}
            {{/if}}
        {{/each}}
    {{/systems/wh40k-rpg/templates/actor/partial/item-table.hbs}}
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
