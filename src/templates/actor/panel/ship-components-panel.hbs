<div class="wh40k-panel spacer wh40k-grid-col-6 wh40k-grid-row-2">
    <h1 class="wh40k-panel-header">{{localize "WH40K.Starship.Components.Header"}}</h1>
    <div class="wh40k-table--border">
        <div class="table-row--head">
            <div class="table-cell--span2">{{localize "WH40K.Starship.Components.Name"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Components.Type"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Components.Power"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Components.Space"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Components.SP"}}</div>
            <div class="table-cell--last">
                <label class="wh40k-control-button" data-action="itemCreate" data-type="shipComponent">
                    <span class="wh40k-control-button__span material-icons">add_circle</span>
                </label>
            </div>
        </div>
        {{#each actor.items as |item|}}
            {{#if item.isShipComponent}}
                <div class="table-row">
                    <div class="table-cell--span2">
                        <button class="item-name wh40k-item-button" data-item-id="{{item.id}}" type="button">
                            <img class="wh40k-item-img" src="{{item.img}}" alt="{{item.name}}" />
                            {{item.name}}
                        </button>
                    </div>
                    <div class="table-cell" title="{{item.system.componentTypeLabel}}">
                        {{item.system.componentTypeLabel}}
                    </div>
                    <div class="table-cell {{#if (gt item.system.power.generated 0)}}wh40k-power-gen{{else if (gt item.system.power.used 0)}}wh40k-power-use{{/if}}">
                        {{item.system.powerDisplay}}
                    </div>
                    <div class="table-cell">{{item.system.space}}</div>
                    <div class="table-cell">{{item.system.shipPoints}}</div>
                    <div class="table-cell--last">
                        <label class="wh40k-control-button item-edit" data-item-id="{{item.id}}">
                            <span class="wh40k-control-button__span material-icons">settings</span>
                        </label>
                        <label class="wh40k-control-button item-delete" data-item-id="{{item.id}}">
                            <span class="wh40k-control-button__span material-icons">delete</span>
                        </label>
                    </div>
                </div>
            {{/if}}
        {{/each}}
    </div>
</div>
