{{!-- Active Effects Panel - Card/Row Structure --}}
<div class="wh40k-panel wh40k-effects-panel">
    <div class="wh40k-panel-header wh40k-panel-header--clickable sheet-control__hide-control"
         data-toggle="effects_details"
         title="{{#if (isExpanded 'effects_details' actor)}}{{localize 'WH40K.Effects.ClickToCollapse'}}{{else}}{{localize 'WH40K.Effects.ClickToExpand'}}{{/if}}">
        <span class="wh40k-panel-title">
            <i class="fas fa-sparkles"></i> {{localize 'WH40K.Effects.ActiveLabel'}}
            {{#if effects.length}}
                <span class="wh40k-badge">{{effects.length}}</span>
            {{/if}}
        </span>
        <i class="fas fa-chevron-down wh40k-panel-chevron {{#if (isExpanded 'effects_details' actor)}}wh40k-panel-chevron--open{{/if}}"></i>
    </div>

    <div class="wh40k-panel-body">
        {{#if effects.length}}
            <div class="wh40k-effects-list tw-flex tw-flex-col tw-gap-2 tw-mb-3">
                {{#each effects as |effect|}}
                    {{> systems/wh40k-rpg/templates/actor/partial/effect-row.hbs
                        effect=effect
                        expanded=(isExpanded 'effects_details' @root.actor)
                        editable=true}}
                {{/each}}
            </div>
        {{/if}}

        <div class="wh40k-dropzone effect-create">
            <i class="fas fa-sparkles wh40k-dropzone-icon"></i>
            <span class="wh40k-dropzone-text" data-dropzone-text>{{localize 'WH40K.Effects.DropHere'}}</span>
        </div>
    </div>
</div>
