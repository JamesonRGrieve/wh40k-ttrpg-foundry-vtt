{{!-- Active Effects Panel - Card/Row Structure --}}
<div class="wh40k-panel">
    <div class="wh40k-panel-header sheet-control__hide-control tw-cursor-pointer tw-select-none hover:tw-bg-gradient-to-b hover:tw-from-[rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.2)] hover:tw-to-[rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.08)]"
         data-toggle="effects_details"
         title="{{#if (isExpanded 'effects_details' actor)}}{{localize 'WH40K.Effects.ClickToCollapse'}}{{else}}{{localize 'WH40K.Effects.ClickToExpand'}}{{/if}}">
        <span class="wh40k-panel-title tw-text-gold {{themeClassFor 'accent'}}">
            <i class="fas fa-sparkles"></i> {{localize 'WH40K.Effects.ActiveLabel'}}
            {{#if effects.length}}
                <span class="wh40k-badge tw-inline-flex tw-items-center tw-justify-center tw-min-w-[20px] tw-h-5 tw-px-1.5 tw-ml-2 tw-bg-gradient-to-br tw-from-[var(--wh40k-accent-gold)] tw-to-[color-mix(in_srgb,var(--wh40k-accent-gold),black_10%)] tw-text-[#0a0a0f] tw-rounded-[10px] tw-text-[0.7rem] tw-font-bold tw-shadow-sm">{{effects.length}}</span>
            {{/if}}
        </span>
        <i class="fas fa-chevron-down wh40k-panel-chevron tw-text-xs tw-text-[var(--wh40k-text-muted)] tw-transition-[transform,color] tw-duration-200 tw-ml-auto tw-flex-shrink-0 {{#if (isExpanded 'effects_details' actor)}}tw-rotate-180{{/if}}"></i>
    </div>

    <div class="wh40k-panel-body">
        {{#if effects.length}}
            <div class="tw-flex tw-flex-col tw-gap-2 tw-mb-3">
                {{#each effects as |effect|}}
                    {{> systems/wh40k-rpg/templates/actor/partial/effect-row.hbs
                        effect=effect
                        expanded=(isExpanded 'effects_details' @root.actor)
                        editable=true}}
                {{/each}}
            </div>
        {{/if}}

        {{> systems/wh40k-rpg/templates/actor/partial/effect-dropzone.hbs iconClass="fa-sparkles"}}
    </div>
</div>
