{{!-- Rituals Panel V2 - Modern Card-based Design --}}
<div class="wh40k-panel wh40k-panel-powers wh40k-panel-rituals">
    <header class="wh40k-panel-header" data-action="togglePanel" data-panel-id="rituals">
        <span class="wh40k-panel-title">
            <i class="fas fa-pray"></i>
            Rituals
            {{#if ritualsCount}}
            <span class="wh40k-count-badge">{{ritualsCount}}</span>
            {{/if}}
        </span>
        <i class="fas fa-chevron-down wh40k-panel-toggle"></i>
    </header>
    <div class="wh40k-panel-body">
        {{!-- Rituals List --}}
        <div class="wh40k-powers-list" data-drop-zone="powers" data-accepts="ritual">
            {{#each rituals as |ritual|}}
            <div class="wh40k-power-card wh40k-ritual-card item-drag" data-item-id="{{ritual.id}}" data-ritual-type="{{ritual.system.type}}" draggable="true">
                {{!-- Ritual Header --}}
                <div class="tw-flex tw-items-center tw-gap-2 tw-p-2">
                    <img class="wh40k-power-icon" src="{{ritual.img}}" alt="{{ritual.name}}" />
                    <div class="tw-flex-1 tw-min-w-0">
                        <button type="button" class="wh40k-power-name" data-action="itemEdit" data-item-id="{{ritual.id}}" title="Edit Ritual">
                            {{ritual.name}}
                        </button>
                        <div class="tw-flex tw-flex-wrap tw-gap-1.5 tw-mt-0.5">
                            <span class="wh40k-ritual-type wh40k-type-{{ritual.system.type}}">
                                {{#if (eq ritual.system.type "prayer")}}
                                <i class="fas fa-praying-hands"></i>
                                {{else if (eq ritual.system.type "rite")}}
                                <i class="fas fa-book-dead"></i>
                                {{else if (eq ritual.system.type "invocation")}}
                                <i class="fas fa-hand-sparkles"></i>
                                {{else if (eq ritual.system.type "ceremony")}}
                                <i class="fas fa-church"></i>
                                {{else if (eq ritual.system.type "tech-rite")}}
                                <i class="fas fa-cog"></i>
                                {{else}}
                                <i class="fas fa-scroll"></i>
                                {{/if}}
                                {{ritual.system.typeLabel}}
                            </span>
                        </div>
                    </div>
                    <div class="tw-flex tw-gap-0.5 tw-shrink-0">
                        <button type="button" class="wh40k-power-btn wh40k-btn-roll" data-action="rollRitual" data-item-id="{{ritual.id}}" title="Perform Ritual">
                            <i class="fas fa-dice-d20"></i>
                        </button>
                        <button type="button" class="wh40k-power-btn wh40k-btn-chat" data-action="vocalizeRitual" data-item-id="{{ritual.id}}" title="Post to Chat">
                            <i class="fas fa-comment"></i>
                        </button>
                        <button type="button" class="wh40k-power-btn wh40k-btn-expand" data-action="togglePowerDetails" data-item-id="{{ritual.id}}" title="Toggle Details">
                            <i class="fas fa-chevron-down"></i>
                        </button>
                    </div>
                </div>
                
                {{!-- Ritual Stats Row --}}
                <div class="tw-flex tw-flex-wrap tw-gap-2 tw-px-3 tw-py-1">
                    <div class="tw-flex tw-flex-col tw-gap-px tw-min-w-[80px]">
                        <span class="wh40k-stat-label">Test</span>
                        <span class="wh40k-stat-value">{{ritual.system.testLabel}}</span>
                    </div>
                    <div class="tw-flex tw-flex-col tw-gap-px tw-min-w-[80px]">
                        <span class="wh40k-stat-label">Action</span>
                        <span class="wh40k-stat-value">{{ritual.system.activationLabel}}</span>
                    </div>
                    {{#if ritual.system.test.threshold}}
                    <div class="tw-flex tw-flex-col tw-gap-px tw-min-w-[80px]">
                        <span class="wh40k-stat-label">Threshold</span>
                        <span class="wh40k-stat-value">{{ritual.system.test.threshold}} DoS</span>
                    </div>
                    {{/if}}
                </div>
                
                {{!-- Expandable Details --}}
                <div class="wh40k-power-details" data-power-id="{{ritual.id}}" hidden>
                    {{#if ritual.system.requirements}}
                    <div class="wh40k-power-detail-section">
                        <span class="wh40k-detail-heading"><i class="fas fa-list-check"></i> Requirements</span>
                        <div class="wh40k-detail-content">{{{ritual.system.requirements}}}</div>
                    </div>
                    {{/if}}
                    {{#if ritual.system.costs}}
                    <div class="wh40k-power-detail-section">
                        <span class="wh40k-detail-heading"><i class="fas fa-coins"></i> Costs</span>
                        <div class="wh40k-detail-content">{{{ritual.system.costs}}}</div>
                    </div>
                    {{/if}}
                    {{#if ritual.system.effect}}
                    <div class="wh40k-power-detail-section wh40k-section-success">
                        <span class="wh40k-detail-heading"><i class="fas fa-check-circle"></i> Effect</span>
                        <div class="wh40k-detail-content">{{{ritual.system.effect}}}</div>
                    </div>
                    {{/if}}
                    {{#if ritual.system.failure}}
                    <div class="wh40k-power-detail-section wh40k-section-danger">
                        <span class="wh40k-detail-heading"><i class="fas fa-skull"></i> Failure</span>
                        <div class="wh40k-detail-content">{{{ritual.system.failure}}}</div>
                    </div>
                    {{/if}}
                    {{#if ritual.system.description}}
                    <div class="wh40k-power-detail-section">
                        <span class="wh40k-detail-heading">Description</span>
                        <div class="wh40k-detail-content">{{{ritual.system.description}}}</div>
                    </div>
                    {{/if}}
                    <div class="wh40k-power-detail-actions">
                        <button type="button" class="wh40k-detail-btn" data-action="itemEdit" data-item-id="{{ritual.id}}">
                            <i class="fas fa-cog"></i> Edit
                        </button>
                        <button type="button" class="wh40k-detail-btn wh40k-btn-danger" data-action="itemDelete" data-item-id="{{ritual.id}}">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                </div>
            </div>
            {{else}}
            <div class="wh40k-empty-state">
                <i class="fas fa-pray"></i>
                <p>No rituals known</p>
            </div>
            {{/each}}
        </div>
        
        {{!-- Add Ritual Dropzone --}}
        <div class="wh40k-dropzone {{#if ritualsCount}}wh40k-dropzone--compact{{/if}}" data-action="itemCreate" data-type="ritual">
            <i class="fas fa-plus wh40k-dropzone-icon"></i>
            <span class="wh40k-dropzone-text" data-dropzone-text>{{#if ritualsCount}}Drop or click to add{{else}}Drop Ritual or Click to Create{{/if}}</span>
        </div>
    </div>
</div>
