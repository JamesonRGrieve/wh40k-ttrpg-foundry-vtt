{{!-- Rituals Panel --}}
{{#> systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs panelId="rituals" label="Rituals" icon="fa-pray" count=ritualsCount rootClass="wh40k-panel-powers wh40k-panel-rituals" bodyClass="tw-p-0"}}
    {{!-- Rituals List --}}
    <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)] tw-min-h-[60px] tw-p-[var(--wh40k-space-md)]" data-drop-zone="powers" data-accepts="ritual">
        {{#each rituals as |ritual|}}
        {{#> systems/wh40k-rpg/templates/actor/partial/item-list-row.hbs
            item=ritual
            accentColor="#d97706"
            dragType="ritual"
            extraAttrs=(concat 'data-ritual-type="' ritual.system.type '"')
            editTitle="Edit Ritual"
            pills=(array ritual.system.pill)
            stats=(iff ritual.system.test.threshold
                (array
                    (hash label="Test" value=ritual.system.testLabel)
                    (hash label="Action" value=ritual.system.activationLabel)
                    (hash label="Threshold" value=(concat ritual.system.test.threshold ' DoS')))
                (array
                    (hash label="Test" value=ritual.system.testLabel)
                    (hash label="Action" value=ritual.system.activationLabel)))
            actions=(array
                (hash action="rollRitual" icon="fa-dice-d20" title="Perform Ritual" hoverClass="hover:tw-text-[color:var(--wh40k-accent-powers)]")
                (hash action="vocalizeRitual" icon="fa-comment" title="Post to Chat" hoverClass="hover:tw-bg-[rgba(59,130,246,0.15)] hover:tw-border-[rgba(59,130,246,0.3)] hover:tw-text-[#3b82f6]")
                (hash action="togglePowerDetails" icon="fa-chevron-down" title="Toggle Details" hoverClass="hover:tw-text-[color:var(--wh40k-text-dark)]"))
        }}
            {{#if ritual.system.requirements}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1"><i class="fas fa-list-check tw-text-[0.7rem]"></i> Requirements</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.requirements}}}</div>
            </div>
            {{/if}}
            {{#if ritual.system.costs}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1"><i class="fas fa-coins tw-text-[0.7rem]"></i> Costs</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.costs}}}</div>
            </div>
            {{/if}}
            {{#if ritual.system.effect}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#22c55e] tw-mb-1"><i class="fas fa-check-circle tw-text-[0.7rem]"></i> Effect</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.effect}}}</div>
            </div>
            {{/if}}
            {{#if ritual.system.failure}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#ef4444] tw-mb-1"><i class="fas fa-skull tw-text-[0.7rem]"></i> Failure</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.failure}}}</div>
            </div>
            {{/if}}
            {{#if ritual.system.description}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1">Description</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.description}}}</div>
            </div>
            {{/if}}
        {{/systems/wh40k-rpg/templates/actor/partial/item-list-row.hbs}}
        {{else}}
        {{> systems/wh40k-rpg/templates/actor/partial/empty-state.hbs icon="fa-pray" text="No rituals known" padding="md"}}
        {{/each}}
    </div>

    {{!-- Add Ritual Dropzone --}}
    {{> systems/wh40k-rpg/templates/actor/partial/dropzone.hbs type="ritual" hasItems=ritualsCount label="Drop Ritual or Click to Create" compactLabel="Drop or click to add"}}
{{/systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs}}
