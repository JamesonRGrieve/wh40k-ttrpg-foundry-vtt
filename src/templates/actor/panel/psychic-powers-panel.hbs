{{!-- Psychic Powers Panel --}}
{{#> systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs panelId="psychic-powers" label="Psychic Powers" icon="fa-hat-wizard" count=psychicPowersCount rootClass="wh40k-panel-powers wh40k-panel-psychic-powers" bodyClass="tw-p-0" titleClass="tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"}}
    {{!-- Discipline Filter Tabs --}}
    {{#if psychicDisciplines.length}}
    <div class="wh40k-power-filters">
        <button type="button" class="wh40k-filter-btn {{#unless activeDiscipline}}active{{/unless}}" data-action="filterPowers" data-discipline="">
            All
        </button>
        {{#each psychicDisciplines as |disc|}}
        <button type="button" class="wh40k-filter-btn wh40k-filter-{{disc.id}}" data-action="filterPowers" data-discipline="{{disc.id}}">
            {{disc.label}}
        </button>
        {{/each}}
    </div>
    {{/if}}

    {{!-- Powers List --}}
    <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)] tw-min-h-[60px] tw-p-[var(--wh40k-space-md)]" data-drop-zone="powers" data-accepts="psychicPower">
        {{#each psychicPowers as |power|}}
        {{#> systems/wh40k-rpg/templates/actor/partial/item-list-row.hbs
            item=power
            accentColor="#0891b2"
            dragType="psychicPower"
            extraAttrs=(concat 'data-discipline="' power.system.discipline '"')
            editTitle="Edit Power"
            pills=(iff power.system.sustained
                (array power.system.pill (hash bgClass="tw-bg-[rgba(8,145,178,0.2)]" textClass="tw-text-[#0891b2]" icon="fa-sync-alt" label="Sustained") (hash bgClass="tw-bg-[rgba(0,0,0,0.1)]" textClass="tw-text-[color:var(--wh40k-text-muted)]" label=(concat 'PR ' power.system.prCost)))
                (array power.system.pill (hash bgClass="tw-bg-[rgba(0,0,0,0.1)]" textClass="tw-text-[color:var(--wh40k-text-muted)]" label=(concat 'PR ' power.system.prCost))))
            stats=(iff power.system.isAttack
                (array
                    (hash label="Focus" value=power.system.focusTestLabel)
                    (hash label="Action" value=power.system.activationLabel)
                    (hash label="Damage" value=power.system.damageLabel)
                    (hash label="Range" value=power.system.targetLabel))
                (array
                    (hash label="Focus" value=power.system.focusTestLabel)
                    (hash label="Action" value=power.system.activationLabel)
                    (hash label="Range" value=power.system.targetLabel)))
            actions=(iff power.system.isAttack
                (array
                    (hash action="rollPower" icon="fa-dice-d20" title="Focus Power" hoverClass="hover:tw-text-[color:var(--wh40k-accent-powers)]")
                    (hash action="rollPowerDamage" icon="fa-bolt" title="Roll Damage" hoverClass="hover:tw-bg-[rgba(239,68,68,0.15)] hover:tw-border-[rgba(239,68,68,0.3)] hover:tw-text-[#ef4444]")
                    (hash action="togglePowerDetails" icon="fa-chevron-down" title="Toggle Details" hoverClass="hover:tw-text-[color:var(--wh40k-text-dark)]"))
                (array
                    (hash action="rollPower" icon="fa-dice-d20" title="Focus Power" hoverClass="hover:tw-text-[color:var(--wh40k-accent-powers)]")
                    (hash action="vocalizePower" icon="fa-comment" title="Post to Chat" hoverClass="hover:tw-bg-[rgba(59,130,246,0.15)] hover:tw-border-[rgba(59,130,246,0.3)] hover:tw-text-[#3b82f6]")
                    (hash action="togglePowerDetails" icon="fa-chevron-down" title="Toggle Details" hoverClass="hover:tw-text-[color:var(--wh40k-text-dark)]")))
        }}
            {{#if power.system.effect}}
                {{> systems/wh40k-rpg/templates/actor/partial/labeled-rich-text-section.hbs label="Effect" content=power.system.effect}}
            {{/if}}
            {{#if power.system.overbleed}}
                {{> systems/wh40k-rpg/templates/actor/partial/labeled-rich-text-section.hbs label="Overbleed" icon="fa-fire" labelClass="tw-text-[#f97316]" content=power.system.overbleed}}
            {{/if}}
            {{#if power.system.description}}
                {{> systems/wh40k-rpg/templates/actor/partial/labeled-rich-text-section.hbs label="Description" content=power.system.description}}
            {{/if}}
        {{/systems/wh40k-rpg/templates/actor/partial/item-list-row.hbs}}
        {{else}}
        {{> systems/wh40k-rpg/templates/actor/partial/empty-state.hbs icon="fa-hat-wizard" text="No psychic powers" padding="md"}}
        {{/each}}
    </div>

    {{!-- Add Power Dropzone --}}
    {{> systems/wh40k-rpg/templates/actor/partial/dropzone.hbs type="psychicPower" hasItems=psychicPowersCount label="Drop Psychic Power or Click to Create" compactLabel="Drop or click to add"}}
{{/systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs}}
