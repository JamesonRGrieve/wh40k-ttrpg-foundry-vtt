{{!-- Psychic Powers Panel --}}
{{#> systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs panelId="psychic-powers" label="Psychic Powers" icon="fa-hat-wizard" count=psychicPowersCount rootClass="wh40k-panel-powers wh40k-panel-psychic-powers" bodyClass="tw-p-0"}}
    {{!-- Discipline Filter Tabs --}}
    {{#if psychicDisciplines.length}}
    <div class="wh40k-power-filters">
        <button type="button" class="wh40k-filter-btn {{#unless activeDiscipline}}active{{/unless}}" data-action="filterPowers" data-discipline="">
            All
        </button>
        {{#each psychicDisciplines as |disc|}}
        <button type="button" class="wh40k-filter-btn wh40k-filter-{{disc.id}}" data-action="filterPowers" data-discipline="{{disc.id}}">
            {{disc.label}}
        </button>
        {{/each}}
    </div>
    {{/if}}

    {{!-- Powers List --}}
    <div class="wh40k-powers-list" data-drop-zone="powers" data-accepts="psychicPower">
        {{#each psychicPowers as |power|}}
        <div class="wh40k-power-card item-drag" data-item-id="{{power.id}}" data-discipline="{{power.system.discipline}}" draggable="true">
            {{!-- Power Header --}}
            <div class="tw-flex tw-items-center tw-gap-2 tw-p-2">
                <img class="wh40k-power-icon" src="{{power.img}}" alt="{{power.name}}" />
                <div class="tw-flex-1 tw-min-w-0">
                    <button type="button" class="wh40k-power-name" data-action="itemEdit" data-item-id="{{power.id}}" title="Edit Power">
                        {{power.name}}
                    </button>
                    <div class="tw-flex tw-flex-wrap tw-gap-1.5 tw-mt-0.5">
                        <span class="wh40k-power-discipline wh40k-disc-{{power.system.discipline}}">
                            {{power.system.disciplineLabel}}
                        </span>
                        <span class="wh40k-power-pr">
                            PR {{power.system.prCost}}
                        </span>
                        {{#if power.system.sustained}}
                        <span class="wh40k-power-sustained">
                            <i class="fas fa-sync-alt"></i> Sustained
                        </span>
                        {{/if}}
                    </div>
                </div>
                <div class="tw-flex tw-gap-0.5 tw-shrink-0">
                    <button type="button" class="wh40k-power-btn wh40k-btn-roll" data-action="rollPower" data-item-id="{{power.id}}" title="Focus Power">
                        <i class="fas fa-dice-d20"></i>
                    </button>
                    {{#if power.system.isAttack}}
                    <button type="button" class="wh40k-power-btn wh40k-btn-damage" data-action="rollPowerDamage" data-item-id="{{power.id}}" title="Roll Damage">
                        <i class="fas fa-bolt"></i>
                    </button>
                    {{else}}
                    <button type="button" class="wh40k-power-btn wh40k-btn-chat" data-action="vocalizePower" data-item-id="{{power.id}}" title="Post to Chat">
                        <i class="fas fa-comment"></i>
                    </button>
                    {{/if}}
                    <button type="button" class="wh40k-power-btn wh40k-btn-expand" data-action="togglePowerDetails" data-item-id="{{power.id}}" title="Toggle Details">
                        <i class="fas fa-chevron-down"></i>
                    </button>
                </div>
            </div>

            {{!-- Power Stats Row --}}
            <div class="tw-flex tw-flex-wrap tw-gap-2 tw-px-3 tw-py-1">
                <div class="tw-flex tw-flex-col tw-gap-px tw-min-w-[80px]">
                    <span class="wh40k-stat-label">Focus</span>
                    <span class="wh40k-stat-value">{{power.system.focusTestLabel}}</span>
                </div>
                <div class="tw-flex tw-flex-col tw-gap-px tw-min-w-[80px]">
                    <span class="wh40k-stat-label">Action</span>
                    <span class="wh40k-stat-value">{{power.system.activationLabel}}</span>
                </div>
                {{#if power.system.isAttack}}
                <div class="tw-flex tw-flex-col tw-gap-px tw-min-w-[80px]">
                    <span class="wh40k-stat-label">Damage</span>
                    <span class="wh40k-stat-value">{{power.system.damageLabel}}</span>
                </div>
                {{/if}}
                <div class="tw-flex tw-flex-col tw-gap-px tw-min-w-[80px]">
                    <span class="wh40k-stat-label">Range</span>
                    <span class="wh40k-stat-value">{{power.system.targetLabel}}</span>
                </div>
            </div>

            {{!-- Expandable Details --}}
            <div class="wh40k-power-details" data-power-id="{{power.id}}" hidden>
                {{#if power.system.effect}}
                <div class="tw-mb-3">
                    <span class="wh40k-detail-heading">Effect</span>
                    <div class="wh40k-detail-content">{{{power.system.effect}}}</div>
                </div>
                {{/if}}
                {{#if power.system.overbleed}}
                <div class="tw-mb-3 wh40k-section-overbleed">
                    <span class="wh40k-detail-heading"><i class="fas fa-fire"></i> Overbleed</span>
                    <div class="wh40k-detail-content">{{{power.system.overbleed}}}</div>
                </div>
                {{/if}}
                {{#if power.system.description}}
                <div class="tw-mb-3">
                    <span class="wh40k-detail-heading">Description</span>
                    <div class="wh40k-detail-content">{{{power.system.description}}}</div>
                </div>
                {{/if}}
                <div class="tw-flex tw-gap-2 tw-mt-2">
                    <button type="button" class="wh40k-detail-btn" data-action="itemEdit" data-item-id="{{power.id}}">
                        <i class="fas fa-cog"></i> Edit
                    </button>
                    <button type="button" class="wh40k-detail-btn wh40k-btn-danger" data-action="itemDelete" data-item-id="{{power.id}}">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
        {{else}}
        <div class="wh40k-empty-state">
            <i class="fas fa-hat-wizard"></i>
            <p>No psychic powers</p>
        </div>
        {{/each}}
    </div>

    {{!-- Add Power Dropzone --}}
    <div class="wh40k-dropzone {{#if psychicPowersCount}}wh40k-dropzone--compact{{/if}}" data-action="itemCreate" data-type="psychicPower">
        <i class="fas fa-plus wh40k-dropzone-icon"></i>
        <span class="wh40k-dropzone-text" data-dropzone-text>{{#if psychicPowersCount}}Drop or click to add{{else}}Drop Psychic Power or Click to Create{{/if}}</span>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs}}
