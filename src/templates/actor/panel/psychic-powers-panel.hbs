<div class="wh40k-panel wh40k-psychic-powers-panel wh40k-grid-col-4 wh40k-grid-row-2" data-drop-zone="general" data-accepts="psychicPower">
    <div class="wh40k-panel-header-flex">
        <h1 class="wh40k-panel-header">Psychic Powers</h1>
        <button type="button" class="wh40k-add-item-btn" data-action="itemCreate" data-type="psychicPower">
            <i class="fas fa-plus"></i>
            Add Power
        </button>
    </div>
    <div class="wh40k-powers-list">
        {{#each actor.items as |item|}}
            {{#if item.isPsychicPower}}
                <div class="wh40k-power-card item-drag" data-item-id="{{item.id}}" data-item-type="psychicPower">
                    <div class="wh40k-power-header">
                        <button type="button" class="wh40k-power-name" data-toggle="description_{{item.id}}">
                            <i class="fas fa-brain"></i>
                            {{item.name}}
                        </button>
                        <div class="wh40k-power-badges">
                            {{#if item.system.discipline}}
                                <span class="wh40k-power-badge wh40k-badge-discipline">{{item.system.discipline}}</span>
                            {{/if}}
                            {{#if item.system.sustained}}
                                <span class="wh40k-power-badge wh40k-badge-sustained">{{item.system.sustained}}</span>
                            {{/if}}
                        </div>
                    </div>
                    <div class="wh40k-power-actions">
                        <button type="button" class="wh40k-power-btn wh40k-power-roll item-roll" data-item-id="{{item.id}}" title="Roll Power">
                            <i class="fas fa-dice-d20"></i>
                        </button>
                        {{#if (isPsychicAttack item)}}
                            <button type="button" class="wh40k-power-btn wh40k-power-damage item-damage" data-item-id="{{item.id}}" title="Roll Damage">
                                <i class="fas fa-bolt"></i>
                            </button>
                        {{else}}
                            <button type="button" class="wh40k-power-btn item-vocalize" data-item-id="{{item.id}}" title="Post to Chat">
                                <i class="fas fa-comment"></i>
                            </button>
                        {{/if}}
                        <button type="button" class="wh40k-power-btn item-edit" data-item-id="{{item.id}}" title="Edit">
                            <i class="fas fa-cog"></i>
                        </button>
                        <button type="button" class="wh40k-power-btn wh40k-power-delete item-delete" data-item-id="{{item.id}}" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                    <div class="wh40k-power-description description_{{item.id}}" {{hideIfNot (isExpanded (concat "description_" item.id))}}>
                        {{item.system.description}}
                    </div>
                </div>
            {{/if}}
        {{/each}}
    </div>
</div>