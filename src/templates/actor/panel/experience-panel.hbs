{{!-- Simplified Experience Panel --}}
<div class="wh40k-panel wh40k-experience-panel-v2">

    {{!-- Panel Header --}}
    <div class="wh40k-panel-header wh40k-panel-header--clickable sheet-control__hide-control"
         data-toggle="experience_details"
         title="Click to {{#if (isExpanded 'experience_details' actor)}}collapse{{else}}expand{{/if}}">
        <span class="wh40k-panel-title">
            <i class="fas fa-graduation-cap"></i> Experience
        </span>
        <i class="fas fa-chevron-down wh40k-panel-chevron {{#if (isExpanded 'experience_details' actor)}}wh40k-panel-chevron--open{{/if}}"></i>
    </div>

    {{!-- Panel Body --}}
    <div class="wh40k-panel-body">

        {{!-- Compact XP Display - Single horizontal line --}}
        <div class="wh40k-xp-compact-display tw-flex tw-items-center tw-rounded-[6px] tw-mb-[var(--wh40k-space-md)]">
            {{!-- Progress Ring --}}
            <div class="wh40k-xp-ring-inline tw-relative tw-w-[50px] tw-h-[50px] tw-shrink-0">
                <svg viewBox="0 0 100 100" class="wh40k-xp-ring-svg tw-w-full tw-h-full">
                    {{!-- Background circle --}}
                    <circle cx="50" cy="50" r="45"
                            fill="none"
                            stroke="rgba(120, 46, 34, 0.2)"
                            stroke-width="10"/>
                    {{!-- Progress circle --}}
                    <circle cx="50" cy="50" r="45"
                            fill="none"
                            stroke="url(#xpGradient)"
                            stroke-width="10"
                            stroke-linecap="round"
                            stroke-dasharray="282.74"
                            stroke-dashoffset="{{multiply (subtract 1 (divide actor.system.experience.used actor.system.experience.total)) 282.74}}"
                            class="wh40k-xp-ring-progress"
                            transform="rotate(-90 50 50)"/>
                    {{!-- Gradient definition --}}
                    <defs>
                        <linearGradient id="xpGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#c08020;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#d09838;stop-opacity:1" />
                        </linearGradient>
                    </defs>
                </svg>
                <div class="wh40k-xp-ring-percent tw-absolute tw-top-1/2 tw-left-1/2 tw-translate-x-[-50%] tw-translate-y-[-50%] tw-text-[0.75rem] tw-font-bold tw-font-alt tw-leading-none">
                    {{#if actor.system.experience.total}}{{floor (multiply (divide actor.system.experience.used actor.system.experience.total) 100)}}{{else}}0{{/if}}%
                </div>
            </div>

            {{!-- Available XP Box --}}
            <div class="wh40k-xp-available-box tw-flex tw-flex-col tw-items-center tw-shrink-0 tw-rounded-[6px]">
                <span class="wh40k-xp-available-value tw-text-[1.4rem] tw-font-bold tw-font-alt tw-leading-none">{{system.experience.available}}</span>
                <span class="wh40k-xp-available-label tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em]">Available</span>
            </div>

            {{!-- Visual Buffer --}}
            <span class="wh40k-xp-separator tw-text-[1.2rem] tw-font-light tw-shrink-0">|</span>

            {{!-- Spent XP --}}
            <div class="wh40k-xp-inline-stat tw-flex tw-items-baseline tw-shrink-0">
                <span class="wh40k-xp-inline-value tw-text-[1.1rem] tw-font-bold tw-font-alt tw-leading-none">{{system.experience.used}}</span>
                <span class="wh40k-xp-inline-label tw-text-[0.7rem] tw-font-semibold">Spent</span>
            </div>

            {{!-- Visual Buffer --}}
            <span class="wh40k-xp-separator tw-text-[1.2rem] tw-font-light tw-shrink-0">|</span>

            {{!-- Total XP --}}
            <div class="wh40k-xp-inline-stat tw-flex tw-items-baseline tw-shrink-0">
                <span class="wh40k-xp-inline-value tw-text-[1.1rem] tw-font-bold tw-font-alt tw-leading-none">{{system.experience.total}}</span>
                <span class="wh40k-xp-inline-label tw-text-[0.7rem] tw-font-semibold">Total</span>
            </div>

            {{!-- Visual Buffer --}}
            <span class="wh40k-xp-separator tw-text-[1.2rem] tw-font-light tw-shrink-0">|</span>

            {{!-- Add XP Button --}}
            <button type="button"
                    class="wh40k-xp-add-button-inline tw-flex tw-items-center tw-justify-center tw-w-[36px] tw-h-[36px] tw-p-0 tw-rounded-full tw-cursor-pointer tw-shrink-0 tw-ml-auto"
                    data-action="customXP"
                    title="Add XP">
                <i class="fas fa-plus tw-text-[1rem]"></i>
            </button>

            {{!-- Advancement Button --}}
            <button type="button"
                    class="wh40k-xp-advancement-button tw-flex tw-items-center tw-justify-center tw-w-[36px] tw-h-[36px] tw-p-0 tw-rounded-full tw-cursor-pointer tw-shrink-0 tw-ml-0"
                    data-action="openAdvancement"
                    title="{{localize 'WH40K.Advancement.Title'}}">
                <i class="fa-solid fa-arrow-up-big-small tw-text-[1rem]"></i>
            </button>
        </div>

        {{!-- Edit Mode (Expandable) --}}
        <div class="wh40k-panel-details experience_details" {{hideIfNot (isExpanded 'experience_details' actor)}}>

            {{!-- Direct Edit Section --}}
            <div class="wh40k-xp-edit-section tw-rounded-lg tw-mb-[var(--wh40k-space-sm)]">
                <div class="wh40k-xp-edit-grid tw-grid tw-grid-cols-2 tw-gap-2">
                    <label class="wh40k-edit-field tw-flex tw-flex-col">
                        <span class="wh40k-edit-label tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em]">Total XP Earned</span>
                        <input type="number"
                               data-dtype="Number"
                               class="wh40k-edit-input tw-w-full tw-h-[40px] tw-text-center tw-font-alt tw-font-bold tw-text-[1.1rem] tw-rounded-[6px]"
                               name="system.experience.total"
                               value="{{system.experience.total}}"
                               min="0"
                               placeholder="0" />
                    </label>

                    <label class="wh40k-edit-field tw-flex tw-flex-col">
                        <span class="wh40k-edit-label tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em]">XP Spent</span>
                        <input type="number"
                               data-dtype="Number"
                               class="wh40k-edit-input tw-w-full tw-h-[40px] tw-text-center tw-font-alt tw-font-bold tw-text-[1.1rem] tw-rounded-[6px]"
                               name="system.experience.used"
                               value="{{system.experience.used}}"
                               min="0"
                               max="{{system.experience.total}}"
                               placeholder="0" />
                    </label>
                </div>
            </div>

            {{!-- Info Section --}}
            <div class="wh40k-xp-info-section tw-mt-[var(--wh40k-space-sm)]">
                <div class="wh40k-xp-info-box tw-flex tw-rounded-md">
                    <i class="fas fa-book tw-text-[1.2rem] tw-mt-[2px] tw-shrink-0"></i>
                    <div class="wh40k-info-content tw-flex tw-flex-col">
                        <strong>About Experience Points</strong>
                        <p>Spend XP to improve characteristics, acquire skills and talents, or gain psychic powers. Costs vary based on the advancement being purchased.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
