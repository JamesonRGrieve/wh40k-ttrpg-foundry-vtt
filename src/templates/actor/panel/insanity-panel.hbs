{{!-- Insanity Panel — thin caller; degree-meter-panel does the heavy lifting. --}}
{{> systems/wh40k-rpg/templates/actor/partial/degree-meter-panel
    key="insanity"
    label=(localize "WH40K.Status.Insanity.Label")
    icon="fa-brain"
    actor=actor
    system=system
    value=system.insanity
    sourceValue=source.insanity
    field="system.insanity"
    cssPrefix="wh40k-insanity"
    gradientClass="tw-from-purple-700 tw-to-crimson-dark"
    decTitle=(localize "WH40K.Status.Insanity.Decrease")
    incTitle=(localize "WH40K.Status.Insanity.Increase")
    modifierWord=(localize "WH40K.Status.Modifier")
    editTitle=(localize "WH40K.Status.Insanity.EditTitle")
    editLabel=(localize "WH40K.Status.Insanity.EditLabel")
    meta=(object
        degreeLabel=(insanityDegree system.insanity)
        degreeClass=(insanityDegreeClass system.insanity)
        modifier=(insanityModifier system.insanity))
    thresholds=(array
        (object at=10 label="10" title=(localize "WH40K.Status.Insanity.Threshold10"))
        (object at=40 label="40" title=(localize "WH40K.Status.Insanity.Threshold40"))
        (object at=60 label="60" title=(localize "WH40K.Status.Insanity.Threshold60"))
        (object at=80 label="80" title=(localize "WH40K.Status.Insanity.Threshold80")))
    activeWarning=(iff (eq system.insanity 100)
        (object
            icon="fa-dizzy"
            text=(localize "WH40K.Status.Insanity.Warn100")
            bannerClass="tw-text-crimson")
        (iff (gte system.insanity 80)
            (object
                icon="fa-exclamation-triangle"
                text=(localize "WH40K.Status.Insanity.Warn80")
                bannerClass="tw-text-crimson-light")
            (iff (gte system.insanity 60)
                (object
                    icon="fa-user-injured"
                    text=(localize "WH40K.Status.Insanity.Warn60")
                    bannerClass="tw-text-warning")
                false)))
    itemFlag="isMentalDisorder"
    itemIcon="fa-head-side-virus"
    itemPlural=(localize "WH40K.Status.Insanity.DisordersPlural")
    itemSingular=(localize "WH40K.Status.Insanity.DisorderSingular")
    dropType="mentalDisorder"
    dropLabel=(localize "WH40K.Status.Insanity.DropEmpty")
    dropCompactLabel=(localize "WH40K.Status.Insanity.DropFull")
    infoIcon="fa-book-medical"
    infoIntro=(localize "WH40K.Status.Insanity.InfoIntro")
    degreeInfoTitle=(localize "WH40K.Status.Insanity.DegreesTitle")
    degreeInfo=(array
        (object label=(localize "WH40K.Status.Insanity.Degree.Stable.Label") range="0-9" description=(localize "WH40K.Status.Insanity.Degree.Stable.Description"))
        (object label=(localize "WH40K.Status.Insanity.Degree.Unsettled.Label") range="10-39" description=(localize "WH40K.Status.Insanity.Degree.Unsettled.Description"))
        (object label=(localize "WH40K.Status.Insanity.Degree.Disturbed.Label") range="40-59" description=(localize "WH40K.Status.Insanity.Degree.Disturbed.Description"))
        (object label=(localize "WH40K.Status.Insanity.Degree.Unhinged.Label") range="60-79" description=(localize "WH40K.Status.Insanity.Degree.Unhinged.Description"))
        (object label=(localize "WH40K.Status.Insanity.Degree.Deranged.Label") range="80-99" description=(localize "WH40K.Status.Insanity.Degree.Deranged.Description"))
        (object label=(localize "WH40K.Status.Insanity.Degree.Terminal.Label") range="100" description=(localize "WH40K.Status.Insanity.Degree.Terminal.Description") extraClass="tw-text-crimson"))}}
