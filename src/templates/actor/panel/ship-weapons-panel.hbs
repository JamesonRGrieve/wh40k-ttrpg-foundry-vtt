<div class="wh40k-panel spacer wh40k-grid-col-6 wh40k-grid-row-2">
    <h1 class="wh40k-panel-header">{{localize "WH40K.Starship.Weapons.Header"}}</h1>
    <div class="wh40k-table--border">
        <div class="table-row--head">
            <div class="table-cell--span2">{{localize "WH40K.Starship.Weapons.Name"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Weapons.Location"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Weapons.Strength"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Weapons.Damage"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Weapons.Crit"}}</div>
            <div class="table-cell">{{localize "WH40K.Starship.Weapons.Range"}}</div>
            <div class="table-cell--last">
                <label class="wh40k-control-button" data-action="itemCreate" data-type="shipWeapon">
                    <span class="wh40k-control-button__span material-icons">add_circle</span>
                </label>
            </div>
        </div>
        {{#each actor.items as |item|}}
            {{#if item.isShipWeapon}}
                <div class="table-row">
                    <div class="table-cell--span2">
                        <button class="item-name wh40k-item-button" data-item-id="{{item.id}}" type="button">
                            <img class="wh40k-item-img" src="{{item.img}}" alt="{{item.name}}" />
                            {{item.name}}
                        </button>
                    </div>
                    <div class="table-cell">{{item.system.locationLabel}}</div>
                    <div class="table-cell">{{displayStrength item.system.strength}}</div>
                    <div class="table-cell">{{item.system.damage}}</div>
                    <div class="table-cell">{{displayCrit item.system.crit}}</div>
                    <div class="table-cell">{{item.system.range}}</div>
                    <div class="table-cell--last">
                        <label class="wh40k-control-button wh40k-ship-weapon-fire" data-item-id="{{item.id}}" title="Fire Weapon">
                            <span class="wh40k-control-button__span material-icons">gps_fixed</span>
                        </label>
                        <label class="wh40k-control-button item-delete" data-item-id="{{item.id}}">
                            <span class="wh40k-control-button__span material-icons">delete</span>
                        </label>
                    </div>
                </div>
            {{/if}}
        {{/each}}
    </div>
</div>