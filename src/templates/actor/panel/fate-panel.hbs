{{!-- Fate Panel — vital meter with Inquisitorial rosette pips (no bar). --}}
{{#> systems/wh40k-rpg/templates/actor/partial/vital-panel-shell key="fate" label="Fate" icon="fa-skull" actor=actor
    rootStateClass=(iff (eq system.fate.value 0) "wh40k-fate-empty-state")}}

    {{!-- Main Display: Rosette Pips + Counter --}}
    <div class="tw-flex tw-flex-col tw-gap-1 tw-items-center">
        {{> systems/wh40k-rpg/templates/actor/partial/vital-quick-controls
            wrapperClass="wh40k-fate-tracker tw-flex tw-items-center tw-justify-between tw-mb-2"
            cssPrefix="wh40k-fate"
            field="system.fate.value"
            current=system.fate.value
            maxLabel=system.fate.max
            decTitle="Spend Fate Point"
            incTitle="Restore Fate Point"
            maxValue=system.fate.max}}

        {{!-- Rosette Pip Display --}}
        <div class="tw-flex tw-flex-wrap tw-justify-center tw-gap-1 tw-mb-2 tw-py-1">
            {{#if (gt system.fate.max 0)}}
                {{#each (range 1 system.fate.max) as |index|}}
                    <button type="button"
                            class="tw-size-[42px] tw-p-0 tw-bg-transparent tw-border-none tw-cursor-pointer tw-relative tw-flex tw-items-center tw-justify-center {{#if (lte index ../system.fate.value)}}tw-animate-gentle-glow{{/if}}"
                            data-action="setFateStar"
                            data-fate-index="{{index}}"
                            title="Fate Point {{index}}{{#if (lte index ../system.fate.value)}} (Available — click to spend){{else}} (Spent — click to restore){{/if}}">
                        <i class="{{concat 'fas' ' fa-skull'}}"></i>
                    </button>
                {{/each}}
            {{else}}
                <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-text-gray-500 tw-opacity-60">
                    <i class="{{concat 'far' ' fa-circle'}}"></i>
                    <span>No Fate Points</span>
                </div>
            {{/if}}
        </div>

        {{!-- Stat Breakdown Button --}}
        <button
            type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-size-5 tw-p-0 tw-bg-transparent tw-border-none tw-rounded-[3px] tw-text-[color:var(--color-text-secondary,#94a3b8)] tw-cursor-pointer tw-opacity-60 tw-absolute tw-top-2 tw-right-2 tw-z-10"
            data-action="showStatBreakdown"
            data-stat-key="fate"
            title="Show fate calculation">
            <i class="{{concat 'fa-solid' ' fa-calculator'}} tw-text-xs"></i>
        </button>
    </div>

    {{!-- Edit Mode (Expandable) --}}
    <div class="tw-mt-2 tw-px-2 tw-py-1.5 tw-bg-black/[.02] tw-border-t tw-border-[color:var(--wh40k-border-color-light)]" {{hideIfNot (isExpanded 'fate_details' actor)}}>

        {{!-- Quick Edit Section --}}
        <div class="tw-p-2 tw-bg-[color:var(--wh40k-panel-bg-translucent)] tw-border tw-border-[color:var(--wh40k-border-color-light)] tw-rounded-lg tw-mb-1">
            <div class="tw-text-[0.8rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--wh40k-text-medium)] tw-mb-1 tw-flex tw-items-center tw-gap-[6px]">
                <i class="{{concat 'fas' ' fa-cog'}}"></i> Edit Fate Points
            </div>

            <div class="tw-grid tw-grid-cols-2 tw-gap-2">
                {{> systems/wh40k-rpg/templates/actor/partial/vital-edit-input
                    name="system.fate.max"
                    label="Max Fate Points"
                    value=system.fate.max
                    min="0"
                    max="10"
                    placeholder="Max"}}

                {{> systems/wh40k-rpg/templates/actor/partial/vital-edit-input
                    name="system.fate.value"
                    label="Current Fate"
                    value=system.fate.value
                    min="0"
                    max=system.fate.max
                    placeholder="Current"}}
            </div>
        </div>

        {{!-- About Fate Info Section --}}
        {{#> systems/wh40k-rpg/templates/actor/partial/vital-info-card.hbs
              icon="fa-book-open"
              title=(localize "WH40K.VitalInfoCard.FateAboutTitle")
              accent="gold"
              iconClass="tw-text-xl"}}
            <p class="tw-text-[0.75rem] tw-leading-snug tw-m-0">{{localize "WH40K.VitalInfoCard.FateAboutDesc"}}</p>

            <strong class="tw-text-[0.8rem] tw-font-bold tw-text-[color:var(--wh40k-text-medium)] tw-uppercase tw-tracking-[0.03em]">{{localize "WH40K.VitalInfoCard.FateUsesTitle"}}</strong>
            <ul class="tw-list-disc tw-pl-4 tw-text-[0.75rem] tw-leading-[1.5] tw-m-0">
                <li><strong>{{localize "WH40K.VitalInfoCard.FateRerollTitle"}}</strong> {{localize "WH40K.VitalInfoCard.FateRerollDesc"}}</li>
                <li><strong>{{localize "WH40K.VitalInfoCard.FateAvoidDeathTitle"}}</strong> {{localize "WH40K.VitalInfoCard.FateAvoidDeathDesc"}}</li>
                <li><strong>{{localize "WH40K.VitalInfoCard.FateInterventionTitle"}}</strong> {{localize "WH40K.VitalInfoCard.FateInterventionDesc"}}</li>
                <li><strong>{{localize "WH40K.VitalInfoCard.FateRighteousFuryTitle"}}</strong> {{localize "WH40K.VitalInfoCard.FateRighteousFuryDesc"}}</li>
            </ul>

            <p class="tw-text-crimson tw-mt-[6px] tw-px-1 tw-py-0.5 tw-bg-[color:var(--wh40k-wounds-bg)] tw-border-l-2 tw-border-l-[color:var(--wh40k-wounds-secondary)] tw-rounded-[3px] tw-text-[0.75rem]"><i class="fas fa-fire"></i> <strong class="tw-text-[color:var(--wh40k-wounds-secondary)]">{{localize "WH40K.VitalInfoCard.FateBurningTitle"}}</strong> {{localize "WH40K.VitalInfoCard.FateBurningDesc"}}</p>
        {{/systems/wh40k-rpg/templates/actor/partial/vital-info-card.hbs}}

    </div>
{{/systems/wh40k-rpg/templates/actor/partial/vital-panel-shell}}
