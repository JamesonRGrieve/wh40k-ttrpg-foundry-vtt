{{!-- Fate Panel - Inquisitorial Rosette Pips (count up like fatigue) --}}
<div class="wh40k-panel tw-rounded-lg tw-bg-[rgba(40,35,30,0.7)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-overflow-hidden tw-relative tw-mb-4 tw-shadow-[0_2px_8px_var(--wh40k-shadow-soft)] {{#if (eq system.fate.value 0)}}wh40k-fate-empty-state{{/if}}">

    {{!-- Panel Header - Click to expand/collapse --}}
    <div class="wh40k-panel-header tw-flex tw-flex-row tw-items-center tw-gap-2 tw-p-2 tw-bg-gradient-to-b tw-from-[rgba(var(--wh40k-accent-gold),0.15)] tw-to-[rgba(var(--wh40k-accent-gold),0.05)] tw-border-b tw-border-[var(--wh40k-border-color-light)] tw-transition-all tw-duration-200 tw-w-full tw-box-border tw-cursor-pointer sheet-control__hide-control"
         data-toggle="fate_details"
         title="Click to {{#if (isExpanded 'fate_details' actor)}}collapse{{else}}expand{{/if}}">
        <span class="wh40k-panel-title tw-flex-1 tw-flex tw-items-center tw-gap-2 tw-font-display tw-text-[1.1rem] tw-font-semibold tw-text-[var(--wh40k-text-dark)] tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis">
            <i class="fas fa-skull tw-text-[var(--panel-accent,var(--wh40k-accent-gold))] tw-flex-shrink-0"></i> Fate
        </span>
        <i class="fas fa-chevron-down wh40k-panel-chevron {{#if (isExpanded 'fate_details' actor)}}wh40k-panel-chevron--open{{/if}}"></i>
    </div>

    {{!-- Panel Body --}}
    <div class="wh40k-panel-body tw-p-4 tw-bg-[var(--wh40k-panel-body-bg)]">

        {{!-- Main Display: Rosette Pips + Counter --}}
        <div class="wh40k-fate-display">
            <div class="wh40k-fate-tracker tw-flex tw-items-center tw-justify-between tw-mb-2">
                <button type="button"
                        class="wh40k-fate-btn wh40k-fate-minus"
                        data-action="decrement"
                        data-field="system.fate.value"
                        data-min="0"
                        title="Spend Fate Point">
                    <i class="fas fa-minus"></i>
                </button>

                <div class="wh40k-fate-value tw-flex tw-items-center tw-gap-1">
                    <span class="wh40k-fate-current">{{system.fate.value}}</span>
                    <span class="wh40k-fate-sep">/</span>
                    <span class="wh40k-fate-max">{{system.fate.max}}</span>
                </div>

                <button type="button"
                        class="wh40k-fate-btn wh40k-fate-plus"
                        data-action="increment"
                        data-field="system.fate.value"
                        data-max="{{system.fate.max}}"
                        title="Restore Fate Point">
                    <i class="fas fa-plus"></i>
                </button>
            </div>

            {{!-- Rosette Pip Display --}}
            <div class="wh40k-fate-pips tw-flex tw-flex-wrap tw-justify-center tw-gap-1 tw-mb-2">
                {{#if (gt system.fate.max 0)}}
                    {{#each (range 1 system.fate.max) as |index|}}
                        <button type="button"
                                class="wh40k-fate-pip {{#if (lte index ../system.fate.value)}}wh40k-fate-pip--filled{{/if}}"
                                data-action="setFateStar"
                                data-fate-index="{{index}}"
                                title="Fate Point {{index}}{{#if (lte index ../system.fate.value)}} (Available — click to spend){{else}} (Spent — click to restore){{/if}}">
                            <i class="fas fa-skull"></i>
                        </button>
                    {{/each}}
                {{else}}
                    <div class="wh40k-fate-none tw-flex tw-items-center tw-justify-center tw-gap-2 tw-text-gray-500">
                        <i class="far fa-circle"></i>
                        <span>No Fate Points</span>
                    </div>
                {{/if}}
            </div>

            {{!-- Stat Breakdown Button --}}
            <button
                type="button"
                class="wh40k-stat-breakdown-btn wh40k-stat-breakdown-btn--compact tw-mx-auto tw-block"
                data-action="showStatBreakdown"
                data-stat-key="fate"
                title="Show fate calculation">
                <i class="fa-solid fa-calculator"></i>
            </button>
        </div>

        {{!-- Edit Mode (Expandable) --}}
        <div class="wh40k-panel-details fate_details tw-mt-2" {{hideIfNot (isExpanded 'fate_details' actor)}}>

            {{!-- Quick Edit Section --}}
            <div class="wh40k-fate-edit-section">
                <div class="wh40k-fate-edit-header">
                    <i class="fas fa-cog"></i> Edit Fate Points
                </div>

                <div class="wh40k-fate-edit-grid">
                    <label class="wh40k-edit-field">
                        <span class="wh40k-edit-label">Max Fate Points</span>
                        <input type="number"
                               data-dtype="Number"
                               class="wh40k-edit-input"
                               name="system.fate.max"
                               value="{{system.fate.max}}"
                               min="0"
                               max="10"
                               placeholder="Max" />
                    </label>

                    <label class="wh40k-edit-field">
                        <span class="wh40k-edit-label">Current Fate</span>
                        <input type="number"
                               data-dtype="Number"
                               class="wh40k-edit-input"
                               name="system.fate.value"
                               value="{{system.fate.value}}"
                               min="0"
                               max="{{system.fate.max}}"
                               placeholder="Current" />
                    </label>
                </div>
            </div>

            {{!-- About Fate Info Section --}}
            <div class="wh40k-fate-edit-section">
                <div class="wh40k-fate-info-box tw-flex tw-gap-3 tw-bg-[rgba(0,0,0,0.1)] tw-p-3 tw-rounded-md">
                    <i class="fas fa-book-open tw-text-gold tw-text-xl"></i>
                    <div class="wh40k-info-content tw-text-sm tw-space-y-1">
                        <strong>About Fate Points</strong>
                        <p>Fate Points represent the Emperor's favor and divine protection. They can be spent to alter destiny in critical moments.</p>

                        <strong>Uses of Fate:</strong>
                        <ul class="tw-list-disc tw-pl-4">
                            <li><strong>Reroll a Test:</strong> Reroll any failed test, keeping the second result</li>
                            <li><strong>Avoid Death:</strong> When reduced to 0 wounds, spend a Fate Point to survive with 1 wound instead</li>
                            <li><strong>Divine Intervention:</strong> Call upon the Emperor's grace for a minor miracle at the GM's discretion</li>
                            <li><strong>Righteous Fury:</strong> Confirm a Righteous Fury result automatically</li>
                        </ul>

                        <p class="wh40k-fate-warning tw-text-crimson"><i class="fas fa-fire"></i> <strong>Burning Fate:</strong> Permanently spending a Fate Point (reducing your maximum) can achieve truly miraculous results, but this should only be done in the direst circumstances.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
