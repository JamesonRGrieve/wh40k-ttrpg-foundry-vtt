{{!--
    Possession Panel — Daemonic possession track (#82, beyond.md p.69)
    + Possession-power Frenzy-test loop (#132, beyond.md L2095-2116).

    Displays the actor's current possession state (latent / possessed),
    the per-session Unleash Daemon counter, and exposes the Unleash
    Daemon action plus a GM-only "Reset Session" control.

    While the actor is in the `latent` (contested) state — the
    Possession power is sustained — the panel also surfaces the
    per-round Frenzy test and the mismanifest opposed-Willpower contest
    that can escalate to full possession. Those controls are hidden in
    the terminal `possessed` state (the daemon is already in control).

    Rendered only when `system.possession.state !== 'none'`; the call
    site in tab-status.hbs gates the include with `{{#if (neq ...)}}`.
--}}
{{#> systems/wh40k-rpg/templates/actor/partial/system-card.hbs rootClass="wh40k-possession-panel" accentBorderClass="dh2:tw-border-bronze rt:tw-border-amber-700 im:tw-border-failure" accentIconClass="tw-text-crimson dh2:tw-text-crimson rt:tw-text-amber-700 im:tw-text-failure" icon="fa-ghost" label=(localize "WH40K.Possession.Title") rootAttrs=(safeAttrs "data-possession-state" system.possession.state) hasRightSlot=true}}
    {{!-- Header right slot: state badge --}}
    {{#*inline "rightSlot"}}
        <span class="wh40k-possession-state-badge tw-px-2 tw-py-0.5 tw-rounded tw-text-[0.7rem] tw-font-bold tw-uppercase tw-tracking-[0.05em]
                     {{#if (eq system.possession.state 'possessed')}}tw-bg-crimson/30 tw-text-crimson-light tw-border tw-border-solid tw-border-crimson{{else}}{{#if (eq system.possession.state 'latent')}}tw-bg-gold-dark/20 tw-text-gold tw-border tw-border-solid tw-border-gold-raw{{else}}tw-bg-black/20 tw-text-[color:var(--wh40k-text-muted)]{{/if}}{{/if}}">
            {{#if (eq system.possession.state 'possessed')}}{{localize "WH40K.Possession.StatePossessed"}}{{else}}{{#if (eq system.possession.state 'latent')}}{{localize "WH40K.Possession.StateLatent"}}{{else}}{{localize "WH40K.Possession.StateNone"}}{{/if}}{{/if}}
        </span>
    {{/inline}}

    {{!-- Unleash counter --}}
    <div class="tw-flex tw-items-center tw-justify-between tw-gap-2 tw-py-1">
        <span class="tw-flex tw-items-center tw-gap-1.5 tw-text-[0.78rem] tw-text-[color:var(--wh40k-text-medium)] tw-uppercase tw-tracking-[0.03em]">
            <i class="fas fa-bolt"></i>
            <span>{{localize "WH40K.Possession.UnleashCount"}}</span>
        </span>
        <span class="wh40k-possession-counter tw-font-bold tw-text-[0.95rem] tw-text-[color:var(--wh40k-text-bright)]">
            <span class="wh40k-possession-used">{{system.possession.unleashUsed}}</span>
            <span class="tw-text-[color:var(--wh40k-text-muted)]"> / </span>
            <span class="wh40k-possession-max">{{system.possession.unleashMax}}</span>
        </span>
    </div>

    {{!-- Action buttons --}}
    <div class="tw-flex tw-items-center tw-gap-2">
        <button type="button"
                class="wh40k-possession-unleash-btn tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5
                       tw-px-2 tw-py-1.5 tw-rounded tw-bg-crimson/20 tw-border tw-border-solid tw-border-crimson/60
                       tw-text-[0.78rem] tw-font-bold tw-uppercase tw-tracking-[0.03em] tw-text-[color:var(--wh40k-text-bright)]
                       tw-cursor-pointer tw-transition-colors hover:tw-bg-crimson/40
                       disabled:tw-opacity-40 disabled:tw-cursor-not-allowed disabled:hover:tw-bg-crimson/20
                       dh2:tw-border-bronze rt:tw-border-amber-700 im:tw-border-failure"
                data-action="unleashDaemon"
                title="{{localize 'WH40K.Possession.UnleashTitle'}}"
                {{#unless (lt system.possession.unleashUsed system.possession.unleashMax)}}disabled{{/unless}}>
            <i class="fas fa-bolt"></i>
            <span>{{localize "WH40K.Possession.UnleashTitle"}}</span>
        </button>

        {{#if isGM}}
            <button type="button"
                    class="wh40k-possession-reset-btn tw-flex tw-items-center tw-justify-center tw-gap-1.5
                           tw-px-2 tw-py-1.5 tw-rounded tw-bg-transparent tw-border tw-border-solid
                           tw-border-[color:var(--wh40k-border-color-light)]
                           tw-text-[0.72rem] tw-text-[color:var(--wh40k-text-medium)]
                           tw-cursor-pointer tw-transition-colors hover:tw-text-[color:var(--wh40k-text-bright)]"
                    data-action="resetPossessionSession"
                    title="{{localize 'WH40K.Possession.ResetSessionTitle'}}">
                <i class="fas fa-rotate-left"></i>
                <span>{{localize "WH40K.Possession.ResetSession"}}</span>
            </button>
        {{/if}}
    </div>

    {{!-- Frenzy-test loop (#132) — only while the power is sustained
          (contested / latent state). The terminal possessed state hides
          these because the daemon already won the contest. --}}
    {{#if (eq system.possession.state 'latent')}}
        <div class="wh40k-possession-frenzy-loop tw-flex tw-flex-col tw-gap-2 tw-pt-2 tw-mt-1
                    tw-border-t tw-border-solid tw-border-[color:var(--wh40k-border-color-light)]">
            <p class="tw-flex tw-items-center tw-gap-1.5 tw-m-0 tw-text-[0.72rem] tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">
                <i class="fas fa-arrows-rotate" aria-hidden="true"></i>
                <span>{{localize "WH40K.Possession.FrenzyLoopHint"}}</span>
            </p>
            <div class="tw-flex tw-items-center tw-gap-2">
                <button type="button"
                        class="wh40k-possession-frenzy-btn tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5
                               tw-px-2 tw-py-1.5 tw-rounded tw-bg-gold-dark/20 tw-border tw-border-solid tw-border-gold-raw/60
                               tw-text-[0.78rem] tw-font-bold tw-uppercase tw-tracking-[0.03em] tw-text-[color:var(--wh40k-text-bright)]
                               tw-cursor-pointer tw-transition-colors hover:tw-bg-gold-dark/40
                               dh2:tw-border-bronze rt:tw-border-amber-700 im:tw-border-failure"
                        data-action="possessionFrenzyTest"
                        title="{{localize 'WH40K.Possession.FrenzyTestTitle'}}">
                    <i class="fas fa-dice-d20" aria-hidden="true"></i>
                    <span>{{localize "WH40K.Possession.FrenzyTest"}}</span>
                </button>
                <button type="button"
                        class="wh40k-possession-mismanifest-btn tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5
                               tw-px-2 tw-py-1.5 tw-rounded tw-bg-crimson/20 tw-border tw-border-solid tw-border-crimson/60
                               tw-text-[0.78rem] tw-font-bold tw-uppercase tw-tracking-[0.03em] tw-text-[color:var(--wh40k-text-bright)]
                               tw-cursor-pointer tw-transition-colors hover:tw-bg-crimson/40
                               dh2:tw-border-bronze rt:tw-border-amber-700 im:tw-border-failure"
                        data-action="possessionMismanifest"
                        title="{{localize 'WH40K.Possession.MismanifestTitle'}}">
                    <i class="fas fa-skull" aria-hidden="true"></i>
                    <span>{{localize "WH40K.Possession.Mismanifest"}}</span>
                </button>
            </div>
        </div>
    {{/if}}
{{/systems/wh40k-rpg/templates/actor/partial/system-card.hbs}}
