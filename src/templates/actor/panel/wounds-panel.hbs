{{!-- Wounds Panel — vital meter for hit-point tracking + critical-damage pip array. --}}
{{#> systems/wh40k-rpg/templates/actor/partial/vital-panel-shell key="wounds" label="Wounds" icon="fa-heart-broken" actor=actor
    rootStateClass=(concat (iff (eq system.wounds.value 0) "wh40k-wounds-critical") " " (iff (lt (percent system.wounds.value system.wounds.max) 25) "wh40k-wounds-warning"))}}

    {{!-- Main Display: Current/Max with Quick Controls --}}
    <div class="tw-flex tw-flex-col tw-gap-1">
        {{> systems/wh40k-rpg/templates/actor/partial/vital-quick-controls
            wrapperClass="tw-flex tw-items-center tw-justify-between"
            cssPrefix="wh40k-wounds"
            field="system.wounds.value"
            current=system.wounds.value
            maxLabel=system.wounds.max
            decTitle="Reduce Wounds"
            incTitle="Increase Wounds"
            showCalculator=true
            statKey="wounds"}}

        {{> systems/wh40k-rpg/templates/actor/partial/vital-progress-bar
            cssPrefix="wh40k-wounds"
            cssVarName="wounds-percent"
            percent=(percent system.wounds.value system.wounds.max)
            containerClass="tw-flex tw-items-center tw-gap-1"
            showPercentText="right"
            thresholds=(array
                (object at=25 label="25%" title="Severely Injured (25%)")
                (object at=50 label="50%" title="Half Health (50%)")
                (object at=75 label="75%" title="Good Health (75%)"))}}
    </div>

    {{!-- Warning Messages --}}
    {{#if (eq system.wounds.value 0)}}
    <div class="tw-flex tw-items-center tw-gap-1 tw-px-1.5 tw-py-0.5 tw-mt-1 tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.03em] tw-rounded-[6px] tw-border-2 tw-border-solid tw-border-crimson tw-bg-[var(--wh40k-wounds-bg)] tw-text-crimson tw-animate-pulse-red">
        <i class="{{concat 'fas fa-skull-crossbones'}}"></i>
        <span>CRITICALLY WOUNDED - At 0 wounds!</span>
    </div>
    {{else if (lt (percent system.wounds.value system.wounds.max) 25)}}
    <div class="tw-flex tw-items-center tw-gap-1 tw-px-1.5 tw-py-0.5 tw-mt-1 tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.03em] tw-rounded-[6px] tw-border-2 tw-border-solid tw-border-[rgba(196,135,29,0.5)] tw-bg-[var(--wh40k-warning-bg)] tw-text-warning">
        <i class="{{concat 'fas fa-exclamation-triangle'}}"></i>
        <span>Severely Injured - Below 25%</span>
    </div>
    {{/if}}

    {{!-- Critical Damage Pip System - Show if critical > 0 OR wounds = 0 --}}
    {{#if (or (gt system.wounds.critical 0) (eq system.wounds.value 0))}}
    <div class="tw-mt-2 tw-p-1.5 tw-bg-[var(--wh40k-wounds-bg)] tw-border tw-border-solid tw-border-[var(--wh40k-wounds-border)] tw-rounded-lg">
        <div class="tw-flex tw-items-center tw-justify-between tw-mb-1.5">
            <span class="tw-flex tw-items-center tw-gap-1 tw-font-semibold tw-text-[0.8rem] tw-uppercase tw-tracking-[0.05em] tw-text-crimson bc:tw-text-crimson-light dh1e:tw-text-gold-raw dh2e:tw-text-crimson dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
                <i class="{{concat 'fas fa-skull'}}"></i> Critical Damage
            </span>
            <span class="tw-text-[0.8rem] tw-font-bold tw-text-crimson tw-font-alt">{{system.wounds.critical}} / 10</span>
        </div>
        {{> systems/wh40k-rpg/templates/actor/partial/wounds-pip-row.hbs critical=system.wounds.critical mode="display"}}
    </div>
    {{/if}}

    {{!-- Edit Mode (Expandable) --}}
    {{#> systems/wh40k-rpg/templates/actor/partial/vital-edit-body.hbs
          key="wounds" actor=actor
          editIcon="fa-cog" editTitle=(localize "WH40K.VitalEditBody.EditWoundsTitle")
          fields=(array
              (object name="system.wounds.max"   label=(localize "WH40K.VitalEditBody.WoundsMaxLabel")     value=source.wounds.max   min="1" placeholder=(localize "WH40K.VitalEditBody.MaxPlaceholder"))
              (object name="system.wounds.value" label=(localize "WH40K.VitalEditBody.WoundsCurrentLabel") value=source.wounds.value min="0" max=system.wounds.max placeholder=(localize "WH40K.VitalEditBody.CurrentPlaceholder")))}}

        {{!-- Critical Damage Editor --}}
        <div class="tw-p-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-rounded-lg tw-mb-1.5">
            <div class="tw-flex tw-items-center tw-justify-between tw-text-[0.8rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[var(--wh40k-text-medium)] tw-mb-1.5">
                <i class="{{concat 'fas fa-skull'}}" style="margin-right:4px;font-size:0.9em;"></i> Critical Damage
            </div>

            <div class="tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-mb-2">
                <button type="button"
                        class="tw-w-8 tw-h-8 tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-[var(--wh40k-input-bg)] tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-rounded-[6px] tw-cursor-pointer tw-text-accent-combat"
                        data-action="decrement"
                        data-field="system.wounds.critical"
                        data-min="0"
                        title="Reduce Critical">
                    <i class="{{concat 'fas fa-minus'}}" style="font-size:0.75rem;"></i>
                </button>

                <input type="number"
                       data-dtype="Number"
                       class="tw-w-[70px] tw-h-9 tw-px-1.5 tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-rounded-[6px] tw-bg-[var(--wh40k-input-bg)] tw-text-[1.2rem] tw-font-bold tw-text-crimson tw-text-center tw-font-alt"
                       name="system.wounds.critical"
                       value="{{source.wounds.critical}}"
                       min="0"
                       max="10"
                       title="Critical Damage (0-10)" />

                <button type="button"
                        class="tw-w-8 tw-h-8 tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-[var(--wh40k-input-bg)] tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-rounded-[6px] tw-cursor-pointer tw-text-success"
                        data-action="increment"
                        data-field="system.wounds.critical"
                        data-max="10"
                        title="Increase Critical">
                    <i class="{{concat 'fas fa-plus'}}" style="font-size:0.75rem;"></i>
                </button>
            </div>

            {{!-- Critical Pips (Edit Mode) --}}
            {{> systems/wh40k-rpg/templates/actor/partial/wounds-pip-row.hbs critical=system.wounds.critical mode="edit"}}
        </div>

        {{!-- Critical Injuries List --}}
        {{#> systems/wh40k-rpg/templates/actor/partial/section-card
            icon="fa-notes-medical"
            titleKey="WH40K.Status.Wounds.CriticalInjuries"
            addAction="itemCreate"
            addType="criticalInjury"
            addTitleKey="WH40K.Status.Wounds.AddCriticalInjury"}}
            {{#if (any actor.items "isCriticalInjury")}}
            <div class="tw-flex tw-flex-col tw-gap-[6px]">
                {{#each actor.items as |item|}}
                    {{#if item.isCriticalInjury}}
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-1.5 tw-py-0.5 tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-rounded-[6px]">
                        <button type="button"
                                class="item-edit tw-flex-1 tw-bg-transparent tw-border-0 tw-p-1 tw-text-left tw-text-[0.85rem] tw-font-semibold tw-text-[var(--wh40k-text-medium)] tw-cursor-pointer tw-flex tw-items-center tw-gap-[6px]"
                                data-item-id="{{item.id}}"
                                title="{{item.name}}">
                            <i class="fas fa-band-aid" style="font-size:0.85em;color:var(--wh40k-wounds-secondary);"></i>
                            {{item.name}}
                        </button>
                        <button type="button"
                                class="item-delete tw-w-6 tw-h-6 tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-[var(--wh40k-wounds-bg)] tw-border tw-border-solid tw-border-[var(--wh40k-wounds-border)] tw-rounded-md tw-cursor-pointer"
                                data-item-id="{{item.id}}"
                                title="{{item.name}}">
                            <i class="fas fa-times" style="font-size:0.7rem;color:var(--wh40k-wounds-secondary);"></i>
                        </button>
                    </div>
                    {{/if}}
                {{/each}}
            </div>
            {{else}}
            <div class="tw-flex tw-flex-col tw-items-center tw-gap-1 tw-p-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border tw-border-dashed tw-border-[var(--wh40k-border-color-light)] tw-rounded-[6px]">
                <i class="fas fa-shield-alt" style="font-size:1.8rem;color:var(--wh40k-success-secondary);opacity:0.5;"></i>
                <span class="tw-text-[0.75rem] tw-text-[var(--wh40k-text-muted)] tw-italic">{{localize "WH40K.Status.Wounds.NoCriticalInjuries"}}</span>
            </div>
            {{/if}}
        {{/systems/wh40k-rpg/templates/actor/partial/section-card}}
    {{/systems/wh40k-rpg/templates/actor/partial/vital-edit-body.hbs}}
{{/systems/wh40k-rpg/templates/actor/partial/vital-panel-shell}}
