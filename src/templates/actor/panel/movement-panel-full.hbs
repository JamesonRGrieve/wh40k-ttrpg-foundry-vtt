{{!-- Mobility Panel - Clean, Modern Design --}}

<div class="wh40k-panel wh40k-panel-mobility">
    <div class="wh40k-panel-header wh40k-panel-header--clickable sheet-control__hide-control"
         data-toggle="mobility_details"
         title="Click to {{#if (isExpanded 'mobility_details' actor)}}collapse{{else}}expand{{/if}}">
        <span class="wh40k-panel-title">
            <i class="fas fa-person-running"></i> Mobility
        </span>
        <i class="fas fa-chevron-down wh40k-panel-chevron {{#if (isExpanded 'mobility_details' actor)}}wh40k-panel-chevron--open{{/if}}"></i>
    </div>

    <div class="wh40k-panel-body">
        
        {{!-- Movement Speeds - Always Visible --}}
        <div class="wh40k-mobility-speeds">
            <div class="wh40k-speed-box wh40k-speed-half" data-action="setMovementMode" data-movement-type="half"
                 title="Click to set Half Move as active movement mode">
                <i class="fas fa-walking"></i>
                <div class="wh40k-speed-data">
                    <span class="wh40k-speed-value">{{system.movement.half}}</span>
                    <span class="wh40k-speed-unit">m</span>
                </div>
                <span class="wh40k-speed-label">Half</span>
            </div>
            
            <div class="wh40k-speed-box wh40k-speed-full" data-action="setMovementMode" data-movement-type="full"
                 title="Click to set Full Move as active movement mode">
                <i class="fas fa-shoe-prints"></i>
                <div class="wh40k-speed-data">
                    <span class="wh40k-speed-value">{{system.movement.full}}</span>
                    <span class="wh40k-speed-unit">m</span>
                </div>
                <span class="wh40k-speed-label">Full</span>
            </div>
            
            <div class="wh40k-speed-box wh40k-speed-charge" data-action="setMovementMode" data-movement-type="charge"
                 title="Click to set Charge as active movement mode">
                <i class="fas fa-running"></i>
                <div class="wh40k-speed-data">
                    <span class="wh40k-speed-value">{{system.movement.charge}}</span>
                    <span class="wh40k-speed-unit">m</span>
                </div>
                <span class="wh40k-speed-label">Charge</span>
            </div>
            
            <div class="wh40k-speed-box wh40k-speed-run" data-action="setMovementMode" data-movement-type="run"
                 title="Click to set Run as active movement mode">
                <i class="fas fa-wind"></i>
                <div class="wh40k-speed-data">
                    <span class="wh40k-speed-value">{{system.movement.run}}</span>
                    <span class="wh40k-speed-unit">m</span>
                </div>
                <span class="wh40k-speed-label">Run</span>
            </div>
        </div>

        {{!-- Expanded Details --}}
        <div class="wh40k-panel-details mobility_details" {{hideIfNot (isExpanded 'mobility_details' actor)}}>
            
            {{!-- Athletics Section --}}
            <div class="wh40k-mobility-section">
                <div class="wh40k-section-header">
                    <i class="fas fa-person-hiking"></i>
                    <span>Athletics</span>
                </div>
                <div class="wh40k-athletics-grid">
                    <div class="wh40k-athletic-stat">
                        <span class="wh40k-athletic-label">Leap Vertical</span>
                        <span class="wh40k-athletic-value">{{system.movement.leapVertical}}m</span>
                    </div>
                    <div class="wh40k-athletic-stat">
                        <span class="wh40k-athletic-label">Leap Horizontal</span>
                        <span class="wh40k-athletic-value">{{system.movement.leapHorizontal}}m</span>
                    </div>
                    <div class="wh40k-athletic-stat">
                        <span class="wh40k-athletic-label">Jump Height</span>
                        <span class="wh40k-athletic-value">{{system.movement.jump}}cm</span>
                    </div>
                </div>
            </div>

            {{!-- Carrying Capacity Section --}}
            <div class="wh40k-mobility-section">
                <div class="wh40k-section-header">
                    <i class="fas fa-weight-hanging"></i>
                    <span>Carrying Capacity</span>
                </div>
                <div class="wh40k-carrying-grid">
                    <div class="wh40k-carry-stat">
                        <span class="wh40k-carry-label">Lift</span>
                        <span class="wh40k-carry-value">{{system.lifting.lift}}<span class="wh40k-carry-unit">kg</span></span>
                    </div>
                    <div class="wh40k-carry-stat">
                        <span class="wh40k-carry-label">Carry</span>
                        <span class="wh40k-carry-value">{{system.lifting.carry}}<span class="wh40k-carry-unit">kg</span></span>
                    </div>
                    <div class="wh40k-carry-stat">
                        <span class="wh40k-carry-label">Push/Drag</span>
                        <span class="wh40k-carry-value">{{system.lifting.push}}<span class="wh40k-carry-unit">kg</span></span>
                    </div>
                </div>
            </div>

            {{!-- Size --}}
            <div class="wh40k-mobility-section wh40k-size-section">
                <div class="wh40k-section-header">
                    <i class="fas fa-arrows-alt"></i>
                    <span>Size</span>
                </div>
                <select name="system.size" data-dtype="Number" class="wh40k-size-select">
                    <option value="1" {{#if (eq system.size 1)}}selected{{/if}}>Miniscule</option>
                    <option value="2" {{#if (eq system.size 2)}}selected{{/if}}>Puny</option>
                    <option value="3" {{#if (eq system.size 3)}}selected{{/if}}>Scrawny</option>
                    <option value="4" {{#if (eq system.size 4)}}selected{{/if}}>Average</option>
                    <option value="5" {{#if (eq system.size 5)}}selected{{/if}}>Hulking</option>
                    <option value="6" {{#if (eq system.size 6)}}selected{{/if}}>Enormous</option>
                    <option value="7" {{#if (eq system.size 7)}}selected{{/if}}>Massive</option>
                    <option value="8" {{#if (eq system.size 8)}}selected{{/if}}>Immense</option>
                </select>
            </div>

        </div>
    </div>
</div>
