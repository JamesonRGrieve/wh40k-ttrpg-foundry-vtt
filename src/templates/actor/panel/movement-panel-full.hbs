{{!-- Mobility Panel — collapsible vital-panel-shell with mobility / athletics / carry stat grids. --}}
{{#> systems/wh40k-rpg/templates/actor/partial/vital-panel-shell key="mobility" label=(localize "WH40K.MOVEMENT.Mobility") icon="fa-person-running" actor=actor}}

    {{!-- Movement Speeds — always visible --}}
    {{> systems/wh40k-rpg/templates/actor/partial/stat-grid-section
        columns=4
        sectionClass="tw-mb-3"
        stats=(array
            (object
                label=(localize "WH40K.MOVEMENT.Stat.Half")
                value=system.movement.half
                unit="m"
                icon="fa-walking"
                action="setMovementMode"
                attrs="data-movement-type=\"half\""
                title=(localize "WH40K.MOVEMENT.Tooltip.Half"))
            (object
                label=(localize "WH40K.MOVEMENT.Stat.Full")
                value=system.movement.full
                unit="m"
                icon="fa-shoe-prints"
                action="setMovementMode"
                attrs="data-movement-type=\"full\""
                title=(localize "WH40K.MOVEMENT.Tooltip.Full"))
            (object
                label=(localize "WH40K.MOVEMENT.Stat.Charge")
                value=system.movement.charge
                unit="m"
                icon="fa-running"
                action="setMovementMode"
                attrs="data-movement-type=\"charge\""
                title=(localize "WH40K.MOVEMENT.Tooltip.Charge"))
            (object
                label=(localize "WH40K.MOVEMENT.Stat.Run")
                value=system.movement.run
                unit="m"
                icon="fa-wind"
                action="setMovementMode"
                attrs="data-movement-type=\"run\""
                title=(localize "WH40K.MOVEMENT.Tooltip.Run")))}}

    {{!-- Expanded Details --}}
    <div class="wh40k-panel-details mobility_details" {{hideIfNot (isExpanded 'mobility_details' actor)}}>

        {{!-- Athletics --}}
        {{> systems/wh40k-rpg/templates/actor/partial/stat-grid-section
            heading=(localize "WH40K.MOVEMENT.Athletics")
            headingIcon="fa-person-hiking"
            columns=3
            stats=(array
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.LeapVerticalLong")
                    value=system.movement.leapVertical
                    unit="m"
                    title=(localize "WH40K.MOVEMENT.Tooltip.LeapVertical"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.LeapHorizontalLong")
                    value=system.movement.leapHorizontal
                    unit="m"
                    title=(localize "WH40K.MOVEMENT.Tooltip.LeapHorizontal"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.JumpHeight")
                    value=system.movement.jump
                    unit="cm"
                    title=(localize "WH40K.MOVEMENT.Tooltip.Jump")))}}

        {{!-- Carrying Capacity --}}
        {{> systems/wh40k-rpg/templates/actor/partial/stat-grid-section
            heading=(localize "WH40K.MOVEMENT.CarryingCapacity")
            headingIcon="fa-weight-hanging"
            columns=3
            stats=(array
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Lift")
                    value=system.lifting.lift
                    unit="kg"
                    title=(localize "WH40K.MOVEMENT.Tooltip.Lift"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.Carry")
                    value=system.lifting.carry
                    unit="kg"
                    title=(localize "WH40K.MOVEMENT.Tooltip.Carry"))
                (object
                    label=(localize "WH40K.MOVEMENT.Stat.PushDrag")
                    value=system.lifting.push
                    unit="kg"
                    title=(localize "WH40K.MOVEMENT.Tooltip.Push")))}}

        {{!-- Size --}}
        <div class="wh40k-mobility-section wh40k-size-section tw-rounded-md tw-p-2 tw-mb-[var(--wh40k-space-md)] tw-bg-[var(--wh40k-bg-paper-light)] tw-border tw-border-solid tw-border-[var(--wh40k-border-light)]">
            <div class="wh40k-stat-grid-header tw-flex tw-items-center tw-gap-2 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-mb-2 tw-pb-1">
                <i class="fas fa-arrows-alt tw-text-[0.85rem] tw-text-[color:var(--wh40k-accent-gold)] bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                <span class="tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.MOVEMENT.Size"}}</span>
            </div>
            <select name="system.size" data-dtype="Number" class="wh40k-size-select tw-w-full tw-text-[0.85rem] tw-font-semibold tw-text-center tw-rounded-md tw-cursor-pointer tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-border tw-border-solid tw-border-[var(--wh40k-border-medium)] tw-bg-[rgba(255,255,255,0.8)] tw-text-[color:var(--color-text-primary)] tw-transition-all hover:tw-border-[color:var(--wh40k-accent-gold)] focus:tw-outline-none focus:tw-border-[color:var(--wh40k-accent-gold)] focus:tw-shadow-[0_0_0_3px_rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.15)]">
                {{selectOptions dh.sizes selected=system.size labelAttr="label" valueAttr="@key"}}
            </select>
        </div>

    </div>

{{/systems/wh40k-rpg/templates/actor/partial/vital-panel-shell}}
