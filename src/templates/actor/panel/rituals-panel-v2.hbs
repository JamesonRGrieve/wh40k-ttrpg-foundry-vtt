{{!-- Rituals Panel V2 - Modern Card-based Design --}}
<div class="wh40k-panel">
    <header class="wh40k-panel-header" data-action="togglePanel" data-panel-id="rituals">
        <span class="tw-flex-1 tw-font-[var(--wh40k-font-display,'Modesto_Condensed',serif)] tw-text-[var(--wh40k-text-h3,1.1rem)] tw-font-semibold tw-text-[color:var(--wh40k-text-dark)] tw-tracking-[0.02em] tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-min-w-0">
            <i class="fas fa-pray"></i>
            Rituals
            {{#if ritualsCount}}
            <span class="tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-px-[6px] tw-py-[2px] tw-rounded-[10px] tw-text-[0.65rem] tw-font-semibold tw-min-w-[20px] tw-text-center">{{ritualsCount}}</span>
            {{/if}}
        </span>
        <i class="fas fa-chevron-down tw-w-6 tw-h-6 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-bg-[var(--wh40k-btn-bg)] tw-inline-flex tw-items-center tw-justify-center tw-cursor-pointer"></i>
    </header>
    <div class="wh40k-panel-body">
        {{!-- Rituals List --}}
        <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)] tw-min-h-[60px]" data-drop-zone="powers" data-accepts="ritual">
            {{#each rituals as |ritual|}}
            <div class="tw-bg-[var(--wh40k-panel-bg-solid)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-border-l-[3px] tw-border-l-[#d97706] tw-rounded-md tw-overflow-hidden tw-transition-all tw-cursor-grab active:tw-cursor-grabbing hover:tw-bg-[var(--wh40k-panel-bg)] hover:tw-border-[var(--wh40k-border-color)] hover:tw-shadow-[0_2px_8px_var(--wh40k-shadow-soft)] item-drag" data-item-id="{{ritual.id}}" data-ritual-type="{{ritual.system.type}}" draggable="true">
                {{!-- Ritual Header --}}
                <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-bg-gradient-to-r tw-from-[rgba(0,0,0,0.05)] tw-to-transparent">
                    <img class="tw-w-9 tw-h-9 tw-rounded-[var(--wh40k-radius-md)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-object-cover tw-shrink-0" src="{{ritual.img}}" alt="{{ritual.name}}" />
                    <div class="tw-flex-1 tw-min-w-0">
                        <button type="button" class="tw-block tw-w-full tw-bg-transparent tw-border-none tw-p-0 tw-text-left tw-text-[0.95rem] tw-font-semibold tw-text-[color:var(--wh40k-text-dark)] tw-cursor-pointer tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis hover:tw-text-[color:var(--wh40k-accent-powers)]" data-action="itemEdit" data-item-id="{{ritual.id}}" title="Edit Ritual">
                            {{ritual.name}}
                        </button>
                        <div class="tw-flex tw-flex-wrap tw-gap-[6px] tw-mt-[2px]">
                            <span class="tw-inline-flex tw-items-center tw-gap-[3px] tw-px-[6px] tw-py-[2px] tw-rounded-[3px] tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.03em]
                                {{#if (eq ritual.system.type "prayer")}}tw-bg-[rgba(217,119,6,0.2)] tw-text-[#d97706]{{else if (eq ritual.system.type "rite")}}tw-bg-[rgba(124,58,237,0.2)] tw-text-[#7c3aed]{{else if (eq ritual.system.type "invocation")}}tw-bg-[rgba(220,38,38,0.2)] tw-text-[#dc2626]{{else if (eq ritual.system.type "ceremony")}}tw-bg-[rgba(2,132,199,0.2)] tw-text-[#0284c7]{{else if (eq ritual.system.type "tech-rite")}}tw-bg-[rgba(100,116,139,0.2)] tw-text-[#64748b]{{else}}tw-bg-[rgba(0,0,0,0.1)] tw-text-[color:var(--wh40k-text-muted)]{{/if}}">
                                {{#if (eq ritual.system.type "prayer")}}
                                <i class="fas fa-praying-hands tw-text-[0.65rem]"></i>
                                {{else if (eq ritual.system.type "rite")}}
                                <i class="fas fa-book-dead tw-text-[0.65rem]"></i>
                                {{else if (eq ritual.system.type "invocation")}}
                                <i class="fas fa-hand-sparkles tw-text-[0.65rem]"></i>
                                {{else if (eq ritual.system.type "ceremony")}}
                                <i class="fas fa-church tw-text-[0.65rem]"></i>
                                {{else if (eq ritual.system.type "tech-rite")}}
                                <i class="fas fa-cog tw-text-[0.65rem]"></i>
                                {{else}}
                                <i class="fas fa-scroll tw-text-[0.65rem]"></i>
                                {{/if}}
                                {{ritual.system.typeLabel}}
                            </span>
                        </div>
                    </div>
                    <div class="tw-flex tw-gap-[2px] tw-shrink-0">
                        <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-[30px] tw-h-[30px] tw-border tw-border-transparent tw-rounded tw-bg-transparent tw-text-[color:var(--wh40k-text-muted)] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-panel-bg-translucent)] hover:tw-border-[var(--wh40k-border-color-light)] hover:tw-text-[color:var(--wh40k-accent-powers)]" data-action="rollRitual" data-item-id="{{ritual.id}}" title="Perform Ritual">
                            <i class="fas fa-dice-d20"></i>
                        </button>
                        <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-[30px] tw-h-[30px] tw-border tw-border-transparent tw-rounded tw-bg-transparent tw-text-[color:var(--wh40k-text-muted)] tw-cursor-pointer tw-transition-all hover:tw-bg-[rgba(59,130,246,0.15)] hover:tw-border-[rgba(59,130,246,0.3)] hover:tw-text-[#3b82f6]" data-action="vocalizeRitual" data-item-id="{{ritual.id}}" title="Post to Chat">
                            <i class="fas fa-comment"></i>
                        </button>
                        <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-[30px] tw-h-[30px] tw-border tw-border-transparent tw-rounded tw-bg-transparent tw-text-[color:var(--wh40k-text-muted)] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-panel-bg-translucent)] hover:tw-border-[var(--wh40k-border-color-light)] hover:tw-text-[color:var(--wh40k-text-dark)]" data-action="togglePowerDetails" data-item-id="{{ritual.id}}" title="Toggle Details">
                            <i class="fas fa-chevron-down"></i>
                        </button>
                    </div>
                </div>

                {{!-- Ritual Stats Row --}}
                <div class="tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-xs)] tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color-light)]">
                    <div class="tw-flex tw-flex-col tw-gap-[1px] tw-min-w-[80px]">
                        <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">Test</span>
                        <span class="tw-text-[0.8rem] tw-font-medium tw-text-[color:var(--wh40k-text-dark)]">{{ritual.system.testLabel}}</span>
                    </div>
                    <div class="tw-flex tw-flex-col tw-gap-[1px] tw-min-w-[80px]">
                        <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">Action</span>
                        <span class="tw-text-[0.8rem] tw-font-medium tw-text-[color:var(--wh40k-text-dark)]">{{ritual.system.activationLabel}}</span>
                    </div>
                    {{#if ritual.system.test.threshold}}
                    <div class="tw-flex tw-flex-col tw-gap-[1px] tw-min-w-[80px]">
                        <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">Threshold</span>
                        <span class="tw-text-[0.8rem] tw-font-medium tw-text-[color:var(--wh40k-text-dark)]">{{ritual.system.test.threshold}} DoS</span>
                    </div>
                    {{/if}}
                </div>

                {{!-- Expandable Details --}}
                <div class="tw-p-[var(--wh40k-space-md)] tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color-light)]" data-power-id="{{ritual.id}}" hidden>
                    {{#if ritual.system.requirements}}
                    <div class="tw-mb-[var(--wh40k-space-md)]">
                        <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1"><i class="fas fa-list-check tw-text-[0.7rem]"></i> Requirements</span>
                        <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.requirements}}}</div>
                    </div>
                    {{/if}}
                    {{#if ritual.system.costs}}
                    <div class="tw-mb-[var(--wh40k-space-md)]">
                        <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1"><i class="fas fa-coins tw-text-[0.7rem]"></i> Costs</span>
                        <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.costs}}}</div>
                    </div>
                    {{/if}}
                    {{#if ritual.system.effect}}
                    <div class="tw-mb-[var(--wh40k-space-md)]">
                        <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#22c55e] tw-mb-1"><i class="fas fa-check-circle tw-text-[0.7rem]"></i> Effect</span>
                        <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.effect}}}</div>
                    </div>
                    {{/if}}
                    {{#if ritual.system.failure}}
                    <div class="tw-mb-[var(--wh40k-space-md)]">
                        <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#ef4444] tw-mb-1"><i class="fas fa-skull tw-text-[0.7rem]"></i> Failure</span>
                        <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.failure}}}</div>
                    </div>
                    {{/if}}
                    {{#if ritual.system.description}}
                    <div class="tw-mb-[var(--wh40k-space-md)]">
                        <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1">Description</span>
                        <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{ritual.system.description}}}</div>
                    </div>
                    {{/if}}
                    <div class="tw-flex tw-gap-[var(--wh40k-space-sm)] tw-mt-[var(--wh40k-space-md)] tw-pt-[var(--wh40k-space-sm)] tw-border-t tw-border-[var(--wh40k-border-color-light)]">
                        <button type="button" class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-px-3 tw-py-[6px] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-[var(--wh40k-radius-md)] tw-bg-[var(--wh40k-btn-bg)] tw-text-[color:var(--wh40k-text-secondary)] tw-text-[0.75rem] tw-font-semibold tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-btn-bg-hover)] hover:tw-border-[var(--wh40k-border-color-strong)]" data-action="itemEdit" data-item-id="{{ritual.id}}">
                            <i class="fas fa-cog"></i> Edit
                        </button>
                        <button type="button" class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-px-3 tw-py-[6px] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-[var(--wh40k-radius-md)] tw-bg-[var(--wh40k-btn-bg)] tw-text-[color:var(--wh40k-text-secondary)] tw-text-[0.75rem] tw-font-semibold tw-cursor-pointer tw-transition-all hover:tw-bg-[rgba(239,68,68,0.1)] hover:tw-border-[rgba(239,68,68,0.3)] hover:tw-text-[#ef4444]" data-action="itemDelete" data-item-id="{{ritual.id}}">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                </div>
            </div>
            {{else}}
            <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[var(--wh40k-space-xl)] tw-text-[color:var(--wh40k-text-muted)] tw-text-center">
                <i class="fas fa-pray tw-text-[2rem] tw-mb-[var(--wh40k-space-sm)] tw-opacity-40"></i>
                <p class="tw-m-0 tw-text-[0.9rem] tw-italic">No rituals known</p>
            </div>
            {{/each}}
        </div>

        {{!-- Add Ritual Dropzone --}}
        <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-m-2 tw-rounded tw-cursor-pointer tw-transition-all tw-border-2 tw-border-dashed tw-border-[var(--wh40k-border-color-light)] hover:tw-border-[var(--wh40k-accent-gold)] hover:tw-bg-[rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.05)] {{#if ritualsCount}}tw-flex-row tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-min-h-0{{else}}tw-flex-col tw-p-4 tw-min-h-[80px]{{/if}}" data-action="itemCreate" data-type="ritual">
            <i class="fas fa-plus {{#if ritualsCount}}tw-text-[0.9rem]{{else}}tw-text-[2rem]{{/if}} tw-text-[color:var(--wh40k-text-muted)] tw-transition-all hover:tw-text-[color:var(--wh40k-accent-gold)]"></i>
            <span class="tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.05em] tw-text-center {{#if ritualsCount}}tw-text-[0.7rem]{{else}}tw-text-[0.75rem]{{/if}}">{{#if ritualsCount}}Drop or click to add{{else}}Drop Ritual or Click to Create{{/if}}</span>
        </div>
    </div>
</div>
