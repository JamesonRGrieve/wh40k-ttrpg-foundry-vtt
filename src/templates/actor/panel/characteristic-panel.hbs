{{!-- Compact Characteristics Panel - Expandable Rows --}}
<div class="wh40k-panel wh40k-char-panel">
    <h1 class="wh40k-panel-header">
        Characteristics
        <button type="button" 
                class="wh40k-char-setup-btn" 
                data-action="openCharacteristicSetup"
                title="{{localize 'WH40K.CharacteristicSetup.OpenSetup'}}">
            <i class="fa-solid fa-sliders"></i>
        </button>
    </h1>
    <div class="wh40k-char-list">
        {{#each actor.characteristics as |characteristic name|}}
            {{!-- Filter out Influence (Inf) - not a real RT characteristic --}}
            {{#unless (eq name "influence")}}
            <details class="wh40k-char-item">
                <summary class="wh40k-char-summary {{#if (gt this.originPathModifier 0)}}wh40k-char-bonus{{/if}}{{#if (lt this.originPathModifier 0)}}wh40k-char-penalty{{/if}}">
                    <span
                        class="wh40k-char-name roll-characteristic actor-drag"
                        data-item-type="characteristic"
                        data-item-id="{{name}}"
                        data-characteristic="{{name}}"
                        data-tooltip
                        aria-label="{{this.label}}: {{this.total}}"
                        data-wh40k-tooltip="characteristic"
                        data-wh40k-tooltip-data="{{this.tooltipData}}"
                    >{{this.short}}</span>
                    <button 
                        type="button" 
                        class="wh40k-stat-breakdown-btn"
                        data-action="showStatBreakdown"
                        data-stat-key="{{name}}"
                        title="Show stat breakdown">
                        <i class="fa-solid fa-calculator"></i>
                    </button>
                    <span class="wh40k-char-total" title="Current total">{{this.total}}</span>
                </summary>
                <div class="wh40k-char-controls">
                    {{#if @root.editable}}
                    <label class="wh40k-char-field">
                        <span class="wh40k-char-field-label">Base</span>
                        <input
                            type="number"
                            class="wh40k-char-direct-input"
                            data-action="editCharacteristicField"
                            data-characteristic="{{name}}"
                            data-field="base"
                            data-dtype="Number"
                            value="{{this.base}}"
                            min="0"
                            max="100"
                            title="Base characteristic value (from character creation)"
                        />
                    </label>
                    {{else}}
                    <label class="wh40k-char-field">
                        <span class="wh40k-char-field-label">Base</span>
                        <span class="wh40k-char-field-value">{{this.base}}</span>
                    </label>
                    {{/if}}
                    <label class="wh40k-char-field">
                        <span class="wh40k-char-field-label">Advances</span>
                        <select class="wh40k-char-direct-input"
                            data-action="editCharacteristicField"
                            data-characteristic="{{name}}"
                            data-field="advance"
                            data-dtype="Number"
                            title="Characteristic advancement level">
                            {{option "0" this.advance "None (+0)"}}
                            {{option "1" this.advance "Simple (+5)"}}
                            {{option "2" this.advance "Intermediate (+10)"}}
                            {{option "3" this.advance "Trained (+15)"}}
                            {{option "4" this.advance "Proficient (+20)"}}
                            {{option "5" this.advance "Expert (+25)"}}
                        </select>
                    </label>
                    {{#if @root.editable}}
                    <label class="wh40k-char-field">
                        <span class="wh40k-char-field-label">Unnatural</span>
                        <select class="wh40k-char-direct-input"
                            data-action="editCharacteristicField"
                            data-characteristic="{{name}}"
                            data-field="unnatural"
                            data-dtype="Number"
                            title="Unnatural characteristic multiplier">
                            <option value="0" {{#if (eq this.unnatural 0)}}selected{{/if}}>None</option>
                            <option value="2" {{#if (eq this.unnatural 2)}}selected{{/if}}>×2</option>
                            <option value="3" {{#if (eq this.unnatural 3)}}selected{{/if}}>×3</option>
                            <option value="4" {{#if (eq this.unnatural 4)}}selected{{/if}}>×4</option>
                        </select>
                    </label>
                    {{/if}}
                    <label class="wh40k-char-field">
                        <span class="wh40k-char-field-label">Modifier</span>
                        <input
                            type="number"
                            class="wh40k-char-direct-input"
                            data-action="editCharacteristicField"
                            data-characteristic="{{name}}"
                            data-field="modifier"
                            data-dtype="Number"
                            value="{{this.modifier}}"
                            min="-100"
                            max="100"
                            title="Additional bonus or penalty to this characteristic"
                        />
                    </label>
                </div>
            </details>
            {{/unless}}
        {{/each}}
    </div>
</div>
