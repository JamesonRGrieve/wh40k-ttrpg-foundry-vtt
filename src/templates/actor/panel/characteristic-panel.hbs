{{!-- Compact Characteristics Panel - Expandable Rows --}}
{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label=(localize "WH40K.CharacteristicSetup.Characteristics")
    bodyClass="!tw-p-0"
    headerActionIcon="fa-sliders"
    headerAction="openCharacteristicSetup"
    headerActionTitle=(localize "WH40K.CharacteristicSetup.OpenSetup")}}
    <div class="tw-flex tw-flex-col tw-gap-[6px] tw-p-[6px]">
        {{#each actor.characteristics as |characteristic name|}}
            {{!-- Influence appears as a characteristic only in DH2 RAW mode (per Dark Heresy 2e rules
                 it can be tested against for Requisition, social, and Investigation rolls). In
                 Homebrew mode and in non-DH2 systems it lives in the Overview > Resources panel as
                 an economy stat. --}}
            {{#unless (and (eq name "influence") (not @root.isRaw))}}
            <details class="tw-border tw-border-[rgba(74,55,40,0.15)] dh2e:hover:tw-border-bronze rt:hover:tw-border-accent-dynasty bc:hover:tw-border-crimson dw:hover:tw-border-bronze ow:hover:tw-border-brass im:hover:tw-border-crimson-light dh1e:hover:tw-border-gold-raw tw-rounded-md tw-bg-white/70 tw-overflow-hidden tw-transition-all hover:tw-border-[rgba(74,55,40,0.35)] hover:tw-shadow-[0_2px_6px_rgba(0,0,0,0.1)] {{#if (gt this.originPathModifier 0)}}tw-bg-[rgba(0,128,0,0.15)]{{/if}}{{#if (lt this.originPathModifier 0)}}tw-bg-[rgba(139,0,0,0.15)]{{/if}}">
                <summary class="tw-flex tw-items-center tw-justify-between tw-gap-[6px] tw-px-2 tw-py-[6px] tw-cursor-pointer tw-list-none tw-font-semibold tw-text-[#4a3728] hover:tw-bg-[rgba(74,55,40,0.05)] [&::-webkit-details-marker]:tw-hidden [&::marker]:tw-content-['']">
                    <span
                        class="tw-uppercase tw-tracking-[0.08em] tw-text-[#4a3728] bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"
                        data-item-type="characteristic"
                        data-item-id="{{name}}"
                        data-characteristic="{{name}}"
                        data-tooltip
                        aria-label="{{this.label}}: {{this.total}}"
                        data-wh40k-tooltip="characteristic"
                        data-wh40k-tooltip-data="{{this.tooltipData}}"
                    >{{this.short}}</span>
                    {{> systems/wh40k-rpg/templates/actor/partial/stat-breakdown-button.hbs
                        statKey=name}}
                    <span class="tw-text-[0.95em] tw-text-[#2a1a0a] tw-font-bold" title="Current total">{{this.total}}</span>
                </summary>
                <div class="tw-grid tw-grid-cols-1 tw-gap-[6px] tw-px-2 tw-pt-[6px] tw-pb-2 tw-border-t tw-border-[rgba(74,55,40,0.1)] tw-bg-white/90">
                    {{#if @root.editable}}
                    <label class="tw-grid tw-grid-cols-1 tw-gap-[2px] tw-text-[0.75em] tw-uppercase tw-tracking-[0.06em] tw-text-[#4a3728]">
                        <span>Base</span>
                        <input
                            type="number"
                            class="tw-border tw-border-[rgba(74,55,40,0.2)] tw-rounded tw-px-[6px] tw-py-1 tw-bg-white/90 tw-text-[0.9em] tw-text-center focus:tw-outline-none focus:tw-border-[rgba(74,55,40,0.4)]"
                            data-action="editCharacteristicField"
                            data-characteristic="{{name}}"
                            data-field="base"
                            data-dtype="Number"
                            value="{{this.base}}"
                            min="0"
                            max="100"
                            title="Base characteristic value (from character creation)"
                        />
                    </label>
                    {{else}}
                    <label class="tw-grid tw-grid-cols-1 tw-gap-[2px] tw-text-[0.75em] tw-uppercase tw-tracking-[0.06em] tw-text-[#4a3728]">
                        <span>Base</span>
                        <span class="tw-text-[0.9em]">{{this.base}}</span>
                    </label>
                    {{/if}}
                    <label class="tw-grid tw-grid-cols-1 tw-gap-[2px] tw-text-[0.75em] tw-uppercase tw-tracking-[0.06em] tw-text-[#4a3728]">
                        <span>Advances</span>
                        <select class="tw-border tw-border-[rgba(74,55,40,0.2)] tw-rounded tw-px-[6px] tw-py-1 tw-bg-white/90 tw-text-[0.9em] focus:tw-outline-none focus:tw-border-[rgba(74,55,40,0.4)]"
                            data-action="editCharacteristicField"
                            data-characteristic="{{name}}"
                            data-field="advance"
                            data-dtype="Number"
                            title="Characteristic advancement level">
                            {{option "0" this.advance "None (+0)"}}
                            {{option "1" this.advance "Simple (+5)"}}
                            {{option "2" this.advance "Intermediate (+10)"}}
                            {{option "3" this.advance "Trained (+15)"}}
                            {{option "4" this.advance "Proficient (+20)"}}
                            {{option "5" this.advance "Expert (+25)"}}
                        </select>
                    </label>
                    {{#if @root.editable}}
                    <label class="tw-grid tw-grid-cols-1 tw-gap-[2px] tw-text-[0.75em] tw-uppercase tw-tracking-[0.06em] tw-text-[#4a3728]">
                        <span>Unnatural</span>
                        <select class="tw-border tw-border-[rgba(74,55,40,0.2)] tw-rounded tw-px-[6px] tw-py-1 tw-bg-white/90 tw-text-[0.9em] focus:tw-outline-none focus:tw-border-[rgba(74,55,40,0.4)]"
                            data-action="editCharacteristicField"
                            data-characteristic="{{name}}"
                            data-field="unnatural"
                            data-dtype="Number"
                            title="Unnatural characteristic multiplier">
                            <option value="0" {{#if (eq this.unnatural 0)}}selected{{/if}}>None</option>
                            <option value="2" {{#if (eq this.unnatural 2)}}selected{{/if}}>×2</option>
                            <option value="3" {{#if (eq this.unnatural 3)}}selected{{/if}}>×3</option>
                            <option value="4" {{#if (eq this.unnatural 4)}}selected{{/if}}>×4</option>
                        </select>
                    </label>
                    {{/if}}
                    <label class="tw-grid tw-grid-cols-1 tw-gap-[2px] tw-text-[0.75em] tw-uppercase tw-tracking-[0.06em] tw-text-[#4a3728]">
                        <span>Modifier</span>
                        <input
                            type="number"
                            class="tw-border tw-border-[rgba(74,55,40,0.2)] tw-rounded tw-px-[6px] tw-py-1 tw-bg-white/90 tw-text-[0.9em] tw-text-center focus:tw-outline-none focus:tw-border-[rgba(74,55,40,0.4)]"
                            data-action="editCharacteristicField"
                            data-characteristic="{{name}}"
                            data-field="modifier"
                            data-dtype="Number"
                            value="{{this.modifier}}"
                            min="-100"
                            max="100"
                            title="Additional bonus or penalty to this characteristic"
                        />
                    </label>
                </div>
            </details>
            {{/unless}}
        {{/each}}
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
