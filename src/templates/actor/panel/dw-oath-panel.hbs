{{!--
    Deathwatch Mission Oath panel (#168 — core.md Table 7-16 §"OATHS").

    Surfaces the squad-level Mission Oath state on the kill-team
    leader's character sheet:

      - current Oath label (or "no Oath sworn") readout
      - "Swear Oath" button — gated on `canSwear` (leader + no active oath)
      - "Release Oath" button — gated on `canRelease` (active oath present)

    Sheet context (built by character-sheet `_prepareContext`):

      oathPanel: {
        isLeader:     boolean
        active:       boolean         // isOathActive(activeOathId)
        activeOathId: string | null
        activeLabel:  string | null   // uuidNameCache.getName(activeOathId) when active
        canSwear:     boolean         // isLeader && !active
        canRelease:   boolean         // active (regardless of leader — covers death/GM fiat)
      }

    Rendered only for DW actors; the include in tab-status.hbs gates on
    `isDW` from context.
--}}
{{#> systems/wh40k-rpg/templates/actor/partial/system-card.hbs rootClass="wh40k-dw-oath-panel" accentBorderClass="dw:tw-border-bronze" accentIconClass="dw:tw-text-bronze" icon="fa-scroll" label=(localize "WH40K.DW.Oath.Label") rootAttrs=(safeAttrs "data-dw-oath-active" oathPanel.active "data-dw-oath-id" oathPanel.activeOathId) hasRightSlot=true}}
    {{!-- Header right slot: current oath readout --}}
    {{#*inline "rightSlot"}}
        <span class="wh40k-dw-oath-current tw-font-bold tw-text-[0.9rem] tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze">
            {{#if oathPanel.active}}
                {{oathPanel.activeLabel}}
            {{else}}
                <em class="tw-text-[color:var(--wh40k-text-muted)] tw-not-italic">&mdash;</em>
            {{/if}}
        </span>
    {{/inline}}

    {{#if oathPanel.active}}
        <div class="wh40k-dw-oath-sworn tw-px-2 tw-py-1 tw-text-[0.75rem] tw-italic tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] tw-rounded">
            <i class="fas fa-check"></i>
            {{localize "WH40K.DW.Oath.Sworn"}}
        </div>
    {{else}}
        {{#unless oathPanel.isLeader}}
            <div class="wh40k-dw-oath-not-leader tw-px-2 tw-py-1 tw-text-[0.72rem] tw-italic tw-text-[color:var(--wh40k-text-muted)] tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] tw-rounded">
                <i class="fas fa-circle-info"></i>
                {{localize "WH40K.DW.Oath.Validation.NotLeader"}}
            </div>
        {{/unless}}
    {{/if}}

    {{!-- Action affordances --}}
    <div class="wh40k-dw-oath-actions tw-flex tw-flex-wrap tw-gap-1.5">
        <button type="button"
                class="wh40k-dw-oath-swear-btn tw-inline-flex tw-items-center tw-justify-center tw-bg-transparent tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dw:tw-border-bronze tw-rounded tw-px-2 tw-py-0.5 tw-cursor-pointer tw-text-[0.72rem] tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze hover:tw-bg-[color:var(--wh40k-border-color-light)] hover:tw-text-white disabled:tw-cursor-not-allowed disabled:tw-opacity-50"
                data-action="dwSwearOath"
                title="{{localize 'WH40K.DW.Oath.Label'}}"
                {{#unless oathPanel.canSwear}}disabled aria-disabled="true"{{/unless}}>
            <i class="fas fa-hand-fist tw-mr-1"></i>
            {{localize "WH40K.DW.Oath.Sworn"}}
        </button>
        <button type="button"
                class="wh40k-dw-oath-release-btn tw-inline-flex tw-items-center tw-justify-center tw-bg-transparent tw-border tw-border-solid tw-border-crimson tw-rounded tw-px-2 tw-py-0.5 tw-cursor-pointer tw-text-[0.72rem] tw-text-crimson hover:tw-bg-crimson hover:tw-text-white disabled:tw-cursor-not-allowed disabled:tw-opacity-50"
                data-action="dwReleaseOath"
                title="{{localize 'WH40K.DW.Oath.Released'}}"
                {{#unless oathPanel.canRelease}}disabled aria-disabled="true"{{/unless}}>
            <i class="fas fa-xmark tw-mr-1"></i>
            {{localize "WH40K.DW.Oath.Released"}}
        </button>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/system-card.hbs}}
