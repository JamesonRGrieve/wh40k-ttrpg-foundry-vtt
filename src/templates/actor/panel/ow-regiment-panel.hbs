{{!--
    Only War · Regiment Creation panel (#151).

    Passive readout of the 12-point Regiment Creation budget and the
    30-point Standard Kit budget, plus the "Edit Regiment" button that
    opens the RegimentBuilderDialog.

    Context (built by the OW character sheet's _prepareContext, gated
    on `gameSystem === 'ow'`):

        regimentPanel: {
            regiment: {
                spent:       number   // total spent across six categories
                remaining:   number   // 12 − spent (negative if over)
                valid:       boolean  // spent === 12
                budget:      number   // REGIMENT_BUDGET (12)
                perCategory: { homeWorld, commandingOfficer, regimentType,
                               trainingDoctrine, specialEquipmentDoctrine,
                               favouredWeapons } — each a number
            }
            kit: {
                spent:       number
                remaining:   number
                valid:       boolean
                budget:      number   // STANDARD_KIT_BUDGET + kitModifier
            }
        }

    The panel renders nothing actor-mutating itself; "Edit Regiment"
    opens the RegimentBuilderDialog where the live editor lives.
--}}
{{#> systems/wh40k-rpg/templates/actor/partial/system-card.hbs rootClass="wh40k-ow-regiment-panel" accentBorderClass="ow:tw-border-brass-l20" accentIconClass="ow:tw-text-brass-l20" icon="fa-shield-halved" label=(localize "WH40K.OW.Regiment.Label") rootAttrs=(safeAttrs "data-ow-regiment-spent" regimentPanel.regiment.spent "data-ow-regiment-valid" (iff regimentPanel.regiment.valid "1" "0")) hasRightSlot=true}}
    {{!-- Header right slot: edit button --}}
    {{#*inline "rightSlot"}}
        <button type="button"
                class="wh40k-ow-regiment-edit-btn tw-inline-flex tw-items-center tw-gap-1 tw-bg-transparent tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] tw-rounded tw-px-2 tw-py-0.5 tw-cursor-pointer tw-text-[0.72rem] tw-text-[color:var(--wh40k-text-bright)] hover:tw-bg-[rgba(255,255,255,0.05)]"
                data-action="owRegimentEdit"
                title="{{localize 'WH40K.OW.Regiment.EditButtonTitle'}}">
            <i class="fas fa-pen"></i>
            {{localize "WH40K.OW.Regiment.EditButton"}}
        </button>
    {{/inline}}

    {{!-- 12-point Regiment budget readout --}}
    <div class="wh40k-ow-regiment-budget tw-flex tw-items-center tw-justify-between tw-px-2 tw-py-1 tw-rounded tw-bg-[rgba(0,0,0,0.18)]">
        <span class="tw-text-[0.72rem] tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--wh40k-text-muted)]">
            {{localize "WH40K.OW.Regiment.Budget.Total"}}
        </span>
        <span class="wh40k-ow-regiment-budget-readout tw-text-[0.78rem] tw-font-semibold tw-text-[color:var(--wh40k-text-bright)]"
              data-budget-spent="{{regimentPanel.regiment.spent}}"
              data-budget-total="{{regimentPanel.regiment.budget}}">
            {{regimentPanel.regiment.spent}} / {{regimentPanel.regiment.budget}}
        </span>
        {{#if regimentPanel.regiment.valid}}
            <span class="wh40k-ow-regiment-valid tw-text-[0.7rem] tw-italic tw-text-emerald-400">
                <i class="fas fa-check"></i>
            </span>
        {{else}}
            {{#if (lt regimentPanel.regiment.remaining 0)}}
                <span class="wh40k-ow-regiment-over tw-text-[0.7rem] tw-italic tw-text-red-400"
                      data-over-by="{{regimentPanel.regiment.remaining}}">
                    {{localize "WH40K.OW.Regiment.Budget.OverBudget" amount=regimentPanel.regiment.remaining}}
                </span>
            {{else}}
                <span class="wh40k-ow-regiment-remaining tw-text-[0.7rem] tw-italic tw-text-[color:var(--wh40k-text-muted)]">
                    {{regimentPanel.regiment.remaining}} {{localize "WH40K.OW.Regiment.Budget.Remaining"}}
                </span>
            {{/if}}
        {{/if}}
    </div>

    {{!-- Per-category breakdown --}}
    <div class="wh40k-ow-regiment-categories tw-grid tw-grid-cols-2 tw-gap-1">
        <div class="wh40k-ow-regiment-category tw-flex tw-items-center tw-justify-between tw-px-2 tw-py-0.5 tw-rounded tw-bg-[rgba(0,0,0,0.12)]" data-category="homeWorld">
            <span class="tw-text-[0.7rem] tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.OW.Regiment.Category.HomeWorld"}}</span>
            <span class="wh40k-ow-regiment-category-cost tw-text-[0.75rem] tw-font-bold tw-text-[color:var(--wh40k-text-bright)]">{{regimentPanel.regiment.perCategory.homeWorld}}</span>
        </div>
        <div class="wh40k-ow-regiment-category tw-flex tw-items-center tw-justify-between tw-px-2 tw-py-0.5 tw-rounded tw-bg-[rgba(0,0,0,0.12)]" data-category="commandingOfficer">
            <span class="tw-text-[0.7rem] tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.OW.Regiment.Category.CommandingOfficer"}}</span>
            <span class="wh40k-ow-regiment-category-cost tw-text-[0.75rem] tw-font-bold tw-text-[color:var(--wh40k-text-bright)]">{{regimentPanel.regiment.perCategory.commandingOfficer}}</span>
        </div>
        <div class="wh40k-ow-regiment-category tw-flex tw-items-center tw-justify-between tw-px-2 tw-py-0.5 tw-rounded tw-bg-[rgba(0,0,0,0.12)]" data-category="regimentType">
            <span class="tw-text-[0.7rem] tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.OW.Regiment.Category.RegimentType"}}</span>
            <span class="wh40k-ow-regiment-category-cost tw-text-[0.75rem] tw-font-bold tw-text-[color:var(--wh40k-text-bright)]">{{regimentPanel.regiment.perCategory.regimentType}}</span>
        </div>
        <div class="wh40k-ow-regiment-category tw-flex tw-items-center tw-justify-between tw-px-2 tw-py-0.5 tw-rounded tw-bg-[rgba(0,0,0,0.12)]" data-category="trainingDoctrine">
            <span class="tw-text-[0.7rem] tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.OW.Regiment.Category.TrainingDoctrine"}}</span>
            <span class="wh40k-ow-regiment-category-cost tw-text-[0.75rem] tw-font-bold tw-text-[color:var(--wh40k-text-bright)]">{{regimentPanel.regiment.perCategory.trainingDoctrine}}</span>
        </div>
        <div class="wh40k-ow-regiment-category tw-flex tw-items-center tw-justify-between tw-px-2 tw-py-0.5 tw-rounded tw-bg-[rgba(0,0,0,0.12)]" data-category="specialEquipmentDoctrine">
            <span class="tw-text-[0.7rem] tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.OW.Regiment.Category.SpecialEquipmentDoctrine"}}</span>
            <span class="wh40k-ow-regiment-category-cost tw-text-[0.75rem] tw-font-bold tw-text-[color:var(--wh40k-text-bright)]">{{regimentPanel.regiment.perCategory.specialEquipmentDoctrine}}</span>
        </div>
        <div class="wh40k-ow-regiment-category tw-flex tw-items-center tw-justify-between tw-px-2 tw-py-0.5 tw-rounded tw-bg-[rgba(0,0,0,0.12)]" data-category="favouredWeapons">
            <span class="tw-text-[0.7rem] tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.OW.Regiment.Category.FavouredWeapons"}}</span>
            <span class="wh40k-ow-regiment-category-cost tw-text-[0.75rem] tw-font-bold tw-text-[color:var(--wh40k-text-bright)]">{{regimentPanel.regiment.perCategory.favouredWeapons}}</span>
        </div>
    </div>

    {{!-- 30-point Standard Kit budget readout --}}
    <div class="wh40k-ow-regiment-kit-budget tw-flex tw-items-center tw-justify-between tw-px-2 tw-py-1 tw-rounded tw-bg-[rgba(0,0,0,0.18)]">
        <span class="tw-text-[0.72rem] tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--wh40k-text-muted)]">
            {{localize "WH40K.OW.Regiment.Kit.Total"}}
        </span>
        <span class="wh40k-ow-regiment-kit-readout tw-text-[0.78rem] tw-font-semibold tw-text-[color:var(--wh40k-text-bright)]"
              data-kit-spent="{{regimentPanel.kit.spent}}"
              data-kit-total="{{regimentPanel.kit.budget}}">
            {{regimentPanel.kit.spent}} / {{regimentPanel.kit.budget}}
        </span>
        {{#if regimentPanel.kit.valid}}
            <span class="wh40k-ow-regiment-kit-ok tw-text-[0.7rem] tw-italic tw-text-[color:var(--wh40k-text-muted)]">
                {{regimentPanel.kit.remaining}} {{localize "WH40K.OW.Regiment.Kit.Remaining"}}
            </span>
        {{else}}
            <span class="wh40k-ow-regiment-kit-over tw-text-[0.7rem] tw-italic tw-text-red-400"
                  data-over-by="{{regimentPanel.kit.remaining}}">
                {{localize "WH40K.OW.Regiment.Kit.OverBudget" amount=regimentPanel.kit.remaining}}
            </span>
        {{/if}}
    </div>
{{/system-card}}
