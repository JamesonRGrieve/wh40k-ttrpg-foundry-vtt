<div class="wh40k-skills-panel tw-p-2">
    {{!-- Trained / Basic Skills (2 columns) --}}
    <div class="wh40k-skills-columns tw-grid tw-grid-cols-2 tw-gap-4 tw-relative">
        <!-- Left Column -->
        <div class="wh40k-skills-column tw-flex tw-flex-col tw-gap-0.75">
            {{#each skillLists.standardColumns.[0] as |entry|}}
                {{> systems/wh40k-rpg/templates/actor/partial/skill-row.hbs entry=entry}}
            {{/each}}
        </div>
        <!-- Right Column -->
        <div class="wh40k-skills-column tw-flex tw-flex-col tw-gap-0.75">
            {{#each skillLists.standardColumns.[1] as |entry|}}
                {{> systems/wh40k-rpg/templates/actor/partial/skill-row.hbs entry=entry}}
            {{/each}}
        </div>
    </div>

    {{!-- Untrained Advanced Skills (4 columns, compact) --}}
    {{#if skillLists.advancedUntrained.length}}
    <div class="wh40k-advanced-untrained-section">
        <h4 class="wh40k-section-divider tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">Advanced Skills (Untrained)</h4>
        <div class="tw-grid tw-grid-cols-4 tw-gap-0.5">
            {{#each skillLists.advancedUntrained as |entry|}}
            <div class="wh40k-skill-row wh40k-skill-row--advanced wh40k-skill-row--compact tw-grid tw-grid-cols-skill-row-compact tw-gap-1 tw-items-center tw-py-0.5 tw-px-1.5" data-skill="{{entry.[0]}}" data-skill-name="{{entry.[1].label}}" data-characteristic="{{entry.[1].characteristic}}" data-training-level="0">
                <div class="wh40k-skill-info tw-flex tw-items-center tw-gap-1">
                    <button type="button" class="wh40k-skill-name"
                            data-action="viewSkillInfo" data-skill="{{entry.[0]}}"
                            title="{{entry.[1].label}} (untrained)">
                        <span class="wh40k-skill-label">{{entry.[1].label}} <span class="wh40k-skill-char">({{entry.[1].charShort}})</span></span>
                    </button>
                </div>
                <div class="wh40k-skill-total tw-inline-flex tw-items-center tw-justify-center" title="Half characteristic (untrained)">
                    <span>{{entry.[1].current}}</span>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
    {{/if}}
</div>
