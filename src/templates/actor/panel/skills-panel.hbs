<div class="tw-p-2 tw-font-alt">
    {{!-- Trained / Basic Skills (2 columns) --}}
    <div class="tw-grid tw-grid-cols-2 tw-gap-4 tw-relative">
        <!-- Left Column -->
        <div class="tw-flex tw-flex-col tw-gap-0.75">
            {{#each skillLists.standardColumns.[0] as |entry|}}
                {{> systems/wh40k-rpg/templates/actor/partial/skill-row.hbs entry=entry}}
            {{/each}}
        </div>
        <!-- Right Column -->
        <div class="tw-flex tw-flex-col tw-gap-0.75">
            {{#each skillLists.standardColumns.[1] as |entry|}}
                {{> systems/wh40k-rpg/templates/actor/partial/skill-row.hbs entry=entry}}
            {{/each}}
        </div>
    </div>

    {{!-- DH2e has no separate "Advanced Skills" tier; advancedUntrained is now empty and
         every standard skill renders in the two-column grid above. See issue #2. --}}
</div>
