{{!--
    Shock panel (DH2 — #66).

    Rendered as a compact vital ROW (the same `vital-pip-row` chrome Fatigue
    uses), so Shock sits immediately under Fatigue inside the Vitals card and
    reads as one of the vital rows rather than a separate panel. Shock has no
    derived max (it is an open accumulator), so it shows a value readout +
    GM −/+ steppers instead of a pip strip, plus the "Snap Out of It" action.

    Surfaces `system.shock.{value,max}`. The brain button dispatches the
    `snapOutOfShock` action on CharacterSheet (Willpower test, Challenging +0;
    success → `actor.applyShock(-1)`, narrated via shock-snap-chat). The −/+
    steppers reuse the standard increment/decrement StatActions.

    Render gate (parent template): only DH2 actors include this row —
    `actor._gameSystemId === 'dh2'`. The `wh40k-shock-panel` row class and the
    `wh40k-shock-value` / `wh40k-shock-snap-btn` selectors are pinned for the
    e2e spec (`tests/e2e/shock-panel.spec.ts`).
--}}
{{#> systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs
        icon="fa-bolt" label=(localize "WH40K.Shock.Header") rowClass="wh40k-shock-panel"}}
    <div class="tw-flex tw-items-center tw-gap-1.5 tw-ml-auto" data-shock-value="{{system.shock.value}}">
        <span class="wh40k-shock-value tw-text-[1.1rem] tw-font-bold tw-font-alt tw-text-[color:var(--color-text-primary)] tw-min-w-[20px] tw-text-center">{{system.shock.value}}</span>
        {{#if (gt system.shock.max 0)}}
        <span class="tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)]">/&nbsp;<span class="wh40k-shock-max">{{system.shock.max}}</span></span>
        {{/if}}
        <button type="button"
                class="wh40k-shock-stepper-minus tw-w-[18px] tw-h-[18px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[0.7rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-text-medium)]"
                data-action="decrement"
                data-field="system.shock.value"
                data-min="0"
                title="{{localize 'WH40K.Shock.Value'}} −1">
            <i class="fas fa-minus"></i>
        </button>
        <button type="button"
                class="wh40k-shock-stepper-plus tw-w-[18px] tw-h-[18px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[0.7rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-text-medium)]"
                data-action="increment"
                data-field="system.shock.value"
                title="{{localize 'WH40K.Shock.Value'}} +1">
            <i class="fas fa-plus"></i>
        </button>
        <button type="button"
                class="wh40k-shock-snap-btn tw-w-[18px] tw-h-[18px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[0.7rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-text-bright)] disabled:tw-opacity-40 disabled:tw-cursor-not-allowed"
                data-action="snapOutOfShock"
                title="{{localize 'WH40K.Shock.SnapOutTooltip'}}"
                {{#if (lte system.shock.value 0)}}disabled{{/if}}>
            <i class="fas fa-brain"></i>
        </button>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs}}
