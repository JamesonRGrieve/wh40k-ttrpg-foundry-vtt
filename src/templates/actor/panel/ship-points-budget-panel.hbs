{{!--
    SP-budget panel for the starship build (issue #190).

    Renders:
      • The hull's SP budget vs amount currently spent across owned components,
        weapons, and upgrades.
      • A list of essential component slots required by RAW Rogue Trader. Each
        slot shows whether it is filled, with empty REQUIRED slots highlighted.
      • The "Validate Build" action button — disabled when no validation is
        possible (no budget), otherwise dispatches `data-action="validateBuild"`.

    Context required:
        buildValidation.spent                 — number
        buildValidation.budget                — number
        buildValidation.isOverBudget          — boolean
        buildValidation.missingEssentialSlots — string[]
        buildValidation.isValid               — boolean
        essentialSlots                        — { id, label, filled }[]
--}}
{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label=(localize "WH40K.Starship.Build.Header")
    rootClass="tw-col-span-6 wh40k-ship-points-budget-panel"
    titleClass="tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"}}
    <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3" data-component="ship-points-budget">
        <div class="tw-flex tw-flex-row tw-items-center tw-justify-between tw-gap-3">
            <div class="tw-flex tw-flex-col">
                <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">{{localize "WH40K.Starship.Build.SpentLabel"}}</span>
                <span class="wh40k-ship-points-budget__spent tw-text-2xl tw-font-semibold {{#if buildValidation.isOverBudget}}tw-text-crimson{{else}}tw-text-success{{/if}}"
                      data-field="spent">{{buildValidation.spent}}</span>
            </div>
            <div class="tw-text-3xl tw-opacity-40">/</div>
            <div class="tw-flex tw-flex-col tw-items-end">
                <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">{{localize "WH40K.Starship.Build.BudgetLabel"}}</span>
                <span class="wh40k-ship-points-budget__budget tw-text-2xl tw-font-semibold" data-field="budget">{{buildValidation.budget}}</span>
            </div>
        </div>

        {{#if buildValidation.isOverBudget}}
            <div class="wh40k-ship-points-budget__over-budget tw-rounded tw-border tw-border-crimson tw-bg-crimson/10 tw-p-2 tw-text-sm tw-text-crimson"
                 data-state="over-budget" role="alert">
                {{localize "WH40K.Starship.Build.OverBudget"}}
            </div>
        {{/if}}

        <div class="tw-flex tw-flex-col tw-gap-1">
            <h4 class="tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-opacity-80">
                {{localize "WH40K.Starship.Build.EssentialSlots"}}
            </h4>
            <ul class="wh40k-ship-points-budget__slots tw-flex tw-flex-col tw-gap-0.5 tw-text-sm">
                {{#each essentialSlots as |slot|}}
                    <li class="wh40k-ship-points-budget__slot tw-flex tw-flex-row tw-items-center tw-justify-between tw-gap-2 tw-rounded tw-px-2 tw-py-1 {{#unless slot.filled}}wh40k-ship-points-budget__slot--missing tw-bg-crimson/10 tw-border tw-border-crimson{{/unless}}"
                        data-slot="{{slot.id}}" data-filled="{{slot.filled}}">
                        <span class="wh40k-ship-points-budget__slot-label">{{localize slot.labelKey}}</span>
                        {{#if slot.filled}}
                            <span class="wh40k-ship-points-budget__slot-status tw-text-success">{{localize "WH40K.Starship.Build.SlotFilled"}}</span>
                        {{else}}
                            <span class="wh40k-ship-points-budget__slot-status tw-text-crimson tw-font-semibold">{{localize "WH40K.Starship.Build.SlotMissing"}}</span>
                        {{/if}}
                    </li>
                {{/each}}
            </ul>
        </div>

        <div class="tw-flex tw-flex-row tw-items-center tw-justify-end tw-gap-2">
            <span class="wh40k-ship-points-budget__status tw-text-sm {{#if buildValidation.isValid}}tw-text-success{{else}}tw-text-crimson{{/if}}"
                  data-state="{{#if buildValidation.isValid}}valid{{else}}invalid{{/if}}">
                {{#if buildValidation.isValid}}
                    {{localize "WH40K.Starship.Build.Valid"}}
                {{else}}
                    {{localize "WH40K.Starship.Build.Invalid"}}
                {{/if}}
            </span>
            <button type="button"
                    class="wh40k-ship-points-budget__validate tw-rounded tw-border tw-border-gold tw-px-3 tw-py-1 tw-text-sm hover:tw-bg-gold/10 disabled:tw-cursor-not-allowed disabled:tw-opacity-50"
                    data-action="validateBuild"
                    {{#unless buildValidation.isValid}}data-commit-blocked="true"{{/unless}}>
                {{localize "WH40K.Starship.Build.Validate"}}
            </button>
            <button type="button"
                    class="wh40k-ship-points-budget__commit tw-rounded tw-border tw-border-gold tw-px-3 tw-py-1 tw-text-sm tw-bg-gold/20 hover:tw-bg-gold/40 disabled:tw-cursor-not-allowed disabled:tw-opacity-50"
                    data-action="commitBuild"
                    {{#unless buildValidation.isValid}}disabled aria-disabled="true"{{/unless}}>
                {{localize "WH40K.Starship.Build.Commit"}}
            </button>
        </div>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
