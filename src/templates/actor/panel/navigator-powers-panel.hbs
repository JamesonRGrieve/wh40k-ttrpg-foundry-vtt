{{!-- Navigator Powers Panel --}}
{{#> systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs panelId="navigator-powers" label="Navigator Powers" icon="fa-eye" count=navigatorPowersCount rootClass="wh40k-panel-powers wh40k-panel-navigator-powers" bodyClass="tw-p-0" titleClass="tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"}}
    {{!-- Powers List --}}
    <div class="tw-flex tw-flex-col tw-gap-2 tw-min-h-[60px] tw-p-[var(--wh40k-space-md)]" data-drop-zone="powers" data-accepts="navigatorPower">
        {{#each navigatorPowers as |power|}}
        {{#> systems/wh40k-rpg/templates/actor/partial/item-list-row.hbs
            item=power
            accentColor="#0891b2"
            dragType="navigatorPower"
            editTitle="Edit Power"
            pills=power.system.pills
            stats=(array
                (hash label="Test" value=power.system.testLabel)
                (hash label="Action" value=power.system.activationLabel))
            actions=(array
                (hash action="rollPower" icon="fa-dice-d20" title="Use Power" hoverClass="hover:tw-text-[color:var(--wh40k-accent-powers)]")
                (hash action="vocalizePower" icon="fa-comment" title="Post to Chat" hoverClass="hover:tw-bg-[rgba(59,130,246,0.15)] hover:tw-border-[rgba(59,130,246,0.3)] hover:tw-text-[#3b82f6]")
                (hash action="togglePowerDetails" icon="fa-chevron-down" title="Toggle Details" hoverClass="hover:tw-text-[color:var(--wh40k-text-dark)]"))
        }}
            {{#if power.system.levels.novice.effect}}
                {{> systems/wh40k-rpg/templates/actor/partial/labeled-rich-text-section.hbs label="Novice" icon="fa-seedling" labelClass="tw-text-[#22c55e]" content=power.system.levels.novice.effect}}
            {{/if}}
            {{#if power.system.levels.adept.effect}}
                {{> systems/wh40k-rpg/templates/actor/partial/labeled-rich-text-section.hbs label="Adept" icon="fa-star-half-alt" labelClass="tw-text-[#3b82f6]" content=power.system.levels.adept.effect}}
            {{/if}}
            {{#if power.system.levels.master.effect}}
                {{> systems/wh40k-rpg/templates/actor/partial/labeled-rich-text-section.hbs label="Master" icon="fa-crown" labelClass="tw-text-[#f59e0b]" content=power.system.levels.master.effect}}
            {{/if}}
            {{#if power.system.sideEffects}}
                {{> systems/wh40k-rpg/templates/actor/partial/labeled-rich-text-section.hbs label="Side Effects" icon="fa-exclamation-triangle" labelClass="tw-text-[#ef4444]" content=power.system.sideEffects}}
            {{/if}}
            {{#if power.system.description}}
                {{> systems/wh40k-rpg/templates/actor/partial/labeled-rich-text-section.hbs label="Description" content=power.system.description}}
            {{/if}}
        {{/systems/wh40k-rpg/templates/actor/partial/item-list-row.hbs}}
        {{else}}
        {{> systems/wh40k-rpg/templates/actor/partial/empty-state.hbs icon="fa-eye" text="No navigator powers" padding="md"}}
        {{/each}}
    </div>

    {{!-- Add Power Dropzone --}}
    {{> systems/wh40k-rpg/templates/actor/partial/dropzone.hbs type="navigatorPower" hasItems=navigatorPowersCount label="Drop Navigator Power or Click to Create" compactLabel="Drop or click to add"}}
{{/systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs}}
