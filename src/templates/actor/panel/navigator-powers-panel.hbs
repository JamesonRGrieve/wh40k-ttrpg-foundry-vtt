{{!-- Navigator Powers Panel V2 - Modern Card-based Design --}}
<div class="wh40k-panel">
    <header class="wh40k-panel-header" data-action="togglePanel" data-panel-id="navigator-powers">
        <span class="tw-flex-1 tw-font-[var(--wh40k-font-display,'Modesto_Condensed',serif)] tw-text-[var(--wh40k-text-h3,1.1rem)] tw-font-semibold tw-text-[color:var(--wh40k-text-dark)] tw-tracking-[0.02em] tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-min-w-0">
            <i class="fas fa-eye"></i>
            Navigator Powers
            {{#if navigatorPowersCount}}
            <span class="tw-bg-[rgba(0,0,0,0.2)] tw-text-[color:var(--wh40k-accent-powers)] tw-px-2 tw-py-px tw-rounded-[10px] tw-text-[0.75rem] tw-font-semibold">{{navigatorPowersCount}}</span>
            {{/if}}
        </span>
        <i class="fas fa-chevron-down tw-w-6 tw-h-6 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-bg-[var(--wh40k-btn-bg)] tw-inline-flex tw-items-center tw-justify-center tw-cursor-pointer"></i>
    </header>
    <div class="wh40k-panel-body">
        {{!-- Powers List --}}
        <div class="tw-flex tw-flex-col tw-gap-2 tw-min-h-[60px]" data-drop-zone="powers" data-accepts="navigatorPower">
            {{#each navigatorPowers as |power|}}
            <div class="tw-bg-[var(--wh40k-panel-bg-solid)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-border-l-[3px] tw-border-l-[#0891b2] tw-rounded-md tw-overflow-hidden tw-transition-all tw-cursor-grab active:tw-cursor-grabbing hover:tw-bg-[var(--wh40k-panel-bg)] hover:tw-border-[var(--wh40k-border-color)] hover:tw-shadow-[0_2px_8px_var(--wh40k-shadow-soft)] item-drag" data-item-id="{{power.id}}" draggable="true">
                {{!-- Power Header --}}
                <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(0,0,0,0.05)] tw-to-transparent">
                    <img class="tw-w-9 tw-h-9 tw-rounded tw-border tw-border-[var(--wh40k-border-color-light)] tw-object-cover tw-shrink-0" src="{{power.img}}" alt="{{power.name}}" />
                    <div class="tw-flex-1 tw-min-w-0">
                        <button type="button" class="tw-block tw-w-full tw-bg-transparent tw-border-none tw-p-0 tw-text-left tw-text-[0.95rem] tw-font-semibold tw-text-[color:var(--wh40k-text-dark)] tw-cursor-pointer tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis hover:tw-text-[color:var(--wh40k-accent-powers)]" data-action="itemEdit" data-item-id="{{power.id}}" title="Edit Power">
                            {{power.name}}
                        </button>
                        <div class="tw-flex tw-flex-wrap tw-gap-[6px] tw-mt-[2px]">
                            <span class="tw-inline-flex tw-items-center tw-gap-[3px] tw-px-[6px] tw-py-[2px] tw-bg-[rgba(8,145,178,0.2)] tw-text-[#0891b2] tw-rounded-[3px] tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.03em]">
                                <i class="fas fa-eye tw-text-[0.65rem]"></i> Navigator
                            </span>
                        </div>
                    </div>
                    <div class="tw-flex tw-gap-[2px] tw-shrink-0">
                        <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-[30px] tw-h-[30px] tw-border tw-border-transparent tw-rounded tw-bg-transparent tw-text-[color:var(--wh40k-text-muted)] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-panel-bg-translucent)] hover:tw-border-[var(--wh40k-border-color-light)] hover:tw-text-[color:var(--wh40k-text-dark)] hover:tw-bg-[rgba(0,0,0,0.08)] hover:tw-border-[rgba(0,0,0,0.2)] hover:tw-text-[color:var(--wh40k-accent-powers)]" data-action="rollPower" data-item-id="{{power.id}}" title="Use Power">
                            <i class="fas fa-dice-d20"></i>
                        </button>
                        <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-[30px] tw-h-[30px] tw-border tw-border-transparent tw-rounded tw-bg-transparent tw-text-[color:var(--wh40k-text-muted)] tw-cursor-pointer tw-transition-all hover:tw-bg-[rgba(59,130,246,0.15)] hover:tw-border-[rgba(59,130,246,0.3)] hover:tw-text-[#3b82f6]" data-action="vocalizePower" data-item-id="{{power.id}}" title="Post to Chat">
                            <i class="fas fa-comment"></i>
                        </button>
                        <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-[30px] tw-h-[30px] tw-border tw-border-transparent tw-rounded tw-bg-transparent tw-text-[color:var(--wh40k-text-muted)] tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-panel-bg-translucent)] hover:tw-border-[var(--wh40k-border-color-light)] hover:tw-text-[color:var(--wh40k-text-dark)]" data-action="togglePowerDetails" data-item-id="{{power.id}}" title="Toggle Details">
                            <i class="fas fa-chevron-down"></i>
                        </button>
                    </div>
                </div>

                {{!-- Power Stats Row --}}
                <div class="tw-flex tw-flex-wrap tw-gap-2 tw-px-3 tw-py-1 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color-light)]">
                    <div class="tw-flex tw-flex-col tw-gap-[1px] tw-min-w-[80px]">
                        <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">Test</span>
                        <span class="tw-text-[0.8rem] tw-font-medium tw-text-[color:var(--wh40k-text-dark)]">{{power.system.testLabel}}</span>
                    </div>
                    <div class="tw-flex tw-flex-col tw-gap-[1px] tw-min-w-[80px]">
                        <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-muted)]">Action</span>
                        <span class="tw-text-[0.8rem] tw-font-medium tw-text-[color:var(--wh40k-text-dark)]">{{power.system.activationLabel}}</span>
                    </div>
                </div>

                {{!-- Power Level Badges --}}
                <div class="tw-flex tw-gap-1 tw-px-3 tw-py-1 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color-light)]">
                    {{#if power.system.levels.novice.effect}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-[3px] tw-rounded-[12px] tw-text-[0.7rem] tw-font-semibold tw-bg-[rgba(34,197,94,0.15)] tw-text-[#22c55e] tw-border tw-border-[rgba(34,197,94,0.3)]" title="Novice Effect">
                        <i class="fas fa-seedling tw-text-[0.65rem]"></i> Novice
                    </span>
                    {{/if}}
                    {{#if power.system.levels.adept.effect}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-[3px] tw-rounded-[12px] tw-text-[0.7rem] tw-font-semibold tw-bg-[rgba(59,130,246,0.15)] tw-text-[#3b82f6] tw-border tw-border-[rgba(59,130,246,0.3)]" title="Adept Effect">
                        <i class="fas fa-star-half-alt tw-text-[0.65rem]"></i> Adept
                    </span>
                    {{/if}}
                    {{#if power.system.levels.master.effect}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-[3px] tw-rounded-[12px] tw-text-[0.7rem] tw-font-semibold tw-bg-[rgba(245,158,11,0.15)] tw-text-[#f59e0b] tw-border tw-border-[rgba(245,158,11,0.3)]" title="Master Effect">
                        <i class="fas fa-crown tw-text-[0.65rem]"></i> Master
                    </span>
                    {{/if}}
                </div>

                {{!-- Expandable Details --}}
                <div class="tw-p-3 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color-light)]" data-power-id="{{power.id}}" hidden>
                    {{#if power.system.levels.novice.effect}}
                    <div class="tw-mb-3">
                        <span class="tw-flex tw-items-center tw-gap-1 tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#22c55e] tw-mb-1"><i class="fas fa-seedling tw-text-[0.7rem]"></i> Novice</span>
                        <div class="tw-p-2 tw-bg-[var(--wh40k-panel-bg)] tw-rounded tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{power.system.levels.novice.effect}}}</div>
                    </div>
                    {{/if}}
                    {{#if power.system.levels.adept.effect}}
                    <div class="tw-mb-3">
                        <span class="tw-flex tw-items-center tw-gap-1 tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#3b82f6] tw-mb-1"><i class="fas fa-star-half-alt tw-text-[0.7rem]"></i> Adept</span>
                        <div class="tw-p-2 tw-bg-[var(--wh40k-panel-bg)] tw-rounded tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{power.system.levels.adept.effect}}}</div>
                    </div>
                    {{/if}}
                    {{#if power.system.levels.master.effect}}
                    <div class="tw-mb-3">
                        <span class="tw-flex tw-items-center tw-gap-1 tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#f59e0b] tw-mb-1"><i class="fas fa-crown tw-text-[0.7rem]"></i> Master</span>
                        <div class="tw-p-2 tw-bg-[var(--wh40k-panel-bg)] tw-rounded tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{power.system.levels.master.effect}}}</div>
                    </div>
                    {{/if}}
                    {{#if power.system.sideEffects}}
                    <div class="tw-mb-3">
                        <span class="tw-flex tw-items-center tw-gap-1 tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#ef4444] tw-mb-1"><i class="fas fa-exclamation-triangle tw-text-[0.7rem]"></i> Side Effects</span>
                        <div class="tw-p-2 tw-bg-[var(--wh40k-panel-bg)] tw-rounded tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{power.system.sideEffects}}}</div>
                    </div>
                    {{/if}}
                    {{#if power.system.description}}
                    <div class="tw-mb-3">
                        <span class="tw-flex tw-items-center tw-gap-1 tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1">Description</span>
                        <div class="tw-p-2 tw-bg-[var(--wh40k-panel-bg)] tw-rounded tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{power.system.description}}}</div>
                    </div>
                    {{/if}}
                    <div class="tw-flex tw-gap-2 tw-mt-3 tw-pt-2 tw-border-t tw-border-[var(--wh40k-border-color-light)]">
                        <button type="button" class="tw-flex tw-items-center tw-gap-1 tw-px-3 tw-py-[6px] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded tw-bg-[var(--wh40k-btn-bg)] tw-text-[color:var(--wh40k-text-secondary)] tw-text-[0.75rem] tw-font-semibold tw-cursor-pointer tw-transition-all hover:tw-bg-[var(--wh40k-btn-bg-hover)] hover:tw-border-[var(--wh40k-border-color-strong)]" data-action="itemEdit" data-item-id="{{power.id}}">
                            <i class="fas fa-cog"></i> Edit
                        </button>
                        <button type="button" class="tw-flex tw-items-center tw-gap-1 tw-px-3 tw-py-[6px] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded tw-bg-[var(--wh40k-btn-bg)] tw-text-[color:var(--wh40k-text-secondary)] tw-text-[0.75rem] tw-font-semibold tw-cursor-pointer tw-transition-all hover:tw-bg-[rgba(239,68,68,0.1)] hover:tw-border-[rgba(239,68,68,0.3)] hover:tw-text-[#ef4444]" data-action="itemDelete" data-item-id="{{power.id}}">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                </div>
            </div>
            {{else}}
            <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-[color:var(--wh40k-text-muted)] tw-text-center">
                <i class="fas fa-eye tw-text-[2rem] tw-mb-2 tw-opacity-40"></i>
                <p class="tw-m-0 tw-text-[0.9rem] tw-italic">No navigator powers</p>
            </div>
            {{/each}}
        </div>

        {{!-- Add Power Dropzone --}}
        <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-m-2 tw-rounded tw-cursor-pointer tw-transition-all tw-border-2 tw-border-dashed tw-border-[var(--wh40k-border-color-light)] hover:tw-border-[var(--wh40k-accent-gold)] hover:tw-bg-[rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.05)] {{#if navigatorPowersCount}}tw-flex-row tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-min-h-0{{else}}tw-flex-col tw-p-4 tw-min-h-[80px]{{/if}}" data-action="itemCreate" data-type="navigatorPower">
            <i class="fas fa-plus {{#if navigatorPowersCount}}tw-text-[0.9rem]{{else}}tw-text-[2rem]{{/if}} tw-text-[color:var(--wh40k-text-muted)] tw-transition-all hover:tw-text-[color:var(--wh40k-accent-gold)]"></i>
            <span class="tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.05em] tw-text-center {{#if navigatorPowersCount}}tw-text-[0.7rem]{{else}}tw-text-[0.75rem]{{/if}}">{{#if navigatorPowersCount}}Drop or click to add{{else}}Drop Navigator Power or Click to Create{{/if}}</span>
        </div>
    </div>
</div>
