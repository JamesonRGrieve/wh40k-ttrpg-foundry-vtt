{{! Journal Entries Section }}
<div class="tw-mt-3">
    <div class="tw-flex tw-items-center tw-justify-between tw-mb-2 tw-pb-1">
        <span class="tw-flex tw-items-center tw-gap-1 tw-font-semibold tw-uppercase tw-tracking-wide wh40k-section-title"><i class="fas fa-book"></i> Journal Entries</span>
        <button type="button" class="wh40k-add-btn" data-action="itemCreate" data-type="journalEntry" title="Add Journal Entry">
            <i class="fas fa-plus"></i>
        </button>
    </div>

    {{#if journalEntries.length}}
        <div class="tw-flex tw-flex-col tw-gap-1">
            {{#each journalEntries as |entry|}}
                <div class="wh40k-journal-entry" data-item-id="{{entry.id}}">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <button type="button" class="wh40k-entry-name" data-action="itemEdit" data-item-id="{{entry.id}}" title="Click to edit">
                            {{entry.name}}
                        </button>
                        <span class="tw-text-[0.7rem] tw-whitespace-nowrap">
                            {{#if entry.system.time}}{{entry.system.time}}{{/if}}
                            {{#if entry.system.place}}{{#if entry.system.time}} · {{/if}}{{entry.system.place}}{{/if}}
                        </span>
                        <button type="button" class="wh40k-entry-delete" data-action="itemDelete" data-item-id="{{entry.id}}" title="Delete">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    {{#if entry.system.description}}
                        <div class="wh40k-entry-preview">
                            {{truncate entry.system.description 150}}
                        </div>
                    {{/if}}
                </div>
            {{/each}}
        </div>
    {{else}}
        <div class="wh40k-empty-state">
            <i class="fas fa-book-open"></i>
            <p>No journal entries yet</p>
        </div>
    {{/if}}
</div>