{{!--
    Deathwatch Vehicle Critical Hit + Repair panel (#170 — rites.md
    §"DAMAGING VEHICLES" Table 4-2 / §"REPAIRING VEHICLES").

    Renders the vehicle Integrity readout plus two action affordances:

      - "Roll Critical Hit" — rolls 1d10 + over-Integrity on Table 4-2
      - "Repair Test"       — opens a Tech-Use Test at the difficulty
                              implied by the last suffered crit result

    Sheet context (built by character-sheet / npc-sheet _prepareContext):

      vehiclePanel: {
        integrity:      number   // sys.vehicleIntegrity
        overIntegrity:  number   // sys.overIntegrity
        canRollCrit:    boolean  // overIntegrity > 0 OR integrity <= 0
        canRepair:      boolean  // overIntegrity > 0
      }

    Rendered only for DW actors; the include in tab-status.hbs gates on
    `isDW` from context.
--}}
{{#> systems/wh40k-rpg/templates/actor/partial/system-card.hbs rootClass="wh40k-dw-vehicle-panel" accentBorderClass="dw:tw-border-bronze" accentIconClass="dw:tw-text-bronze" icon="fa-truck-monster" label=(localize "WH40K.DW.Vehicle.Label") rootAttrs=(safeAttrs "data-dw-vehicle-integrity" vehiclePanel.integrity "data-dw-vehicle-over-integrity" vehiclePanel.overIntegrity)}}

    {{!-- Pool readouts --}}
    <div class="wh40k-dw-vehicle-readouts tw-flex tw-flex-col tw-gap-1 tw-text-[0.8rem]">
        <div class="wh40k-dw-vehicle-integrity-row tw-flex tw-items-center tw-justify-between tw-gap-2">
            <span class="tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.DW.Vehicle.Integrity"}}</span>
            <span class="wh40k-dw-vehicle-integrity-value tw-font-bold tw-tabular-nums tw-text-[color:var(--wh40k-text-bright)]">
                {{vehiclePanel.integrity}}
            </span>
        </div>
        <div class="wh40k-dw-vehicle-over-row tw-flex tw-items-center tw-justify-between tw-gap-2">
            <span class="tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.DW.Vehicle.OverIntegrity"}}</span>
            <span class="wh40k-dw-vehicle-over-value tw-font-bold tw-tabular-nums tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze">
                +{{vehiclePanel.overIntegrity}}
            </span>
        </div>
    </div>

    {{!-- Action affordances --}}
    <div class="wh40k-dw-vehicle-actions tw-flex tw-flex-wrap tw-gap-1.5">
        <button type="button"
                class="wh40k-dw-vehicle-crit-btn tw-inline-flex tw-items-center tw-justify-center tw-bg-transparent tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dw:tw-border-bronze tw-rounded tw-px-2 tw-py-0.5 tw-cursor-pointer tw-text-[0.72rem] tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze hover:tw-bg-[color:var(--wh40k-border-color-light)] hover:tw-text-white disabled:tw-cursor-not-allowed disabled:tw-opacity-50"
                data-action="dwVehicleRollCrit"
                title="{{localize 'WH40K.DW.Vehicle.RollCritTooltip'}}"
                {{#unless vehiclePanel.canRollCrit}}disabled aria-disabled="true"{{/unless}}>
            <i class="fas fa-dice-d10 tw-mr-1"></i>
            {{localize "WH40K.DW.Vehicle.RollCrit"}}
        </button>
        <button type="button"
                class="wh40k-dw-vehicle-repair-btn tw-inline-flex tw-items-center tw-justify-center tw-bg-transparent tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dw:tw-border-bronze tw-rounded tw-px-2 tw-py-0.5 tw-cursor-pointer tw-text-[0.72rem] tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze hover:tw-bg-[color:var(--wh40k-border-color-light)] hover:tw-text-white disabled:tw-cursor-not-allowed disabled:tw-opacity-50"
                data-action="dwVehicleRepair"
                title="{{localize 'WH40K.DW.Vehicle.RepairTestTooltip'}}"
                {{#unless vehiclePanel.canRepair}}disabled aria-disabled="true"{{/unless}}>
            <i class="fas fa-wrench tw-mr-1"></i>
            {{localize "WH40K.DW.Vehicle.RepairTest"}}
        </button>
    </div>
{{/system-card}}
