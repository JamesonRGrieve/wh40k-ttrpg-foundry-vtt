{{!-- Orders Panel --}}
{{#> systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs panelId="orders" label="Ship Orders" icon="fa-ship" count=ordersCount rootClass="wh40k-panel-powers wh40k-panel-orders" bodyClass="tw-p-0"}}
    {{!-- Category Filter Tabs --}}
    {{#if orderCategories.length}}
    <div class="wh40k-power-filters">
        <button type="button" class="wh40k-filter-btn {{#unless activeOrderCategory}}active{{/unless}}" data-action="filterOrders" data-category="">
            All
        </button>
        {{#each orderCategories as |cat|}}
        <button type="button" class="wh40k-filter-btn wh40k-filter-{{cat.id}}" data-action="filterOrders" data-category="{{cat.id}}">
            {{cat.label}}
        </button>
        {{/each}}
    </div>
    {{/if}}

    {{!-- Orders List --}}
    <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)] tw-min-h-[60px] tw-p-[var(--wh40k-space-md)]" data-drop-zone="powers" data-accepts="order">
        {{#each orders as |order|}}
        {{#> systems/wh40k-rpg/templates/actor/partial/item-list-row.hbs
            item=order
            accentColor="#0891b2"
            dragType="order"
            extraAttrs=(concat 'data-category="' order.system.category '"')
            editTitle="Edit Order"
            pills=(array order.system.pill (hash bgClass="tw-bg-[rgba(0,0,0,0.1)]" textClass="tw-text-[color:var(--wh40k-text-muted)]" label=order.system.actionTypeLabel))
            stats=(array
                (hash label="Test" value=order.system.testLabel)
                (hash label="Action" value=order.system.actionTypeLabel))
            actions=(array
                (hash action="rollOrder" icon="fa-dice-d20" title="Execute Order" hoverClass="hover:tw-text-[color:var(--wh40k-accent-powers)]")
                (hash action="vocalizeOrder" icon="fa-comment" title="Post to Chat" hoverClass="hover:tw-bg-[rgba(59,130,246,0.15)] hover:tw-border-[rgba(59,130,246,0.3)] hover:tw-text-[#3b82f6]")
                (hash action="togglePowerDetails" icon="fa-chevron-down" title="Toggle Details" hoverClass="hover:tw-text-[color:var(--wh40k-text-dark)]"))
        }}
            {{#if order.system.requirements}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1"><i class="fas fa-list-check tw-text-[0.7rem]"></i> Requirements</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{order.system.requirements}}}</div>
            </div>
            {{/if}}
            {{#if order.system.effect}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#22c55e] tw-mb-1"><i class="fas fa-check-circle tw-text-[0.7rem]"></i> Effect</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{order.system.effect}}}</div>
            </div>
            {{/if}}
            {{#if order.system.failure}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[#ef4444] tw-mb-1"><i class="fas fa-exclamation-triangle tw-text-[0.7rem]"></i> Failure</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{order.system.failure}}}</div>
            </div>
            {{/if}}
            {{#if order.system.description}}
            <div class="tw-mb-[var(--wh40k-space-md)]">
                <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.04em] tw-text-[color:var(--wh40k-text-secondary)] tw-mb-1">Description</span>
                <div class="tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.8rem] tw-leading-relaxed tw-text-[color:var(--wh40k-text-dark)]">{{{order.system.description}}}</div>
            </div>
            {{/if}}
        {{/systems/wh40k-rpg/templates/actor/partial/item-list-row.hbs}}
        {{else}}
        {{> systems/wh40k-rpg/templates/actor/partial/empty-state.hbs icon="fa-ship" text="No ship orders known" padding="md"}}
        {{/each}}
    </div>

    {{!-- Add Order Dropzone --}}
    {{> systems/wh40k-rpg/templates/actor/partial/dropzone.hbs type="order" hasItems=ordersCount label="Drop Ship Order or Click to Create" compactLabel="Drop or click to add"}}
{{/systems/wh40k-rpg/templates/actor/partial/collapsible-panel.hbs}}
