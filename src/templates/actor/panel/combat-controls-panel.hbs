{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label="Controls"
    icon="fa-crosshairs"
    rootClass="tw-col-auto"
    bodyClass="tw-p-3"}}
    <div class="tw-grid tw-grid-cols-2 tw-gap-2">
        <button type="roll" class="tw-grid tw-grid-cols-[auto_1fr] tw-items-center tw-gap-2 tw-px-[10px] tw-py-2 tw-rounded-lg tw-border tw-border-[rgba(74,55,40,0.3)] tw-bg-gradient-to-b tw-from-[rgba(255,255,255,0.85)] tw-to-[rgba(245,240,232,0.8)] tw-text-[#3a2820] tw-font-semibold tw-uppercase tw-tracking-[0.06em] tw-cursor-pointer tw-transition-all" data-action="attack">
            <i class="{{concat 'fas fa-bullseye'}}" style="color:#7a3a2f;font-size:0.9em"></i>
            <span>Attack</span>
        </button>
        <button type="roll" class="tw-grid tw-grid-cols-[auto_1fr] tw-items-center tw-gap-2 tw-px-[10px] tw-py-2 tw-rounded-lg tw-border tw-border-[rgba(74,55,40,0.3)] tw-bg-gradient-to-b tw-from-[rgba(255,255,255,0.85)] tw-to-[rgba(245,240,232,0.8)] tw-text-[#3a2820] tw-font-semibold tw-uppercase tw-tracking-[0.06em] tw-cursor-pointer tw-transition-all" data-action="assign-damage">
            <i class="{{concat 'fas fa-bolt'}}" style="color:#7a3a2f;font-size:0.9em"></i>
            <span>Assign Damage</span>
        </button>
        <button type="roll" class="tw-grid tw-grid-cols-[auto_1fr] tw-items-center tw-gap-2 tw-px-[10px] tw-py-2 tw-rounded-lg tw-border tw-border-[rgba(74,55,40,0.3)] tw-bg-gradient-to-b tw-from-[rgba(255,255,255,0.85)] tw-to-[rgba(245,240,232,0.8)] tw-text-[#3a2820] tw-font-semibold tw-uppercase tw-tracking-[0.06em] tw-cursor-pointer tw-transition-all" data-action="dodge">
            <i class="{{concat 'fas fa-shoe-prints'}}" style="color:#7a3a2f;font-size:0.9em"></i>
            <span>Dodge</span>
        </button>
        <button type="roll" class="tw-grid tw-grid-cols-[auto_1fr] tw-items-center tw-gap-2 tw-px-[10px] tw-py-2 tw-rounded-lg tw-border tw-border-[rgba(74,55,40,0.3)] tw-bg-gradient-to-b tw-from-[rgba(255,255,255,0.85)] tw-to-[rgba(245,240,232,0.8)] tw-text-[#3a2820] tw-font-semibold tw-uppercase tw-tracking-[0.06em] tw-cursor-pointer tw-transition-all" data-action="parry">
            <i class="{{concat 'fas fa-shield-alt'}}" style="color:#7a3a2f;font-size:0.9em"></i>
            <span>Parry</span>
        </button>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
