{{!-- Specialist Skills Panel — routed through the shared panel.hbs header so its
     heading matches the other Statistics-tab panels (Characteristics / Skills /
     Traits), instead of a bare hand-rolled header (#238). --}}
{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label=(localize "WH40K.Skills.SpecialistHeader")
    icon="fa-graduation-cap"
    headerActionIcon="fa-plus"
    headerAction="openAddSpecialistDialog"
    headerActionTitle=(localize "WH40K.Skills.AddSpecialistSkillTitle")
    headerActionTone="gold"}}
        {{#if skillLists.specialist.length}}
            {{!-- Specialist skill groups flow into 1–3 width-responsive columns (#267):
                 auto-fit follows the panel width, collapses to one column when narrow,
                 caps at three (gap = 0.5rem). items-start keeps variable-height group
                 cards from stretching to the tallest in their row. Floor reduced to
                 11rem (down from 16rem): specialist group cards carry more fixed-width
                 chrome (training badges + score column) than plain skill rows, so a
                 slightly larger floor than skills (10rem) keeps entries viable while
                 still letting columns reflow before text is truncated. --}}
            <div class="tw-grid tw-gap-2 tw-items-start" style="grid-template-columns: repeat(auto-fit, minmax(max(11rem, calc((100% - 1rem) / 3)), 1fr));">
            {{#each skillLists.specialist as |entry|}}
                {{#if entry.[1].entries.length}}
                <div class="{{#if entry.[1].advanced}}tw-border-l-2 tw-border-l-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.5)]{{/if}} tw-bg-[var(--wh40k-bg-paper)] tw-border tw-border-solid tw-border-[var(--wh40k-border-light)] tw-rounded-lg tw-overflow-hidden" data-skill="{{entry.[0]}}">
                    <!-- Group Header -->
                    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-1 tw-bg-gradient-to-b tw-from-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.12)] tw-to-transparent tw-border-b tw-border-b-[var(--wh40k-border-light)]">
                        <span class="tw-flex-1 tw-font-semibold tw-font-alt">{{entry.[1].label}}</span>
                        <span class="tw-text-[0.7rem] tw-uppercase tw-px-[6px] tw-py-[2px] tw-rounded-md tw-border tw-border-solid tw-bg-[var(--wh40k-bg-input)] tw-border-[var(--wh40k-border-light)]">{{entry.[1].charShort}}</span>
                    </div>

                    <!-- Entries -->
                    <div class="tw-block tw-p-1">
                        {{#each entry.[1].entries as |spec|}}
                        <div class="tw-grid tw-grid-cols-[1fr_auto_50px] tw-items-center tw-gap-2 tw-px-2 tw-py-1 tw-bg-[var(--wh40k-bg-input)] tw-border tw-border-solid tw-border-[var(--wh40k-border-light)] tw-rounded-md tw-mb-[2px] hover:tw-bg-[var(--wh40k-bg-paper)] hover:tw-border-[var(--wh40k-border-medium)]" data-skill="{{spec.skillKey}}" data-index="{{spec.entryIndex}}">
                            <div class="tw-flex tw-items-center tw-gap-1 tw-min-w-0">
                                <span class="tw-flex-1 tw-truncate tw-text-[0.9rem]">{{spec.name}}</span>
                                <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-[4px] tw-rounded-md tw-shrink-0 tw-text-[color:var(--wh40k-text-muted)] hover:tw-bg-[var(--wh40k-bg-subtle)] hover:tw-text-[color:var(--wh40k-accent-talents)]"
                                        data-action="roll" data-roll-type="skill"
                                        data-roll-target="{{spec.skillKey}}"
                                        data-specialty="{{spec.entryIndex}}"
                                        title="{{localize "WH40K.Skills.RollSpecializationTitle"}} {{spec.name}}">
                                    <i class="fas fa-dice-d20"></i>
                                </button>
                                <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-[4px] tw-rounded-md tw-shrink-0 tw-text-[color:var(--wh40k-text-muted)] hover:tw-bg-[var(--wh40k-bg-subtle)] hover:tw-text-[#f5a623] {{#if spec.isFavorite}}active tw-text-[#f5a623]{{/if}}"
                                        data-action="toggleFavoriteSpecialistSkill"
                                        data-skill="{{spec.skillKey}}"
                                        data-index="{{spec.entryIndex}}"
                                        title="{{#if spec.isFavorite}}{{localize "WH40K.Skills.RemoveFromFavorites"}}{{else}}{{localize "WH40K.Skills.AddToFavorites"}}{{/if}}">
                                    <i class="{{#if spec.isFavorite}}fas{{else}}far{{/if}} fa-star"></i>
                                </button>
                            </div>
                            <div class="tw-flex tw-gap-[2px]">
                                {{#each spec.trainingIndicators as |ind|}}
                                {{#if @root.inEditMode}}
                                <button type="button" class="tw-border tw-border-solid tw-rounded-[3px] tw-text-[0.65rem] tw-font-semibold tw-px-[4px] tw-py-[2px] tw-min-w-[24px] tw-text-center {{#if ind.active}}active tw-bg-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.25)] tw-border-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.55)] tw-text-[color:var(--color-text-primary)] tw-opacity-100 tw-font-bold{{else}}tw-bg-[rgba(255,255,255,0.35)] tw-border-[rgba(120,46,34,0.35)] tw-text-[#3a2820] tw-opacity-50{{/if}}" title="{{ind.tooltip}} — Click to cycle (Shift+click to reverse)" data-action="cycleSpecialistTraining" data-skill="{{../spec.skillKey}}" data-index="{{../spec.entryIndex}}">{{ind.label}}</button>
                                {{else}}
                                <span class="tw-border tw-border-solid tw-rounded-[3px] tw-text-[0.65rem] tw-font-semibold tw-px-[4px] tw-py-[2px] tw-min-w-[24px] tw-text-center {{#if ind.active}}active tw-bg-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.25)] tw-border-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.55)] tw-text-[color:var(--color-text-primary)] tw-opacity-100 tw-font-bold{{else}}tw-bg-[rgba(255,255,255,0.35)] tw-border-[rgba(120,46,34,0.35)] tw-text-[#3a2820] tw-opacity-50{{/if}}" title="{{ind.tooltip}}">{{ind.label}}</span>
                                {{/if}}
                                {{/each}}
                            </div>
                            <div class="tw-min-w-[34px] tw-h-[26px] tw-px-[8px] tw-rounded-[6px] tw-inline-flex tw-items-center tw-justify-center tw-border-2 tw-border-solid tw-bg-[var(--color-bg-option)] tw-border-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.45)] tw-shadow-[inset_0_1px_2px_rgba(255,255,255,0.1),0_2px_6px_rgba(0,0,0,0.15)]" title="{{spec.breakdown}}">
                                <span class="tw-font-alt tw-text-[1.05rem] tw-font-bold tw-text-[color:var(--wh40k-accent-talents)]">{{spec.current}}</span>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
                {{else}}
                {{!-- Parent specialist with no entries yet — render a greyed "untrained" row so
                     the player knows the skill exists (issue #3). The dice button rolls the
                     group untrained (no specialisation) at the usual –20 penalty, keeping the
                     skill available as an action even before any specialisation is added. --}}
                <div class="tw-bg-[var(--wh40k-bg-paper)] tw-border tw-border-solid tw-border-[var(--wh40k-border-light)] tw-rounded-lg tw-overflow-hidden tw-opacity-70" data-skill="{{entry.[0]}}">
                    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-1 tw-bg-gradient-to-b tw-from-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.06)] tw-to-transparent tw-border-b tw-border-b-[var(--wh40k-border-light)]" title="{{localize "WH40K.Skills.AddFirstSpecializationHint"}}">
                        <span class="tw-flex-1 tw-font-semibold tw-font-alt tw-italic">{{entry.[1].label}}</span>
                        <span class="tw-text-[0.7rem] tw-uppercase tw-px-[6px] tw-py-[2px] tw-rounded-md tw-border tw-border-solid tw-bg-[var(--wh40k-bg-input)] tw-border-[var(--wh40k-border-light)]">{{entry.[1].charShort}}</span>
                        <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-[4px] tw-rounded-md tw-text-[color:var(--wh40k-text-muted)] hover:tw-bg-[var(--wh40k-bg-subtle)] hover:tw-text-[color:var(--wh40k-accent-talents)]"
                                data-action="roll" data-roll-type="skill" data-roll-target="{{entry.[0]}}"
                                title="{{localize "WH40K.Skills.RollUntrainedTitle"}}: {{entry.[1].label}}">
                            <i class="fas fa-dice-d20"></i>
                        </button>
                        <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-[4px] tw-rounded-md tw-text-[color:var(--wh40k-text-muted)] hover:tw-bg-[var(--wh40k-bg-subtle)] hover:tw-text-[color:var(--wh40k-accent-talents)]" data-action="openAddSpecialistDialog" data-skill="{{entry.[0]}}" title="{{localize "WH40K.Skills.AddSpecializationTitle"}}">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                </div>
                {{/if}}
            {{/each}}
            </div>
        {{else}}
            <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-text-center tw-px-4 tw-py-8 tw-text-[color:var(--wh40k-text-muted)] tw-bg-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.03)] tw-border-2 tw-border-dashed tw-border-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.2)] tw-rounded-lg tw-m-2">
                <i class="fas fa-graduation-cap tw-text-[2.5rem] tw-text-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.3)] tw-mb-2"></i>
                <p class="tw-font-alt tw-text-[1.1rem] tw-font-semibold tw-text-[color:var(--wh40k-text-secondary)] tw-m-0 tw-mb-1">{{localize "WH40K.Skills.NoSpecialistSkillsYet"}}</p>
                <span class="tw-text-[0.85rem]">{{localize "WH40K.Skills.AddFirstSpecializationHint"}}</span>
            </div>
        {{/if}}
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
