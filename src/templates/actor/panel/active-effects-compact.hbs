{{!-- Active Effects - Compact Vitals Version --}}
{{!-- Designed to fit in the Combat tab vitals column --}}
<div class="tw-flex tw-flex-col tw-gap-[6px] tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-light)] tw-rounded-[6px] tw-transition-all tw-relative tw-overflow-hidden tw-min-w-0 tw-w-full tw-box-border before:tw-content-[''] before:tw-absolute before:tw-left-0 before:tw-top-0 before:tw-bottom-0 before:tw-w-[3px] before:tw-bg-[var(--wh40k-border-medium)] before:tw-transition-all">
    <div class="tw-flex tw-items-center tw-justify-between tw-gap-[var(--wh40k-space-sm)] tw-w-full">
        <div class="tw-flex tw-items-center tw-gap-1">
            <i class="fas fa-sparkles"></i>
            <span>{{localize 'WH40K.Effects.HeaderShort'}}</span>
            {{#if effects.length}}
                <span class="tw-ml-1 tw-text-[0.65rem] tw-font-semibold tw-text-[var(--wh40k-accent-gold)]">({{effects.length}})</span>
            {{/if}}
        </div>
    </div>
    <div class="tw-flex tw-flex-col tw-gap-[6px] tw-w-full">
        {{#if effects.length}}
            <div class="tw-flex tw-flex-col tw-gap-[3px]">
                {{#each effects as |effect|}}
                    {{> systems/wh40k-rpg/templates/actor/partial/effect-row.hbs
                        effect=effect
                        compact=true}}
                {{/each}}
            </div>
        {{else}}
            <div class="tw-flex tw-flex-col tw-items-center tw-gap-1 tw-py-3 tw-text-[color:var(--wh40k-text-muted)]">
                <i class="fas fa-sparkles tw-text-[1.2rem] tw-opacity-50"></i>
                <span class="tw-text-[0.75rem] tw-italic">{{localize 'WH40K.Effects.NoneShort'}}</span>
            </div>
        {{/if}}
    </div>
</div>
