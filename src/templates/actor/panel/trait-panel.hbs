{{!-- Traits Panel - Compact Table View with Grouping --}}
<div class="wh40k-panel wh40k-panel-traits-table">
    <div class="wh40k-panel-header">
        <span class="wh40k-panel-title">
            <i class="fas fa-shield-alt"></i> Traits
        </span>
    </div>
    
    <div class="wh40k-panel-body">
        {{!-- Grouped Trait Table --}}
        {{#if traits.length}}
        <div class="wh40k-traits-grouped">
            {{#each groupedByCategory as |group|}}
            <div class="wh40k-trait-group">
                <div class="wh40k-group-header {{traitCategoryColor group.category}}">
                    <i class="fas {{traitIcon group.category}}"></i>
                    <span class="wh40k-group-title">{{group.categoryLabel}}</span>
                    <span class="wh40k-count-badge">{{group.traits.length}}</span>
                </div>
                
                <div class="wh40k-traits-table" data-category="{{group.category}}">
                    {{#each group.traits as |trait|}}
                    <div class="wh40k-trait-row item-drag" 
                         data-item-id="{{trait.id}}" 
                         draggable="true">
                        <i class="fas {{trait.categoryIcon}} wh40k-row-icon-inline"></i>
                        
                        <div class="wh40k-row-main">
                            <button type="button" 
                                  class="wh40k-row-name" 
                                  data-action="itemEdit" 
                                  data-item-id="{{trait.id}}" 
                                  title="Click to open item sheet">
                                {{trait.name}}
                            </button>
                            
                            {{#if trait.system.requirements}}
                            <div class="wh40k-row-meta">
                                <span class="wh40k-meta-item">
                                    <i class="fas fa-lock"></i> {{trait.system.requirements}}
                                </span>
                            </div>
                            {{/if}}
                        </div>
                        
                        {{!-- Level Stepper for variable traits --}}
                        {{#if trait.hasLevel}}
                        <div class="wh40k-level-stepper">
                            <button type="button" 
                                    class="wh40k-stepper-btn" 
                                    data-action="adjustTraitLevel" 
                                    data-item-id="{{trait.id}}" 
                                    data-delta="-1"
                                    title="Decrease Level">
                                <i class="fas fa-minus"></i>
                            </button>
                            <span class="wh40k-level-display">{{trait.system.level}}</span>
                            <button type="button" 
                                    class="wh40k-stepper-btn" 
                                    data-action="adjustTraitLevel" 
                                    data-item-id="{{trait.id}}" 
                                    data-delta="1"
                                    title="Increase Level">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        {{/if}}
                        
                        <div class="wh40k-row-actions">
                            <button type="button" 
                                    class="wh40k-action-btn" 
                                    data-action="itemVocalize" 
                                    data-item-id="{{trait.id}}" 
                                    title="Send to Chat">
                                <i class="fas fa-comment"></i>
                            </button>
                            <button type="button" 
                                    class="wh40k-action-btn wh40k-btn-danger" 
                                    data-action="itemDelete" 
                                    data-item-id="{{trait.id}}" 
                                    title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}
        
        {{!-- Dropzone --}}
        <div class="wh40k-dropzone {{#if traits.length}}wh40k-dropzone--compact{{/if}}" data-action="itemCreate" data-type="trait">
            <i class="fas fa-shield-alt wh40k-dropzone-icon"></i>
            <span class="wh40k-dropzone-text">{{#if traits.length}}Drop to add{{else}}Drop Trait or Click to Create{{/if}}</span>
        </div>
    </div>
</div>
