{{!-- Traits Panel - Compact Table View with Grouping --}}
{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label="Traits"
    icon="fa-shield-alt"
    rootClass="tw-mt-0 tw-mb-0 tw-w-full tw-box-border tw-self-stretch"
    rootAttrs="data-drop-zone=\"general\" data-accepts=\"trait\""
    bodyClass="tw-flex tw-flex-col tw-gap-2 tw-w-full tw-box-border"
    titleClass="tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"}}
    {{!-- Grouped Trait Table --}}
    {{#if traits.length}}
    <div class="tw-flex tw-flex-col tw-gap-3">
        {{#each groupedByCategory as |group|}}
        <div class="tw-flex tw-flex-col tw-relative tw-gap-[var(--wh40k-space-xs)] tw-z-[1]">
            <div class="tw-flex tw-items-center tw-gap-1 tw-sticky tw-top-0 tw-z-[2] tw-text-[0.75rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-py-[4px] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-l-[3px] tw-border-l-solid tw-border-l-[var(--wh40k-accent-equipment)] tw-rounded-[3px] tw-text-[var(--wh40k-text-secondary)] {{traitCategoryColor group.category}}">
                <i class="{{concat 'fas'}} {{traitIcon group.category}} tw-text-[0.8rem] tw-shrink-0"></i>
                <span class="tw-flex-1 tw-min-w-0 tw-truncate">{{group.categoryLabel}}</span>
                <span class="tw-rounded-[10px] tw-px-[6px] tw-py-[2px] tw-text-[0.65rem] tw-font-semibold tw-min-w-[20px] tw-text-center tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-solid tw-border-[var(--wh40k-border-color-light)]">{{group.traits.length}}</span>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-[2px]" data-category="{{group.category}}">
                {{#each group.traits as |trait|}}
                <div class="tw-flex tw-items-center tw-gap-2 tw-overflow-hidden tw-min-h-[40px] tw-cursor-grab tw-py-[6px] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-panel-bg-solid)] tw-border tw-border-solid tw-border-[var(--wh40k-border-color-light)] tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-equipment)] tw-rounded-md tw-transition-all"
                     data-item-id="{{trait.id}}"
                     draggable="true">
                    <i class="{{concat 'fas'}} {{trait.categoryIcon}} tw-shrink-0 tw-w-[20px] tw-text-center tw-text-[1rem] tw-text-[var(--wh40k-text-muted)]"></i>

                    <div class="tw-flex-1 tw-flex tw-flex-col tw-min-w-0 tw-overflow-hidden">
                        <button type="button"
                              class="tw-text-left tw-cursor-pointer tw-truncate tw-w-full tw-font-semibold tw-bg-transparent tw-border-none tw-p-0"
                              data-action="itemEdit"
                              data-item-id="{{trait.id}}"
                              title="Click to open item sheet">
                            {{trait.name}}
                        </button>

                        {{#if trait.system.requirements}}
                        <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2 tw-text-[0.7rem]">
                            <span class="tw-flex tw-items-center tw-whitespace-nowrap">
                                <i class="{{concat 'fas fa-lock'}} tw-shrink-0 tw-text-[0.7rem]"></i> {{trait.system.requirements}}
                            </span>
                        </div>
                        {{/if}}
                    </div>

                    {{!-- Level Stepper for variable traits --}}
                    {{#if trait.hasLevel}}
                    <div class="tw-flex tw-items-center tw-gap-1 tw-shrink-0 tw-py-[2px] tw-px-[6px] tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-md">
                        <button type="button"
                                class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-px-[4px] tw-py-[2px] tw-rounded-sm tw-text-[0.7rem]"
                                data-action="adjustTraitLevel"
                                data-item-id="{{trait.id}}"
                                data-delta="-1"
                                title="Decrease Level">
                            <i class="{{concat 'fas fa-minus'}}"></i>
                        </button>
                        <span class="tw-text-[0.75rem] tw-font-semibold tw-min-w-[20px] tw-text-center">{{trait.system.level}}</span>
                        <button type="button"
                                class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-px-[4px] tw-py-[2px] tw-rounded-sm tw-text-[0.7rem]"
                                data-action="adjustTraitLevel"
                                data-item-id="{{trait.id}}"
                                data-delta="1"
                                title="Increase Level">
                            <i class="{{concat 'fas fa-plus'}}"></i>
                        </button>
                    </div>
                    {{/if}}

                    <div class="tw-flex tw-items-center tw-ml-auto tw-shrink-0">
                        <button type="button"
                                class="tw-bg-none tw-border-none tw-cursor-pointer tw-px-[6px] tw-py-[4px] tw-rounded-[3px] tw-text-[0.85rem] tw-text-[var(--wh40k-text-muted)]"
                                data-action="itemVocalize"
                                data-item-id="{{trait.id}}"
                                title="Send to Chat">
                            <i class="{{concat 'fas fa-comment'}}"></i>
                        </button>
                        <button type="button"
                                class="tw-bg-none tw-border-none tw-cursor-pointer tw-px-[6px] tw-py-[4px] tw-rounded-[3px] tw-text-[0.85rem] tw-text-[var(--wh40k-text-muted)]"
                                data-action="itemDelete"
                                data-item-id="{{trait.id}}"
                                title="Delete">
                            <i class="{{concat 'fas fa-trash'}}"></i>
                        </button>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
        {{/each}}
    </div>
    {{/if}}

    {{!-- Dropzone --}}
    <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-m-2 tw-cursor-pointer tw-transition-all tw-border-2 tw-border-dashed tw-border-[var(--wh40k-border-color-light)] tw-rounded {{#if traits.length}}tw-flex-row tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-md)] tw-min-h-0{{else}}tw-flex-col tw-p-4 tw-min-h-[80px]{{/if}}" data-action="itemCreate" data-type="trait">
        <i class="{{concat 'fas fa-shield-alt'}} tw-text-[var(--wh40k-text-muted)] {{#if traits.length}}tw-text-[0.9rem]{{else}}tw-text-[2rem]{{/if}}"></i>
        <span data-dropzone-text class="tw-text-[var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.05em] tw-text-center {{#if traits.length}}tw-text-[0.7rem]{{else}}tw-text-[0.75rem]{{/if}}">{{#if traits.length}}Drop to add{{else}}Drop Trait or Click to Create{{/if}}</span>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
