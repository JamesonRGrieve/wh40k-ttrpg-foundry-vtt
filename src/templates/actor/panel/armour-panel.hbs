{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label=(localize "WH40K.Equipment.Armour")
    icon="fa-shield-alt"
    rootClass="tw-col-auto"}}
    {{#> systems/wh40k-rpg/templates/actor/partial/item-table.hbs
        rootClass="wh40k-armourtable--border"
        addAction="itemCreate"
        addType="armour"
        addTitleKey="WH40K.Common.AddArmour"
        headers=(array
            (object cellClass="table-cell--span2" labelKey="WH40K.Weapon.Name")
            (object labelKey="WH40K.Common.Type")
            (object labelKey="WH40K.Armour.AP")
            (object labelKey="WH40K.Weapon.Equipped"))}}
        {{#each actor.items as | item |}}
            {{#if item.isArmour}}
                {{#> systems/wh40k-rpg/templates/actor/partial/item-table-row.hbs
                    item=item
                    dragType="armour"
                    nameToggleId=(concat 'description_' item.id)
                    cells=(array
                        (object value=item.system.type)
                        (object value=(armourDisplay item.system))
                        (object value=item.system.equipped))
                    actions=(array
                        (object action="itemDelete" iconKey="fa:trash" titleKey="WH40K.Common.Delete"))}}
                    <div class="tw-grid tw-grid-cols-2 tw-gap-[3px]">
                        <div class="tw-flex tw-items-baseline tw-gap-2 tw-px-2 tw-py-1.5 tw-bg-white/50 tw-rounded-md">
                            <span class="tw-text-[0.85em] tw-font-semibold tw-uppercase tw-tracking-wide">{{localize "WH40K.BodyLocation.Head"}}</span>
                            <span class="tw-font-bold">{{armourLocation item.system "head"}}</span>
                        </div>
                        <div class="tw-flex tw-items-baseline tw-gap-2 tw-px-2 tw-py-1.5 tw-bg-white/50 tw-rounded-md">
                            <span class="tw-text-[0.85em] tw-font-semibold tw-uppercase tw-tracking-wide">{{localize "WH40K.BodyLocation.LeftArm"}}</span>
                            <span class="tw-font-bold">{{armourLocation item.system "leftArm"}}</span>
                        </div>
                        <div class="tw-flex tw-items-baseline tw-gap-2 tw-px-2 tw-py-1.5 tw-bg-white/50 tw-rounded-md">
                            <span class="tw-text-[0.85em] tw-font-semibold tw-uppercase tw-tracking-wide">{{localize "WH40K.BodyLocation.RightArm"}}</span>
                            <span class="tw-font-bold">{{armourLocation item.system "rightArm"}}</span>
                        </div>
                        <div class="tw-flex tw-items-baseline tw-gap-2 tw-px-2 tw-py-1.5 tw-bg-white/50 tw-rounded-md">
                            <span class="tw-text-[0.85em] tw-font-semibold tw-uppercase tw-tracking-wide">{{localize "WH40K.BodyLocation.Body"}}</span>
                            <span class="tw-font-bold">{{armourLocation item.system "body"}}</span>
                        </div>
                        <div class="tw-flex tw-items-baseline tw-gap-2 tw-px-2 tw-py-1.5 tw-bg-white/50 tw-rounded-md">
                            <span class="tw-text-[0.85em] tw-font-semibold tw-uppercase tw-tracking-wide">{{localize "WH40K.BodyLocation.LeftLeg"}}</span>
                            <span class="tw-font-bold">{{armourLocation item.system "leftLeg"}}</span>
                        </div>
                        <div class="tw-flex tw-items-baseline tw-gap-2 tw-px-2 tw-py-1.5 tw-bg-white/50 tw-rounded-md">
                            <span class="tw-text-[0.85em] tw-font-semibold tw-uppercase tw-tracking-wide">{{localize "WH40K.BodyLocation.RightLeg"}}</span>
                            <span class="tw-font-bold">{{armourLocation item.system "rightLeg"}}</span>
                        </div>
                    </div>
                {{/systems/wh40k-rpg/templates/actor/partial/item-table-row.hbs}}
            {{/if}}
        {{/each}}
    {{/systems/wh40k-rpg/templates/actor/partial/item-table.hbs}}
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
