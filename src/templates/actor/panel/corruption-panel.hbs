{{!-- Corruption Panel — thin caller; degree-meter-panel does the heavy lifting. --}}
<div class="tw-border-t-2 tw-border-t-gold bc:tw-border-t-crimson-light dh1e:tw-border-t-gold-raw-l5 dh2e:tw-border-t-gold-raw dw:tw-border-t-accent-combat ow:tw-border-t-brass-l20 rt:tw-border-t-gold im:tw-border-t-failure tw-border-t-solid tw-rounded-t-sm"></div>
{{> systems/wh40k-rpg/templates/actor/partial/degree-meter-panel
    key="corruption"
    label=(localize "WH40K.Status.Corruption.Label")
    icon="fa-skull"
    actor=actor
    system=system
    value=system.corruption
    sourceValue=source.corruption
    field="system.corruption"
    cssPrefix="wh40k-corruption"
    gradientClass="tw-from-green-700 tw-to-crimson-dark"
    decTitle=(localize "WH40K.Status.Corruption.Decrease")
    incTitle=(localize "WH40K.Status.Corruption.Increase")
    modifierWord=(localize "WH40K.Status.Modifier")
    editTitle=(localize "WH40K.Status.Corruption.EditTitle")
    editLabel=(localize "WH40K.Status.Corruption.EditLabel")
    meta=(object
        degreeLabel=(corruptionDegree system.corruption)
        degreeClass=(corruptionDegreeClass system.corruption)
        modifier=(corruptionModifier system.corruption))
    thresholds=(array
        (object at=30 label="30" title=(localize "WH40K.Status.Corruption.Threshold30"))
        (object at=60 label="60" title=(localize "WH40K.Status.Corruption.Threshold60"))
        (object at=90 label="90" title=(localize "WH40K.Status.Corruption.Threshold90")))
    activeWarning=(iff (eq system.corruption 100)
        (object
            icon="fa-fire-alt"
            text=(localize "WH40K.Status.Corruption.Warn100")
            bannerClass="tw-bg-[rgba(0,0,0,0.3)] tw-border-2 tw-border-[#8b0000] tw-text-crimson")
        (iff (gte system.corruption 90)
            (object
                icon="fa-exclamation-triangle"
                text=(localize "WH40K.Status.Corruption.Warn90")
                bannerClass="tw-bg-[rgba(139,0,0,0.2)] tw-border-2 tw-border-[rgba(139,0,0,0.6)] tw-text-crimson-light")
            (iff (gte system.corruption 60)
                (object
                    icon="fa-skull-crossbones"
                    text=(localize "WH40K.Status.Corruption.Warn60")
                    bannerClass="tw-bg-[rgba(139,69,19,0.2)] tw-border-2 tw-border-[rgba(139,69,19,0.5)] tw-text-warning")
                false)))
    itemFlag="isMalignancy"
    itemIcon="fa-biohazard"
    itemPlural=(localize "WH40K.Status.Corruption.MalignanciesPlural")
    itemSingular=(localize "WH40K.Status.Corruption.MalignancySingular")
    dropType="malignancy"
    dropLabel=(localize "WH40K.Status.Corruption.DropEmpty")
    dropCompactLabel=(localize "WH40K.Status.Corruption.DropFull")
    infoIcon="fa-book-dead"
    infoIntro=(localize "WH40K.Status.Corruption.InfoIntro")
    degreeInfoTitle=(localize "WH40K.Status.Corruption.DegreesTitle")
    degreeInfo=(array
        (object label=(localize "WH40K.Status.Corruption.Degree.Pure.Label") range="0" description=(localize "WH40K.Status.Corruption.Degree.Pure.Description"))
        (object label=(localize "WH40K.Status.Corruption.Degree.Tainted.Label") range="1-30" description=(localize "WH40K.Status.Corruption.Degree.Tainted.Description"))
        (object label=(localize "WH40K.Status.Corruption.Degree.Soiled.Label") range="31-60" description=(localize "WH40K.Status.Corruption.Degree.Soiled.Description"))
        (object label=(localize "WH40K.Status.Corruption.Degree.Debased.Label") range="61-90" description=(localize "WH40K.Status.Corruption.Degree.Debased.Description"))
        (object label=(localize "WH40K.Status.Corruption.Degree.Profane.Label") range="91-99" description=(localize "WH40K.Status.Corruption.Degree.Profane.Description"))
        (object label=(localize "WH40K.Status.Corruption.Degree.Damned.Label") range="100" description=(localize "WH40K.Status.Corruption.Degree.Damned.Description") extraClass="wh40k-degree-damned"))}}
