{{!-- Corruption Panel — vital meter with degree badge, threshold warnings, malignancy tracking. --}}
{{#> systems/wh40k-rpg/templates/actor/partial/vital-panel-shell key="corruption" label="Corruption" icon="fa-skull" actor=actor
    rootStateClass=(corruptionDegreeClass system.corruption)
    badge=(object
        stateClass=(corruptionDegreeClass system.corruption)
        icon="fa-certificate"
        label=(corruptionDegree system.corruption)
        tooltip=(concat (corruptionDegree system.corruption) " - " (corruptionModifier system.corruption) " to tests"))}}

    {{!-- Main Display --}}
    <div class="wh40k-corruption-display">

        {{!-- Current Value & Modifier --}}
        <div class="wh40k-corruption-header tw-flex tw-items-center tw-justify-between tw-mb-2">
            {{> systems/wh40k-rpg/templates/actor/partial/vital-quick-controls
                wrapperClass="wh40k-corruption-value tw-flex tw-items-center tw-gap-2"
                cssPrefix="wh40k-corruption"
                field="system.corruption"
                current=system.corruption
                maxLabel="100"
                decTitle="Reduce Corruption"
                incTitle="Increase Corruption"
                maxValue="100"
                valueWrapperClass="wh40k-corruption-number tw-flex tw-items-baseline tw-gap-1"}}

            <div class="wh40k-corruption-modifier tw-text-sm tw-font-medium">
                <span class="wh40k-modifier-label">Modifier:</span>
                <span class="wh40k-modifier-value tw-text-gold">{{corruptionModifier system.corruption}}</span>
            </div>
        </div>

        {{!-- Progress Bar with Threshold Markers --}}
        {{> systems/wh40k-rpg/templates/actor/partial/vital-progress-bar
            cssPrefix="wh40k-corruption"
            percent=system.corruption
            containerClass="wh40k-corruption-bar-container tw-relative tw-h-4 tw-bg-[rgba(0,0,0,0.3)] tw-rounded-md tw-overflow-hidden tw-mb-2"
            fillExtraClass="tw-h-full tw-bg-gradient-to-r tw-from-green-700 tw-to-crimson-dark"
            fillStyleWidth=true
            thresholds=(array
                (object at=30 label="30" title="TAINTED → SOILED (30)")
                (object at=60 label="60" title="SOILED → DEBASED (60)")
                (object at=90 label="90" title="DEBASED → PROFANE (90)"))}}

        {{!-- Warning Messages at Thresholds --}}
        {{#if (eq system.corruption 100)}}
        <div class="wh40k-corruption-alert wh40k-alert-damned tw-text-crimson tw-flex tw-items-center tw-gap-2">
            <i class="fas fa-fire-alt"></i>
            <span>DAMNED - Soul Lost to Chaos!</span>
        </div>
        {{else if (gte system.corruption 90)}}
        <div class="wh40k-corruption-alert wh40k-alert-profane tw-text-crimson-light tw-flex tw-items-center tw-gap-2">
            <i class="fas fa-exclamation-triangle"></i>
            <span>PROFANE - On the Edge of Damnation (-30)</span>
        </div>
        {{else if (gte system.corruption 60)}}
        <div class="wh40k-corruption-alert wh40k-alert-debased tw-text-warning tw-flex tw-items-center tw-gap-2">
            <i class="fas fa-skull-crossbones"></i>
            <span>DEBASED - Deeply Corrupted (-20)</span>
        </div>
        {{/if}}

    </div>

    {{!-- Malignancies Section (always visible if any exist) --}}
    {{#if (any actor.items "isMalignancy")}}
    <div class="wh40k-malignancy-preview tw-mt-2 tw-text-sm tw-text-gray-400">
        <div class="wh40k-malignancy-count tw-flex tw-items-center tw-gap-2">
            <i class="fas fa-biohazard"></i>
            <span>{{countType actor.items "isMalignancy"}} Malignancies</span>
        </div>
    </div>
    {{/if}}

    {{!-- Edit Mode (Expandable) --}}
    <div class="wh40k-panel-details corruption_details tw-mt-2" {{hideIfNot (isExpanded 'corruption_details' actor)}}>

        {{!-- Direct Edit Section --}}
        <div class="wh40k-corruption-edit-section">
            <div class="wh40k-corruption-edit-header">
                <i class="fas fa-cog"></i> Edit Corruption
            </div>

            <div class="wh40k-corruption-edit-field tw-mt-1">
                {{> systems/wh40k-rpg/templates/actor/partial/vital-edit-input
                    name="system.corruption"
                    label="Corruption Points (0-100)"
                    value=source.corruption
                    labelClass="tw-text-xs tw-text-gray-400"
                    inputClass="tw-w-full tw-p-1 tw-rounded"
                    min="0"
                    max="100"
                    placeholder="0"}}
            </div>

            {{!-- Quick Adjust Buttons --}}
            {{> systems/wh40k-rpg/templates/actor/partial/vital-quick-adjust
                field="system.corruption"
                wrapperClass="wh40k-corruption-quick-set tw-flex tw-gap-1 tw-mt-2"
                maxValue="100"}}
        </div>

        {{!-- Malignancies List --}}
        <div class="wh40k-corruption-edit-section tw-mt-4">
            <div class="wh40k-corruption-edit-header">
                <i class="fas fa-biohazard"></i> Malignancies
            </div>

            {{#if (any actor.items "isMalignancy")}}
            <div class="wh40k-malignancy-list tw-space-y-1 tw-mt-1">
                {{#each actor.items as |item|}}
                    {{#if item.isMalignancy}}
                    <div class="wh40k-malignancy-card tw-flex tw-justify-between tw-bg-[rgba(0,0,0,0.2)] tw-p-1 tw-rounded">
                        <button type="button"
                                class="wh40k-malignancy-name item-edit"
                                data-item-id="{{item.id}}"
                                title="Edit {{item.name}}">
                            <i class="fas fa-virus"></i>
                            {{item.name}}
                        </button>
                        <button type="button"
                                class="wh40k-malignancy-delete item-delete"
                                data-item-id="{{item.id}}"
                                title="Remove {{item.name}}">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    {{/if}}
                {{/each}}
            </div>
            {{/if}}

            {{!-- Drop Zone (always visible) --}}
            <div class="wh40k-dropzone {{#unless (any actor.items "isMalignancy")}}wh40k-dropzone-empty{{/unless}} tw-mt-2 tw-border tw-border-dashed tw-border-gray-600 tw-p-2 tw-text-center tw-rounded"
                 data-action="itemCreate"
                 data-type="malignancy">
                <i class="fas fa-shield-alt wh40k-dropzone-icon"></i>
                <span class="wh40k-dropzone-text tw-text-xs">
                    {{#if (any actor.items "isMalignancy")}}
                        Drop Malignancies Here or Click to Create
                    {{else}}
                        No malignancies (yet)
                    {{/if}}
                </span>
            </div>
        </div>

        {{!-- Info Section --}}
        <div class="wh40k-corruption-edit-section tw-mt-4">
            <div class="wh40k-corruption-info-box tw-bg-[rgba(0,0,0,0.2)] tw-p-3 tw-rounded">
                <i class="fas fa-book-dead tw-text-crimson"></i>
                <div class="wh40k-info-content tw-text-xs tw-space-y-1 tw-mt-1">
                    <strong>Corruption Degrees</strong>
                    <ul class="wh40k-degree-list tw-list-none tw-pl-0">
                        <li><span class="wh40k-degree-name">PURE (0):</span> Untainted by Chaos - No penalty</li>
                        <li><span class="wh40k-degree-name">TAINTED (1-30):</span> Minor exposure - No penalty</li>
                        <li><span class="wh40k-degree-name">SOILED (31-60):</span> Visibly corrupted - <strong>-10</strong> to checks</li>
                        <li><span class="wh40k-degree-name">DEBASED (61-90):</span> Deeply fallen - <strong>-20</strong> to checks</li>
                        <li><span class="wh40k-degree-name">PROFANE (91-99):</span> On the edge - <strong>-30</strong> to checks</li>
                        <li><span class="wh40k-degree-name wh40k-degree-damned">DAMNED (100):</span> Soul lost to Chaos - <strong>NPC only</strong></li>
                    </ul>
                    <p class="wh40k-corruption-warning tw-text-gray-400 tw-italic"><i class="fas fa-skull"></i> Malignancies are physical and mental manifestations of Chaos corruption.</p>
                </div>
            </div>
        </div>

    </div>
{{/systems/wh40k-rpg/templates/actor/partial/vital-panel-shell}}
