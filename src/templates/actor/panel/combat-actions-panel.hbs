{{! Combat Actions Panel - Comprehensive Quick Reference }}
<div class="wh40k-panel">
    <div class="wh40k-panel-header">
        <span class="wh40k-panel-title">
            <i class="fas fa-fist-raised"></i>
            Combat Actions
        </span>
    </div>

    <div class="wh40k-panel-body">

        {{! COMBAT TALENTS }}
        {{#if combatTalents.length}}
            <div class="wh40k-combat-actions-group">
                <div class="wh40k-combat-actions-group-header">
                    <i class="fas fa-star wh40k-group-icon"></i>
                    <span class="wh40k-combat-actions-group-label">Combat Talents</span>
                </div>
                <div class="wh40k-combat-actions-grid">
                    {{#each combatTalents as |talent|}}
                        <button
                            type="button"
                            class="wh40k-combat-action-btn wh40k-combat-action-attack"
                            data-action="itemVocalize"
                            data-item-id="{{talent.id}}"
                            data-tooltip
                            aria-label="{{talent.name}}"
                            title="{{talent.name}}"
                        >
                            <i class="fas fa-star"></i>
                            <span class="wh40k-combat-action-name">{{talent.name}}</span>
                            {{#if talent.system.tier}}
                                <span class="wh40k-combat-action-type">T{{talent.system.tier}}</span>
                            {{/if}}
                        </button>
                    {{/each}}
                </div>
            </div>
        {{/if}}

        {{! ATTACK ACTIONS }}
        <div class="wh40k-combat-actions-group">
            <div class="wh40k-combat-actions-group-header">
                <i class="fas fa-crosshairs wh40k-group-icon"></i>
                <span class="wh40k-combat-actions-group-label">Attack Actions</span>
            </div>
            <div class="wh40k-combat-actions-grid">
                {{#each dh.combatActions.attacks as |action|}}
                    <button
                        type="button"
                        class="wh40k-combat-action-btn wh40k-combat-action-attack"
                        data-action="vocalizeCombatAction"
                        data-action-key="{{action.key}}"
                        data-tooltip
                        aria-label="{{localize action.label}}: {{localize action.description}}"
                        title="{{localize action.label}}"
                    >
                        <i class="fas {{action.icon}}"></i>
                        <span class="wh40k-combat-action-name">{{localize action.label}}</span>
                        <span class="wh40k-combat-action-type">{{action.type}}</span>
                    </button>
                {{/each}}
            </div>
        </div>

        {{! MOVEMENT ACTIONS }}
        <div class="wh40k-combat-actions-group">
            <div class="wh40k-combat-actions-group-header">
                <i class="fas fa-walking wh40k-group-icon"></i>
                <span class="wh40k-combat-actions-group-label">Movement Actions</span>
            </div>
            <div class="wh40k-combat-actions-grid">
                {{#each dh.combatActions.movement as |action|}}
                    <button
                        type="button"
                        class="wh40k-combat-action-btn wh40k-combat-action-movement"
                        data-action="vocalizeCombatAction"
                        data-action-key="{{action.key}}"
                        data-tooltip
                        aria-label="{{localize action.label}}: {{localize action.description}}"
                        title="{{localize action.label}}"
                    >
                        <i class="fas {{action.icon}}"></i>
                        <span class="wh40k-combat-action-name">{{localize action.label}}</span>
                        <span class="wh40k-combat-action-type">{{action.type}}</span>
                    </button>
                {{/each}}
            </div>
        </div>

        {{! REACTION ACTIONS }}
        <div class="wh40k-combat-actions-group">
            <div class="wh40k-combat-actions-group-header">
                <i class="fas fa-bolt wh40k-group-icon"></i>
                <span class="wh40k-combat-actions-group-label">Reactions</span>
            </div>
            <div class="wh40k-combat-actions-grid">
                {{! Dodge }}
                <button
                    type="button"
                    class="wh40k-combat-action-btn wh40k-combat-action-reaction"
                    data-action="dodge"
                    data-tooltip
                    aria-label="Dodge: Reaction"
                    title="Dodge"
                >
                    <i class="fas fa-running"></i>
                    <span class="wh40k-combat-action-name">Dodge</span>
                    <span class="wh40k-combat-action-type">Reaction</span>
                </button>
                {{! Parry }}
                <button
                    type="button"
                    class="wh40k-combat-action-btn wh40k-combat-action-reaction"
                    data-action="parry"
                    data-tooltip
                    aria-label="Parry: Reaction"
                    title="Parry"
                >
                    <i class="fas fa-shield-alt"></i>
                    <span class="wh40k-combat-action-name">Parry</span>
                    <span class="wh40k-combat-action-type">Reaction</span>
                </button>
            </div>
        </div>

        {{! UTILITY ACTIONS }}
        <div class="wh40k-combat-actions-group">
            <div class="wh40k-combat-actions-group-header">
                <i class="fas fa-tools wh40k-group-icon"></i>
                <span class="wh40k-combat-actions-group-label">Utility Actions</span>
            </div>
            <div class="wh40k-combat-actions-grid">
                {{! Initiative }}
                <button
                    type="button"
                    class="wh40k-combat-action-btn wh40k-combat-action-utility"
                    data-action="initiative"
                    title="Roll Initiative (Current: {{system.initiative.total}})"
                >
                    <i class="fas fa-dice-d20"></i>
                    <span class="wh40k-action-name">Initiative</span>
                    <span class="wh40k-action-value">
                        {{system.initiative.total}}
                    </span>
                </button>
                {{! Assign Damage }}
                <button type="button" class="wh40k-combat-action-btn wh40k-combat-action-utility" data-action="assign-damage" title="Assign Damage">
                    <i class="fas fa-heart-broken"></i>
                    <span class="wh40k-combat-action-name">Assign Damage</span>
                    <span class="wh40k-combat-action-type">Tool</span>
                </button>
                {{! Other utility actions from config }}
                {{#each dh.combatActions.utility as |action|}}
                    <button
                        type="button"
                        class="wh40k-combat-action-btn wh40k-combat-action-utility"
                        data-action="vocalizeCombatAction"
                        data-action-key="{{action.key}}"
                        data-tooltip
                        aria-label="{{localize action.label}}: {{localize action.description}}"
                        title="{{localize action.label}}"
                    >
                        <i class="fas {{action.icon}}"></i>
                        <span class="wh40k-combat-action-name">{{localize action.label}}</span>
                        <span class="wh40k-combat-action-type">{{action.type}}</span>
                    </button>
                {{/each}}
            </div>
        </div>

        {{! Info Note }}
        <div class="wh40k-combat-actions-info">
            <i class="fas fa-info-circle"></i>
            <span>Click any action for a detailed description. Action types:
                <strong>Half</strong>
                (½ turn),
                <strong>Full</strong>
                (full turn),
                <strong>Reaction</strong>
                (out of turn).</span>
        </div>
    </div>
</div>