                {{! Other utility actions from config }}
                {{#each dh.combatActions.utility as |action|}}
                    <button
                        type="button"
                        class="wh40k-combat-action-btn wh40k-combat-action-utility tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-xs)] tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-bg-paper)] tw-border tw-border-solid tw-border-[var(--wh40k-border-light)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer tw-transition-all tw-min-h-[80px] tw-relative tw-overflow-hidden [--action-color:var(--wh40k-accent-talents)] hover:tw-border-[color:var(--action-color)] hover:tw-translate-y-[-2px] hover:tw-shadow-[0_2px_6px_rgba(0,0,0,0.08)] active:tw-translate-y-0"
                        data-action="vocalizeCombatAction"
                        data-action-key="{{action.key}}"
                        data-tooltip
                        aria-label="{{localize action.label}}: {{localize action.description}}"
                        title="{{localize action.label}}"
                    >
                        <i class="fas {{action.icon}} tw-text-[1.1rem] tw-text-[color:var(--action-color)] tw-transition-all"></i>
                        <span class="wh40k-combat-action-name tw-text-[0.65rem] tw-font-semibold tw-text-center tw-leading-[1.2] tw-text-[color:var(--wh40k-text-primary)]">{{localize action.label}}</span>
                        <span class="wh40k-combat-action-type tw-text-[0.55rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--action-color)] tw-opacity-80">{{action.type}}</span>
                    </button>
                {{/each}}
            </div>
        </div>

        {{! Info Note }}
        <div class="wh40k-combat-actions-info tw-flex tw-items-start tw-gap-[var(--wh40k-space-xs)] tw-p-[var(--wh40k-space-sm)] tw-mt-[var(--wh40k-space-md)] tw-bg-[rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.06)] tw-border tw-border-solid tw-border-[rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.15)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.65rem] tw-leading-[1.4] tw-text-[color:var(--wh40k-text-secondary)]">
            <i class="fas fa-info-circle tw-text-[0.75rem] tw-text-[color:var(--wh40k-accent-gold)] tw-shrink-0 tw-mt-[2px]"></i>
            <span>Click any action for a detailed description. Action types:
                <strong class="tw-text-[color:var(--wh40k-text-primary)] tw-font-bold">Half</strong>
                (½ turn),
                <strong class="tw-text-[color:var(--wh40k-text-primary)] tw-font-bold">Full</strong>
                (full turn),
                <strong class="tw-text-[color:var(--wh40k-text-primary)] tw-font-bold">Reaction</strong>
                (out of turn).</span>
        </div>
    </div>
</div>