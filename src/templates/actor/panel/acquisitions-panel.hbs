{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs
    label=(localize "WH40K.Acquisitions.Header")
    rootClass="tw-col-span-6"}}
    <div class="tw-rounded-[6px] tw-overflow-hidden tw-border tw-border-solid">
        {{!-- Header row: Name | Availability | Modifier | Acquired | Notes | Action --}}
        <div class="tw-grid tw-grid-cols-[2fr_1fr_1fr_1fr_2fr_auto] tw-items-center tw-text-[0.9em] tw-uppercase tw-tracking-[0.05em] tw-px-[4px] tw-py-[6px]">
            <div class="tw-px-[4px] tw-py-[6px]">{{localize "WH40K.Acquisitions.Name"}}</div>
            <div class="tw-px-[4px] tw-py-[6px]">{{localize "WH40K.Acquisitions.Availability"}}</div>
            <div class="tw-px-[4px] tw-py-[6px]">{{localize "WH40K.Acquisitions.Modifier"}}</div>
            <div class="tw-px-[4px] tw-py-[6px]">{{localize "WH40K.Acquisitions.Acquired"}}</div>
            <div class="tw-px-[4px] tw-py-[6px]">{{localize "WH40K.Acquisitions.Notes"}}</div>
            <div class="tw-px-[4px] tw-py-[6px]">
                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-cursor-pointer tw-bg-transparent tw-border-none tw-p-0 tw-opacity-70 tw-transition-[opacity,transform] tw-duration-200 hover:tw-opacity-100 hover:tw-scale-110" data-action="addAcquisition">
                    <span class="{{concat 'material-icons'}}">add_circle</span>
                </button>
            </div>
        </div>
        {{#each system.rogueTrader.acquisitions as |acquisition index|}}
            <div class="tw-grid tw-grid-cols-[2fr_1fr_1fr_1fr_2fr_auto] tw-items-center">
                <div class="tw-px-[4px] tw-py-[6px]">
                    <input class="tw-w-full" type="text" name="system.rogueTrader.acquisitions.{{index}}.name" value="{{acquisition.name}}" />
                </div>
                <div class="tw-px-[4px] tw-py-[6px]">
                    <input
                        class="tw-w-full"
                        type="text"
                        name="system.rogueTrader.acquisitions.{{index}}.availability"
                        value="{{acquisition.availability}}"
                    />
                </div>
                <div class="tw-px-[4px] tw-py-[6px]">
                    <input
                        class="tw-w-full"
                        type="number"
                        data-dtype="Number"
                        name="system.rogueTrader.acquisitions.{{index}}.modifier"
                        value="{{acquisition.modifier}}"
                    />
                </div>
                <div class="tw-text-center tw-px-[4px] tw-py-[6px]">
                    <input type="checkbox" data-dtype="Boolean" name="system.rogueTrader.acquisitions.{{index}}.acquired" {{checked acquisition.acquired}} />
                </div>
                <div class="tw-px-[4px] tw-py-[6px]">
                    <input class="tw-w-full" type="text" name="system.rogueTrader.acquisitions.{{index}}.notes" value="{{acquisition.notes}}" />
                </div>
                <div class="tw-px-[4px] tw-py-[6px]">
                    <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-cursor-pointer tw-bg-transparent tw-border-none tw-p-0 tw-opacity-70 tw-transition-[opacity,transform] tw-duration-200 hover:tw-opacity-100 hover:tw-scale-110" data-action="removeAcquisition" data-index="{{index}}">
                        <span class="{{concat 'material-icons'}}">delete</span>
                    </button>
                </div>
            </div>
        {{/each}}
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
