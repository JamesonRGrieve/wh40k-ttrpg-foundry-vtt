{{! Armour Display Panel - Character Body Silhouette Layout }}
<div class="wh40k-panel wh40k-armour-panel">
    <div class="wh40k-panel-header">
        <span class="wh40k-panel-title"><i class="fas fa-shield-alt"></i> Armour Points</span>
    </div>
    <div class="wh40k-panel-body">
        <div class="wh40k-armour-silhouette">
            {{! Head (centered at top) }}
            <div class="wh40k-armour-box wh40k-box-head" data-location="head" data-roll-min="1" data-roll-max="10" title="Head - Roll: 01-10">
                <span class="wh40k-box-label">Head</span>
                <span class="wh40k-box-ap">{{system.armour.head.total}}</span>
                <span class="wh40k-box-range">01-10</span>
            </div>

            {{! Right Arm (left side of screen, character's right) }}
            <div class="wh40k-armour-box wh40k-box-right-arm" data-location="rightArm" data-roll-min="11" data-roll-max="20" title="Right Arm - Roll: 11-20">
                <span class="wh40k-box-label">R.Arm</span>
                <span class="wh40k-box-ap">{{system.armour.rightArm.total}}</span>
                <span class="wh40k-box-range">11-20</span>
            </div>

            {{! Left Arm (right side of screen, character's left) }}
            <div class="wh40k-armour-box wh40k-box-left-arm" data-location="leftArm" data-roll-min="21" data-roll-max="30" title="Left Arm - Roll: 21-30">
                <span class="wh40k-box-label">L.Arm</span>
                <span class="wh40k-box-ap">{{system.armour.leftArm.total}}</span>
                <span class="wh40k-box-range">21-30</span>
            </div>

            {{! Body (center, largest box) }}
            <div class="wh40k-armour-box wh40k-box-body" data-location="body" data-roll-min="31" data-roll-max="70" title="Body - Roll: 31-70">
                <span class="wh40k-box-label">Body</span>
                <span class="wh40k-box-ap">{{system.armour.body.total}}</span>
                <span class="wh40k-box-range">31-70</span>
            </div>

            {{! Right Leg (left side of screen, character's right) }}
            <div class="wh40k-armour-box wh40k-box-right-leg" data-location="rightLeg" data-roll-min="71" data-roll-max="85" title="Right Leg - Roll: 71-85">
                <span class="wh40k-box-label">R.Leg</span>
                <span class="wh40k-box-ap">{{system.armour.rightLeg.total}}</span>
                <span class="wh40k-box-range">71-85</span>
            </div>

            {{! Left Leg (right side of screen, character's left) }}
            <div class="wh40k-armour-box wh40k-box-left-leg" data-location="leftLeg" data-roll-min="86" data-roll-max="100" title="Left Leg - Roll: 86-00">
                <span class="wh40k-box-label">L.Leg</span>
                <span class="wh40k-box-ap">{{system.armour.leftLeg.total}}</span>
                <span class="wh40k-box-range">86-00</span>
            </div>
        </div>
    </div>
</div>