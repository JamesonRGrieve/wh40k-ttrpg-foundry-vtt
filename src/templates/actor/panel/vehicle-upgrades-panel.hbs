{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs label=(localize "WH40K.Vehicle.Upgrades.Header") icon="fa-cogs" rootClass="tw-col-span-6 tw-row-span-1" bodyClass="tw-p-0"}}
    {{#> systems/wh40k-rpg/templates/actor/partial/item-table.hbs
        addAction="itemCreate"
        addType="vehicleUpgrade"
        addTitleKey="WH40K.Common.AddVehicleUpgrade"
        headers=(array
            (object cellClass="table-cell--span2" labelKey="WH40K.Vehicle.Upgrades.Name")
            (object labelKey="WH40K.VehicleUpgrade.Type")
            (object labelKey="WH40K.VehicleUpgrade.Difficulty")
            (object cellClass="table-cell--span2" labelKey="WH40K.Vehicle.Upgrades.Modifiers"))}}
        {{#each upgrades as |item|}}
            {{#> systems/wh40k-rpg/templates/actor/partial/item-table-row.hbs
                item=item
                showImg=true
                editAction=false
                cells=(array
                    (object value=item.system.upgradeTypeLabel)
                    (object value=item.system.difficultyFormatted)
                    (object cellClass="table-cell--span2 tw-flex tw-flex-col tw-gap-0.5" isHtml=true value=item.system.modifiersHtml))
                actions=(array
                    (object action="itemDelete" iconKey="fa:trash" titleKey="WH40K.Common.Delete"))}}
            {{/systems/wh40k-rpg/templates/actor/partial/item-table-row.hbs}}
        {{/each}}
    {{/systems/wh40k-rpg/templates/actor/partial/item-table.hbs}}
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}
