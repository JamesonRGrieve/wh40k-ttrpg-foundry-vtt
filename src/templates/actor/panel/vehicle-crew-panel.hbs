{{! Vehicle Crew Panel }}
{{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs label=(localize "WH40K.Vehicle.Crew") icon="fa-users" rootClass="tw-col-span-2" bodyClass="tw-p-0"}}
    <div class="tw-flex tw-flex-col tw-gap-2 tw-p-2">
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Vehicle.Crew.Required"}}</span>
            <input
                type="number"
                data-dtype="Number"
                class="wh40k-field__input"
                name="system.crew.required"
                value="{{source.crew.required}}"
                min="0"
                placeholder="1"
            />
        </div>
        <div class="wh40k-field__wrapper">
            <span class="wh40k-field__header">{{localize "WH40K.Vehicle.Passengers"}}</span>
            <input type="number" data-dtype="Number" class="wh40k-field__input" name="system.passengers" value="{{source.passengers}}" min="0" placeholder="0" />
        </div>
        <div class="wh40k-field__wrapper tw-col-span-full">
            <span class="wh40k-field__header">{{localize "WH40K.Vehicle.Crew.Notes"}}</span>
            <textarea
                class="wh40k-field__textarea tw-w-full tw-min-h-[4.5rem]"
                name="system.crew.notes"
                rows="3"
                placeholder="Crew positions, roles, requirements..."
            >{{system.crew.notes}}</textarea>
        </div>
    </div>
{{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}