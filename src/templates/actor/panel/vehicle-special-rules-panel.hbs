{{! Vehicle Special Rules Panel }}
<div class="rt-panel spacer rt-grid-col-6">
    <h1 class="rt-panel-header">
        <i class="fas fa-scroll"></i>
        {{localize "WH40K.Vehicle.SpecialRules"}}
    </h1>
    <div class="rt-special-rules-section">
        <div class="rt-editor">
            {{editor system.specialRules target="system.specialRules" button=true editable=editable}}
        </div>
        <small class="rt-field__hint">{{localize "WH40K.Vehicle.SpecialRules.Hint"}}</small>
    </div>
</div>