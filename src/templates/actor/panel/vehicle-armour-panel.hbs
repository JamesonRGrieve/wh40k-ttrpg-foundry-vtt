<div class="wh40k-panel spacer wh40k-grid-col-3">
    <h1 class="wh40k-panel-header">
        <i class="fas fa-shield-alt"></i>
        {{localize "WH40K.Vehicle.Armour"}}
    </h1>
    <div class="wh40k-vehicle-armour-grid">
        <div class="wh40k-armour-facing">
            <span class="wh40k-field__header">{{localize "WH40K.Vehicle.Armour.Front"}}</span>
            <div class="wh40k-field__wrapper">
                <input
                    type="number"
                    data-dtype="Number"
                    class="wh40k-field__input"
                    name="system.armour.front.value"
                    value="{{source.armour.front.value}}"
                    placeholder="0"
                />
                <input
                    type="text"
                    class="wh40k-field__input wh40k-field__descriptor"
                    name="system.armour.front.descriptor"
                    value="{{source.armour.front.descriptor}}"
                    placeholder="Descriptor"
                />
            </div>
        </div>
        <div class="wh40k-armour-facing">
            <span class="wh40k-field__header">{{localize "WH40K.Vehicle.Armour.Side"}}</span>
            <div class="wh40k-field__wrapper">
                <input
                    type="number"
                    data-dtype="Number"
                    class="wh40k-field__input"
                    name="system.armour.side.value"
                    value="{{source.armour.side.value}}"
                    placeholder="0"
                />
                <input
                    type="text"
                    class="wh40k-field__input wh40k-field__descriptor"
                    name="system.armour.side.descriptor"
                    value="{{source.armour.side.descriptor}}"
                    placeholder="Descriptor"
                />
            </div>
        </div>
        <div class="wh40k-armour-facing">
            <span class="wh40k-field__header">{{localize "WH40K.Vehicle.Armour.Rear"}}</span>
            <div class="wh40k-field__wrapper">
                <input
                    type="number"
                    data-dtype="Number"
                    class="wh40k-field__input"
                    name="system.armour.rear.value"
                    value="{{source.armour.rear.value}}"
                    placeholder="0"
                />
                <input
                    type="text"
                    class="wh40k-field__input wh40k-field__descriptor"
                    name="system.armour.rear.descriptor"
                    value="{{source.armour.rear.descriptor}}"
                    placeholder="Descriptor"
                />
            </div>
        </div>
    </div>
    <div class="wh40k-armour-summary">
        <strong>Summary:</strong>
        {{system.armourSummary}}
    </div>
</div>