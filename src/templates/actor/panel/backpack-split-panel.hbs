{{!-- Backpack Split Panel - Personal & Ship Storage --}}
{{!-- Checkbox selection with swap button --}}

<div class="wh40k-panel wh40k-panel-backpack-split">
    {{!-- Panel Header with Encumbrance Bar --}}
    <div class="wh40k-panel-header">
        <span class="wh40k-panel-title"><i class="fas fa-boxes"></i> Inventory</span>
        <div class="wh40k-encumbrance-display">
            <span class="wh40k-enc-label">Carry:</span>
            <div class="wh40k-encumbrance-bar-container">
                <div class="wh40k-encumbrance-bar-fill {{#if (gte encumbrancePercent 100)}}wh40k-enc-danger{{else if (gte encumbrancePercent 75)}}wh40k-enc-warning{{else if (gte encumbrancePercent 50)}}wh40k-enc-caution{{/if}}"
                     style="width: {{encumbrancePercent}}%"></div>
            </div>
            <span class="wh40k-enc-value">{{actor.encumbrance.current}} / {{actor.encumbrance.max}} kg</span>
            {{#if actor.encumbrance.encumbered}}
            <i class="fas fa-exclamation-triangle wh40k-enc-alert" title="Encumbered!"></i>
            {{/if}}
        </div>
    </div>

    {{!-- Split Panel Body --}}
    <div class="wh40k-panel-body wh40k-split-container">
        {{!-- LEFT: Backpack --}}
        <div class="wh40k-split-column wh40k-backpack-inventory">
            <div class="wh40k-column-header">
                <i class="fas fa-suitcase"></i>
                <span>Backpack</span>
                <span class="wh40k-item-badge">{{allCarriedItems.length}}</span>
            </div>
            <div class="wh40k-column-body">
                {{#if allCarriedItems.length}}
                <div class="wh40k-inventory-table">
                    <table class="wh40k-item-table">
                        <thead>
                            <tr>
                                <th class="wh40k-col-check"></th>
                                <th class="wh40k-col-icon"></th>
                                <th class="wh40k-col-name">Item</th>
                                <th class="wh40k-col-type">Type</th>
                                <th class="wh40k-col-weight">Weight</th>
                                <th class="wh40k-col-actions"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each allCarriedItems as |item|}}
                            <tr class="wh40k-backpack-item-row"
                                data-item-id="{{item.id}}"
                                data-item-type="{{item.type}}"
                                data-disable-drag="true"
                                draggable="false">
                                <td class="wh40k-col-check">
                                    <input type="checkbox" class="wh40k-transfer-check" data-item-id="{{item.id}}" />
                                </td>
                                <td class="wh40k-col-icon">
                                    <img src="{{item.img}}" alt="{{item.name}}" class="wh40k-item-icon" />
                                </td>
                                <td class="wh40k-col-name">
                                    <button type="button" class="wh40k-item-name" data-action="itemEdit" data-item-id="{{item.id}}" title="{{item.name}}">
                                        {{item.name}}
                                    </button>
                                </td>
                                <td class="wh40k-col-type">
                                    <span class="wh40k-item-type">{{item.type}}</span>
                                </td>
                                <td class="wh40k-col-weight">
                                    {{#if item.system.weight}}
                                    <span class="wh40k-item-weight">{{item.system.weight}}kg</span>
                                    {{else}}
                                    <span class="wh40k-item-weight wh40k-weight-none">—</span>
                                    {{/if}}
                                </td>
                                <td class="wh40k-col-actions">
                                    <button type="button" class="wh40k-inv-btn wh40k-inv-danger" data-action="itemDelete" data-item-id="{{item.id}}" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <div class="wh40k-empty-state">
                    <i class="fas fa-box-open wh40k-empty-icon"></i>
                    <p class="wh40k-empty-text">No items in backpack</p>
                    <p class="wh40k-empty-hint">Select items from ship storage and click the swap button</p>
                </div>
                {{/if}}
            </div>
        </div>

        {{!-- DIVIDER with Give To + Swap Buttons --}}
        <div class="wh40k-split-divider">
            <div class="wh40k-divider-line"></div>
            <button type="button" class="wh40k-divider-icon wh40k-divider-give" data-action="giveCheckedItems" title="Give selected items to another character">
                <i class="fas fa-hand-holding"></i>
            </button>
            <button type="button" class="wh40k-divider-icon" data-action="swapCheckedItems" title="Move selected items between backpack and ship">
                <i class="fas fa-exchange-alt"></i>
            </button>
            <div class="wh40k-divider-line"></div>
        </div>

        {{!-- RIGHT: Ship Storage --}}
        <div class="wh40k-split-column wh40k-ship-storage">
            <div class="wh40k-column-header">
                <i class="fas fa-rocket"></i>
                <span>Ship Storage</span>
                <span class="wh40k-item-badge">{{allShipItems.length}}</span>
            </div>
            <div class="wh40k-column-body">
                {{#if allShipItems.length}}
                <div class="wh40k-inventory-table">
                    <table class="wh40k-item-table">
                        <thead>
                            <tr>
                                <th class="wh40k-col-check"></th>
                                <th class="wh40k-col-icon"></th>
                                <th class="wh40k-col-name">Item</th>
                                <th class="wh40k-col-type">Type</th>
                                <th class="wh40k-col-weight">Weight</th>
                                <th class="wh40k-col-actions"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each allShipItems as |item|}}
                            <tr class="wh40k-backpack-item-row wh40k-row-ship"
                                data-item-id="{{item.id}}"
                                data-item-type="{{item.type}}"
                                data-disable-drag="true"
                                draggable="false">
                                <td class="wh40k-col-check">
                                    <input type="checkbox" class="wh40k-transfer-check" data-item-id="{{item.id}}" />
                                </td>
                                <td class="wh40k-col-icon">
                                    <img src="{{item.img}}" alt="{{item.name}}" class="wh40k-item-icon" />
                                </td>
                                <td class="wh40k-col-name">
                                    <button type="button" class="wh40k-item-name" data-action="itemEdit" data-item-id="{{item.id}}" title="{{item.name}}">
                                        {{item.name}}
                                    </button>
                                </td>
                                <td class="wh40k-col-type">
                                    <span class="wh40k-item-type">{{item.type}}</span>
                                </td>
                                <td class="wh40k-col-weight">
                                    {{#if item.system.weight}}
                                    <span class="wh40k-item-weight">{{item.system.weight}}kg</span>
                                    {{else}}
                                    <span class="wh40k-item-weight wh40k-weight-none">—</span>
                                    {{/if}}
                                </td>
                                <td class="wh40k-col-actions">
                                    <button type="button" class="wh40k-inv-btn wh40k-inv-danger" data-action="itemDelete" data-item-id="{{item.id}}" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <div class="wh40k-empty-state">
                    <i class="fas fa-rocket wh40k-empty-icon"></i>
                    <p class="wh40k-empty-text">No items in ship storage</p>
                    <p class="wh40k-empty-hint">Select items from backpack and click the swap button</p>
                </div>
                {{/if}}
            </div>
        </div>
    </div>

</div>
