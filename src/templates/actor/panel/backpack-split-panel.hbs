{{!-- Backpack Split Panel - Personal & Ship Storage --}}
{{!-- Checkbox selection with swap button --}}

<div class="wh40k-panel tw-flex tw-flex-col tw-flex-1 tw-min-h-0">
    {{!-- Panel Header with Encumbrance Bar --}}
    <div class="wh40k-panel-header">
        <div class="tw-flex tw-items-center tw-gap-3">
            {{> systems/wh40k-rpg/templates/actor/partial/panel-header.hbs label="Inventory" icon="fa-boxes"}}
        </div>
        <div class="tw-flex tw-items-center tw-gap-2 tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-secondary)]">
            <span>Carry:</span>
            <div class="tw-relative tw-h-2 tw-w-24 tw-rounded-full tw-bg-[var(--wh40k-bg-input)] tw-border tw-border-[var(--wh40k-border-light)] tw-overflow-hidden">
                <div class="tw-h-full tw-rounded-full tw-transition-all {{#if (gte encumbrancePercent 100)}}tw-bg-accent-combat{{else if (gte encumbrancePercent 75)}}tw-bg-yellow-500{{else if (gte encumbrancePercent 50)}}tw-bg-yellow-400{{else}}tw-bg-success{{/if}}"
                     style="width: {{encumbrancePercent}}%"></div>
            </div>
            <span>{{actor.encumbrance.value}} / {{actor.encumbrance.max}} kg</span>
            {{#if actor.encumbrance.encumbered}}
            <i class="fas fa-exclamation-triangle tw-text-accent-combat tw-animate-pulse-glow" title="Encumbered!"></i>
            {{/if}}
        </div>
    </div>

    {{!-- Split Panel Body --}}
    <div class="wh40k-panel-body tw-flex tw-gap-3 tw-flex-1 tw-min-h-0">
        {{!-- LEFT: Backpack --}}
        <div class="tw-flex tw-flex-col tw-flex-1 tw-min-w-0">
            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2 tw-pb-1 tw-border-b tw-border-[var(--wh40k-border-light)] tw-text-[0.75rem] tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-secondary)]">
                <i class="fas fa-suitcase"></i>
                <span>Backpack</span>
                <span class="tw-ml-auto tw-rounded-full tw-bg-[var(--wh40k-bg-input)] tw-px-1.5 tw-py-0.5 tw-text-[0.65rem] tw-font-bold">{{allCarriedItems.length}}</span>
            </div>
            <div class="tw-flex-1 tw-overflow-y-auto tw-min-h-0">
                {{#if allCarriedItems.length}}
                <div class="tw-w-full tw-overflow-x-auto">
                    <table class="tw-w-full tw-text-[0.78rem] tw-border-collapse">
                        <thead>
                            <tr>
                                <th class="tw-w-6 tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold"></th>
                                <th class="tw-w-6 tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold"></th>
                                <th class="tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Item</th>
                                <th class="tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Type</th>
                                <th class="tw-p-1 tw-text-right tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Weight</th>
                                <th class="tw-w-8 tw-p-1 tw-border-b tw-border-[rgba(255,255,255,0.1)]"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each allCarriedItems as |item|}}
                            <tr class="tw-border-b tw-border-[rgba(255,255,255,0.04)] hover:tw-bg-[rgba(255,255,255,0.03)] tw-transition-colors"
                                data-item-id="{{item.id}}"
                                data-item-type="{{item.type}}"
                                data-disable-drag="true"
                                draggable="false">
                                <td class="tw-p-1 tw-align-middle">
                                    <input type="checkbox" data-item-id="{{item.id}}" />
                                </td>
                                <td class="tw-p-1 tw-align-middle">
                                    <img src="{{item.img}}" alt="{{item.name}}" class="tw-w-[22px] tw-h-[22px] tw-object-cover tw-rounded" />
                                </td>
                                <td class="tw-p-1 tw-align-middle">
                                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-text-[color:var(--color-text-primary)] tw-text-left tw-p-0 tw-max-w-[120px] tw-truncate tw-block hover:tw-text-gold" data-action="itemEdit" data-item-id="{{item.id}}" title="{{item.name}}">
                                        {{item.name}}
                                    </button>
                                </td>
                                <td class="tw-p-1 tw-align-middle tw-text-[color:var(--wh40k-text-muted)] tw-capitalize">
                                    <span>{{item.type}}</span>
                                </td>
                                <td class="tw-p-1 tw-align-middle tw-text-right">
                                    {{#if item.system.weight}}
                                    <span>{{item.system.weight}}kg</span>
                                    {{else}}
                                    <span class="tw-text-[color:var(--wh40k-text-muted)] tw-italic">—</span>
                                    {{/if}}
                                </td>
                                <td class="tw-p-1 tw-align-middle tw-whitespace-nowrap tw-text-right">
                                    {{!-- Equip toggle for every equippable carried item — gear (auspex,
                                         rebreather, micro-bead), armour, cybernetics, weapons, force fields
                                         (#332). Gated on system.state, which only EquippableTemplate items
                                         carry, so consumables/ammunition show no toggle. --}}
                                    {{#if item.system.state}}
                                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-0.5 tw-mr-1 {{#if item.system.state.equipped}}tw-text-gold{{else}}tw-text-[color:var(--wh40k-text-muted)]{{/if}} hover:tw-text-gold" data-action="toggleEquip" data-item-id="{{item.id}}" title="{{#if item.system.state.equipped}}{{localize 'WH40K.Equipment.Unequip'}}{{else}}{{localize 'WH40K.Equipment.Equip'}}{{/if}}" aria-label="{{#if item.system.state.equipped}}{{localize 'WH40K.Equipment.Unequip'}}{{else}}{{localize 'WH40K.Equipment.Equip'}}{{/if}}">
                                        <i class="fas {{#if item.system.state.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}} tw-text-[0.75rem]"></i>
                                    </button>
                                    {{/if}}
                                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-0.5 tw-mr-1 tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-gold" data-action="dropItem" data-item-id="{{item.id}}" title="{{localize 'WH40K.Loot.Drop'}}" aria-label="{{localize 'WH40K.Loot.Drop'}}">
                                        <i class="fas fa-arrow-down tw-text-[0.75rem]"></i>
                                    </button>
                                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-0.5 tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-accent-combat" data-action="itemDelete" data-item-id="{{item.id}}" title="{{localize 'WH40K.Common.Delete'}}" aria-label="{{localize 'WH40K.Common.Delete'}}">
                                        <i class="fas fa-trash tw-text-[0.75rem]"></i>
                                    </button>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-center tw-opacity-70">
                    <i class="fas fa-box-open tw-text-[2rem] tw-mb-2 tw-opacity-50"></i>
                    <p class="tw-italic tw-opacity-70 tw-text-sm tw-m-0">No items in backpack</p>
                    <p class="tw-text-[0.75rem] tw-italic tw-mt-1 tw-text-[color:var(--wh40k-text-muted)] tw-m-0">Select items from ship storage and click the swap button</p>
                </div>
                {{/if}}
            </div>
        </div>

        {{!-- DIVIDER with Give To + Swap Buttons --}}
        <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-2 tw-py-2">
            <div class="tw-flex-1 tw-w-px tw-bg-[var(--wh40k-border-light)]"></div>
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-full tw-bg-[var(--wh40k-bg-paper)] tw-border tw-border-[var(--wh40k-border-light)] tw-cursor-pointer tw-text-[color:var(--wh40k-text-secondary)] hover:tw-border-gold hover:tw-text-gold tw-transition-all" data-action="giveCheckedItems" title="Give selected items to another character">
                <i class="fas fa-hand-holding tw-text-[0.85rem]"></i>
            </button>
            <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-full tw-bg-[var(--wh40k-bg-paper)] tw-border tw-border-[var(--wh40k-border-light)] tw-cursor-pointer tw-text-[color:var(--wh40k-text-secondary)] hover:tw-border-gold hover:tw-text-gold tw-transition-all" data-action="swapCheckedItems" title="Move selected items between backpack and ship">
                <i class="fas fa-exchange-alt tw-text-[0.85rem]"></i>
            </button>
            <div class="tw-flex-1 tw-w-px tw-bg-[var(--wh40k-border-light)]"></div>
        </div>

        {{!-- RIGHT: Ship Storage --}}
        <div class="tw-flex tw-flex-col tw-flex-1 tw-min-w-0">
            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2 tw-pb-1 tw-border-b tw-border-[var(--wh40k-border-light)] tw-text-[0.75rem] tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-secondary)]">
                <i class="fas fa-rocket"></i>
                <span>Ship Storage</span>
                <span class="tw-ml-auto tw-rounded-full tw-bg-[var(--wh40k-bg-input)] tw-px-1.5 tw-py-0.5 tw-text-[0.65rem] tw-font-bold">{{allShipItems.length}}</span>
            </div>
            <div class="tw-flex-1 tw-overflow-y-auto tw-min-h-0">
                {{#if allShipItems.length}}
                <div class="tw-w-full tw-overflow-x-auto">
                    <table class="tw-w-full tw-text-[0.78rem] tw-border-collapse">
                        <thead>
                            <tr>
                                <th class="tw-w-6 tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold"></th>
                                <th class="tw-w-6 tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold"></th>
                                <th class="tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Item</th>
                                <th class="tw-p-1 tw-text-left tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Type</th>
                                <th class="tw-p-1 tw-text-right tw-text-[0.65rem] tw-uppercase tw-tracking-wide tw-text-[color:var(--wh40k-text-muted)] tw-border-b tw-border-[rgba(255,255,255,0.1)] tw-font-semibold">Weight</th>
                                <th class="tw-w-8 tw-p-1 tw-border-b tw-border-[rgba(255,255,255,0.1)]"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each allShipItems as |item|}}
                            <tr class="tw-border-b tw-border-[rgba(255,255,255,0.04)] hover:tw-bg-[rgba(255,255,255,0.03)] tw-transition-colors"
                                data-item-id="{{item.id}}"
                                data-item-type="{{item.type}}"
                                data-disable-drag="true"
                                draggable="false">
                                <td class="tw-p-1 tw-align-middle">
                                    <input type="checkbox" data-item-id="{{item.id}}" />
                                </td>
                                <td class="tw-p-1 tw-align-middle">
                                    <img src="{{item.img}}" alt="{{item.name}}" class="tw-w-[22px] tw-h-[22px] tw-object-cover tw-rounded" />
                                </td>
                                <td class="tw-p-1 tw-align-middle">
                                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-text-[color:var(--color-text-primary)] tw-text-left tw-p-0 tw-max-w-[120px] tw-truncate tw-block hover:tw-text-gold" data-action="itemEdit" data-item-id="{{item.id}}" title="{{item.name}}">
                                        {{item.name}}
                                    </button>
                                </td>
                                <td class="tw-p-1 tw-align-middle tw-text-[color:var(--wh40k-text-muted)] tw-capitalize">
                                    <span>{{item.type}}</span>
                                </td>
                                <td class="tw-p-1 tw-align-middle tw-text-right">
                                    {{#if item.system.weight}}
                                    <span>{{item.system.weight}}kg</span>
                                    {{else}}
                                    <span class="tw-text-[color:var(--wh40k-text-muted)] tw-italic">—</span>
                                    {{/if}}
                                </td>
                                <td class="tw-p-1 tw-align-middle tw-whitespace-nowrap tw-text-right">
                                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-0.5 tw-mr-1 tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-gold" data-action="dropItem" data-item-id="{{item.id}}" title="{{localize 'WH40K.Loot.Drop'}}" aria-label="{{localize 'WH40K.Loot.Drop'}}">
                                        <i class="fas fa-arrow-down tw-text-[0.75rem]"></i>
                                    </button>
                                    <button type="button" class="tw-bg-transparent tw-border-none tw-cursor-pointer tw-p-0.5 tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-accent-combat" data-action="itemDelete" data-item-id="{{item.id}}" title="{{localize 'WH40K.Common.Delete'}}" aria-label="{{localize 'WH40K.Common.Delete'}}">
                                        <i class="fas fa-trash tw-text-[0.75rem]"></i>
                                    </button>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-center tw-opacity-70">
                    <i class="fas fa-rocket tw-text-[2rem] tw-mb-2 tw-opacity-50"></i>
                    <p class="tw-italic tw-opacity-70 tw-text-sm tw-m-0">No items in ship storage</p>
                    <p class="tw-text-[0.75rem] tw-italic tw-mt-1 tw-text-[color:var(--wh40k-text-muted)] tw-m-0">Select items from backpack and click the swap button</p>
                </div>
                {{/if}}
            </div>
        </div>
    </div>

</div>
