{{!--
    Combat action group — a labelled section header (gradient bar + FA icon +
    uppercase title) above a responsive grid of square action buttons. Used by
    combat-actions-panel for every action cluster (talents / attacks / movement /
    reactions / utility). Replaces ~6 copy-pasted section blocks.

    Block-partial usage (manual buttons rendered into the same grid before/after
    the iterated collection):
        {{#> systems/wh40k-rpg/templates/actor/panel/combat-action-group.hbs
            heading=(localize "WH40K.…") icon="fa-bolt" actionColor="--wh40k-accent-skills"}}
            … hand-authored <button>s …
        {{/ systems/wh40k-rpg/templates/actor/panel/combat-action-group.hbs}}

    Hash arguments:
        heading      — section heading text (required; caller localises).
        icon         — FA class for the section-header icon (e.g. "fa-star").
        items        — collection to iterate. Each entry is rendered as a button
                       per `mode`. Optional (sections may be block-only).
        mode         — "item" (talent items: data-item-id, plain name) or
                       "action" (combat actions: data-action-key, localized
                       label/description, type badge). Default "action".
        dataAction   — `data-action` value for iterated buttons
                       ("itemVocalize" for talents, "vocalizeCombatAction"
                       for combat actions).
        actionColor  — CSS custom-property name driving --action-color
                       (e.g. "--wh40k-accent-combat"). Default
                       "--wh40k-accent-combat".

    The outer section is unconditional; callers that should hide an empty
    cluster wrap the include in their own `{{#if items.length}}`.
--}}
<div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)] tw-mb-[var(--wh40k-space-md)] last:tw-mb-0">
    <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-py-[6px] tw-bg-gradient-to-br tw-from-[rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.08)] tw-to-[rgb(from_var(--wh40k-accent-gold)_r_g_b_/_0.03)] tw-border-l-[3px] tw-border-l-[color:var(--wh40k-accent-gold)] tw-rounded-r">
        <i class="fas {{icon}} tw-text-[0.85rem] tw-text-[color:var(--wh40k-accent-gold)]"></i>
        <span class="tw-text-[0.7rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[color:var(--wh40k-text-secondary)]">{{heading}}</span>
    </div>
    <div class="tw-grid tw-gap-[6px]" style="grid-template-columns: repeat(auto-fill, minmax(72px, 1fr)); grid-auto-rows: 80px;">
        {{> @partial-block}}
        {{#each items as |entry|}}
            {{#if (eq ../mode "item")}}
                <button
                    type="button"
                    class="tw-group tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-xs)] tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-bg-paper)] tw-border tw-border-solid tw-border-[var(--wh40k-border-light)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer tw-transition-all tw-min-h-[80px] tw-relative tw-overflow-hidden [--action-color:var({{../actionColor}})] hover:tw-border-[color:var(--action-color)] hover:tw-translate-y-[-2px] hover:tw-shadow-[0_2px_6px_rgba(0,0,0,0.08)] active:tw-translate-y-0"
                    data-action="{{../dataAction}}"
                    data-item-id="{{entry.id}}"
                    data-tooltip
                    aria-label="{{entry.name}}"
                    title="{{entry.name}}"
                >
                    <span class="tw-absolute tw-left-0 tw-top-0 tw-bottom-0 tw-w-[3px] tw-bg-[var(--action-color,var(--wh40k-border-medium))] tw-opacity-0 tw-transition-opacity tw-pointer-events-none group-hover:tw-opacity-100" aria-hidden="true"></span>
                    <i class="fas {{../icon}} tw-text-[1.1rem] tw-text-[color:var(--action-color)] tw-transition-all"></i>
                    <span class="tw-text-[0.65rem] tw-font-semibold tw-text-center tw-leading-[1.2] tw-text-[color:var(--wh40k-text-primary)]">{{entry.name}}</span>
                    {{#if entry.system.tier}}
                        <span class="tw-text-[0.55rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--action-color)] tw-opacity-80">T{{entry.system.tier}}</span>
                    {{/if}}
                </button>
            {{else}}
                <button
                    type="button"
                    class="tw-group tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-xs)] tw-p-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-bg-paper)] tw-border tw-border-solid tw-border-[var(--wh40k-border-light)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer tw-transition-all tw-min-h-[80px] tw-relative tw-overflow-hidden [--action-color:var({{../actionColor}})] hover:tw-border-[color:var(--action-color)] hover:tw-translate-y-[-2px] hover:tw-shadow-[0_2px_6px_rgba(0,0,0,0.08)] active:tw-translate-y-0"
                    data-action="{{../dataAction}}"
                    data-action-key="{{entry.key}}"
                    data-tooltip
                    aria-label="{{localize entry.label}}: {{localize entry.description}}"
                    title="{{localize entry.label}} — {{localize "WH40K.Combat.Actions.ButtonTitleClickForDescription"}}"
                >
                    <span class="tw-absolute tw-left-0 tw-top-0 tw-bottom-0 tw-w-[3px] tw-bg-[var(--action-color,var(--wh40k-border-medium))] tw-opacity-0 tw-transition-opacity tw-pointer-events-none group-hover:tw-opacity-100" aria-hidden="true"></span>
                    <i class="fas {{entry.icon}} tw-text-[1.1rem] tw-text-[color:var(--action-color)] tw-transition-all"></i>
                    <span class="tw-text-[0.65rem] tw-font-semibold tw-text-center tw-leading-[1.2] tw-text-[color:var(--wh40k-text-primary)]">{{localize entry.label}}</span>
                    <span class="tw-text-[0.55rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--action-color)] tw-opacity-80">{{entry.type}}</span>
                </button>
            {{/if}}
        {{/each}}
    </div>
</div>
