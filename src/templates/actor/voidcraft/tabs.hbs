{{! Voidcraft Sheet Tab Navigation }}
{{!-- Routed through the shared actor tab-strip partial (the same SSOT used by
     actor/craft/tabs.hbs and actor/player/tabs.hbs). The vertical chrome wraps
     each anchor in a <label> (withLabelWrap) and the per-system border accent is
     supplied by the partial's nav. Tabs are data-driven from the sheet's
     _getTabs(), so every registered tab (including manoeuvreActions) renders. --}}
{{> systems/wh40k-rpg/templates/actor/partial/tab-strip.hbs
    tabs=tabs
    withLabelWrap=true
    itemClass="tw-w-full tw-px-3.5 tw-py-2 tw-text-[0.85em] tw-font-semibold tw-tracking-wide tw-uppercase tw-text-[#4a3728] tw-bg-white/60 tw-border tw-border-[rgba(74,55,40,0.2)] tw-rounded-r-[10px] [&.active]:tw-bg-white/90 [&.active]:tw-text-[var(--wh40k-text-dark,#1a1a1a)] [&.active]:tw-border-gold bc:[&.active]:tw-border-crimson-light dh1:[&.active]:tw-border-gold-raw-l5 dh2:[&.active]:tw-border-gold-raw dw:[&.active]:tw-border-accent-combat ow:[&.active]:tw-border-brass-l20 rt:[&.active]:tw-border-gold im:[&.active]:tw-border-failure"}}
