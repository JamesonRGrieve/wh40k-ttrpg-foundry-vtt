{{!-- NPC V2 Abilities Tab - Talent & Trait Management --}}
<section class="tab {{#if tab.active}}active{{/if}} {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
  <div class="wh40k-abilities-tab">
    
    {{!-- Talents Section --}}
    <div class="wh40k-panel wh40k-panel--talents" data-drop-zone="ability" data-accepts="talent">
      <div class="wh40k-panel-header">
        <i class="fa-solid fa-stars"></i>
        <span>{{localize "WH40K.Talents"}}</span>
        <span class="wh40k-count-badge">{{talents.length}}</span>
      </div>
      
      <div class="wh40k-panel-body">
        {{#if talents.length}}
        <div class="wh40k-abilities-grid">
          {{#each talents}}
          <div class="wh40k-ability-card {{#if isPinned}}pinned{{/if}}" data-item-id="{{id}}">
            <div class="wh40k-ability-header">
              <img src="{{img}}" class="wh40k-ability-img" alt="{{name}}" />
              <span class="wh40k-ability-name">{{name}}</span>
              <div class="wh40k-ability-actions">
                <button type="button" 
                        class="wh40k-btn-icon wh40k-btn-toggle-desc"
                        data-action="toggleAbilityDesc"
                        data-item-id="{{id}}"
                        title="Toggle Description">
                  <i class="fa-solid fa-chevron-down"></i>
                </button>
                {{#if ../editable}}
                <button type="button" 
                        class="wh40k-btn-icon {{#if isPinned}}active{{/if}}"
                        data-action="pinAbility"
                        data-item-id="{{id}}"
                        title="{{#if isPinned}}Unpin{{else}}Pin to Overview{{/if}}">
                  <i class="fa-solid fa-thumbtack"></i>
                </button>
                <button type="button" 
                        class="wh40k-btn-icon"
                        data-action="itemEdit"
                        data-item-id="{{id}}"
                        title="Edit">
                  <i class="fa-solid fa-pen-to-square"></i>
                </button>
                <button type="button" 
                        class="wh40k-btn-icon wh40k-btn-icon--danger"
                        data-action="itemDelete"
                        data-item-id="{{id}}"
                        title="Delete">
                  <i class="fa-solid fa-trash-can"></i>
                </button>
                {{/if}}
              </div>
            </div>
            {{#if system.description.value}}
            <div class="wh40k-ability-desc" hidden>
              {{{system.description.value}}}
            </div>
            {{/if}}
          </div>
          {{/each}}
        </div>
        {{else}}
        <div class="wh40k-empty-state wh40k-dropzone">
          <i class="fa-solid fa-stars"></i>
          <p>No talents</p>
          <span class="wh40k-empty-hint">Drag talent items here to add</span>
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- Traits Section --}}
    <div class="wh40k-panel wh40k-panel--traits" data-drop-zone="ability" data-accepts="trait">
      <div class="wh40k-panel-header">
        <i class="fa-solid fa-paw-claws"></i>
        <span>{{localize "WH40K.Traits"}}</span>
        <span class="wh40k-count-badge">{{traits.length}}</span>
      </div>
      
      <div class="wh40k-panel-body">
        {{#if traits.length}}
        <div class="wh40k-abilities-grid">
          {{#each traits}}
          <div class="wh40k-ability-card trait {{#if isPinned}}pinned{{/if}}" data-item-id="{{id}}">
            <div class="wh40k-ability-header">
              <img src="{{img}}" class="wh40k-ability-img" alt="{{name}}" />
              <span class="wh40k-ability-name">{{name}}</span>
              <div class="wh40k-ability-actions">
                <button type="button" 
                        class="wh40k-btn-icon wh40k-btn-toggle-desc"
                        data-action="toggleAbilityDesc"
                        data-item-id="{{id}}"
                        title="Toggle Description">
                  <i class="fa-solid fa-chevron-down"></i>
                </button>
                {{#if ../editable}}
                <button type="button" 
                        class="wh40k-btn-icon"
                        data-action="itemEdit"
                        data-item-id="{{id}}"
                        title="Edit">
                  <i class="fa-solid fa-pen-to-square"></i>
                </button>
                <button type="button" 
                        class="wh40k-btn-icon wh40k-btn-icon--danger"
                        data-action="itemDelete"
                        data-item-id="{{id}}"
                        title="Delete">
                  <i class="fa-solid fa-trash-can"></i>
                </button>
                {{/if}}
              </div>
            </div>
            {{#if system.description.value}}
            <div class="wh40k-ability-desc" hidden>
              {{{system.description.value}}}
            </div>
            {{/if}}
          </div>
          {{/each}}
        </div>
        {{else}}
        <div class="wh40k-empty-state wh40k-dropzone">
          <i class="fa-solid fa-paw-claws"></i>
          <p>No traits</p>
          <span class="wh40k-empty-hint">Drag trait items here to add</span>
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- Psychic Powers Section (if any) --}}
    {{#if psychicPowers.length}}
    <div class="wh40k-panel wh40k-panel--powers" data-drop-zone="ability" data-accepts="psychicPower">
      <div class="wh40k-panel-header">
        <i class="fa-solid fa-head-side-brain"></i>
        <span>{{localize "WH40K.Tabs.Powers"}}</span>
        <span class="wh40k-count-badge">{{psychicPowers.length}}</span>
      </div>
      
      <div class="wh40k-panel-body">
        <div class="wh40k-abilities-grid">
          {{#each psychicPowers}}
          <div class="wh40k-ability-card power" data-item-id="{{id}}">
            <div class="wh40k-ability-header">
              <img src="{{img}}" class="wh40k-ability-img" alt="{{name}}" />
              <span class="wh40k-ability-name">{{name}}</span>
              {{#if system.psy.rating}}
              <span class="wh40k-psy-badge">PR {{system.psy.rating}}</span>
              {{/if}}
              <div class="wh40k-ability-actions">
                <button type="button" 
                        class="wh40k-btn-icon wh40k-btn-toggle-desc"
                        data-action="toggleAbilityDesc"
                        data-item-id="{{id}}"
                        title="Toggle Description">
                  <i class="fa-solid fa-chevron-down"></i>
                </button>
                {{#if ../editable}}
                <button type="button" 
                        class="wh40k-btn-icon"
                        data-action="itemEdit"
                        data-item-id="{{id}}"
                        title="Edit">
                  <i class="fa-solid fa-pen-to-square"></i>
                </button>
                <button type="button" 
                        class="wh40k-btn-icon wh40k-btn-icon--danger"
                        data-action="itemDelete"
                        data-item-id="{{id}}"
                        title="Delete">
                  <i class="fa-solid fa-trash-can"></i>
                </button>
                {{/if}}
              </div>
            </div>
            {{#if system.description.value}}
            <div class="wh40k-ability-desc" hidden>
              {{{system.description.value}}}
            </div>
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>
    </div>
    {{/if}}

    {{!-- Special Abilities (Rich Text) --}}
    <div class="wh40k-panel wh40k-panel--special wh40k-panel--editable">
      <div class="wh40k-panel-header">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
        <span>{{localize "WH40K.SpecialAbilities"}}</span>
        {{#if editable}}
        <i class="fa-solid fa-pen-to-square wh40k-edit-hint"></i>
        {{/if}}
      </div>
      
      <div class="wh40k-panel-body">
        {{#if editable}}
        <div class="wh40k-editor-wrapper">
          {{editor system.specialAbilities
                   target="system.specialAbilities"
                   button=true
                   editable=editable
                   engine="prosemirror"
                  }}
        </div>
        {{else}}
        {{#if system.specialAbilities}}
        <div class="wh40k-special-content">{{{system.specialAbilities}}}</div>
        {{else}}
        <div class="wh40k-empty-state wh40k-empty-state--inline">
          <i class="fa-solid fa-wand-magic-sparkles"></i>
          <span>No special abilities defined</span>
        </div>
        {{/if}}
        {{/if}}
      </div>
    </div>

    {{!-- Description --}}
    <div class="wh40k-panel wh40k-panel--description wh40k-panel--editable">
      <div class="wh40k-panel-header">
        <i class="fa-solid fa-scroll"></i>
        <span>Description</span>
        {{#if editable}}
        <i class="fa-solid fa-pen-to-square wh40k-edit-hint"></i>
        {{/if}}
      </div>
      <div class="wh40k-panel-body">
        {{#if editable}}
        <div class="wh40k-editor-wrapper">
          {{editor system.description target="system.description" button=true editable=editable engine="prosemirror"}}
        </div>
        {{else}}
        <div class="wh40k-description-content">{{{system.description}}}</div>
        {{/if}}
      </div>
    </div>

  </div>
</section>
