{{!-- NPC Sheet Header — mirrors the PC header layout (portrait | info rows)
      with NPC-specific identity fields: threat + type + role instead of origin path/career. --}}
<div class="wh40k-header wh40k-grid-col-6 wh40k-panel wh40k-character-header">
    <div class="wh40k-header__info wh40k-header-grid tw-grid tw-grid-cols-header-main tw-gap-3 tw-items-start tw-pt-2 tw-px-3 tw-pb-1.5">
        <div class="wh40k-header-left tw-flex tw-flex-col tw-gap-2">
            <div class="wh40k-header-topline tw-grid tw-grid-cols-header-topline tw-gap-2.5 tw-items-center">
                <div class="wh40k-header__logo wh40k-portrait-container">
                    <img class="wh40k-header__logo-image wh40k-portrait" src="{{actor.img}}" data-action="editImage" data-edit="img" alt="{{actor.name}}" title="{{actor.name}}" />
                </div>
                <div class="wh40k-header-info">
                    <div class="wh40k-header-row wh40k-name-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Name"}}</span>
                        <input class="wh40k-header-input wh40k-name-input" name="name" type="text" value="{{actor.name}}" />
                    </div>
                    <div class="wh40k-header-row wh40k-threat-row">
                        <span class="wh40k-header-label"><i class="fa-solid fa-skull"></i> Threat</span>
                        <input class="wh40k-header-input wh40k-threat-input"
                               name="system.threatLevel"
                               type="number"
                               min="1"
                               max="30"
                               value="{{source.threatLevel}}"
                               {{#unless editable}}disabled{{/unless}}
                               style="border-color: {{threatTier.color}};" />
                        <span class="wh40k-header-value wh40k-threat-tier" style="color: {{threatTier.color}};">{{threatTier.label}}</span>
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">Type</span>
                        <select class="wh40k-header-input" name="system.type" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions npcTypeOptions selected=source.type}}
                        </select>
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">Role</span>
                        <select class="wh40k-header-input" name="system.role" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions npcRoleOptions selected=source.role}}
                        </select>
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">Faction</span>
                        <input class="wh40k-header-input"
                               name="system.faction"
                               type="text"
                               value="{{source.faction}}"
                               placeholder="Faction (e.g. Imperial Guard)"
                               {{#unless editable}}disabled{{/unless}} />
                    </div>
                </div>
            </div>
        </div>
        <div class="wh40k-header-right tw-flex tw-flex-col tw-items-end tw-gap-2 tw-justify-self-end tw-justify-start tw-max-w-[620px]">
            <div class="wh40k-hud-stack tw-relative tw-flex tw-flex-col tw-items-end tw-gap-1.5 tw-h-full">
                {{!-- NPC Characteristics HUD — same visual shape as PC's, without advance rings --}}
                <div class="wh40k-characteristics-hud">
                    {{#each characteristicsArray}}
                        <div class="wh40k-char-hud-item {{#if (gt modifier 0)}}wh40k-char-buffed{{/if}}{{#if (lt modifier 0)}}wh40k-char-debuffed{{/if}}"
                             data-characteristic="{{key}}">
                            <button
                                class="wh40k-char-hud-name rollable"
                                type="button"
                                data-action="rollCharacteristic"
                                data-characteristic="{{key}}"
                                title="{{label}}"
                            >{{short}}</button>
                            <div class="wh40k-char-hud-circle" title="{{label}}">
                                <span class="wh40k-char-hud-mod">{{bonus}}</span>
                                <span class="wh40k-char-hud-mod-label">MOD</span>
                            </div>
                            {{#if ../editable}}
                            <div class="wh40k-char-hud-base wh40k-char-hud-base--edit">
                                <input type="number" class="wh40k-char-direct-input wh40k-char-inline-input" name="system.characteristics.{{key}}.base" value="{{base}}" title="Base {{label}}" />
                            </div>
                            {{else}}
                            <div class="wh40k-char-hud-base">Total {{total}}</div>
                            {{/if}}
                        </div>
                    {{/each}}
                </div>
                <div class="wh40k-dropzone wh40k-dropzone-small" data-drop-zone="general">
                    <i class="fas fa-plus-circle wh40k-dropzone-icon"></i>
                    <span class="wh40k-dropzone-text">Drag and Drop from Compendium to Add</span>
                </div>
            </div>
        </div>
    </div>
</div>
