{{!-- NPC Equipment Tab — embedded item inventory. NPCs can still carry item
      documents; for pure stat-block fighters use the simple weapons array in the
      combat tab instead. --}}
<section class="tab {{#if tab.active}}active{{/if}} {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
  <div class="wh40k-equipment-tab">

    <div class="wh40k-panel wh40k-panel--inventory" data-drop-zone="item">
      <div class="wh40k-panel-header">
        <i class="fa-solid fa-boxes-stacked"></i>
        <span>Inventory</span>
        <span class="wh40k-count-badge">{{allItems.length}}</span>
      </div>
      <div class="wh40k-panel-body">
        {{#if allItems.length}}
        <table class="wh40k-inventory-table">
          <thead>
            <tr>
              <th class="wh40k-inv-col-icon"></th>
              <th class="wh40k-inv-col-name">Name</th>
              <th class="wh40k-inv-col-type">Type</th>
              <th class="wh40k-inv-col-qty">Qty</th>
              {{#if editable}}<th class="wh40k-inv-col-actions"></th>{{/if}}
            </tr>
          </thead>
          <tbody>
            {{#each allItems}}
            <tr class="wh40k-inv-row wh40k-inv-row--{{type}}" data-item-id="{{id}}">
              <td class="wh40k-inv-col-icon"><img src="{{img}}" class="wh40k-inv-img" alt="" /></td>
              <td class="wh40k-inv-col-name"><a class="wh40k-inv-name" data-action="itemEdit" data-item-id="{{id}}">{{name}}</a></td>
              <td class="wh40k-inv-col-type"><span class="wh40k-inv-type-badge {{type}}">{{type}}</span></td>
              <td class="wh40k-inv-col-qty">{{#if system.quantity}}{{system.quantity}}{{else}}—{{/if}}</td>
              {{#if ../editable}}<td class="wh40k-inv-col-actions">
                <button type="button" class="wh40k-inv-remove" data-action="removeItem" data-item-id="{{id}}" title="Remove"><i class="fa-solid fa-trash-can"></i></button>
              </td>{{/if}}
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{else}}
        <div class="wh40k-empty-state">
          <i class="fa-solid fa-box-open"></i>
          <p>No inventory</p>
          <span class="wh40k-empty-hint">Drag items here, or use the simple weapons in the Combat tab.</span>
        </div>
        {{/if}}
      </div>
    </div>

  </div>
</section>
