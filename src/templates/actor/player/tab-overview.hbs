{{!-- Acolyte Sheet Overview Tab - Ultra-Dense Dashboard --}}
{{!-- At-a-glance view of all critical information --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    
    {{!-- Column sizing rationale (issue #15): Favourites + Progression panels (col 2) do not
         benefit from extra width — their content is short rows. Resources (in col 3) cramps
         badly under tw-grid-cols-3 because Influence/Requisition/Throne Gelt buttons overlap.
         Cap col 1 (Vitals) and col 2 to 360px max; let col 3 absorb the remaining width. --}}
    <div class="tw-grid tw-grid-cols-[minmax(280px,360px)_minmax(280px,360px)_1fr] tw-grid-rows-[auto_auto] tw-items-start tw-gap-2 tw-p-2 tw-h-full tw-overflow-y-auto tw-overflow-x-hidden tw-border-t-2 tw-border-t-gold bc:tw-border-t-crimson-light dh1e:tw-border-t-gold-raw-l5 dh2e:tw-border-t-gold-raw dw:tw-border-t-accent-combat ow:tw-border-t-brass-l20 rt:tw-border-t-gold im:tw-border-t-failure">

        {{!-- COLUMN 1: Vitals → Active Effects --}}
        <div class="tw-flex tw-flex-col tw-gap-2">
            {{!-- Vitals --}}
            <div class="tw-flex tw-flex-col tw-overflow-hidden tw-bg-[var(--color-bg-secondary)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-combat)]">
                <div class="tw-flex tw-items-center tw-gap-1.5 tw-py-1.5 tw-px-2.5 tw-bg-[linear-gradient(90deg,rgb(from_var(--wh40k-accent-combat)_r_g_b_/_0.12)_0%,var(--color-bg-tertiary)_100%)] tw-border-b tw-border-solid tw-border-[var(--color-border-secondary)] tw-text-xs tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)] [&>i]:tw-text-[color:var(--wh40k-accent-combat)]">
                    <i class="fas fa-heartbeat"></i>
                    <span>Vitals</span>
                </div>
                <div class="tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    {{!-- Wounds --}}
                    {{> systems/wh40k-rpg/templates/actor/partial/vital-inline-row
                        icon="fa-heart"
                        label="Wounds"
                        field="system.wounds.value"
                        current=system.wounds.value
                        max=system.wounds.max
                        maxAttr=system.wounds.max
                        stateClass=(iff (eq system.wounds.value 0) "wh40k-critical" (iff (lt (percent system.wounds.value system.wounds.max) 25) "wh40k-warning" ""))}}

                    {{!-- Critical Wounds --}}
                    {{#if (or (gt system.wounds.critical 0) (eq system.wounds.value 0))}}
                    {{#> systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs
                        icon="fa-skull" label="Critical" rowClass="wh40k-vital-critical-row"}}
                        {{> systems/wh40k-rpg/templates/actor/partial/pip-tracker-row
                            count=10
                            current=system.wounds.critical
                            action="setCriticalPip"
                            dataAttr="crit-level"
                            pipClass="wh40k-crit-pip-mini"
                            titlePrefix="Critical Level"}}
                    {{/systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs}}
                    {{/if}}

                    {{#unless isNPC}}
                    {{!-- Fatigue (PC-only) --}}
                    {{#> systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs
                        icon="fa-bolt" label="Fatigue"}}
                        {{> systems/wh40k-rpg/templates/actor/partial/pip-tracker-row
                            count=system.fatigue.max
                            current=system.fatigue.value
                            action="setFatigueBolt"
                            dataAttr="fatigue-index"
                            pipClass="wh40k-fatigue-pip"
                            filledClass=" tw-animate-bolt-glow"
                            iconClass="fa-bolt"
                            titlePrefix="Fatigue Level"}}
                        {{#if (gt system.fatigue.value 0)}}
                        <span class="tw-text-[0.7rem] tw-font-bold tw-text-[color:var(--wh40k-accent-combat)] tw-bg-[rgb(from_var(--wh40k-accent-combat)_r_g_b_/_0.1)] tw-px-1 tw-py-[1px] tw-rounded-[3px]">−10</span>
                        {{/if}}
                    {{/systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs}}

                    {{!-- Lift & Push (PC-only) --}}
                    <div class="tw-flex tw-items-center tw-justify-between tw-py-0.5">
                        <span class="tw-flex tw-items-center tw-gap-1.5">
                            <span class="tw-w-[18px] tw-text-center tw-text-[color:var(--color-text-tertiary)] tw-text-[0.85rem]"><i class="fas fa-dumbbell"></i></span>
                            <span class="tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--color-text-secondary)] tw-min-w-[50px] tw-normal-case tw-tracking-normal">Lift</span>
                            <span class="tw-text-[1.4rem] tw-font-bold tw-font-alt tw-text-[color:var(--color-text-primary)] tw-min-w-[45px] tw-text-center">{{system.lifting.lift}} kg</span>
                        </span>
                        <span class="tw-flex tw-items-center tw-gap-1.5">
                            <span class="tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--color-text-secondary)] tw-min-w-[50px] tw-normal-case tw-tracking-normal">Push</span>
                            <span class="tw-text-[1.4rem] tw-font-bold tw-font-alt tw-text-[color:var(--color-text-primary)] tw-min-w-[45px] tw-text-center">{{system.lifting.push}} kg</span>
                        </span>
                    </div>

                    {{!-- Fate Points (PC-only) --}}
                    {{#if (gt system.fate.max 0)}}
                    {{#> systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs
                        icon="fa-star" label="Fate"}}
                        {{> systems/wh40k-rpg/templates/actor/partial/pip-tracker-row
                            count=system.fate.max
                            current=system.fate.value
                            action="setFateStar"
                            dataAttr="fate-index"
                            pipClass="wh40k-fate-pip"
                            iconClass="fa-star"
                            titlePrefix="Fate Point"}}
                        <button type="button" class="tw-w-[18px] tw-h-[18px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[0.7rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)] hover:tw-text-[color:var(--wh40k-text-medium)]"
                            data-action="viewFateUses"
                            title="{{localize 'WH40K.FateUses.DialogTitle'}}">
                            <i class="fas fa-circle-info"></i>
                        </button>
                        <button type="button" class="tw-w-[18px] tw-h-[18px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[0.7rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)]" data-action="restoreFate" title="Restore All">
                            <i class="fas fa-redo"></i>
                        </button>
                    {{/systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs}}
                    {{/if}}
                    {{/unless}}
                </div>

                {{#unless isNPC}}
                {{!-- Mental State (compact) — PC-only (NPC schema has no corruption/insanity) --}}
                <div class="tw-px-2 tw-py-1.5 tw-bg-[rgba(0,0,0,0.05)] tw-border-t tw-border-solid tw-border-[var(--color-border-light)] tw-mt-auto">
                    {{> systems/wh40k-rpg/templates/actor/partial/vital-inline-row
                        icon="fa-skull"
                        label="Corruption"
                        field="system.corruption"
                        current=system.corruption
                        maxAttr=100
                        rowClass="wh40k-mental-row"
                        labelGroupClass="wh40k-mental-label-group"
                        iconClass="wh40k-mental-icon"
                        labelClass="wh40k-mental-label"
                        valueClass="wh40k-mental-value"
                        stateClass=(corruptionDegreeClass system.corruption)
                        degreeText=(corruptionDegree system.corruption)}}
                    {{> systems/wh40k-rpg/templates/actor/partial/vital-inline-row
                        icon="fa-brain"
                        label="Insanity"
                        field="system.insanity"
                        current=system.insanity
                        maxAttr=100
                        rowClass="wh40k-mental-row"
                        labelGroupClass="wh40k-mental-label-group"
                        iconClass="wh40k-mental-icon"
                        labelClass="wh40k-mental-label"
                        valueClass="wh40k-mental-value"
                        stateClass=(insanityDegreeClass system.insanity)
                        degreeText=(insanityDegree system.insanity)}}
                </div>
                {{/unless}}
            </div>

            {{!-- Active Effects --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Active Effects" icon="fa-magic" zoneClass="tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-psychic)]"}}
                    {{#if effects.length}}
                    <div class="tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)]">
                        {{#each effects as |effect|}}
                        <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-px-1.5 tw-py-[3px] tw-bg-[var(--color-bg-option)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.7rem] {{#if effect.disabled}}tw-opacity-50{{/if}}" title="{{effect.name}}">
                            <img src="{{effect.icon}}" alt="" class="tw-w-[14px] tw-h-[14px] tw-rounded-[var(--wh40k-radius-sm)]" />
                            <span class="tw-text-[color:var(--color-text-secondary)] tw-max-w-[80px] tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap">{{effect.name}}</span>
                            <div class="tw-flex tw-gap-[2px] tw-ml-[2px]">
                                <button type="button" class="tw-w-[16px] tw-h-[16px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.6rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)]"
                                        data-action="toggleEffect"
                                        data-effect-id="{{effect.id}}"
                                        title="{{#if effect.disabled}}Enable{{else}}Disable{{/if}}">
                                    <i class="fas {{#if effect.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
                                </button>
                                <button type="button" class="tw-w-[16px] tw-h-[16px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.6rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)]"
                                        data-action="deleteEffect"
                                        data-effect-id="{{effect.id}}"
                                        title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="tw-flex tw-items-center tw-justify-center tw-h-full tw-text-[color:var(--color-text-tertiary)] tw-text-[0.75rem] tw-italic">
                        <span>No active effects</span>
                    </div>
                    {{/if}}
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}
        </div>

        {{!-- COLUMN 2: Favourite Skills → Favourite Talents → Progression --}}
        <div class="tw-flex tw-flex-col tw-gap-2">
            {{!-- Favourite Skills --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Favourite Skills" icon="fa-star" zoneClass="tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-green-bright)]"}}
                    <div class="tw-flex tw-flex-col tw-gap-[3px]" data-favourite-list="skills">
                        {{#if favoriteSkills}}
                            {{#each favoriteSkills as |skill|}}
                            <div class="tw-flex tw-items-center tw-gap-[6px] tw-px-1.5 tw-py-[3px] tw-bg-[var(--color-bg-option)] tw-rounded-[var(--wh40k-radius-md)]" data-tooltip
                                 draggable="true"
                                 data-favourite-key="{{skill.key}}"
                                 aria-label="{{skill.label}}: {{skill.current}}"
                                 data-wh40k-tooltip="skill"
                                 data-wh40k-tooltip-data="{{skill.tooltipData}}">
                                <i class="fas fa-grip-vertical tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-cursor-grab active:tw-cursor-grabbing" title="Drag to reorder"></i>
                                <span class="tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--color-text-secondary)] tw-flex-1">{{skill.label}}</span>
                                <span class="tw-text-[0.85rem] tw-font-bold tw-font-alt tw-text-[color:var(--color-text-primary)] tw-min-w-[28px] tw-text-right">{{skill.current}}</span>
                                <button type="button"
                                        class="tw-w-[20px] tw-h-[20px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[0.7rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)]"
                                        data-action="roll"
                                        data-roll-type="skill"
                                        data-roll-target="{{skill.key}}"
                                        title="Roll {{skill.label}}">
                                    <i class="fas fa-dice"></i>
                                </button>
                            </div>
                            {{/each}}
                        {{else}}
                            <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-px-4 tw-py-6 tw-gap-[var(--wh40k-space-xs)] tw-text-[color:var(--color-text-tertiary)] tw-text-center tw-min-h-[120px]">
                                <i class="far fa-star"></i>
                                <p>{{localize "WH40K.Favourites.NoSkills"}}</p>
                                <p class="tw-text-[0.7rem] tw-italic tw-opacity-80">{{localize "WH40K.Favourites.StarSkillsHint"}}</p>
                            </div>
                        {{/if}}
                    </div>
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}

            {{!-- Favourite Talents --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Favourite Talents" icon="fa-star-half-alt" zoneClass="tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-talents)]"}}
                    <div class="tw-flex tw-flex-col tw-gap-[3px]" data-favourite-list="talents">
                        {{#if favoriteTalents}}
                            {{#each favoriteTalents as |talent|}}
                            <div class="tw-flex tw-items-center tw-gap-[6px] tw-px-1.5 tw-py-[3px] tw-bg-[var(--color-bg-option)] tw-rounded-[var(--wh40k-radius-md)]" data-tooltip
                                 draggable="true"
                                 data-favourite-key="{{talent.id}}"
                                 title="{{talent.name}}{{#if talent.specialization}} ({{talent.specialization}}){{/if}}">
                                <i class="fas fa-grip-vertical tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-cursor-grab active:tw-cursor-grabbing" title="Drag to reorder"></i>
                                <img class="tw-w-[20px] tw-h-[20px] tw-rounded-[3px] tw-object-cover tw-shrink-0" src="{{talent.img}}" alt="{{talent.name}}" />
                                <span class="tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--color-text-secondary)] tw-flex-1 tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)]">
                                    {{talent.fullName}}
                                    {{#if talent.system.tier}}
                                    <span class="tw-text-[0.6rem] tw-font-bold tw-px-1 tw-py-[1px] tw-bg-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.15)] tw-border tw-border-solid tw-border-[rgb(from_var(--wh40k-accent-talents)_r_g_b_/_0.4)] tw-rounded-[3px] tw-text-[color:var(--wh40k-accent-talents)]">T{{talent.system.tier}}</span>
                                    {{/if}}
                                </span>
                                <button type="button"
                                        class="tw-w-[20px] tw-h-[20px] tw-p-0 tw-flex tw-items-center tw-justify-center tw-bg-transparent tw-border-none tw-text-[0.7rem] tw-cursor-pointer tw-text-[color:var(--color-text-tertiary)]"
                                        data-action="itemEdit"
                                        data-item-id="{{talent.id}}"
                                        title="View {{talent.name}}">
                                    <i class="fas fa-info-circle"></i>
                                </button>
                            </div>
                            {{/each}}
                        {{else}}
                            <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-px-4 tw-py-6 tw-gap-[var(--wh40k-space-xs)] tw-text-[color:var(--color-text-tertiary)] tw-text-center tw-min-h-[120px]">
                                <i class="far fa-star"></i>
                                <p>{{localize "WH40K.Favourites.NoTalents"}}</p>
                                <p class="tw-text-[0.7rem] tw-italic tw-opacity-80">{{localize "WH40K.Favourites.StarTalentsHint"}}</p>
                            </div>
                        {{/if}}
                    </div>
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}

            {{#unless isNPC}}
            {{!-- Progression (XP) — PC-only — kept inline due to SVG ring + action-button header --}}
            <div class="tw-flex tw-flex-col tw-overflow-hidden tw-bg-[var(--color-bg-secondary)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-border-l-[3px] tw-border-l-[var(--wh40k-color-gold)]">
                <div class="tw-flex tw-items-center tw-gap-1.5 tw-py-1.5 tw-px-2.5 tw-bg-[linear-gradient(90deg,rgb(from_var(--wh40k-color-gold)_r_g_b_/_0.12)_0%,var(--color-bg-tertiary)_100%)] tw-border-b tw-border-solid tw-border-[var(--color-border-secondary)] tw-text-xs tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)] [&>i]:tw-text-[color:var(--wh40k-color-gold)]">
                    <div class="tw-relative tw-w-[20px] tw-h-[20px] tw-shrink-0"data-tooltip="{{#if system.experience.total}}{{floor (multiply (divide system.experience.used system.experience.total) 100)}}{{else}}0{{/if}}% XP spent ({{system.experience.used}}/{{system.experience.total}})">
                        <svg viewBox="0 0 100 100" class="tw-w-full tw-h-full">
                            <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(120, 46, 34, 0.2)" stroke-width="12"/>
                            <circle cx="50" cy="50" r="45" fill="none" stroke="#c08020" stroke-width="12" stroke-linecap="round"
                                    stroke-dasharray="282.74"
                                    stroke-dashoffset="{{multiply (subtract 1 (divide system.experience.used system.experience.total)) 282.74}}"
                                    transform="rotate(-90 50 50)"/>
                        </svg>
                    </div>
                    <span>Progression — Rank {{system.rank}}</span>
                    <div class="tw-flex tw-gap-1 tw-ml-auto">
                        {{#if isGM}}
                        <button type="button" class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-xs)] tw-px-2 tw-py-1 tw-bg-[var(--color-bg-option)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.7rem] tw-font-semibold tw-cursor-pointer tw-text-[color:var(--color-text-secondary)]" data-action="customXP" title="Add XP">
                            <i class="fas fa-plus"></i> Add XP
                        </button>
                        {{/if}}
                        <button type="button" class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-xs)] tw-px-2 tw-py-1 tw-bg-[var(--color-bg-option)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.7rem] tw-font-semibold tw-cursor-pointer tw-text-[color:var(--color-text-secondary)]" data-action="openAdvancement" title="Buy Advancements">
                            <i class="fa-solid fa-arrow-up-big-small"></i> Advance
                        </button>
                    </div>
                </div>
                <div class="tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="tw-grid tw-grid-cols-2 tw-gap-2">
                        <span class="tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.03em] tw-text-[var(--color-text-secondary)]">Experience</span>
                        <span class="tw-text-[0.85rem] tw-font-bold tw-font-alt tw-text-[color:var(--color-text-primary)]">{{system.experience.available}}/{{system.experience.total}}</span>
                    </div>
                    {{#if aptitudePills.length}}
                    <div class="tw-flex tw-flex-wrap tw-items-baseline tw-gap-1 tw-pt-1">
                        <span class="tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.03em] tw-text-[var(--color-text-secondary)] tw-shrink-0">Aptitudes</span>
                        <div class="tw-flex tw-flex-wrap tw-gap-1">
                            {{#each aptitudePills as |pill|}}
                            <span class="tw-text-[0.7rem] tw-px-1.5 tw-py-0.5 tw-rounded tw-border tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-[rgba(212,175,55,0.08)]"
                                  data-tooltip="{{#each pill.sources}}{{this}}{{#unless @last}} · {{/unless}}{{/each}}">
                                {{pill.aptitude}}
                            </span>
                            {{/each}}
                        </div>
                    </div>
                    {{/if}}
                </div>
            </div>
            {{/unless}}
            {{#if isNPC}}
            {{!-- NPC summary panel in the progression slot --}}
            <div class="tw-flex tw-flex-col tw-overflow-hidden tw-bg-[var(--color-bg-secondary)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-border-l-[3px] tw-border-l-[var(--wh40k-color-gold)]">
                <div class="tw-flex tw-items-center tw-gap-1.5 tw-py-1.5 tw-px-2.5 tw-bg-[linear-gradient(90deg,rgb(from_var(--wh40k-color-gold)_r_g_b_/_0.12)_0%,var(--color-bg-tertiary)_100%)] tw-border-b tw-border-solid tw-border-[var(--color-border-secondary)] tw-text-xs tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)] [&>i]:tw-text-[color:var(--wh40k-color-gold)]">
                    <i class="fa-solid fa-skull"></i>
                    <span>Threat — {{threatTier.label}}</span>
                </div>
                <div class="tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="tw-grid tw-grid-cols-2 tw-gap-2">
                        <span class="tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.03em] tw-text-[var(--color-text-secondary)]">Threat Level</span>
                        <span class="tw-text-[0.85rem] tw-font-bold tw-font-alt tw-text-[color:var(--color-text-primary)]" style="color: {{threatTier.color}};">{{source.threatLevel}}/30</span>
                    </div>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-2">
                        <span class="tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.03em] tw-text-[var(--color-text-secondary)]">Type / Role</span>
                        <span class="tw-text-[0.85rem] tw-font-bold tw-font-alt tw-text-[color:var(--color-text-primary)]">{{source.type}} / {{source.role}}</span>
                    </div>
                    {{#if horde.enabled}}
                    <div class="tw-grid tw-grid-cols-2 tw-gap-2">
                        <span class="tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.03em] tw-text-[var(--color-text-secondary)]">Magnitude</span>
                        <span class="tw-text-[0.85rem] tw-font-bold tw-font-alt tw-text-[color:var(--color-text-primary)]">{{horde.magnitude}}/{{horde.magnitudeMax}}</span>
                    </div>
                    {{/if}}
                </div>
            </div>
            {{/if}}


        </div>

        {{!-- COLUMN 3: Weapons + [Movement | Armour] → Resources --}}
        <div class="tw-flex tw-flex-col tw-gap-2">
            {{!-- Equipped Weapons --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Equipped Weapons" icon="fa-crosshairs" zoneClass="tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-combat)]"}}
                    {{#if equippedWeapons.length}}
                    <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-xs)]">
                        {{#each equippedWeapons as |weapon|}}
                        <div class="tw-flex tw-items-center tw-gap-[6px] tw-px-1.5 tw-py-1 tw-bg-[var(--color-bg-option)] tw-rounded-[var(--wh40k-radius-md)] tw-cursor-pointer" data-action="itemEdit" data-item-id="{{weapon.id}}" title="Open {{weapon.name}}">
                            <img class="tw-w-[20px] tw-h-[20px] tw-rounded-[var(--wh40k-radius-sm)] tw-shrink-0" src="{{weapon.img}}" alt="{{weapon.name}}" />
                            <div class="tw-flex tw-flex-col tw-flex-1 tw-min-w-0">
                                <span class="tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--color-text-primary)] tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap">{{weapon.name}}</span>
                                <span class="tw-flex tw-gap-[6px] tw-text-[0.6rem] tw-text-[color:var(--color-text-tertiary)]">
                                    <span class="tw-font-semibold tw-uppercase">{{weapon.system.classLabel}}</span>
                                    {{#if weapon.system.rangeLabel}}<span class="">{{weapon.system.rangeLabel}}</span>{{/if}}
                                </span>
                            </div>
                            <span class=" tw-text-[0.7rem] tw-text-[color:var(--color-text-secondary)] tw-font-alt tw-whitespace-nowrap tw-shrink-0">{{weapon.system.damageLabel}}</span>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="tw-flex tw-items-center tw-justify-center tw-gap-[6px] tw-h-full tw-text-[color:var(--color-text-tertiary)] tw-text-[0.75rem] tw-italic">
                        <i class="fas fa-crosshairs"></i>
                        <span>No weapons equipped</span>
                    </div>
                    {{/if}}
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}

            {{!-- Movement & Armour side by side --}}
            <div class="tw-grid tw-grid-cols-2 tw-gap-2">
                {{!-- Movement 2x2 --}}
                {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Movement" icon="fa-running" zoneClass="tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-info)]"}}
                        <div class="tw-grid tw-grid-cols-2 tw-gap-1">
                            <div class="tw-flex tw-flex-col tw-items-center tw-px-2 tw-py-1 tw-bg-[var(--color-bg-option)] tw-rounded-[var(--wh40k-radius-md)] tw-flex-1">
                                <span class="tw-font-alt tw-text-[1.5rem] tw-font-bold tw-text-[color:var(--color-text-primary)] tw-leading-none">{{actor.movement.half}}</span>
                                <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--wh40k-text-muted)]"><i class="fas fa-walking "></i> Half</span>
                            </div>
                            <div class="tw-flex tw-flex-col tw-items-center tw-px-2 tw-py-1 tw-bg-[var(--color-bg-option)] tw-rounded-[var(--wh40k-radius-md)] tw-flex-1">
                                <span class="tw-font-alt tw-text-[1.5rem] tw-font-bold tw-text-[color:var(--color-text-primary)] tw-leading-none">{{actor.movement.full}}</span>
                                <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--wh40k-text-muted)]"><i class="fas fa-shoe-prints "></i> Full</span>
                            </div>
                            <div class="tw-flex tw-flex-col tw-items-center tw-px-2 tw-py-1 tw-bg-[var(--color-bg-option)] tw-rounded-[var(--wh40k-radius-md)] tw-flex-1">
                                <span class="tw-font-alt tw-text-[1.5rem] tw-font-bold tw-text-[color:var(--color-text-primary)] tw-leading-none">{{actor.movement.charge}}</span>
                                <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--wh40k-text-muted)]"><i class="fas fa-running "></i> Charge</span>
                            </div>
                            <div class=" tw-flex tw-flex-col tw-items-center tw-px-2 tw-py-1 tw-bg-[rgba(52,152,219,0.15)] tw-border tw-border-solid tw-border-[rgba(52,152,219,0.3)] tw-rounded-[var(--wh40k-radius-md)] tw-flex-1">
                                <span class="tw-font-alt tw-text-[1.5rem] tw-font-bold tw-text-[color:var(--color-text-primary)] tw-leading-none">{{actor.movement.run}}</span>
                                <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--wh40k-text-muted)]"><i class="fas fa-wind "></i> Run</span>
                            </div>
                        </div>
                        <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-xs)]">
                            <div class="tw-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.75rem]">
                                <span class="tw-font-bold tw-text-[color:var(--color-text-primary)]">{{actor.encumbrance.value}}</span>
                                <span class="tw-text-[color:var(--color-text-tertiary)]">/</span>
                                <span class="tw-text-[color:var(--color-text-secondary)]">{{actor.encumbrance.max}} kg</span>
                            </div>
                            <div class="tw-h-[6px] tw-bg-[var(--color-bg-tertiary)] tw-rounded-[3px] tw-overflow-hidden {{#if actor.encumbrance.encumbered}}{{/if}}">
                                <div class="tw-h-full tw-rounded-[3px] {{#if actor.encumbrance.encumbered}}tw-bg-[var(--wh40k-accent-combat)]{{else}}tw-bg-[linear-gradient(90deg,var(--wh40k-accent-green)_0%,var(--wh40k-accent-info)_100%)]{{/if}}" style="width: {{encumbrancePercent}}%"></div>
                            </div>
                        </div>
                {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}

                {{!-- Armour — reuses the combat-tab silhouette (issue #7).
                     `compact=true` drops the fitted-items strip + roll-range badge so the
                     silhouette fits inside the dashboard-zone footprint. --}}
                {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Armour" icon="fa-shield-alt" zoneClass="tw-border-l-[3px] tw-border-l-[#7f8c8d]"}}
                        {{> systems/wh40k-rpg/templates/actor/partial/armour-silhouette.hbs armourDisplay=armourDisplay compact=true}}
                {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}
            </div>

            {{#unless isNPC}}
            {{!-- Resources (Influence / Requisition / Gelt) — PC-only.
                 In DH2 RAW mode Influence is a Statistics characteristic, not an economy stat,
                 so it (and Throne Gelt) drop out of this panel and the grid collapses. --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Resources" icon="fa-coins" zoneClass="tw-border-l-[3px] tw-border-l-[var(--wh40k-color-gold)]" contentClass="tw-p-2 tw-flex-1 tw-w-full"}}
                    <div class="tw-grid {{#if isRaw}}tw-grid-cols-1{{else}}{{#if hideThroneGelt}}tw-grid-cols-2{{else}}tw-grid-cols-3{{/if}}{{/if}} tw-gap-2 tw-w-full">
                        {{#unless isRaw}}
                        <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                            <span class="tw-text-xs tw-normal-case tw-font-semibold tw-text-[color:var(--color-text-secondary)] tw-tracking-normal" data-tooltip="Social and political pull — calling in favours, securing audiences, persuading officials. Not bought with coin.">Influence</span>
                            <div class="tw-flex tw-items-center tw-gap-1">
                                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-p-0 tw-m-0 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-text-[var(--color-text-primary)] tw-font-bold tw-cursor-pointer tw-w-7 tw-h-7 tw-text-base tw-select-none tw-whitespace-nowrap" data-action="decrement" data-field="system.influence" data-min="0" title="-1">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" class="tw-py-1 tw-px-2 tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[var(--color-text-primary)] tw-font-numeric tw-text-center tw-h-9 tw-text-base tw-font-semibold tw-w-full tw-min-w-[50px] tw-max-w-[150px]" name="system.influence" value="{{system.influence}}" min="0" max="100" />
                                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-p-0 tw-m-0 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-text-[var(--color-text-primary)] tw-font-bold tw-cursor-pointer tw-w-7 tw-h-7 tw-text-base tw-select-none tw-whitespace-nowrap" data-action="increment" data-field="system.influence" data-max="100" title="+1">
                                    <i class="fas fa-plus"></i>
                                </button>
                                {{#if isHomebrew}}
                                {{!-- Issue #13 follow-up: Influence is not solely an economy stat
                                     (it gates social manipulation, audiences, Requisition tests).
                                     In Homebrew mode Influence lives here rather than Statistics,
                                     so surface a roll button that reuses the same `roll` action
                                     dispatch as the RAW characteristic row (rollType=characteristic,
                                     rollTarget=influence → actor.rollCharacteristic('influence')). --}}
                                <button type="button"
                                    class="tw-inline-flex tw-items-center tw-justify-center tw-p-0 tw-m-0 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-text-[var(--color-text-primary)] tw-font-bold tw-cursor-pointer tw-w-7 tw-h-7 tw-text-base tw-select-none tw-whitespace-nowrap tw-ml-1"
                                    data-action="roll"
                                    data-roll-type="characteristic"
                                    data-roll-target="influence"
                                    data-characteristic="influence"
                                    data-tooltip="{{localize 'WH40K.CharacteristicSetup.RollInfluence'}}"
                                    aria-label="{{localize 'WH40K.CharacteristicSetup.RollInfluence'}}">
                                    <i class="fas fa-dice-d10"></i>
                                </button>
                                {{/if}}
                            </div>
                        </div>
                        {{/unless}}
                        <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                            <span class="tw-text-xs tw-normal-case tw-font-semibold tw-text-[color:var(--color-text-secondary)] tw-tracking-normal" data-tooltip="Drawing on Inquisitorial resources — weapons from the armoury, specialist equipment, transport, and backup.">Requisition</span>
                            <div class="tw-flex tw-items-center tw-gap-1">
                                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-p-0 tw-m-0 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-text-[var(--color-text-primary)] tw-font-bold tw-cursor-pointer tw-w-7 tw-h-7 tw-text-base tw-select-none tw-whitespace-nowrap" data-action="decrement" data-field="system.requisition" data-min="0" title="-1">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" class="tw-py-1 tw-px-2 tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[var(--color-text-primary)] tw-font-numeric tw-text-center tw-h-9 tw-text-base tw-font-semibold tw-w-full tw-min-w-[50px] tw-max-w-[150px]" name="system.requisition" value="{{system.requisition}}" min="0" />
                                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-p-0 tw-m-0 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-text-[var(--color-text-primary)] tw-font-bold tw-cursor-pointer tw-w-7 tw-h-7 tw-text-base tw-select-none tw-whitespace-nowrap" data-action="increment" data-field="system.requisition" title="+1">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                        {{#unless hideThroneGelt}}
                        <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                            <span class="tw-text-xs tw-normal-case tw-font-semibold tw-text-[color:var(--color-text-secondary)] tw-tracking-normal" data-tooltip="Hard currency for street-level transactions — food, lodging, bribes, and black market purchases.">Throne Gelt</span>
                            <div class="tw-flex tw-items-center tw-gap-1">
                                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-p-0 tw-m-0 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-text-[var(--color-text-primary)] tw-font-bold tw-cursor-pointer tw-w-7 tw-h-7 tw-text-base tw-select-none tw-whitespace-nowrap" data-action="decrement" data-field="system.throneGelt" data-min="0" title="-1">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" class="tw-py-1 tw-px-2 tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[var(--color-text-primary)] tw-font-numeric tw-text-center tw-h-9 tw-text-base tw-font-semibold tw-w-full tw-min-w-[50px] tw-max-w-[150px]" name="system.throneGelt" value="{{system.throneGelt}}" min="0" />
                                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-p-0 tw-m-0 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-solid tw-border-[var(--color-border-secondary)] tw-rounded-[6px] tw-text-[var(--color-text-primary)] tw-font-bold tw-cursor-pointer tw-w-7 tw-h-7 tw-text-base tw-select-none tw-whitespace-nowrap" data-action="increment" data-field="system.throneGelt" title="+1">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                        {{/unless}}
                    </div>
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}
            {{/unless}}
        </div>

    </div>
</section>
