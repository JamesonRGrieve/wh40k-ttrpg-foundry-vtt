{{!-- Acolyte Sheet Overview Tab - Ultra-Dense Dashboard --}}
{{!-- At-a-glance view of all critical information --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    
    <div class="wh40k-dashboard tw-grid tw-grid-cols-3 tw-grid-rows-[auto_auto] tw-items-start tw-gap-2 tw-p-2 tw-h-full tw-overflow-y-auto tw-overflow-x-hidden tw-border-t-2 tw-border-t-gold bc:tw-border-t-crimson-light dh1e:tw-border-t-gold-raw-l5 dh2e:tw-border-t-gold-raw dw:tw-border-t-accent-combat ow:tw-border-t-brass-l20 rt:tw-border-t-gold im:tw-border-t-failure">

        {{!-- COLUMN 1: Vitals → Active Effects --}}
        <div class="tw-flex tw-flex-col tw-gap-2">
            {{!-- Vitals --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-vitals">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-1.5 tw-py-1.5 tw-px-2.5">
                    <i class="fas fa-heartbeat"></i>
                    <span>Vitals</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    {{!-- Wounds --}}
                    {{> systems/wh40k-rpg/templates/actor/partial/vital-inline-row
                        icon="fa-heart"
                        label="Wounds"
                        field="system.wounds.value"
                        current=system.wounds.value
                        max=system.wounds.max
                        maxAttr=system.wounds.max
                        stateClass=(iff (eq system.wounds.value 0) "wh40k-critical" (iff (lt (percent system.wounds.value system.wounds.max) 25) "wh40k-warning" ""))}}

                    {{!-- Critical Wounds --}}
                    {{#if (or (gt system.wounds.critical 0) (eq system.wounds.value 0))}}
                    {{#> systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs
                        icon="fa-skull" label="Critical" rowClass="wh40k-vital-critical-row"}}
                        {{> systems/wh40k-rpg/templates/actor/partial/pip-tracker-row
                            count=10
                            current=system.wounds.critical
                            action="setCriticalPip"
                            dataAttr="crit-level"
                            pipClass="wh40k-crit-pip-mini"
                            wrapperClass="wh40k-critical-pips-inline"
                            titlePrefix="Critical Level"}}
                    {{/systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs}}
                    {{/if}}

                    {{#unless isNPC}}
                    {{!-- Fatigue (PC-only) --}}
                    {{#> systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs
                        icon="fa-bolt" label="Fatigue"}}
                        {{> systems/wh40k-rpg/templates/actor/partial/pip-tracker-row
                            count=system.fatigue.max
                            current=system.fatigue.value
                            action="setFatigueBolt"
                            dataAttr="fatigue-index"
                            pipClass="wh40k-fatigue-pip"
                            filledClass="wh40k-fatigue-pip--filled tw-animate-bolt-glow"
                            wrapperClass="wh40k-fatigue-bolts-inline"
                            iconClass="fa-bolt"
                            titlePrefix="Fatigue Level"}}
                        {{#if (gt system.fatigue.value 0)}}
                        <span class="wh40k-vital-penalty">−10</span>
                        {{/if}}
                    {{/systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs}}

                    {{!-- Lift & Push (PC-only) --}}
                    <div class="wh40k-vital-row tw-flex tw-items-center tw-justify-between tw-py-0.5">
                        <span class="tw-flex tw-items-center tw-gap-1.5">
                            <span class="wh40k-vital-icon"><i class="fas fa-dumbbell"></i></span>
                            <span class="wh40k-vital-label">Lift</span>
                            <span class="wh40k-vital-value">{{system.lifting.lift}} kg</span>
                        </span>
                        <span class="tw-flex tw-items-center tw-gap-1.5">
                            <span class="wh40k-vital-label">Push</span>
                            <span class="wh40k-vital-value">{{system.lifting.push}} kg</span>
                        </span>
                    </div>

                    {{!-- Fate Points (PC-only) --}}
                    {{#if (gt system.fate.max 0)}}
                    {{#> systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs
                        icon="fa-star" label="Fate"}}
                        {{> systems/wh40k-rpg/templates/actor/partial/pip-tracker-row
                            count=system.fate.max
                            current=system.fate.value
                            action="setFateStar"
                            dataAttr="fate-index"
                            pipClass="wh40k-fate-pip"
                            wrapperClass="wh40k-fate-stars-inline"
                            iconClass="fa-star"
                            titlePrefix="Fate Point"}}
                        <button type="button" class="wh40k-vital-btn-small" data-action="restoreFate" title="Restore All">
                            <i class="fas fa-redo"></i>
                        </button>
                    {{/systems/wh40k-rpg/templates/actor/partial/vital-pip-row.hbs}}
                    {{/if}}
                    {{/unless}}
                </div>

                {{#unless isNPC}}
                {{!-- Mental State (compact) — PC-only (NPC schema has no corruption/insanity) --}}
                <div class="wh40k-zone-subsection">
                    {{> systems/wh40k-rpg/templates/actor/partial/vital-inline-row
                        icon="fa-skull"
                        label="Corruption"
                        field="system.corruption"
                        current=system.corruption
                        maxAttr=100
                        rowClass="wh40k-mental-row"
                        labelGroupClass="wh40k-mental-label-group"
                        iconClass="wh40k-mental-icon"
                        labelClass="wh40k-mental-label"
                        valueClass="wh40k-mental-value"
                        stateClass=(corruptionDegreeClass system.corruption)
                        degreeText=(corruptionDegree system.corruption)}}
                    {{> systems/wh40k-rpg/templates/actor/partial/vital-inline-row
                        icon="fa-brain"
                        label="Insanity"
                        field="system.insanity"
                        current=system.insanity
                        maxAttr=100
                        rowClass="wh40k-mental-row"
                        labelGroupClass="wh40k-mental-label-group"
                        iconClass="wh40k-mental-icon"
                        labelClass="wh40k-mental-label"
                        valueClass="wh40k-mental-value"
                        stateClass=(insanityDegreeClass system.insanity)
                        degreeText=(insanityDegree system.insanity)}}
                </div>
                {{/unless}}
            </div>

            {{!-- Active Effects --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Active Effects" icon="fa-magic" zoneClass="wh40k-zone-effects"}}
                    {{#if effects.length}}
                    <div class="wh40k-effects-preview">
                        {{#each effects as |effect|}}
                        <div class="wh40k-effect-chip {{#if effect.disabled}}wh40k-effect-chip--disabled{{/if}}" title="{{effect.name}}">
                            <img src="{{effect.icon}}" alt="" class="wh40k-effect-icon-mini" />
                            <span class="wh40k-effect-name-mini">{{effect.name}}</span>
                            <div class="wh40k-effect-chip-controls">
                                <button type="button" class="wh40k-effect-chip-btn"
                                        data-action="toggleEffect"
                                        data-effect-id="{{effect.id}}"
                                        title="{{#if effect.disabled}}Enable{{else}}Disable{{/if}}">
                                    <i class="fas {{#if effect.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
                                </button>
                                <button type="button" class="wh40k-effect-chip-btn wh40k-effect-chip-btn--danger"
                                        data-action="deleteEffect"
                                        data-effect-id="{{effect.id}}"
                                        title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="wh40k-effects-empty">
                        <span>No active effects</span>
                    </div>
                    {{/if}}
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}
        </div>

        {{!-- COLUMN 2: Favourite Skills → Favourite Talents → Progression --}}
        <div class="tw-flex tw-flex-col tw-gap-2">
            {{!-- Favourite Skills --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Favourite Skills" icon="fa-star" zoneClass="wh40k-zone-skills"}}
                    <div class="wh40k-skill-list-compact">
                        {{#if favoriteSkills}}
                            {{#each favoriteSkills as |skill|}}
                            <div class="wh40k-skill-row-compact" data-tooltip
                                 aria-label="{{skill.label}}: {{skill.current}}"
                                 data-wh40k-tooltip="skill"
                                 data-wh40k-tooltip-data="{{skill.tooltipData}}">
                                <span class="wh40k-skill-name-compact">{{skill.label}}</span>
                                <span class="wh40k-skill-value-compact">{{skill.current}}</span>
                                <button type="button"
                                        class="wh40k-skill-roll-btn"
                                        data-action="roll"
                                        data-roll-type="skill"
                                        data-roll-target="{{skill.key}}"
                                        title="Roll {{skill.label}}">
                                    <i class="fas fa-dice"></i>
                                </button>
                            </div>
                            {{/each}}
                        {{else}}
                            <div class="wh40k-no-favorites">
                                <i class="far fa-star"></i>
                                <p>No favourite skills selected</p>
                                <p class="wh40k-hint">Star skills in the Skills tab to add them here</p>
                            </div>
                        {{/if}}
                    </div>
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}

            {{!-- Favourite Talents --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Favourite Talents" icon="fa-star-half-alt" zoneClass="wh40k-zone-talents"}}
                    <div class="wh40k-talent-list-compact">
                        {{#if favoriteTalents}}
                            {{#each favoriteTalents as |talent|}}
                            <div class="wh40k-talent-row-compact" data-tooltip title="{{talent.name}}{{#if talent.specialization}} ({{talent.specialization}}){{/if}}">
                                <img class="wh40k-talent-icon-compact" src="{{talent.img}}" alt="{{talent.name}}" />
                                <span class="wh40k-talent-name-compact">
                                    {{talent.fullName}}
                                    {{#if talent.system.tier}}
                                    <span class="wh40k-talent-tier-badge">T{{talent.system.tier}}</span>
                                    {{/if}}
                                </span>
                                <button type="button"
                                        class="wh40k-talent-info-btn"
                                        data-action="itemEdit"
                                        data-item-id="{{talent.id}}"
                                        title="View {{talent.name}}">
                                    <i class="fas fa-info-circle"></i>
                                </button>
                            </div>
                            {{/each}}
                        {{else}}
                            <div class="wh40k-no-favorites">
                                <i class="far fa-star"></i>
                                <p>No favourite talents selected</p>
                                <p class="wh40k-hint">Star talents in the Skills tab to add them here</p>
                            </div>
                        {{/if}}
                    </div>
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}

            {{#unless isNPC}}
            {{!-- Progression (XP) — PC-only — kept inline due to SVG ring + action-button header --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-progression">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-1.5 tw-py-1.5 tw-px-2.5">
                    <div class="wh40k-xp-ring-header" data-tooltip="{{#if system.experience.total}}{{floor (multiply (divide system.experience.used system.experience.total) 100)}}{{else}}0{{/if}}% XP spent ({{system.experience.used}}/{{system.experience.total}})">
                        <svg viewBox="0 0 100 100" class="wh40k-xp-ring-header-svg">
                            <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(120, 46, 34, 0.2)" stroke-width="12"/>
                            <circle cx="50" cy="50" r="45" fill="none" stroke="#c08020" stroke-width="12" stroke-linecap="round"
                                    stroke-dasharray="282.74"
                                    stroke-dashoffset="{{multiply (subtract 1 (divide system.experience.used system.experience.total)) 282.74}}"
                                    transform="rotate(-90 50 50)"/>
                        </svg>
                    </div>
                    <span>Progression — Rank {{system.rank}}</span>
                    <div class="wh40k-zone-header-actions tw-flex tw-gap-1 tw-ml-auto">
                        {{#if isGM}}
                        <button type="button" class="wh40k-xp-action-btn" data-action="customXP" title="Add XP">
                            <i class="fas fa-plus"></i> Add XP
                        </button>
                        {{/if}}
                        <button type="button" class="wh40k-xp-action-btn" data-action="openAdvancement" title="Buy Advancements">
                            <i class="fa-solid fa-arrow-up-big-small"></i> Advance
                        </button>
                    </div>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="wh40k-xp-row">
                        <span class="wh40k-xp-label">Experience</span>
                        <span class="wh40k-xp-value">{{system.experience.available}}/{{system.experience.total}}</span>
                    </div>
                    {{#if aptitudePills.length}}
                    <div class="wh40k-aptitude-row tw-flex tw-flex-wrap tw-items-baseline tw-gap-1 tw-pt-1">
                        <span class="wh40k-xp-label tw-shrink-0">Aptitudes</span>
                        <div class="wh40k-aptitude-pills tw-flex tw-flex-wrap tw-gap-1">
                            {{#each aptitudePills as |pill|}}
                            <span class="wh40k-aptitude-pill tw-text-[0.7rem] tw-px-1.5 tw-py-0.5 tw-rounded tw-border tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-[rgba(212,175,55,0.08)]"
                                  data-tooltip="{{#each pill.sources}}{{this}}{{#unless @last}} · {{/unless}}{{/each}}">
                                {{pill.aptitude}}
                            </span>
                            {{/each}}
                        </div>
                    </div>
                    {{/if}}
                </div>
            </div>
            {{/unless}}
            {{#if isNPC}}
            {{!-- NPC summary panel in the progression slot --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-progression">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-1.5 tw-py-1.5 tw-px-2.5">
                    <i class="fa-solid fa-skull"></i>
                    <span>Threat — {{threatTier.label}}</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="wh40k-xp-row">
                        <span class="wh40k-xp-label">Threat Level</span>
                        <span class="wh40k-xp-value" style="color: {{threatTier.color}};">{{source.threatLevel}}/30</span>
                    </div>
                    <div class="wh40k-xp-row">
                        <span class="wh40k-xp-label">Type / Role</span>
                        <span class="wh40k-xp-value">{{source.type}} / {{source.role}}</span>
                    </div>
                    {{#if horde.enabled}}
                    <div class="wh40k-xp-row">
                        <span class="wh40k-xp-label">Magnitude</span>
                        <span class="wh40k-xp-value">{{horde.magnitude}}/{{horde.magnitudeMax}}</span>
                    </div>
                    {{/if}}
                </div>
            </div>
            {{/if}}


        </div>

        {{!-- COLUMN 3: Weapons + [Movement | Armour] → Resources --}}
        <div class="tw-flex tw-flex-col tw-gap-2">
            {{!-- Equipped Weapons --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Equipped Weapons" icon="fa-crosshairs" zoneClass="wh40k-zone-weapons"}}
                    {{#if equippedWeapons.length}}
                    <div class="wh40k-ew-list">
                        {{#each equippedWeapons as |weapon|}}
                        <div class="wh40k-ew-row" data-action="itemEdit" data-item-id="{{weapon.id}}" title="Open {{weapon.name}}">
                            <img class="wh40k-ew-icon" src="{{weapon.img}}" alt="{{weapon.name}}" />
                            <div class="wh40k-ew-info">
                                <span class="wh40k-ew-name">{{weapon.name}}</span>
                                <span class="wh40k-ew-meta">
                                    <span class="wh40k-ew-class">{{weapon.system.classLabel}}</span>
                                    {{#if weapon.system.rangeLabel}}<span class="wh40k-ew-range">{{weapon.system.rangeLabel}}</span>{{/if}}
                                </span>
                            </div>
                            <span class="wh40k-ew-damage">{{weapon.system.damageLabel}}</span>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="wh40k-ew-empty">
                        <i class="fas fa-crosshairs"></i>
                        <span>No weapons equipped</span>
                    </div>
                    {{/if}}
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}

            {{!-- Movement & Armour side by side --}}
            <div class="tw-grid tw-grid-cols-2 tw-gap-2">
                {{!-- Movement 2x2 --}}
                {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Movement" icon="fa-running" zoneClass="wh40k-zone-movement"}}
                        <div class="tw-grid tw-grid-cols-2 tw-gap-1">
                            <div class="wh40k-speed-item">
                                <span class="wh40k-speed-value">{{actor.movement.half}}</span>
                                <span class="wh40k-speed-label"><i class="fas fa-walking wh40k-speed-icon"></i> Half</span>
                            </div>
                            <div class="wh40k-speed-item">
                                <span class="wh40k-speed-value">{{actor.movement.full}}</span>
                                <span class="wh40k-speed-label"><i class="fas fa-shoe-prints wh40k-speed-icon"></i> Full</span>
                            </div>
                            <div class="wh40k-speed-item">
                                <span class="wh40k-speed-value">{{actor.movement.charge}}</span>
                                <span class="wh40k-speed-label"><i class="fas fa-running wh40k-speed-icon"></i> Charge</span>
                            </div>
                            <div class="wh40k-speed-item wh40k-speed-item--highlight">
                                <span class="wh40k-speed-value">{{actor.movement.run}}</span>
                                <span class="wh40k-speed-label"><i class="fas fa-wind wh40k-speed-icon"></i> Run</span>
                            </div>
                        </div>
                        <div class="wh40k-encumbrance-compact">
                            <div class="wh40k-enc-info">
                                <span class="wh40k-enc-current-compact">{{actor.encumbrance.value}}</span>
                                <span class="wh40k-enc-separator">/</span>
                                <span class="wh40k-enc-max-compact">{{actor.encumbrance.max}} kg</span>
                            </div>
                            <div class="wh40k-enc-bar-compact {{#if actor.encumbrance.encumbered}}wh40k-enc-over{{/if}}">
                                <div class="wh40k-enc-fill-compact" style="width: {{encumbrancePercent}}%"></div>
                            </div>
                        </div>
                {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}

                {{!-- Armour --}}
                {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Armour" icon="fa-shield-alt" zoneClass="wh40k-zone-armour"}}
                        <div class="wh40k-ov-armour-silhouette">
                            <div class="wh40k-ov-armour-box wh40k-ov-box-head" title="Head: 01-10">
                                <span class="wh40k-ov-box-label">Head</span>
                                <span class="wh40k-ov-box-ap">{{system.armour.head.total}}</span>
                            </div>
                            <div class="wh40k-ov-armour-box wh40k-ov-box-right-arm" title="R.Arm: 11-20">
                                <span class="wh40k-ov-box-label">R.Arm</span>
                                <span class="wh40k-ov-box-ap">{{system.armour.rightArm.total}}</span>
                            </div>
                            <div class="wh40k-ov-armour-box wh40k-ov-box-body" title="Body: 31-70">
                                <span class="wh40k-ov-box-label">Body</span>
                                <span class="wh40k-ov-box-ap">{{system.armour.body.total}}</span>
                            </div>
                            <div class="wh40k-ov-armour-box wh40k-ov-box-left-arm" title="L.Arm: 21-30">
                                <span class="wh40k-ov-box-label">L.Arm</span>
                                <span class="wh40k-ov-box-ap">{{system.armour.leftArm.total}}</span>
                            </div>
                            <div class="wh40k-ov-armour-box wh40k-ov-box-right-leg" title="R.Leg: 71-85">
                                <span class="wh40k-ov-box-label">R.Leg</span>
                                <span class="wh40k-ov-box-ap">{{system.armour.rightLeg.total}}</span>
                            </div>
                            <div class="wh40k-ov-armour-box wh40k-ov-box-left-leg" title="L.Leg: 86-00">
                                <span class="wh40k-ov-box-label">L.Leg</span>
                                <span class="wh40k-ov-box-ap">{{system.armour.leftLeg.total}}</span>
                            </div>
                        </div>
                {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}
            </div>

            {{#unless isNPC}}
            {{!-- Resources (Influence / Requisition / Gelt) — PC-only --}}
            {{#> systems/wh40k-rpg/templates/actor/partial/dashboard-zone title="Resources" icon="fa-coins" zoneClass="wh40k-zone-resources" contentClass="wh40k-zone-content tw-p-2 tw-flex-1 tw-w-full"}}
                    <div class="tw-grid {{#if hideThroneGelt}}tw-grid-cols-2{{else}}tw-grid-cols-3{{/if}} tw-gap-2 tw-w-full">
                        <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                            <span class="wh40k-vital-label tw-text-xs" data-tooltip="Social and political pull — calling in favours, securing audiences, persuading officials. Not bought with coin.">Influence</span>
                            <div class="tw-flex tw-items-center tw-gap-1">
                                <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.influence" data-min="0" title="-1">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" class="wh40k-vital-input" name="system.influence" value="{{system.influence}}" min="0" />
                                <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.influence" data-max="100" title="+1">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                        <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                            <span class="wh40k-vital-label tw-text-xs" data-tooltip="Drawing on Inquisitorial resources — weapons from the armoury, specialist equipment, transport, and backup.">Requisition</span>
                            <div class="tw-flex tw-items-center tw-gap-1">
                                <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.requisition" data-min="0" title="-1">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" class="wh40k-vital-input" name="system.requisition" value="{{system.requisition}}" min="0" />
                                <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.requisition" title="+1">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                        {{#unless hideThroneGelt}}
                        <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
                            <span class="wh40k-vital-label tw-text-xs" data-tooltip="Hard currency for street-level transactions — food, lodging, bribes, and black market purchases.">Throne Gelt</span>
                            <div class="tw-flex tw-items-center tw-gap-1">
                                <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.throneGelt" data-min="0" title="-1">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" class="wh40k-vital-input" name="system.throneGelt" value="{{system.throneGelt}}" min="0" />
                                <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.throneGelt" title="+1">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                        {{/unless}}
                    </div>
            {{/systems/wh40k-rpg/templates/actor/partial/dashboard-zone}}
            {{/unless}}
