{{!-- Acolyte Sheet Overview Tab - Ultra-Dense Dashboard --}}
{{!-- At-a-glance view of all critical information --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    
    <div class="wh40k-dashboard tw-flex tw-flex-col tw-gap-2 tw-p-2 tw-h-full tw-overflow-y-auto tw-overflow-x-hidden">
        {{!-- Row 1: Vitals | Key Skills --}}
        <div class="wh40k-dashboard-row tw-grid tw-gap-2 wh40k-dashboard-row--top">
            
            {{!-- Zone 1: Vitals (Top-Left) --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-vitals">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-heartbeat"></i>
                    <span>Vitals</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    {{!-- Wounds --}}
                    <div class="wh40k-vital-row tw-flex tw-items-center tw-gap-[6px] tw-py-[2px]">
                        <span class="wh40k-vital-icon"><i class="fas fa-heart"></i></span>
                        <span class="wh40k-vital-label">Wounds</span>
                        <div class="wh40k-vital-controls tw-flex tw-items-center tw-gap-1 tw-ml-auto">
                            <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.wounds.value" data-min="0" title="−1">
                                <i class="fas fa-minus"></i>
                            </button>
                            <span class="wh40k-vital-value {{#if (eq system.wounds.value 0)}}wh40k-critical{{else if (lt (percent system.wounds.value system.wounds.max) 25)}}wh40k-warning{{/if}}">
                                {{system.wounds.value}}/{{system.wounds.max}}
                            </span>
                            <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.wounds.value" data-max="{{system.wounds.max}}" title="+1">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    
                    {{!-- Critical Wounds - Below wounds, always visible if critical > 0 --}}
                    {{#if (or (gt system.wounds.critical 0) (eq system.wounds.value 0))}}
                    <div class="wh40k-vital-row tw-flex tw-items-center tw-gap-[6px] tw-py-[2px] wh40k-vital-critical-row">
                        <span class="wh40k-vital-icon"><i class="fas fa-skull"></i></span>
                        <span class="wh40k-vital-label">Critical</span>
                        <div class="wh40k-critical-pips-inline">
                            {{#times 10}}
                                <button type="button"
                                        class="wh40k-crit-pip-mini {{#if (lte this ../system.wounds.critical)}}wh40k-crit-pip-mini--filled{{/if}}"
                                        data-action="setCriticalPip"
                                        data-crit-level="{{this}}"
                                        title="Critical Level {{this}}">
                                </button>
                            {{/times}}
                        </div>
                    </div>
                    {{/if}}
                    
                    {{!-- Fatigue --}}
                    <div class="wh40k-vital-row tw-flex tw-items-center tw-gap-[6px] tw-py-[2px]">
                        <span class="wh40k-vital-icon"><i class="fas fa-bolt"></i></span>
                        <span class="wh40k-vital-label">Fatigue</span>
                        <div class="wh40k-fatigue-bolts-inline">
                            {{#each (range 1 system.fatigue.max) as |index|}}
                                <button type="button"
                                        class="wh40k-fatigue-pip {{#if (lte index ../system.fatigue.value)}}wh40k-fatigue-pip--filled{{/if}}"
                                        data-action="setFatigueBolt"
                                        data-fatigue-index="{{index}}"
                                        title="Fatigue Level {{index}}">
                                    <i class="fas fa-bolt"></i>
                                </button>
                            {{/each}}
                        </div>
                        {{#if (gt system.fatigue.value 0)}}
                        <span class="wh40k-vital-penalty">−10</span>
                        {{/if}}
                    </div>
                    
                    {{!-- Fate Points --}}
                    <div class="wh40k-vital-row tw-flex tw-items-center tw-gap-[6px] tw-py-[2px]">
                        <span class="wh40k-vital-icon"><i class="fas fa-star"></i></span>
                        <span class="wh40k-vital-label">Fate</span>
                        <div class="wh40k-fate-stars-inline">
                            {{#each (range 1 system.fate.max) as |index|}}
                                <button type="button"
                                        class="wh40k-fate-pip {{#if (lte index ../system.fate.value)}}wh40k-fate-pip--filled{{/if}}"
                                        data-action="setFateStar"
                                        data-fate-index="{{index}}"
                                        title="Fate Point {{index}}">
                                    <i class="fas fa-star"></i>
                                </button>
                            {{/each}}
                        </div>
                        <button type="button" class="wh40k-vital-btn-small" data-action="restoreFate" title="Restore All">
                            <i class="fas fa-redo"></i>
                        </button>
                    </div>
                </div>
                
                {{!-- Mental State (compact) --}}
                <div class="wh40k-zone-subsection">
                    <div class="wh40k-mental-row">
                        <span class="wh40k-mental-icon"><i class="fas fa-skull"></i></span>
                        <span class="wh40k-mental-label">Corruption</span>
                        <div class="wh40k-vital-controls tw-flex tw-items-center tw-gap-1 tw-ml-auto">
                            <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.corruption" data-min="0" title="−1">
                                <i class="fas fa-minus"></i>
                            </button>
                            <span class="wh40k-mental-value">{{system.corruption}}</span>
                            <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.corruption" data-max="100" title="+1">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        <span class="wh40k-mental-degree {{corruptionDegreeClass system.corruption}}">{{corruptionDegree system.corruption}}</span>
                    </div>
                    <div class="wh40k-mental-row">
                        <span class="wh40k-mental-icon"><i class="fas fa-brain"></i></span>
                        <span class="wh40k-mental-label">Insanity</span>
                        <div class="wh40k-vital-controls tw-flex tw-items-center tw-gap-1 tw-ml-auto">
                            <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.insanity" data-min="0" title="−1">
                                <i class="fas fa-minus"></i>
                            </button>
                            <span class="wh40k-mental-value">{{system.insanity}}</span>
                            <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.insanity" data-max="100" title="+1">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        <span class="wh40k-mental-degree {{insanityDegreeClass system.insanity}}">{{insanityDegree system.insanity}}</span>
                    </div>
                </div>
            </div>
            
            {{!-- Zone 2: Favorite Skills (Top-Right) --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-skills">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-star"></i>
                    <span>Favorite Skills</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="wh40k-skill-list-compact">
                        {{#if favoriteSkills}}
                            {{#each favoriteSkills as |skill|}}
                            <div class="wh40k-skill-row-compact" data-tooltip 
                                 aria-label="{{skill.label}}: {{skill.current}}"
                                 data-wh40k-tooltip="skill" 
                                 data-wh40k-tooltip-data="{{skill.tooltipData}}">
                                <span class="wh40k-skill-name-compact">{{skill.label}}</span>
                                <span class="wh40k-skill-value-compact">{{skill.current}}</span>
                                <button type="button" 
                                        class="wh40k-skill-roll-btn"
                                        data-action="roll"
                                        data-roll-type="skill"
                                        data-roll-target="{{skill.key}}"
                                        title="Roll {{skill.label}}">
                                    <i class="fas fa-dice"></i>
                                </button>
                            </div>
                            {{/each}}
                        {{else}}
                            <div class="wh40k-no-favorites">
                                <i class="far fa-star"></i>
                                <p>No favorite skills selected</p>
                                <p class="wh40k-hint">Star skills in the Skills tab to add them here</p>
                            </div>
                        {{/if}}
                    </div>
                </div>
            </div>
            
            {{!-- Zone 3: Favorite Talents --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-talents">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-star-half-alt"></i>
                    <span>Favorite Talents</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="wh40k-talent-list-compact">
                        {{#if favoriteTalents}}
                            {{#each favoriteTalents as |talent|}}
                            <div class="wh40k-talent-row-compact" data-tooltip title="{{talent.name}}{{#if talent.specialization}} ({{talent.specialization}}){{/if}}">
                                <img class="wh40k-talent-icon-compact" src="{{talent.img}}" alt="{{talent.name}}" />
                                <span class="wh40k-talent-name-compact">
                                    {{talent.fullName}}
                                    {{#if talent.system.tier}}
                                    <span class="wh40k-talent-tier-badge">T{{talent.system.tier}}</span>
                                    {{/if}}
                                </span>
                                <button type="button" 
                                        class="wh40k-talent-info-btn"
                                        data-action="itemEdit"
                                        data-item-id="{{talent.id}}"
                                        title="View {{talent.name}}">
                                    <i class="fas fa-info-circle"></i>
                                </button>
                            </div>
                            {{/each}}
                        {{else}}
                            <div class="wh40k-no-favorites">
                                <i class="far fa-star"></i>
                                <p>No favorite talents selected</p>
                                <p class="wh40k-hint">Star talents in the Talents tab to add them here</p>
                            </div>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
        
        {{!-- Row 2: Equipped Weapons | Movement & Load | Armour --}}
        <div class="wh40k-dashboard-row tw-grid tw-gap-2 wh40k-dashboard-row--middle">
            
            {{!-- Zone 4: Equipped Weapons --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-weapons">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-crosshairs"></i>
                    <span>Equipped Weapons</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    {{#if equippedWeapons.length}}
                    <div class="wh40k-ew-list">
                        {{#each equippedWeapons as |weapon|}}
                        <div class="wh40k-ew-row" data-action="itemEdit" data-item-id="{{weapon.id}}" title="Open {{weapon.name}}">
                            <img class="wh40k-ew-icon" src="{{weapon.img}}" alt="{{weapon.name}}" />
                            <div class="wh40k-ew-info">
                                <span class="wh40k-ew-name">{{weapon.name}}</span>
                                <span class="wh40k-ew-meta">
                                    <span class="wh40k-ew-class">{{weapon.system.class}}</span>
                                    {{#if weapon.system.rangeLabel}}<span class="wh40k-ew-range">{{weapon.system.rangeLabel}}</span>{{/if}}
                                </span>
                            </div>
                            <span class="wh40k-ew-damage">{{weapon.system.damageLabel}}</span>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="wh40k-ew-empty">
                        <i class="fas fa-crosshairs"></i>
                        <span>No weapons equipped</span>
                    </div>
                    {{/if}}
                </div>
            </div>
            
            {{!-- Zone 5: Movement & Load --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-movement">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-running"></i>
                    <span>Movement & Load</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1 wh40k-movement-compact">
                    <div class="wh40k-movement-speeds">
                        <div class="wh40k-speed-item">
                            <span class="wh40k-speed-value">{{actor.movement.half}}</span>
                            <span class="wh40k-speed-label">Half</span>
                        </div>
                        <div class="wh40k-speed-item">
                            <span class="wh40k-speed-value">{{actor.movement.full}}</span>
                            <span class="wh40k-speed-label">Full</span>
                        </div>
                        <div class="wh40k-speed-item">
                            <span class="wh40k-speed-value">{{actor.movement.charge}}</span>
                            <span class="wh40k-speed-label">Charge</span>
                        </div>
                        <div class="wh40k-speed-item wh40k-speed-item--highlight">
                            <span class="wh40k-speed-value">{{actor.movement.run}}</span>
                            <span class="wh40k-speed-label">Run</span>
                        </div>
                    </div>
                    <div class="wh40k-encumbrance-compact">
                        <div class="wh40k-enc-info">
                            <span class="wh40k-enc-current-compact">{{actor.encumbrance.current}}</span>
                            <span class="wh40k-enc-separator">/</span>
                            <span class="wh40k-enc-max-compact">{{actor.encumbrance.max}} kg</span>
                        </div>
                        <div class="wh40k-enc-bar-compact {{#if actor.encumbrance.encumbered}}wh40k-enc-over{{/if}}">
                            <div class="wh40k-enc-fill-compact" style="width: {{encumbrancePercent}}%"></div>
                        </div>
                    </div>
                </div>
            </div>
            
            {{!-- Zone 6: Armour --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-armour">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-shield-alt"></i>
                    <span>Armour</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="wh40k-ov-armour-silhouette">
                        <div class="wh40k-ov-armour-box wh40k-ov-box-head" title="Head: 01-10">
                            <span class="wh40k-ov-box-label">Head</span>
                            <span class="wh40k-ov-box-ap">{{system.armour.head.total}}</span>
                        </div>
                        <div class="wh40k-ov-armour-box wh40k-ov-box-right-arm" title="R.Arm: 11-20">
                            <span class="wh40k-ov-box-label">R.Arm</span>
                            <span class="wh40k-ov-box-ap">{{system.armour.rightArm.total}}</span>
                        </div>
                        <div class="wh40k-ov-armour-box wh40k-ov-box-body" title="Body: 31-70">
                            <span class="wh40k-ov-box-label">Body</span>
                            <span class="wh40k-ov-box-ap">{{system.armour.body.total}}</span>
                        </div>
                        <div class="wh40k-ov-armour-box wh40k-ov-box-left-arm" title="L.Arm: 21-30">
                            <span class="wh40k-ov-box-label">L.Arm</span>
                            <span class="wh40k-ov-box-ap">{{system.armour.leftArm.total}}</span>
                        </div>
                        <div class="wh40k-ov-armour-box wh40k-ov-box-right-leg" title="R.Leg: 71-85">
                            <span class="wh40k-ov-box-label">R.Leg</span>
                            <span class="wh40k-ov-box-ap">{{system.armour.rightLeg.total}}</span>
                        </div>
                        <div class="wh40k-ov-armour-box wh40k-ov-box-left-leg" title="L.Leg: 86-00">
                            <span class="wh40k-ov-box-label">L.Leg</span>
                            <span class="wh40k-ov-box-ap">{{system.armour.leftLeg.total}}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        {{!-- Row 3: Progression | Active Effects (2-wide) --}}
        <div class="wh40k-dashboard-row tw-grid tw-gap-2 wh40k-dashboard-row--bottom">
            
            {{!-- Zone 7: Progression --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-progression">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-graduation-cap"></i>
                    <span>Progression</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="wh40k-xp-row">
                        <span class="wh40k-xp-label">Available XP</span>
                        <span class="wh40k-xp-value wh40k-xp-available">{{system.experience.available}}</span>
                    </div>
                    <div class="wh40k-xp-row">
                        <span class="wh40k-xp-label">Spent XP</span>
                        <span class="wh40k-xp-value">{{system.experience.used}}</span>
                    </div>
                    <div class="wh40k-xp-row">
                        <span class="wh40k-xp-label">Total XP</span>
                        <span class="wh40k-xp-value">{{system.experience.total}}</span>
                    </div>
                    <div class="wh40k-xp-row wh40k-rank-row">
                        <span class="wh40k-xp-label">Rank</span>
                        <span class="wh40k-xp-value wh40k-rank-value">{{system.rank}}</span>
                    </div>
                    <div class="wh40k-xp-actions">
                        <button type="button" class="wh40k-xp-action-btn" data-action="customXP" title="Add XP">
                            <i class="fas fa-plus"></i> Add XP
                        </button>
                        <button type="button" class="wh40k-xp-action-btn" data-action="openAdvancement" title="Buy Advancements">
                            <i class="fa-solid fa-arrow-up-big-small"></i> Advance
                        </button>
                    </div>
                </div>
            </div>
            
            {{!-- Zone: DH2e Resources --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-resources">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-coins"></i>
                    <span>Resources</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    <div class="wh40k-vital-row tw-flex tw-items-center tw-gap-[6px] tw-py-[2px]">
                        <span class="wh40k-vital-icon"><i class="fas fa-handshake"></i></span>
                        <span class="wh40k-vital-label">Influence</span>
                        <div class="wh40k-vital-controls tw-flex tw-items-center tw-gap-1 tw-ml-auto">
                            <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.influence" data-min="0" title="-1">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" class="wh40k-vital-input" name="system.influence" value="{{system.influence}}" min="0" />
                            <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.influence" data-max="100" title="+1">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <div class="wh40k-vital-row tw-flex tw-items-center tw-gap-[6px] tw-py-[2px]">
                        <span class="wh40k-vital-icon"><i class="fas fa-stamp"></i></span>
                        <span class="wh40k-vital-label">Requisition</span>
                        <div class="wh40k-vital-controls tw-flex tw-items-center tw-gap-1 tw-ml-auto">
                            <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.requisition" data-min="0" title="-1">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" class="wh40k-vital-input" name="system.requisition" value="{{system.requisition}}" min="0" />
                            <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.requisition" title="+1">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <div class="wh40k-vital-row tw-flex tw-items-center tw-gap-[6px] tw-py-[2px]">
                        <span class="wh40k-vital-icon"><i class="fas fa-coins"></i></span>
                        <span class="wh40k-vital-label">Throne Gelt</span>
                        <div class="wh40k-vital-controls tw-flex tw-items-center tw-gap-1 tw-ml-auto">
                            <button type="button" class="wh40k-vital-btn" data-action="decrement" data-field="system.throneGelt" data-min="0" title="-1">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" class="wh40k-vital-input" name="system.throneGelt" value="{{system.throneGelt}}" min="0" />
                            <button type="button" class="wh40k-vital-btn" data-action="increment" data-field="system.throneGelt" title="+1">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            {{!-- Zone 8: Active Effects (takes 2fr column) --}}
            <div class="wh40k-dashboard-zone tw-flex tw-flex-col tw-overflow-hidden wh40k-zone-effects">
                <div class="wh40k-zone-header tw-flex tw-items-center tw-gap-[6px] tw-py-[6px] tw-px-[10px]">
                    <i class="fas fa-magic"></i>
                    <span>Active Effects</span>
                </div>
                <div class="wh40k-zone-content tw-p-2 tw-flex-1 tw-flex tw-flex-col tw-gap-1">
                    {{#if effects.length}}
                    <div class="wh40k-effects-preview">
                        {{#each effects as |effect|}}
                        <div class="wh40k-effect-chip {{#if effect.disabled}}wh40k-effect-chip--disabled{{/if}}" title="{{effect.name}}">
                            <img src="{{effect.icon}}" alt="" class="wh40k-effect-icon-mini" />
                            <span class="wh40k-effect-name-mini">{{effect.name}}</span>
                            <div class="wh40k-effect-chip-controls">
                                <button type="button" class="wh40k-effect-chip-btn"
                                        data-action="toggleEffect"
                                        data-effect-id="{{effect.id}}"
                                        title="{{#if effect.disabled}}Enable{{else}}Disable{{/if}}">
                                    <i class="fas {{#if effect.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
                                </button>
                                <button type="button" class="wh40k-effect-chip-btn wh40k-effect-chip-btn--danger"
                                        data-action="deleteEffect"
                                        data-effect-id="{{effect.id}}"
                                        title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="wh40k-effects-empty">
                        <span>No active effects</span>
                    </div>
                    {{/if}}
                    <button type="button" class="wh40k-effect-create-btn" data-action="createEffect" title="Create Effect">
                        <i class="fas fa-plus"></i> New Effect
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
