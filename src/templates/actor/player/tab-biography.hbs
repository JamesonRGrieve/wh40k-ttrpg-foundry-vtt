{{!-- Acolyte Sheet Biography Tab --}}
{{!-- This part renders the Biography tab content with identity, origin path, and notes --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
<div class="tw-grid tw-grid-cols-2 tw-gap-3 tw-w-full">
    {{!-- Left Column: Identity & Origin --}}
    <div class="wh40k-bio-col tw-flex tw-flex-col tw-gap-0 tw-overflow-visible tw-min-w-0">
        {{!-- Identity Panel --}}
        <div class="wh40k-panel">
            <div class="wh40k-panel-header">
                <span class="wh40k-panel-title"><i class="fas fa-user"></i> Identity</span>
            </div>
            <div class="wh40k-panel-body">
                <div class="wh40k-identity-grid">
                    <div class="wh40k-field-row">
                        <label class="wh40k-field-label">Gender</label>
                        <input type="text" class="wh40k-field-input" name="system.bio.gender" value="{{system.bio.gender}}" />
                    </div>
                    <div class="wh40k-field-row">
                        <label class="wh40k-field-label">Age</label>
                        <input type="text" class="wh40k-field-input" name="system.bio.age" value="{{system.bio.age}}" />
                    </div>
                    <div class="wh40k-field-row">
                        <label class="wh40k-field-label">Build</label>
                        <input type="text" class="wh40k-field-input" name="system.bio.build" value="{{system.bio.build}}" />
                    </div>
                    <div class="wh40k-field-row">
                        <label class="wh40k-field-label">Complexion</label>
                        <input type="text" class="wh40k-field-input" name="system.bio.complexion" value="{{system.bio.complexion}}" />
                    </div>
                    <div class="wh40k-field-row">
                        <label class="wh40k-field-label">Hair</label>
                        <input type="text" class="wh40k-field-input" name="system.bio.hair" value="{{system.bio.hair}}" />
                    </div>
                    <div class="wh40k-field-row">
                        <label class="wh40k-field-label">Eyes</label>
                        <input type="text" class="wh40k-field-input" name="system.bio.eyes" value="{{system.bio.eyes}}" />
                    </div>
                </div>
            </div>
        </div>
        
        {{!-- Connections Panel --}}
            <div class="wh40k-panel">
                <div class="wh40k-panel-header">
                    <span class="wh40k-panel-title"><i class="fas fa-users"></i> Connections</span>
                </div>
                <div class="wh40k-panel-body">
                    <div class="wh40k-connections-section">
                        <div class="wh40k-affliction-header">
                            <span>Peers</span>
                            <button type="button" class="wh40k-add-btn" data-action="itemCreate" data-type="peer"><i class="fas fa-plus"></i></button>
                        </div>
                        <div class="wh40k-affliction-list">
                            {{#each actor.items as |item|}}
                                {{#if item.isPeer}}
                                <div class="wh40k-affliction-row" data-item-id="{{item.id}}">
                                    <span class="wh40k-affliction-name" data-action="itemEdit" data-item-id="{{item.id}}">{{item.name}}</span>
                                    <span class="wh40k-connection-bonus">+{{item.system.modifier}}</span>
                                    <button type="button" class="wh40k-affliction-del" data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-times"></i></button>
                                </div>
                                {{/if}}
                            {{/each}}
                        </div>
                    </div>
                    <div class="wh40k-connections-section">
                        <div class="wh40k-affliction-header">
                            <span>Enemies</span>
                            <button type="button" class="wh40k-add-btn" data-action="itemCreate" data-type="enemy"><i class="fas fa-plus"></i></button>
                        </div>
                        <div class="wh40k-affliction-list">
                            {{#each actor.items as |item|}}
                                {{#if item.isEnemy}}
                                <div class="wh40k-affliction-row" data-item-id="{{item.id}}">
                                    <span class="wh40k-affliction-name" data-action="itemEdit" data-item-id="{{item.id}}">{{item.name}}</span>
                                    <span class="wh40k-connection-penalty">{{item.system.modifier}}</span>
                                    <button type="button" class="wh40k-affliction-del" data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-times"></i></button>
                                </div>
                                {{/if}}
                            {{/each}}
                        </div>
                    </div>
                </div>
            </div>
        {{!-- End of Connections Panel --}}

        </div>
    {{!-- End of Left Column --}}
        
        {{!-- Right Column: Journal/Notes --}}
        <div class="wh40k-bio-col tw-flex tw-flex-col tw-gap-0 tw-overflow-visible tw-min-w-0">
            {{!-- Character Notes / Journal --}}
            <div class="wh40k-panel wh40k-panel-journal">
                <div class="wh40k-panel-header">
                    <span class="wh40k-panel-title"><i class="fas fa-book-open"></i> Character Journal</span>
                </div>
                <div class="wh40k-panel-body wh40k-journal-body">
                    <div class="wh40k-journal-section">
                        <label class="wh40k-field-label">Personality & Quirks</label>
                        <textarea class="wh40k-textarea" name="system.bio.quirks" rows="2" placeholder="Distinctive habits, mannerisms, beliefs...">{{system.bio.quirks}}</textarea>
                    </div>
                    <div class="wh40k-journal-section">
                        <label class="wh40k-field-label">Superstitions & Rituals</label>
                        <textarea class="wh40k-textarea" name="system.bio.superstition" rows="2" placeholder="Personal beliefs and observances...">{{system.bio.superstition}}</textarea>
                    </div>
                    <div class="wh40k-journal-section">
                        <label class="wh40k-field-label">Treasured Mementos</label>
                        <textarea class="wh40k-textarea" name="system.bio.mementos" rows="2" placeholder="Important possessions and keepsakes...">{{system.bio.mementos}}</textarea>
                    </div>
                    <div class="wh40k-journal-section wh40k-journal-notes">
                        <label class="wh40k-field-label">Background & Notes</label>
                        {{#if editable}}
                        <prose-mirror name="system.bio.notes" 
                                      value="{{biography.source.notes}}" 
                                      document-uuid="{{actor.uuid}}"
                                      class="wh40k-prose-editor"
                                      compact>
                            {{{biography.enriched.notes}}}
                        </prose-mirror>
                        {{else}}
                        <div class="wh40k-prose-content editor-content">
                            {{{biography.enriched.notes}}}
                        </div>
                        {{/if}}
                    </div>
                    {{> systems/wh40k-rpg/templates/actor/panel/journal-panel.hbs includePanel=false}}
                </div>
            </div>
        </div>
    </div>
</div>
</section>
