{{!-- Acolyte Sheet Status Tab --}}
{{!-- Detailed status tracking - moved from Overview tab --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }} bc:tw-bg-crimson/[2%] dh1e:tw-bg-gold-dark/[2%] dh2e:tw-bg-gold-dark/[2%] dw:tw-bg-accent-combat/[2%] ow:tw-bg-brass/[2%] rt:tw-bg-gold/[2%] im:tw-bg-failure/[2%]" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    
    {{!-- Two Column Layout --}}
    <div class="tw-grid tw-grid-cols-[repeat(var(--wh40k-columns,2),1fr)] tw-gap-3 tw-w-full tw-border-t-2 tw-border-t-gold bc:tw-border-t-crimson-light dh1e:tw-border-t-gold-raw-l5 dh2e:tw-border-t-gold-raw dw:tw-border-t-accent-combat ow:tw-border-t-brass-l20 rt:tw-border-t-gold im:tw-border-t-failure tw-pt-2">
        {{!-- Left Column --}}
        <div class="tw-flex tw-w-full tw-min-w-0 tw-self-stretch tw-flex-col tw-gap-4 tw-overflow-visible">
            {{!-- Wounds Panel --}}
            {{> systems/wh40k-rpg/templates/actor/panel/wounds-panel.hbs}}

            {{!-- Fatigue Panel --}}
            {{> systems/wh40k-rpg/templates/actor/panel/fatigue-panel.hbs}}

            {{!-- Corruption Panel --}}
            {{> systems/wh40k-rpg/templates/actor/panel/corruption-panel.hbs}}

            {{!-- Insanity Panel --}}
            {{> systems/wh40k-rpg/templates/actor/panel/insanity-panel.hbs}}

            {{!-- Shock Panel (#66) — DH2-only Shock counter + Snap-Out-Of-It. --}}
            {{#if isDH2}}
                {{> systems/wh40k-rpg/templates/actor/panel/shock-panel.hbs}}
            {{/if}}

            {{!-- Possession Panel (#82) — only when the possession track is engaged --}}
            {{#if (neq system.possession.state 'none')}}
                {{> systems/wh40k-rpg/templates/actor/panel/possession-panel.hbs}}
            {{/if}}
        </div>

        {{!-- Right Column --}}
        <div class="tw-flex tw-w-full tw-min-w-0 tw-self-stretch tw-flex-col tw-gap-4 tw-overflow-visible">
            {{!-- Experience Panel --}}
            {{> systems/wh40k-rpg/templates/actor/panel/experience-panel.hbs}}

            {{!-- Fate Panel --}}
            {{> systems/wh40k-rpg/templates/actor/panel/fate-panel.hbs}}

            {{!-- Subtlety Panel (#87) — DH2-only warband subtlety pool.
                 Gate matches `_gameSystemId === 'dh2e'` from CharacterSheet
                 (`isDH2` is the context flag set in _prepareContext). --}}
            {{#if isDH2}}
                {{> systems/wh40k-rpg/templates/actor/panel/subtlety-panel.hbs}}
            {{/if}}

            {{!-- BC Alignment / Infamy Panel (#173) — Black-Crusade-only.
                 Gate matches `_gameSystemId === 'bc'` from CharacterSheet
                 (`isBC` flag + `alignmentPanel` context set in _prepareContext). --}}
            {{#if isBC}}
                {{> systems/wh40k-rpg/templates/actor/panel/bc-alignment-panel.hbs alignmentPanel=alignmentPanel}}
            {{/if}}

            {{!-- DW engine panels (#162 Cohesion, #163 Squad Mode, #164 Renown,
                 #165 Requisition). Gate matches `_gameSystemId === 'dw'`. --}}
            {{#if isDW}}
                {{> systems/wh40k-rpg/templates/actor/panel/dw-cohesion-panel.hbs cohesionPanel=cohesionPanel}}
                {{> systems/wh40k-rpg/templates/actor/panel/dw-mode-panel.hbs modePanel=modePanel}}
                {{> systems/wh40k-rpg/templates/actor/panel/dw-renown-panel.hbs renownPanel=renownPanel}}
                {{> systems/wh40k-rpg/templates/actor/panel/dw-requisition-panel.hbs requisitionPanel=requisitionPanel}}
            {{/if}}

            {{!-- OW engine panels (#152 Comrade, #154 Logistics, #153 Orders).
                 Gate matches `_gameSystemId === 'ow'`. --}}
            {{#if isOW}}
                {{> systems/wh40k-rpg/templates/actor/panel/ow-comrade-panel.hbs comradePanel=comradePanel}}
                {{> systems/wh40k-rpg/templates/actor/panel/ow-logistics-panel.hbs logisticsPanel=logisticsPanel}}
                {{> systems/wh40k-rpg/templates/actor/panel/ow-orders-panel.hbs ordersPanel=ordersPanel}}
            {{/if}}

            {{!-- Movement & Physical Capacity (Full Version) --}}
            {{> systems/wh40k-rpg/templates/actor/panel/movement-panel-full.hbs}}
            
            {{!-- Active Effects Panel --}}
            {{> systems/wh40k-rpg/templates/actor/panel/active-effects-panel.hbs}}
        </div>
    </div>

    {{!-- Dark Pacts (Enemies Beyond p. 72, #84). Renders only when at least one pact is active. --}}
    {{> systems/wh40k-rpg/templates/actor/panel/dark-pact-panel.hbs}}

    {{!-- Penitent role: Mortification of the Flesh action (#94, within.md p.36). --}}
    {{!-- Hidden unless the actor has a Penitent role / Mortification talent (computed in CharacterSheet._prepareContext). --}}
    {{> systems/wh40k-rpg/templates/actor/panel/mortification-button.hbs hasPenitent=hasPenitent}}

    {{!-- Fanatic role: Death to All Who Oppose Me action (#93, within.md p.34). --}}
    {{!-- Hidden unless the actor has a Fanatic role/talent (computed in CharacterSheet._prepareContext). --}}
    {{> systems/wh40k-rpg/templates/actor/panel/fanatic-button.hbs hasFanatic=hasFanatic}}

    {{!-- Crusader role: Smite the Unholy action (#141, beyond.md p.34). --}}
    {{!-- Hidden unless the actor has a Crusader role/talent (computed in CharacterSheet._prepareContext). --}}
    {{> systems/wh40k-rpg/templates/actor/panel/crusader-button.hbs hasCrusader=hasCrusader}}

    {{!-- Grapple Controller Actions (#120, core.md L10155-10180). --}}
    {{!-- Rendered only when the actor is mid-grapple (flag set by combat tooling). --}}
    {{#if (and grappleState (neq grappleState 'none'))}}
        {{> systems/wh40k-rpg/templates/actor/panel/grapple-controller-panel.hbs grappleState=grappleState}}
    {{/if}}
</section>
