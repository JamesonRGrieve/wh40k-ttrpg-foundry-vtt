{{!-- Shared PC + NPC sidebar-layout header body.
     Composes the shared `header-base` block partial in sidebar variant.
     Body renders the canonical `sidebar-header` (name, portrait, divination,
     origin bubbles) followed by the bio fields panel.

     This is the single source of truth for the FFG-family + RT sidebar header;
     the per-system entry files (`header-dh.hbs`, `header-rt.hbs`) delegate here
     so a layout change touches one place. The `{{#if isDaemonic}}` block is a
     no-op on systems without daemonic actors (e.g. RT).

     The per-system Tailwind border variants on the inner column preserve this
     template in the theme-coverage manifest; identical variants live on
     `header-base.hbs`'s outer wrapper, so the rendered DOM shows the
     accent border once at the actual visual edge. --}}

{{#> systems/wh40k-rpg/templates/actor/partial/header-base.hbs
    cardClass="wh40k-character-header wh40k-npc-sidebar-header"
    innerClass="tw-flex tw-flex-col tw-items-center tw-gap-3 tw-border-0 {{themeClassFor 'border'}}"}}
    {{> systems/wh40k-rpg/templates/actor/partial/sidebar-header.hbs}}
    {{> systems/wh40k-rpg/templates/actor/partial/origin-path-bubbles.hbs}}
    {{#if isDaemonic}}
    {{> systems/wh40k-rpg/templates/actor/partial/daemonic-immunities-badge.hbs}}
    {{/if}}
    {{> systems/wh40k-rpg/templates/actor/partial/sidebar-fields-panel.hbs}}
{{/systems/wh40k-rpg/templates/actor/partial/header-base.hbs}}
