{{!-- Acolyte Sheet Powers Tab --}}
{{!-- Modern powers management with psychic powers, navigator powers, rituals, and orders --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }} wh40k-tab-powers tw-p-3 [&.active]:!tw-block bc:tw-bg-crimson/[2%] dh1e:tw-bg-gold-dark/[2%] dh2e:tw-bg-gold-dark/[2%] dw:tw-bg-accent-combat/[2%] ow:tw-bg-brass/[2%] rt:tw-bg-gold/[2%] im:tw-bg-failure/[2%]" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    <div class="tw-grid tw-grid-cols-2 tw-gap-4 tw-min-h-0">
        {{!-- Left Column: Psyker Control & Psychic Powers --}}
        <div class="wh40k-powers-col wh40k-powers-col-left tw-flex tw-flex-col tw-gap-0 tw-overflow-visible tw-min-w-0">
            {{!-- Psy Rating Control Center --}}
            {{> systems/wh40k-rpg/templates/actor/panel/psy-rating-panel.hbs}}
            
            {{!-- Psychic Powers --}}
            {{> systems/wh40k-rpg/templates/actor/panel/psychic-powers-panel.hbs}}
        </div>
        
        {{!-- Right Column: Navigator, Rituals, Orders --}}
        <div class="wh40k-powers-col wh40k-powers-col-right tw-flex tw-flex-col tw-gap-0 tw-overflow-visible tw-min-w-0">
            {{!-- Navigator Powers --}}
            {{> systems/wh40k-rpg/templates/actor/panel/navigator-powers-panel.hbs}}
            
            {{!-- Rituals --}}
            {{> systems/wh40k-rpg/templates/actor/panel/rituals-panel.hbs}}
            
            {{!-- Ship Orders --}}
            {{> systems/wh40k-rpg/templates/actor/panel/orders-panel.hbs}}
        </div>
    </div>
</section>
