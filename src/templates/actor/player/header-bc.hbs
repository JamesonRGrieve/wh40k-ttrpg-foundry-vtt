{{!-- Black Crusade Character Sheet Header --}}
{{!-- Two-column layout: Left (portrait + bio) | Right (characteristics HUD) --}}
<div class="wh40k-header wh40k-grid-col-6 wh40k-panel wh40k-character-header">
    <div class="wh40k-header__info wh40k-header-grid tw-grid tw-grid-cols-header-main tw-gap-3 tw-items-start tw-pt-2 tw-px-3 tw-pb-1.5">
        <div class="wh40k-header-left tw-flex tw-flex-col tw-gap-2">
            <div class="wh40k-header-topline tw-grid tw-grid-cols-header-topline tw-items-center tw-gap-2.5">
                <div class="wh40k-header__logo wh40k-portrait-container tw-relative tw-aspect-[11/15] tw-w-44 tw-shrink-0 tw-overflow-hidden tw-rounded-md tw-border-2 tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-shadow-[0_2px_8px_var(--wh40k-shadow-medium,rgba(0,0,0,0.2))] tw-transition-all hover:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] hover:tw-shadow-[0_0_8px_rgba(212,175,55,0.5)]">
                    <i class="fa-solid fa-dice-d20 wh40k-origin-builder-btn tw-absolute tw-text-2xl tw-top-2 tw-left-2 tw-z-10 tw-cursor-pointer tw-opacity-60 tw-transition-all hover:tw-opacity-100 hover:tw-drop-shadow-[0_0_8px_rgba(212,175,55,0.9)] {{#unless originPathComplete}}pulse{{/unless}}"
                       data-action="openOriginPathBuilder"
                       data-tooltip="{{localize 'WH40K.Utility.SetupOriginPath'}}"></i>
                    <img class="wh40k-header__logo-image wh40k-portrait tw-h-full tw-w-full tw-cursor-pointer tw-bg-[rgba(0,0,0,0.25)] tw-object-cover" src="{{actor.img}}" data-action="editImage" data-edit="img" alt="{{actor.name}}" title="{{actor.name}}" />
                </div>
                <div class="wh40k-header-info tw-flex tw-min-w-0 tw-flex-1 tw-flex-col tw-items-stretch tw-gap-1.5">
                    <div class="wh40k-header-row wh40k-name-row tw-flex tw-min-w-0 tw-items-baseline tw-gap-2.5">
                        <span class="wh40k-header-label tw-min-w-[70px] tw-shrink-0 tw-text-[0.85em] tw-font-bold tw-uppercase tw-text-[var(--wh40k-text-medium,#666)]">{{localize "WH40K.Character.Name"}}</span>
                        <input class="wh40k-header-input wh40k-name-input tw-min-w-[80px] tw-max-w-[320px] tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[1.2em] tw-font-bold tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]" name="name" type="text" value="{{actor.name}}" />
                    </div>
                    <div class="wh40k-header-row wh40k-player-row tw-flex tw-min-w-0 tw-items-baseline tw-gap-2.5">
                        <span class="wh40k-header-label tw-min-w-[70px] tw-shrink-0 tw-text-[0.85em] tw-font-bold tw-uppercase tw-text-[var(--wh40k-text-medium,#666)]">{{localize "WH40K.Character.Player"}}</span>
                        <input class="wh40k-header-input wh40k-player-input tw-min-w-[80px] tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]" name="system.bio.playerName" type="text" value="{{source.bio.playerName}}" placeholder="Player Name" />
                    </div>
                    <div class="wh40k-header-row tw-flex tw-min-w-0 tw-items-baseline tw-gap-2.5">
                        <span class="wh40k-header-label tw-min-w-[70px] tw-shrink-0 tw-text-[0.85em] tw-font-bold tw-uppercase tw-text-[var(--wh40k-text-medium,#666)]">Home World</span>
                        <input class="wh40k-header-input tw-min-w-[80px] tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]" name="system.originPath.homeWorld" type="text" value="{{source.originPath.homeWorld}}" placeholder="Home World" />
                    </div>
                    <div class="wh40k-header-row tw-flex tw-min-w-0 tw-items-baseline tw-gap-2.5">
                        <span class="wh40k-header-label tw-min-w-[70px] tw-shrink-0 tw-text-[0.85em] tw-font-bold tw-uppercase tw-text-[var(--wh40k-text-medium,#666)]">Archetype</span>
                        <input class="wh40k-header-input tw-min-w-[80px] tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]" name="system.originPath.role" type="text" value="{{source.originPath.role}}" placeholder="Archetype" />
                    </div>
                    <div class="wh40k-header-row tw-flex tw-min-w-0 tw-items-baseline tw-gap-2.5">
                        <span class="wh40k-header-label tw-min-w-[70px] tw-shrink-0 tw-text-[0.85em] tw-font-bold tw-uppercase tw-text-[var(--wh40k-text-medium,#666)]">Pride</span>
                        <input class="wh40k-header-input tw-min-w-[80px] tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]" name="system.originPath.background" type="text" value="{{source.originPath.background}}" placeholder="Pride" />
                    </div>
                    <div class="wh40k-header-row tw-flex tw-min-w-0 tw-items-baseline tw-gap-2.5">
                        <span class="wh40k-header-label tw-min-w-[70px] tw-shrink-0 tw-text-[0.85em] tw-font-bold tw-uppercase tw-text-[var(--wh40k-text-medium,#666)]">Disgrace</span>
                        <input class="wh40k-header-input tw-min-w-[80px] tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]" name="system.originPath.trialsAndTravails" type="text" value="{{source.originPath.trialsAndTravails}}" placeholder="Disgrace" />
                    </div>
                    <div class="wh40k-header-row tw-flex tw-min-w-0 tw-items-baseline tw-gap-2.5">
                        <span class="wh40k-header-label tw-min-w-[70px] tw-shrink-0 tw-text-[0.85em] tw-font-bold tw-uppercase tw-text-[var(--wh40k-text-medium,#666)]">Motivation</span>
                        <input class="wh40k-header-input tw-min-w-[80px] tw-flex-1 tw-border-0 tw-border-b tw-border-solid tw-border-[var(--wh40k-border-color,#4a3728)] tw-bg-transparent tw-px-1.5 tw-py-0.5 tw-text-[var(--wh40k-text-dark,#333)] focus:tw-border-[var(--wh40k-gold,var(--wh40k-color-gold))] focus:tw-outline-none focus:tw-shadow-[0_1px_0_var(--wh40k-gold,var(--wh40k-color-gold))]" name="system.originPath.motivation" type="text" value="{{source.originPath.motivation}}" placeholder="Motivation" />
                    </div>
                </div>
            </div>
        </div>
        <div class="wh40k-header-right tw-flex tw-max-w-[620px] tw-flex-col tw-justify-start tw-justify-self-end tw-gap-2 tw-py-1 tw-pr-3 tw-items-end max-[1100px]:tw-justify-self-start max-[1100px]:tw-items-start max-[1100px]:tw-pr-0">
            <div class="wh40k-hud-stack tw-relative tw-flex tw-flex-col tw-items-end tw-gap-1.5 tw-h-full">
                {{!-- Characteristics HUD --}}
                <div class="wh40k-characteristics-hud">
                    {{#each actor.characteristics as |characteristic name|}}
                        {{#unless (eq name "influence")}}
                        <div class="wh40k-char-hud-item {{#if (gt this.modifier 0)}}wh40k-char-buffed{{/if}}{{#if (lt this.modifier 0)}}wh40k-char-debuffed{{/if}}"
                             data-advance="{{this.advance}}"
                             style="--advance-progress: {{divide this.advance 5}};">
                            <button
                                class="wh40k-char-hud-name roll-characteristic actor-drag"
                                type="button"
                                data-action="roll"
                                data-roll-type="characteristic"
                                data-roll-target="{{name}}"
                                data-item-type="characteristic"
                                data-item-id="{{name}}"
                                data-characteristic="{{name}}"
                                title="{{this.label}}"
                            >{{this.short}}</button>
                            <div class="wh40k-char-hud-circle" title="{{this.label}}">
                                <span class="wh40k-char-hud-mod">{{this.bonus}}</span>
                                <span class="wh40k-char-hud-mod-label">MOD</span>
                            </div>
                            <div class="wh40k-char-hud-base">Total {{this.total}}</div>
                        </div>
                        {{/unless}}
                    {{/each}}
                </div>
            </div>
        </div>
    </div>
</div>
