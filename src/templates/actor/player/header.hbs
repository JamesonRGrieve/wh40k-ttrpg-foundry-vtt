{{!-- Acolyte Sheet Header Part --}}
{{!-- Two-column layout: Left (portrait + bio) | Right (characteristics HUD V1 Enhanced) --}}
<div class="wh40k-header wh40k-grid-col-6 wh40k-panel wh40k-character-header">
    <div class="wh40k-header__info wh40k-header-grid tw-grid tw-grid-cols-[minmax(280px,1fr)_auto] tw-gap-3 tw-items-start tw-pt-2 tw-px-3 tw-pb-1.5">
        <div class="wh40k-header-left tw-flex tw-flex-col tw-gap-2">
            <div class="wh40k-header-topline tw-grid tw-grid-cols-[auto_1fr] tw-gap-2.5 tw-items-center">
                <div class="wh40k-header__logo wh40k-portrait-container">
                    <img class="wh40k-header__logo-image wh40k-portrait" src="{{actor.img}}" data-action="editImage" data-edit="img" alt="{{actor.name}}" title="{{actor.name}}" />
                </div>
                <div class="wh40k-header-info">
                    <div class="wh40k-header-row wh40k-name-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Name"}}</span>
                        <input class="wh40k-header-input wh40k-name-input" name="name" type="text" value="{{actor.name}}" />
                    </div>
                    <div class="wh40k-header-row wh40k-player-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Player"}}</span>
                        <input class="wh40k-header-input wh40k-player-input" name="system.bio.playerName" type="text" value="{{system.bio.playerName}}" placeholder="Player Name" />
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">{{localize "WH40K.OriginPath.HomeWorld"}}</span>
                        <input class="wh40k-header-input" name="system.originPath.homeWorld" type="text" value="{{system.originPath.homeWorld}}" placeholder="Home World" />
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">{{localize "WH40K.OriginPath.Career"}}</span>
                        <input class="wh40k-header-input" name="system.originPath.career" type="text" value="{{system.originPath.career}}" placeholder="Career" />
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Rank"}}</span>
                        <input class="wh40k-header-input wh40k-rank-input" name="system.rank" type="number" value="{{system.rank}}" placeholder="Rank" />
                    </div>
                </div>
            </div>
        </div>
        <div class="wh40k-header-right tw-flex tw-flex-col tw-items-end tw-gap-2 tw-justify-self-end tw-justify-start tw-max-w-[620px]">
            <div class="wh40k-hud-stack tw-relative tw-flex tw-flex-col tw-items-end tw-gap-1.5 tw-h-full">
                {{!-- Characteristics HUD V1 Enhanced --}}
                <div class="wh40k-characteristics-hud">
                    {{#each actor.characteristics as |characteristic name|}}
                        {{#unless (eq name "influence")}}
                        <div class="wh40k-char-hud-item {{#if (gt this.modifier 0)}}wh40k-char-buffed{{/if}}{{#if (lt this.modifier 0)}}wh40k-char-debuffed{{/if}}"
                             data-characteristic="{{name}}"
                             data-advance="{{this.advance}}"
                             style="--advance-progress: {{divide this.advance 5}};">
                            <button
                                class="wh40k-char-hud-name roll-characteristic actor-drag"
                                type="button"
                                data-action="roll"
                                data-roll-type="characteristic"
                                data-roll-target="{{name}}"
                                data-item-type="characteristic"
                                data-item-id="{{name}}"
                                data-characteristic="{{name}}"
                                title="{{this.label}}"
                            >{{this.short}}</button>
                            <div class="wh40k-char-hud-circle" title="{{this.label}}">
                                <span class="wh40k-char-hud-mod">{{this.bonus}}</span>
                                <span class="wh40k-char-hud-mod-label">MOD</span>
                            </div>
                            {{#if ../inEditMode}}
                            <div class="wh40k-char-hud-base wh40k-char-hud-base--edit">
                                <input type="number" class="wh40k-char-direct-input wh40k-char-inline-input" data-characteristic="{{name}}" data-field="base" data-dtype="Number" value="{{this.base}}" title="Base {{this.label}}" />
                            </div>
                            {{else}}
                            <div class="wh40k-char-hud-base">Total {{this.total}}</div>
                            {{/if}}
                        </div>
                        {{/unless}}
                    {{/each}}
                </div>
                <div class="wh40k-dropzone wh40k-dropzone-small" data-drop-zone="general">
                    <i class="fas fa-plus-circle wh40k-dropzone-icon"></i>
                    <span class="wh40k-dropzone-text">Drag and Drop from Compendium to Add</span>
                </div>
            </div>
        </div>
    </div>
</div>
