{{!-- Acolyte Sheet Statistics Tab --}}
{{!-- Characteristics HUD + Skills + Specialist Skills + Talents + Traits --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    {{!-- Characteristics Panel --}}
    {{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs label="Characteristics" icon="fa-chart-bar"}}
            <div class="tw-flex tw-flex-wrap tw-justify-center tw-gap-2">
                {{#each actor.characteristics as |characteristic name|}}
                    {{#unless (eq name "influence")}}
                    <div class="wh40k-char-hud-item {{#if (gt this.modifier 0)}}wh40k-char-buffed{{/if}}{{#if (lt this.modifier 0)}}wh40k-char-debuffed{{/if}}"
                         data-characteristic="{{name}}"
                         data-advance="{{this.advance}}"
                         style="--advance-progress: {{divide this.advance 5}};">
                        <button
                            class="wh40k-char-hud-name roll-characteristic actor-drag"
                            type="button"
                            data-action="roll"
                            data-roll-type="characteristic"
                            data-roll-target="{{name}}"
                            data-item-type="characteristic"
                            data-item-id="{{name}}"
                            data-characteristic="{{name}}"
                            title="{{this.label}}"
                        >{{this.short}}</button>
                        <div class="wh40k-char-hud-circle tw-overflow-hidden tw-group/characteristic-roll" title="{{this.label}}">
                            <span class="wh40k-char-hud-mod tw-transition-opacity tw-duration-150 group-hover/characteristic-roll:tw-opacity-15">{{this.bonus}}</span>
                            <span class="wh40k-char-hud-mod-label tw-transition-opacity tw-duration-150 group-hover/characteristic-roll:tw-opacity-15">MOD</span>
                            <button
                                class="tw-absolute tw-inset-0 tw-z-[1] tw-grid tw-place-items-center tw-rounded-full tw-border-0 tw-bg-[rgba(15,23,42,0.08)] tw-text-[rgba(255,255,255,0.78)] tw-opacity-0 tw-transition-all tw-duration-150 hover:tw-bg-[rgba(15,23,42,0.16)] hover:tw-text-white group-hover/characteristic-roll:tw-opacity-100"
                                type="button"
                                data-action="roll"
                                data-roll-type="characteristic"
                                data-roll-target="{{name}}"
                                data-item-type="characteristic"
                                data-item-id="{{name}}"
                                data-characteristic="{{name}}"
                                title="{{localize 'WH40K.Roll.Roll'}} {{this.label}}"
                                aria-label="{{localize 'WH40K.Roll.Roll'}} {{this.label}}"
                            >
                                <i class="fa-solid fa-dice-d20 tw-text-[1rem] tw-leading-none tw-drop-shadow-[0_1px_2px_rgba(0,0,0,0.45)] bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                            </button>
                        </div>
                        {{#if ../inEditMode}}
                        <div class="wh40k-char-hud-base wh40k-char-hud-base--edit">
                            <input type="number" class="wh40k-char-direct-input wh40k-char-inline-input" data-characteristic="{{name}}" data-field="base" data-dtype="Number" value="{{this.base}}" title="Base {{this.label}}" />
                        </div>
                        {{else}}
                        <div class="wh40k-char-hud-base">Total {{this.total}}</div>
                        {{/if}}
                    </div>
                    {{/unless}}
                {{/each}}
            </div>
    {{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}

    {{#> systems/wh40k-rpg/templates/actor/partial/panel.hbs label="Skills" icon="fa-book"}}
        {{> systems/wh40k-rpg/templates/actor/panel/skills-panel.hbs}}
    {{/systems/wh40k-rpg/templates/actor/partial/panel.hbs}}

    {{> systems/wh40k-rpg/templates/actor/panel/skills-specialist-panel.hbs}}

    {{!-- Talents & Traits side by side (equal height) --}}
    <div class="tw-grid tw-grid-cols-2 tw-gap-3 tw-w-full tw-items-stretch">
        <div class="wh40k-talents-col tw-flex tw-w-full tw-min-w-0 tw-self-stretch tw-flex-col tw-gap-4 tw-overflow-visible">
            {{> systems/wh40k-rpg/templates/actor/panel/talent-panel.hbs}}
        </div>
        <div class="wh40k-talents-col tw-flex tw-w-full tw-min-w-0 tw-self-stretch tw-flex-col tw-gap-4 tw-overflow-visible">
            {{> systems/wh40k-rpg/templates/actor/panel/trait-panel.hbs}}
        </div>
    </div>
</section>
