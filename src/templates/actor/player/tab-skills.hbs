{{!-- Acolyte Sheet Skills Tab --}}
{{!-- This part renders the Skills tab content with base skills, advanced untrained, and specialist skills --}}
<section class="tab {{#if tab.active}}active{{/if}} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    <div class="wh40k-panel">
        <div class="wh40k-panel-header">
            <span class="wh40k-panel-title"><i class="fas fa-book"></i> Skills</span>
        </div>
        <div class="wh40k-panel-body">
            {{> systems/wh40k-rpg/templates/actor/panel/skills-panel.hbs}}
        </div>
    </div>

    {{> systems/wh40k-rpg/templates/actor/panel/skills-specialist-panel.hbs}}

    {{!-- Talents & Traits side by side (equal height) --}}
    <div class="tw-grid tw-grid-cols-2 tw-gap-3 tw-w-full tw-items-stretch">
        <div class="wh40k-talents-col tw-flex tw-flex-col tw-gap-0 tw-overflow-visible tw-min-w-0">
            {{> systems/wh40k-rpg/templates/actor/panel/talent-panel.hbs}}
        </div>
        <div class="wh40k-talents-col tw-flex tw-flex-col tw-gap-0 tw-overflow-visible tw-min-w-0">
            {{> systems/wh40k-rpg/templates/actor/panel/trait-panel.hbs}}
        </div>
    </div>
</section>
