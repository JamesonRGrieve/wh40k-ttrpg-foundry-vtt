{{!-- Dark Heresy 2e Character Sheet Header --}}
{{!-- Two-column layout: Left (portrait + bio) | Right (characteristics HUD) --}}
<div class="wh40k-header wh40k-grid-col-6 wh40k-panel wh40k-character-header tw-relative">
    <i class="fa-solid fa-dice-d20 wh40k-origin-builder-btn tw-absolute tw-text-2xl tw-top-4 tw-left-4 tw-z-10 tw-cursor-pointer tw-opacity-60 tw-transition-all hover:tw-opacity-100 hover:tw-drop-shadow-[0_0_8px_rgba(212,175,55,0.9)] {{#unless originPathComplete}}pulse{{/unless}}"
       data-action="openOriginPathBuilder"
       data-tooltip="{{localize 'WH40K.Utility.SetupOriginPath'}}"></i>
    <div class="wh40k-header__info wh40k-header-grid tw-grid tw-grid-cols-header-main tw-gap-3 tw-items-start tw-pt-2 tw-px-3 tw-pb-1.5">
        <div class="wh40k-header-left tw-flex tw-flex-col tw-gap-2">
            <div class="wh40k-header-topline tw-grid tw-grid-cols-header-topline tw-gap-2.5 tw-items-center">
                <div class="tw-flex tw-flex-col tw-items-center tw-gap-1 tw-shrink-0">
                    <div class="wh40k-portrait-container tw-relative tw-shrink-0 tw-cursor-pointer">
                        <img class="wh40k-portrait tw-w-44 tw-h-auto tw-max-h-60 tw-object-contain" src="{{actor.img}}" data-action="editImage" data-edit="img" alt="{{actor.name}}" title="{{actor.name}}" />
                    </div>
                    {{#if system.originPath.divination}}
                    <p class="wh40k-divination tw-italic tw-opacity-50">{{system.originPath.divination}}</p>
                    {{/if}}
                </div>
                <div class="wh40k-header-info tw-grid tw-grid-cols-4 tw-gap-1.5 tw-items-center">
                    <div class="wh40k-header-row wh40k-name-row tw-col-span-4">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Name"}}</span>
                        <input class="wh40k-header-input wh40k-name-input" name="name" type="text" value="{{actor.name}}" />
                    </div>
                    <div class="wh40k-header-row wh40k-player-row tw-col-span-4">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Player"}}</span>
                        <input class="wh40k-header-input wh40k-player-input" name="system.bio.playerName" type="text" value="{{system.bio.playerName}}" placeholder="Player Name" />
                    </div>
                    {{!-- Origin Path Step Icons --}}
                    {{#each originPathSteps as |step|}}
                    <div class="tw-flex tw-items-center tw-justify-center tw-w-14 tw-h-14 tw-rounded-full tw-overflow-hidden tw-border-2 tw-border-solid tw-bg-[rgba(0,0,0,0.2)] tw-justify-self-center tw-transition-all {{#if step.item}}tw-border-gold tw-cursor-pointer hover:tw-border-[#f0d060] hover:tw-shadow-[0_0_8px_rgba(212,175,55,0.5)] hover:tw-scale-110{{else}}tw-border-[var(--wh40k-border-color,#4a3728)] tw-opacity-40 tw-cursor-default{{/if}}"
                         {{#if step.item}}data-action="itemEdit" data-item-id="{{step.item._id}}"{{/if}}
                         {{#if step.tooltipData}}data-wh40k-tooltip="generic" data-wh40k-tooltip-data="{{step.tooltipData}}"{{else}}data-tooltip="{{step.label}}"{{/if}}>
                        {{#if step.item}}
                            <img src="{{step.item.img}}" alt="{{step.item.name}}" class="tw-w-12 tw-h-12 tw-max-w-12 tw-max-h-12 tw-object-cover tw-rounded-full tw-border-2 tw-border-solid tw-border-gold" />
                        {{else}}
                            <i class="fas {{step.icon}} tw-text-xl tw-text-[var(--wh40k-text-muted)]"></i>
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>
        <div class="wh40k-header-right tw-flex tw-flex-col tw-items-end tw-gap-2 tw-justify-self-end tw-justify-start tw-max-w-[620px]">
            <div class="wh40k-hud-stack tw-relative tw-flex tw-flex-col tw-items-end tw-gap-1.5 tw-h-full">
                {{!-- Characteristics HUD --}}
                <div class="wh40k-characteristics-hud">
                    {{#each actor.characteristics as |characteristic name|}}
                        {{#unless (eq name "influence")}}
                        <div class="wh40k-char-hud-item {{#if (gt this.modifier 0)}}wh40k-char-buffed{{/if}}{{#if (lt this.modifier 0)}}wh40k-char-debuffed{{/if}}"
                             data-characteristic="{{name}}"
                             data-advance="{{this.advance}}"
                             style="--advance-progress: {{divide this.advance 5}};">
                            <button
                                class="wh40k-char-hud-name roll-characteristic actor-drag"
                                type="button"
                                data-action="roll"
                                data-roll-type="characteristic"
                                data-roll-target="{{name}}"
                                data-item-type="characteristic"
                                data-item-id="{{name}}"
                                data-characteristic="{{name}}"
                                title="{{this.label}}"
                            >{{this.short}}</button>
                            <div class="wh40k-char-hud-circle" title="{{this.label}}">
                                <span class="wh40k-char-hud-mod">{{this.bonus}}</span>
                                <span class="wh40k-char-hud-mod-label">MOD</span>
                            </div>
                            {{#if ../inEditMode}}
                            <div class="wh40k-char-hud-base wh40k-char-hud-base--edit">
                                <input type="number" class="wh40k-char-direct-input wh40k-char-inline-input" data-characteristic="{{name}}" data-field="base" data-dtype="Number" value="{{this.base}}" title="Base {{this.label}}" />
                            </div>
                            {{else}}
                            <div class="wh40k-char-hud-base">Total {{this.total}}</div>
                            {{/if}}
                        </div>
                        {{/unless}}
                    {{/each}}
                </div>
                <div class="wh40k-dropzone wh40k-dropzone-small" data-drop-zone="general">
                    <i class="fas fa-plus-circle wh40k-dropzone-icon"></i>
                    <span class="wh40k-dropzone-text">Drag and Drop from Compendium to Add</span>
                </div>
            </div>
        </div>
    </div>
</div>
