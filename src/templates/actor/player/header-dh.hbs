{{!-- Dark Heresy 2e Character Sheet Sidebar Header --}}
{{!-- Vertical layout: Name, Portrait w/ d20, Divination, Origin Path Grid --}}
<div class="wh40k-header wh40k-sidebar-header">
    {{!-- Character / Player Name --}}
    <div class="wh40k-header-name-line tw-flex tw-flex-col tw-items-start tw-gap-0.5">
        <span class="wh40k-hdr-name" data-inline-edit {{#unless actor.name}}data-inline-edit-start{{/unless}}>
            <span class="wh40k-hdr-name-text wh40k-inline-edit-text">{{#if actor.name}}{{actor.name}}{{else}}<em class="wh40k-hdr-placeholder">Character Name</em>{{/if}}</span>
            <input class="wh40k-hdr-name-input wh40k-inline-edit-input" name="name" type="text" value="{{actor.name}}" placeholder="Character Name" readonly />
            <button type="button" class="wh40k-inline-edit-save" data-inline-edit-save tabindex="-1" title="Save"><i class="fas fa-check"></i></button>
        </span>
        <span class="wh40k-hdr-player-line tw-flex tw-items-center">
            <span class="wh40k-hdr-paren">(</span>
            <span class="wh40k-hdr-player" data-inline-edit {{#unless system.bio.playerName}}data-inline-edit-start{{/unless}}>
                <span class="wh40k-hdr-player-text wh40k-inline-edit-text">{{#if system.bio.playerName}}{{system.bio.playerName}}{{else}}<em class="wh40k-hdr-placeholder">Player</em>{{/if}}</span>
                <input class="wh40k-hdr-player-input wh40k-inline-edit-input" name="system.bio.playerName" type="text" value="{{system.bio.playerName}}" placeholder="Player" readonly />
                <button type="button" class="wh40k-inline-edit-save" data-inline-edit-save tabindex="-1" title="Save"><i class="fas fa-check"></i></button>
            </span>
            <span class="wh40k-hdr-paren">)</span>
        </span>
    </div>

    {{!-- Portrait with d20 overlay --}}
    <div class="wh40k-portrait-container tw-relative tw-cursor-pointer tw-mx-auto">
        <i class="fa-solid fa-dice-d20 wh40k-origin-builder-btn tw-absolute tw-text-xl tw-top-1 tw-left-1 tw-z-10 tw-cursor-pointer tw-opacity-60 tw-transition-all hover:tw-opacity-100 hover:tw-drop-shadow-[0_0_8px_rgba(212,175,55,0.9)] {{#unless originPathComplete}}pulse{{/unless}}"
           data-action="openOriginPathBuilder"
           data-tooltip="{{localize 'WH40K.Utility.SetupOriginPath'}}"></i>
        <img class="wh40k-portrait tw-w-full tw-object-cover" src="{{actor.img}}" data-action="editImage" data-edit="img" alt="{{actor.name}}" title="{{actor.name}}" />
    </div>

    {{!-- Divination --}}
    {{#if system.originPath.divination}}
    <p class="wh40k-divination tw-italic tw-opacity-50 tw-text-center tw-text-2xs tw-leading-tight tw-px-1">{{system.originPath.divination}}</p>
    {{/if}}

    {{!-- Origin Path Step Icons - 2x2 grid (or 3x2 for RT) --}}
    <div class="wh40k-origin-grid tw-grid tw-grid-cols-2 tw-gap-1.5 tw-justify-items-center">
        {{#each originPathSteps as |step|}}
        <div class="tw-flex tw-items-center tw-justify-center tw-w-10 tw-h-10 tw-rounded-full tw-overflow-hidden tw-border-2 tw-border-solid tw-bg-[rgba(0,0,0,0.2)] tw-transition-all {{#if step.item}}tw-border-gold tw-cursor-pointer hover:tw-border-[#f0d060] hover:tw-shadow-[0_0_6px_rgba(212,175,55,0.5)] hover:tw-scale-110{{else}}tw-border-[var(--wh40k-border-color,#4a3728)] tw-opacity-40 tw-cursor-default{{/if}}"
             {{#if step.item}}data-action="itemEdit" data-item-id="{{step.item._id}}"{{/if}}
             {{#if step.tooltipData}}data-wh40k-tooltip="generic" data-wh40k-tooltip-data="{{step.tooltipData}}"{{else}}data-tooltip="{{step.label}}"{{/if}}>
            {{#if step.item}}
                <img src="{{step.item.img}}" alt="{{step.item.name}}" class="tw-w-8 tw-h-8 tw-max-w-8 tw-max-h-8 tw-object-cover tw-rounded-full tw-border tw-border-solid tw-border-gold" />
            {{else}}
                <i class="fas {{step.icon}} tw-text-sm tw-text-[var(--wh40k-text-muted)]"></i>
            {{/if}}
        </div>
        {{/each}}
    </div>
</div>
