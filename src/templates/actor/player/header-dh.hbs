{{!-- Dark Heresy 2e Character Sheet Header --}}
{{!-- Two-column layout: Left (portrait + bio) | Right (characteristics HUD) --}}
<div class="wh40k-header wh40k-grid-col-6 wh40k-panel wh40k-character-header">
    <div class="wh40k-header__info wh40k-header-grid tw-grid tw-grid-cols-[minmax(280px,1fr)_auto] tw-gap-3 tw-items-start tw-pt-2 tw-px-3 tw-pb-[6px]">
        <div class="wh40k-header-left tw-flex tw-flex-col tw-gap-2">
            <div class="wh40k-header-topline tw-grid tw-grid-cols-[auto_1fr] tw-gap-[10px] tw-items-center">
                <div class="wh40k-header__logo wh40k-portrait-container">
                    <img class="wh40k-header__logo-image wh40k-portrait" src="{{actor.img}}" data-action="editImage" data-edit="img" alt="{{actor.name}}" title="{{actor.name}}" />
                </div>
                <div class="wh40k-header-info">
                    <div class="wh40k-header-row wh40k-name-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Name"}}</span>
                        <input class="wh40k-header-input wh40k-name-input" name="name" type="text" value="{{actor.name}}" />
                    </div>
                    <div class="wh40k-header-row wh40k-player-row">
                        <span class="wh40k-header-label">{{localize "WH40K.Character.Player"}}</span>
                        <input class="wh40k-header-input wh40k-player-input" name="system.bio.playerName" type="text" value="{{system.bio.playerName}}" placeholder="Player Name" />
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">Home World</span>
                        <select class="wh40k-header-input" name="system.originPath.homeWorld">
                            <option value="" {{#unless system.originPath.homeWorld}}selected{{/unless}}>— Select —</option>
                            <option value="Feral World" {{#if (eq system.originPath.homeWorld "Feral World")}}selected{{/if}}>Feral World</option>
                            <option value="Forge World" {{#if (eq system.originPath.homeWorld "Forge World")}}selected{{/if}}>Forge World</option>
                            <option value="Highborn" {{#if (eq system.originPath.homeWorld "Highborn")}}selected{{/if}}>Highborn</option>
                            <option value="Hive World" {{#if (eq system.originPath.homeWorld "Hive World")}}selected{{/if}}>Hive World</option>
                            <option value="Shrine World" {{#if (eq system.originPath.homeWorld "Shrine World")}}selected{{/if}}>Shrine World</option>
                            <option value="Voidborn" {{#if (eq system.originPath.homeWorld "Voidborn")}}selected{{/if}}>Voidborn</option>
                        </select>
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">Background</span>
                        <select class="wh40k-header-input" name="system.originPath.background">
                            <option value="" {{#unless system.originPath.background}}selected{{/unless}}>— Select —</option>
                            <option value="Adeptus Administratum" {{#if (eq system.originPath.background "Adeptus Administratum")}}selected{{/if}}>Adeptus Administratum</option>
                            <option value="Adeptus Arbites" {{#if (eq system.originPath.background "Adeptus Arbites")}}selected{{/if}}>Adeptus Arbites</option>
                            <option value="Adeptus Astra Telepathica" {{#if (eq system.originPath.background "Adeptus Astra Telepathica")}}selected{{/if}}>Adeptus Astra Telepathica</option>
                            <option value="Adeptus Mechanicus" {{#if (eq system.originPath.background "Adeptus Mechanicus")}}selected{{/if}}>Adeptus Mechanicus</option>
                            <option value="Adeptus Ministorum" {{#if (eq system.originPath.background "Adeptus Ministorum")}}selected{{/if}}>Adeptus Ministorum</option>
                            <option value="Imperial Guard" {{#if (eq system.originPath.background "Imperial Guard")}}selected{{/if}}>Imperial Guard</option>
                            <option value="Outcast" {{#if (eq system.originPath.background "Outcast")}}selected{{/if}}>Outcast</option>
                        </select>
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">Role</span>
                        <select class="wh40k-header-input" name="system.originPath.role">
                            <option value="" {{#unless system.originPath.role}}selected{{/unless}}>— Select —</option>
                            <option value="Assassin" {{#if (eq system.originPath.role "Assassin")}}selected{{/if}}>Assassin</option>
                            <option value="Chirurgeon" {{#if (eq system.originPath.role "Chirurgeon")}}selected{{/if}}>Chirurgeon</option>
                            <option value="Desperado" {{#if (eq system.originPath.role "Desperado")}}selected{{/if}}>Desperado</option>
                            <option value="Hierophant" {{#if (eq system.originPath.role "Hierophant")}}selected{{/if}}>Hierophant</option>
                            <option value="Mystic" {{#if (eq system.originPath.role "Mystic")}}selected{{/if}}>Mystic</option>
                            <option value="Sage" {{#if (eq system.originPath.role "Sage")}}selected{{/if}}>Sage</option>
                            <option value="Seeker" {{#if (eq system.originPath.role "Seeker")}}selected{{/if}}>Seeker</option>
                            <option value="Warrior" {{#if (eq system.originPath.role "Warrior")}}selected{{/if}}>Warrior</option>
                        </select>
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">Elite Advance</span>
                        <select class="wh40k-header-input" name="system.originPath.elite">
                            <option value="" {{#unless system.originPath.elite}}selected{{/unless}}>— None —</option>
                            <option value="Adepta Sororitas" {{#if (eq system.originPath.elite "Adepta Sororitas")}}selected{{/if}}>Adepta Sororitas</option>
                            <option value="Crusader" {{#if (eq system.originPath.elite "Crusader")}}selected{{/if}}>Crusader</option>
                            <option value="Inquisitor" {{#if (eq system.originPath.elite "Inquisitor")}}selected{{/if}}>Inquisitor</option>
                            <option value="Null Maiden" {{#if (eq system.originPath.elite "Null Maiden")}}selected{{/if}}>Null Maiden</option>
                            <option value="Sage of the Ordos" {{#if (eq system.originPath.elite "Sage of the Ordos")}}selected{{/if}}>Sage of the Ordos</option>
                            <option value="Sister Hospitaller" {{#if (eq system.originPath.elite "Sister Hospitaller")}}selected{{/if}}>Sister Hospitaller</option>
                            <option value="Templar Calix" {{#if (eq system.originPath.elite "Templar Calix")}}selected{{/if}}>Templar Calix</option>
                            <option value="Untouchable" {{#if (eq system.originPath.elite "Untouchable")}}selected{{/if}}>Untouchable</option>
                        </select>
                    </div>
                    <div class="wh40k-header-row">
                        <span class="wh40k-header-label">Divination</span>
                        <input class="wh40k-header-input" name="system.originPath.divination" type="text" value="{{system.originPath.divination}}" placeholder="Divination" />
                    </div>
                </div>
            </div>
        </div>
        <div class="wh40k-header-right tw-flex tw-flex-col tw-items-end tw-gap-2 tw-justify-self-end tw-justify-start tw-max-w-[620px]">
            <div class="wh40k-hud-stack tw-relative tw-flex tw-flex-col tw-items-end tw-gap-1.5 tw-h-full">
                {{!-- Characteristics HUD --}}
                <div class="wh40k-characteristics-hud">
                    {{#each actor.characteristics as |characteristic name|}}
                        {{#unless (eq name "influence")}}
                        <div class="wh40k-char-hud-item {{#if (gt this.modifier 0)}}wh40k-char-buffed{{/if}}{{#if (lt this.modifier 0)}}wh40k-char-debuffed{{/if}}"
                             data-characteristic="{{name}}"
                             data-advance="{{this.advance}}"
                             style="--advance-progress: {{divide this.advance 5}};">
                            <button
                                class="wh40k-char-hud-name roll-characteristic actor-drag"
                                type="button"
                                data-action="roll"
                                data-roll-type="characteristic"
                                data-roll-target="{{name}}"
                                data-item-type="characteristic"
                                data-item-id="{{name}}"
                                data-characteristic="{{name}}"
                                title="{{this.label}}"
                            >{{this.short}}</button>
                            <div class="wh40k-char-hud-circle" title="{{this.label}}">
                                <span class="wh40k-char-hud-mod">{{this.bonus}}</span>
                                <span class="wh40k-char-hud-mod-label">MOD</span>
                            </div>
                            {{#if ../inEditMode}}
                            <div class="wh40k-char-hud-base wh40k-char-hud-base--edit">
                                <input type="number" class="wh40k-char-direct-input wh40k-char-inline-input" data-characteristic="{{name}}" data-field="base" data-dtype="Number" value="{{this.base}}" title="Base {{this.label}}" />
                            </div>
                            {{else}}
                            <div class="wh40k-char-hud-base">Total {{this.total}}</div>
                            {{/if}}
                        </div>
                        {{/unless}}
                    {{/each}}
                </div>
                <div class="wh40k-dropzone wh40k-dropzone-small" data-drop-zone="general">
                    <i class="fas fa-plus-circle wh40k-dropzone-icon"></i>
                    <span class="wh40k-dropzone-text">Drag and Drop from Compendium to Add</span>
                </div>
            </div>
        </div>
    </div>
</div>
