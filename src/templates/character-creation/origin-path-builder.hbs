{{!-- Origin Path Builder Template - Refactored Design --}}
<div class="origin-builder tw-grid tw-grid-rows-[auto_auto_1fr_auto_auto] tw-h-full tw-gap-0">

    {{!-- Unified Header: Toolbar + Mode + Direction --}}
    <header class="builder-toolbar tw-flex tw-justify-between tw-items-stretch tw-py-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-md)] tw-bg-[linear-gradient(180deg,var(--wh40k-bronze-dark),rgba(0,0,0,0.8))] tw-border-b-2 tw-border-b-[var(--wh40k-gold)]">
        <div class="toolbar-group tw-flex tw-gap-[var(--wh40k-space-sm)] tw-items-center">
            <button type="button" class="toolbar-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="randomize" data-tooltip="{{localize 'WH40K.OriginPath.RandomizeHint'}}">
                <i class="fa-solid fa-dice"></i>
                <span>{{localize "WH40K.OriginPath.Randomize"}}</span>
            </button>
            <button type="button" class="toolbar-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="reset" data-tooltip="{{localize 'WH40K.OriginPath.ResetHint'}}">
                <i class="fa-solid fa-rotate-left"></i>
                <span>{{localize "WH40K.OriginPath.Reset"}}</span>
            </button>
        </div>

        <div class="toolbar-center tw-flex-1 tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-xs)]">
            <h1 class="toolbar-title tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.1rem] tw-text-[color:var(--wh40k-gold)] tw-uppercase tw-tracking-[2px]">{{journeyTitle}}</h1>

            {{!-- Mode and Direction Controls (inline with title) --}}
            <div class="toolbar-controls tw-flex tw-gap-[var(--wh40k-space-md)] tw-items-center">
                {{!-- Guided/Free Mode Toggle --}}
                <div class="mode-toggle tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-p-[var(--wh40k-space-xs)] tw-bg-[rgba(0,0,0,0.3)] tw-rounded-[var(--wh40k-radius-sm)] tw-border tw-border-[var(--wh40k-bronze)]">
                    <label class="mode-option tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-rounded-[var(--wh40k-radius-sm)] tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-[color:var(--wh40k-text-light)] {{#if guidedMode}}tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] tw-text-[color:var(--wh40k-gold)]{{/if}}" data-tooltip="{{localize 'WH40K.OriginPath.GuidedHint'}}">
                        <input type="radio" name="mode" value="guided" {{#if guidedMode}}checked{{/if}} data-action="setMode">
                        <i class="fa-solid fa-route"></i>
                        <span>{{localize "WH40K.OriginPath.Guided"}}</span>
                    </label>
                    <label class="mode-option tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-rounded-[var(--wh40k-radius-sm)] tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-[color:var(--wh40k-text-light)] {{#unless guidedMode}}tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] tw-text-[color:var(--wh40k-gold)]{{/unless}}" data-tooltip="{{localize 'WH40K.OriginPath.FreeHint'}}">
                        <input type="radio" name="mode" value="free" {{#unless guidedMode}}checked{{/unless}} data-action="setMode">
                        <i class="fa-solid fa-unlock"></i>
                        <span>{{localize "WH40K.OriginPath.Free"}}</span>
                    </label>
                </div>

                {{!-- Direction Toggle (RT only — DH2e steps are independent) --}}
                {{#if hasDirectionToggle}}
                <div class="direction-toggle tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-p-[var(--wh40k-space-xs)] tw-bg-[rgba(0,0,0,0.3)] tw-rounded-[var(--wh40k-radius-sm)] tw-border tw-border-[var(--wh40k-bronze)]">
                    <label class="direction-option tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-rounded-[var(--wh40k-radius-sm)] tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-[color:var(--wh40k-text-light)] {{#if isBackward}}tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] tw-text-[color:var(--wh40k-gold)]{{/if}}" data-tooltip="{{localize 'WH40K.OriginPath.DirectionBackwardHint'}}">
                        <input type="radio" name="direction" value="backward" {{#if isBackward}}checked{{/if}} data-action="setDirection">
                        <i class="fa-solid fa-arrow-left"></i>
                        <span>{{localize "WH40K.OriginPath.DirectionBackward"}}</span>
                    </label>
                    <label class="direction-option tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-rounded-[var(--wh40k-radius-sm)] tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-[color:var(--wh40k-text-light)] {{#if isForward}}tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] tw-text-[color:var(--wh40k-gold)]{{/if}}" data-tooltip="{{localize 'WH40K.OriginPath.DirectionForwardHint'}}">
                        <input type="radio" name="direction" value="forward" {{#if isForward}}checked{{/if}} data-action="setDirection">
                        <i class="fa-solid fa-arrow-right"></i>
                        <span>{{localize "WH40K.OriginPath.DirectionForward"}}</span>
                    </label>
                </div>
                {{/if}}
            </div>
        </div>

        <div class="toolbar-group tw-flex tw-gap-[var(--wh40k-space-sm)] tw-items-center">
            <button type="button" class="toolbar-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="export" data-tooltip="{{localize 'WH40K.OriginPath.ExportHint'}}">
                <i class="fa-solid fa-download"></i>
            </button>
            <button type="button" class="toolbar-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="import" data-tooltip="{{localize 'WH40K.OriginPath.ImportHint'}}">
                <i class="fa-solid fa-upload"></i>
            </button>
        </div>
    </header>

    {{!-- Step Navigation with Visual Progress --}}
    <nav class="step-navigation tw-flex tw-justify-center tw-items-center tw-gap-0 tw-py-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-md)] tw-bg-[rgba(0,0,0,0.4)] tw-border-b tw-border-b-[var(--wh40k-bronze)] tw-overflow-x-auto">
        {{#each steps as |step|}}
            <div class="step-nav-item tw-group tw-flex tw-flex-col tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-min-w-[80px] tw-cursor-pointer tw-relative {{#if step.isActive}}tw-scale-105{{/if}} {{#if step.isDisabled}}tw-opacity-40 tw-cursor-not-allowed{{/if}} {{#if step.isLineage}}lineage-step{{/if}}"
                 data-action="goToStep"
                 data-step-index="{{step.index}}"
                 data-step-key="{{step.key}}"
                 data-tooltip="{{step.label}}{{#if step.selection}}: {{step.selection.name}}{{/if}}">
                <div class="step-number tw-w-10 tw-h-10 tw-flex tw-items-center tw-justify-center tw-rounded-full tw-border-2 tw-relative tw-overflow-hidden tw-text-[0.85rem] tw-font-semibold tw-transition-all
                    {{#if step.isActive}}tw-bg-[linear-gradient(135deg,var(--wh40k-gold),rgb(184,147,35))] tw-border-[var(--wh40k-gold)] tw-shadow-[0_0_12px_rgba(201,162,39,0.6)] tw-animate-pulse-glow{{else if step.isComplete}}tw-border-[rgb(166,132,32)] tw-shadow-[0_2px_8px_rgba(201,162,39,0.3)] tw-text-[var(--wh40k-panel-bg-solid)]{{else if step.isLineage}}tw-bg-[linear-gradient(135deg,#9b4dca,#6b2d9b)] tw-border-[#ce93d8]{{else}}tw-border-[var(--wh40k-bronze)] tw-bg-[rgba(0,0,0,0.5)] tw-text-[color:var(--wh40k-text-muted)]{{/if}}
                    group-hover:tw-border-[var(--wh40k-gold)] group-hover:tw-scale-105">
                    {{#if step.isComplete}}
                        {{!-- Complete state: show image if available, else checkmark icon --}}
                        {{#if step.selection}}
                            <img src="{{step.selection.img}}" alt="{{step.selection.name}}" class="step-icon-img tw-w-full tw-h-full tw-object-cover tw-rounded-full" />
                        {{else}}
                            <i class="fa-solid fa-check tw-text-[0.9rem] tw-text-[color:var(--wh40k-bg-dark)] tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-bg-[linear-gradient(135deg,var(--wh40k-gold),rgb(184,147,35))] tw-rounded-full"></i>
                        {{/if}}
                    {{else if step.selection}}
                        <img src="{{step.selection.img}}" alt="{{step.selection.name}}" class="step-icon-img tw-w-full tw-h-full tw-object-cover tw-rounded-full" />
                    {{else if (eq step.key "characteristics")}}
                        <i class="fa-solid {{step.icon}}"></i>
                    {{else}}
                        {{add step.index 1}}
                    {{/if}}
                </div>
                <span class="step-label tw-text-[0.65rem] tw-uppercase tw-tracking-[0.5px] tw-text-center tw-transition-all
                    {{#if step.isActive}}tw-text-[color:var(--wh40k-gold)] tw-font-semibold{{else if step.isComplete}}tw-text-[color:var(--wh40k-gold)]{{else if step.isLineage}}tw-text-[#ce93d8]{{else}}tw-text-[color:var(--wh40k-text-muted)]{{/if}}
                    group-hover:tw-text-[color:var(--wh40k-text-light)]">{{step.shortLabel}}</span>
            </div>
            {{#unless @last}}
                <div class="step-connector tw-flex-[0_0_24px] tw-h-[3px] tw-rounded-[var(--wh40k-radius-sm)] tw-transition-all {{#if step.isComplete}}tw-bg-[linear-gradient(90deg,rgba(201,162,39,0.6),rgba(201,162,39,0.3))]{{else}}tw-bg-[linear-gradient(90deg,rgba(255,255,255,0.1),rgba(255,255,255,0.05))]{{/if}}"></div>
            {{/unless}}
        {{/each}}
    </nav>

    {{!-- Main Content --}}
    <main class="builder-main tw-grid tw-gap-[var(--wh40k-space-md)] tw-p-[var(--wh40k-space-md)] tw-overflow-hidden tw-min-h-0 {{#if showSelectionPanel}}tw-grid-cols-[1fr_350px]{{else}}tw-grid-cols-[1fr]{{/if}}">
        {{!-- Step Content (Left) --}}
        <section class="step-content tw-flex tw-flex-col tw-gap-[var(--wh40k-space-md)] tw-overflow-y-auto tw-pr-[var(--wh40k-space-sm)]">
            <div class="step-header tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)]">
                <div class="step-icon tw-w-12 tw-h-12 tw-flex tw-items-center tw-justify-center tw-bg-[linear-gradient(135deg,var(--wh40k-bronze-dark),var(--wh40k-bronze))] tw-border-2 tw-border-[var(--wh40k-gold)] tw-rounded-[var(--wh40k-radius-md)]">
                    <i class="fa-solid {{currentStep.icon}} tw-text-[1.5rem] tw-text-[color:var(--wh40k-gold)]"></i>
                </div>
                <div class="step-info tw-flex-1">
                    {{#if showEquipment}}
                        <h2 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.3rem] tw-text-[color:var(--wh40k-gold)]"><i class="fa-solid fa-box"></i> {{localize "WH40K.OriginPath.EquipmentTitle"}}</h2>
                        <p class="tw-mt-[var(--wh40k-space-xs)] tw-mb-0 tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.OriginPath.EquipmentDesc"}}</p>
                    {{else if currentStep.isCharacteristics}}
                        <h2 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.3rem] tw-text-[color:var(--wh40k-gold)]"><i class="fa-solid fa-dice-d20"></i> {{localize "WH40K.CharacteristicSetup.Title"}}</h2>
                        <p class="tw-mt-[var(--wh40k-space-xs)] tw-mb-0 tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.CharacteristicSetup.Instructions"}}</p>
                    {{else if currentStep.isLineage}}
                        <h2 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.3rem] tw-text-[color:var(--wh40k-gold)]">{{optionalStepLabel}} <span class="optional-badge tw-text-[0.65rem] tw-font-normal tw-py-[2px] tw-px-[6px] tw-bg-[rgba(156,39,176,0.2)] tw-border tw-border-[rgba(156,39,176,0.4)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[#ce93d8] tw-uppercase tw-tracking-[0.5px] tw-align-middle tw-ml-[var(--wh40k-space-sm)]">{{localize "WH40K.OriginPath.Optional"}}</span></h2>
                        <p class="tw-mt-[var(--wh40k-space-xs)] tw-mb-0 tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)]">{{optionalStepDesc}}</p>
                    {{else}}
                        <h2 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.3rem] tw-text-[color:var(--wh40k-gold)]">{{localize "WH40K.OriginPath.Step"}} {{add currentStep.index 1}}: {{currentStep.label}}</h2>
                        <p class="tw-mt-[var(--wh40k-space-xs)] tw-mb-0 tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)]">{{currentStep.description}}</p>
                    {{/if}}
                </div>
            </div>

            {{#if showEquipment}}
            {{!-- Equip Acolyte — DH2e Stage 4 --}}
            <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3">
                <div class="tw-flex tw-flex-col tw-gap-1 tw-p-2 tw-border tw-border-white/10 tw-rounded">
                    {{#if equipment.hasInfluence}}
                        <div class="tw-flex tw-items-center tw-gap-1.5 tw-font-semibold {{#if equipment.atLimit}}tw-text-amber-400{{/if}}">
                            <i class="fa-solid fa-hashtag"></i>
                            <span>{{equipment.selectedCount}} / {{equipment.maxSelections}} {{localize "WH40K.OriginPath.EquipmentSelectedLabel"}}</span>
                        </div>
                    {{else}}
                        <div class="tw-flex tw-items-center tw-gap-1.5 tw-font-semibold tw-text-amber-400">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <span>{{localize "WH40K.OriginPath.EquipmentNoInfluence"}}</span>
                        </div>
                    {{/if}}
                    {{#if equipment.selectedItems.length}}
                        <ul class="tw-list-disc tw-pl-5 tw-m-0 tw-mt-1 tw-text-sm tw-leading-snug">
                            {{#each equipment.selectedItems as |item|}}
                                <li>{{item.name}}</li>
                            {{/each}}
                        </ul>
                    {{/if}}
                    <div class="tw-text-sm tw-italic tw-opacity-75">{{localize "WH40K.OriginPath.EquipmentRuleHint"}}</div>
                </div>

                <div class="tw-flex tw-items-center tw-gap-2">
                    <input type="search" class="equip-search tw-flex-1 tw-px-2 tw-py-1 tw-text-sm"
                           placeholder="{{localize 'WH40K.OriginPath.EquipmentSearchPlaceholder'}}" value="{{equipment.search}}" />
                    <select class="equip-type-filter tw-basis-44 tw-px-2 tw-py-1 tw-text-sm">
                        {{#each equipment.typeOptions as |option|}}
                            <option value="{{option.value}}" {{#if (eq option.value ../equipment.typeFilter)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                    </select>
                    <button type="button" class="toolbar-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="clearEquipment" data-tooltip="{{localize 'WH40K.OriginPath.EquipmentClearAll'}}">
                        <i class="fa-solid fa-rotate-left"></i>
                        <span>{{localize "WH40K.OriginPath.EquipmentClearAll"}}</span>
                    </button>
                </div>

                <table class="tw-w-full tw-border-collapse tw-text-sm">
                    <thead>
                        <tr class="tw-text-xs tw-uppercase tw-opacity-75 tw-border-b tw-border-white/15">
                            <th class="tw-w-8 tw-text-center tw-px-2 tw-py-1"></th>
                            <th class="tw-w-6 tw-px-2 tw-py-1"></th>
                            <th class="tw-text-left tw-px-2 tw-py-1">{{localize "WH40K.OriginPath.EquipmentColName"}}</th>
                            <th class="tw-text-left tw-px-2 tw-py-1 tw-w-32">{{localize "WH40K.OriginPath.EquipmentColType"}}</th>
                            <th class="tw-text-left tw-px-2 tw-py-1 tw-w-28">{{localize "WH40K.OriginPath.EquipmentColAvailability"}}</th>
                            {{#if equipment.isHomebrew}}
                                <th class="tw-text-right tw-px-2 tw-py-1 tw-w-16">{{localize "WH40K.OriginPath.EquipmentColRequisition"}}</th>
                                <th class="tw-text-right tw-px-2 tw-py-1 tw-w-24">{{localize "WH40K.OriginPath.EquipmentColThroneGelt"}}</th>
                            {{/if}}
                        </tr>
                    </thead>
                    <tbody>
                        {{#each equipment.items as |item|}}
                            <tr class="equip-row tw-border-b tw-border-white/5 tw-cursor-pointer hover:tw-bg-white/5 {{#if item.isSelected}}tw-bg-amber-400/10{{/if}} {{#if item.isDisabled}}tw-opacity-40 tw-cursor-not-allowed{{/if}}"
                                data-action="toggleEquipmentItem"
                                data-uuid="{{item.uuid}}">
                                <td class="tw-w-8 tw-text-center tw-px-2 tw-py-1">
                                    <input type="checkbox"
                                           class="equip-check"
                                           {{#if item.isSelected}}checked{{/if}}
                                           {{#if item.isDisabled}}disabled{{/if}} />
                                </td>
                                <td class="tw-w-6 tw-px-2 tw-py-1">
                                    <img src="{{item.img}}" alt="{{item.name}}" width="16" height="16" class="tw-w-4 tw-h-4 tw-max-w-[16px] tw-max-h-[16px] tw-object-contain tw-block" />
                                </td>
                                <td class="tw-px-2 tw-py-1 tw-font-medium">{{item.name}}</td>
                                <td class="tw-px-2 tw-py-1 tw-capitalize tw-opacity-85">{{item.type}}</td>
                                <td class="tw-px-2 tw-py-1 tw-opacity-85">{{item.availabilityLabel}}</td>
                                {{#if ../equipment.isHomebrew}}
                                    <td class="tw-px-2 tw-py-1 tw-text-right tw-tabular-nums tw-opacity-90">{{#if item.requisition}}{{item.requisition}}{{else}}—{{/if}}</td>
                                    <td class="tw-px-2 tw-py-1 tw-text-right tw-tabular-nums tw-opacity-90">{{#if item.throneGelt}}{{item.throneGelt}}₮{{else}}—{{/if}}</td>
                                {{/if}}
                            </tr>
                        {{else}}
                            <tr><td colspan="{{#if equipment.isHomebrew}}7{{else}}5{{/if}}" class="tw-text-center tw-py-3 tw-italic tw-opacity-70">{{localize "WH40K.OriginPath.EquipmentNoneAvailable"}}</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else if showCharacteristics}}
            {{!-- Characteristic Setup (embedded) --}}
            <div class="csd-embedded">
                <div role="tablist" aria-label="{{localize 'WH40K.CharacteristicSetup.ModeAriaLabel'}}" class="tw-flex tw-gap-1 tw-mb-3 tw-p-1 tw-bg-black/20 tw-rounded-md tw-border tw-border-white/10">
                    <button type="button" role="tab" aria-selected="{{#if charGen.isModePointBuy}}true{{else}}false{{/if}}"
                            class="tw-flex-1 tw-px-3 tw-py-1.5 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-rounded tw-border-0 tw-cursor-pointer tw-transition-colors {{#if charGen.isModePointBuy}}tw-bg-gold/20 tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure{{else}}tw-bg-transparent tw-text-white/70 hover:tw-bg-white/5{{/if}}"
                            data-action="setCharGenMode" data-mode="point-buy">
                        {{localize "WH40K.CharacteristicSetup.Mode.PointBuy"}}
                    </button>
                    <button type="button" role="tab" aria-selected="{{#if charGen.isModeRoll}}true{{else}}false{{/if}}"
                            class="tw-flex-1 tw-px-3 tw-py-1.5 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-rounded tw-border-0 tw-cursor-pointer tw-transition-colors {{#if charGen.isModeRoll}}tw-bg-gold/20 tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure{{else}}tw-bg-transparent tw-text-white/70 hover:tw-bg-white/5{{/if}}"
                            data-action="setCharGenMode" data-mode="roll">
                        {{localize "WH40K.CharacteristicSetup.Mode.Roll"}}
                    </button>
                    <button type="button" role="tab" aria-selected="{{#if charGen.isModeRollPoolHB}}true{{else}}false{{/if}}"
                            class="tw-flex-1 tw-px-3 tw-py-1.5 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-rounded tw-border-0 tw-cursor-pointer tw-transition-colors {{#if charGen.isModeRollPoolHB}}tw-bg-gold/20 tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure{{else}}tw-bg-transparent tw-text-white/70 hover:tw-bg-white/5{{/if}}"
                            data-action="setCharGenMode" data-mode="roll-pool-hb">
                        {{localize "WH40K.CharacteristicSetup.Mode.RollPoolHB"}}
                    </button>
                </div>

                {{#if charGen.isModePointBuy}}
                <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-2 tw-py-12 tw-px-6 tw-text-center tw-text-white/70 tw-border tw-border-dashed tw-border-white/20 tw-rounded-md">
                    <i class="fa-solid fa-screwdriver-wrench tw-text-4xl tw-text-white/40"></i>
                    <h3 class="tw-text-lg tw-font-semibold tw-text-white/85 tw-m-0">{{localize "WH40K.CharacteristicSetup.Mode.PointBuy"}}</h3>
                    <p class="tw-m-0">{{localize "WH40K.CharacteristicSetup.Mode.NotImplemented"}}</p>
                </div>
                {{else if charGen.isModeRoll}}
                <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-2 tw-py-12 tw-px-6 tw-text-center tw-text-white/70 tw-border tw-border-dashed tw-border-white/20 tw-rounded-md">
                    <i class="fa-solid fa-screwdriver-wrench tw-text-4xl tw-text-white/40"></i>
                    <h3 class="tw-text-lg tw-font-semibold tw-text-white/85 tw-m-0">{{localize "WH40K.CharacteristicSetup.Mode.Roll"}}</h3>
                    <p class="tw-m-0">{{localize "WH40K.CharacteristicSetup.Mode.NotImplemented"}}</p>
                </div>
                {{else}}
                <div class="csd-workspace">
                        <section class="csd-section csd-rolls-bank" data-drop-zone="bank">
                        <div class="csd-section-header-row">
                            <h3 class="csd-section-header">
                                <i class="fa-solid fa-dice-d20"></i>
                                {{localize "WH40K.CharacteristicSetup.RollsBank"}}
                            </h3>
                            <button type="button" class="csd-icon-btn tw-max-w-full tw-whitespace-nowrap" data-action="rollCharacteristicsBank" data-tooltip="{{localize 'WH40K.CharacteristicSetup.RollBank'}}">
                                <i class="fa-solid fa-dice"></i>
                            </button>
                        </div>
                        <div class="csd-rolls-container csd-rolls-container--bank">
                            {{#each charGen.rollsBank}}
                            <div class="csd-roll-chip {{#if isEmpty}}empty{{/if}} {{#if isAssigned}}tw-opacity-30 tw-cursor-not-allowed tw-relative{{/if}}"
                                 data-roll-index="{{index}}"
                                 {{#unless isEmpty}}{{#unless isAssigned}}draggable="true"{{/unless}}{{/unless}}>
                                <span class="csd-roll-value">{{#if isEmpty}}—{{else}}{{value}}{{/if}}</span>
                                <span class="csd-roll-label">{{displayIndex}}</span>
                                {{#if isAssigned}}<span class="tw-pointer-events-none tw-absolute tw-top-0.5 tw-right-1 tw-text-[0.7rem] tw-text-[#4caf50]">✓</span>{{/if}}
                            </div>
                            {{/each}}
                        </div>
                        <p class="tw-text-center tw-text-xs tw-text-[rgba(232,220,196,0.5)] tw-mt-2 tw-m-0 tw-italic">{{localize "WH40K.CharacteristicSetup.ClickToEdit"}}</p>
                    </section>

                    <div class="csd-main-column">
                        <section class="csd-section csd-characteristics">
                            <div class="csd-section-header-row">
                                <h3 class="csd-section-header">
                                    <i class="fa-solid fa-user-gear"></i>
                                    {{localize "WH40K.CharacteristicSetup.Characteristics"}}
                                </h3>
                                <div class="csd-header-actions">
                                    <button type="button" class="csd-icon-btn" data-action="charToggleAdvanced" data-tooltip="{{#if charGen.advancedMode}}{{localize 'WH40K.CharacteristicSetup.AdvancedModeOn'}}{{else}}{{localize 'WH40K.CharacteristicSetup.AdvancedModeOff'}}{{/if}}">
                                        <i class="fa-solid {{#if charGen.advancedMode}}fa-lock-open{{else}}fa-lock{{/if}}"></i>
                                    </button>
                                    <button type="button" class="csd-icon-btn" data-action="charReset" data-tooltip="{{localize 'WH40K.CharacteristicSetup.Reset'}}">
                                        <i class="fa-solid fa-rotate-left"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="csd-char-grid">
                                {{#each charGen.characteristicRows}}
                                <div class="csd-char-row">
                                    {{#each this}}
                                    <div class="csd-char-slot {{#if hasRoll}}has-roll{{else}}empty{{/if}}"
                                         data-characteristic="{{key}}">
                                        <div class="csd-char-header">
                                            <span class="csd-char-short">{{short}}</span>
                                            <span class="csd-char-name">{{label}}</span>
                                        </div>
                                        <div class="csd-char-body">
                                            <div class="csd-char-base">
                                                {{#if @root.charGen.advancedMode}}
                                                <input type="number" class="csd-base-input"
                                                       value="{{base}}"
                                                       data-characteristic="{{key}}"
                                                       min="0" max="99">
                                                {{else}}
                                                <span class="csd-base-value">{{base}}</span>
                                                {{/if}}
                                                <span class="csd-base-label">{{localize "WH40K.CharacteristicSetup.Base"}}</span>
                                            </div>
                                            <span class="csd-char-plus">+</span>
                                            <div class="csd-char-roll-slot">
                                                {{#if hasRoll}}
                                                <div class="csd-assigned-roll tw-w-[40px] tw-h-[36px] tw-flex tw-items-center tw-justify-center tw-bg-gradient-to-br tw-from-[rgba(76,175,80,0.3)] tw-to-[rgba(76,175,80,0.15)] tw-border-2 tw-border-[rgba(76,175,80,0.6)] tw-rounded-[6px] tw-text-[1.2rem] tw-font-bold tw-text-[color:var(--csd-bone,#e8dcc4)] tw-cursor-grab hover:tw-scale-110 hover:tw-border-[var(--csd-gold,#b08d57)]"
                                                     draggable="true"
                                                     data-roll-index="{{assignedIndex}}"
                                                     data-characteristic="{{key}}">
                                                    {{rollValue}}
                                                </div>
                                                {{else}}
                                                <div class="csd-drop-zone">
                                                    <i class="fa-solid fa-arrow-down tw-animate-csd-bounce"></i>
                                                </div>
                                                {{/if}}
                                            </div>
                                            <span class="csd-char-plus">+</span>
                                            <div class="csd-char-origin {{#if hasOriginBonus}}has-origin{{/if}}"
                                                 {{#if hasOriginBonusTooltip}}data-wh40k-tooltip="generic" data-wh40k-tooltip-data="{{originBonusTooltipData}}" data-tooltip="{{originBonusTooltip}}"{{/if}}>
                                                <span class="csd-char-origin-value">{{#if hasOriginBonus}}{{#if (gt originBonus 0)}}+{{/if}}{{originBonus}}{{else}}0{{/if}}</span>
                                                <span class="csd-char-origin-label">Origin</span>
                                            </div>
                                            <span class="csd-char-equals">=</span>
                                            <div class="csd-char-total {{#if hasRoll}}has-value tw-animate-csd-value-pop{{/if}}">
                                                {{#if hasRoll}}{{total}}{{else}}??{{/if}}
                                            </div>
                                        </div>
                                    </div>
                                    {{/each}}
                                </div>
                                {{/each}}
                            </div>
                        </section>

                        <section class="csd-section csd-divination">
                            <div class="csd-section-header-row">
                                <h3 class="csd-section-header">
                                    <i class="fa-solid fa-eye"></i>
                                    Divination
                                </h3>
                                <button type="button" class="csd-icon-btn" data-action="rollDivination" data-tooltip="{{localize 'WH40K.OriginPath.RollTooltip'}}">
                                    <i class="fa-solid fa-dice"></i>
                                </button>
                            </div>
                            <input type="text" class="csd-divination-input" value="{{charGen.divination}}" placeholder="Enter divination" />
                        </section>
                    </div>
                </div>
                {{/if}}
            </div>
            {{else}}
            {{!-- Origin Cards --}}
            <div class="origin-cards-grid tw-grid tw-grid-cols-[repeat(auto-fill,minmax(112px,1fr))] tw-gap-[var(--wh40k-space-sm)]">
                {{#each currentStep.origins as |origin|}}
                    <div class="origin-card tw-group tw-flex tw-flex-col tw-bg-[var(--wh40k-panel-bg-solid)] tw-border-2 tw-rounded-[var(--wh40k-radius-md)] tw-p-[var(--wh40k-space-xs)] tw-cursor-pointer tw-relative tw-transition-all
                        {{#if origin.isSelected}}selected tw-border-[var(--wh40k-gold)] tw-bg-[linear-gradient(135deg,rgba(var(--wh40k-gold-rgb),0.1),rgba(var(--wh40k-gold-rgb),0.05))] tw-shadow-[0_0_15px_rgba(var(--wh40k-gold-rgb),0.3)]{{else if origin.isDisabled}}disabled tw-border-[var(--wh40k-bronze)] tw-opacity-40 tw-cursor-not-allowed tw-grayscale-[0.5]{{else if origin.isValidNext}}valid-next tw-border-[#4caf50]{{else}}tw-border-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw--translate-y-[2px] hover:tw-shadow-[0_4px_12px_rgba(0,0,0,0.4)]{{/if}}"
                         data-action="selectOriginCard"
                         data-origin-id="{{origin.id}}"
                         data-origin-uuid="{{origin.uuid}}"
                         data-tooltip="{{origin.shortDescription}}">
                        {{#if origin.isValidNext}}
                            <span class="wh40k-origin-card__valid-border tw-animate-pulse-border tw-absolute tw-inset-[-4px] tw-border-2 tw-border-dashed tw-border-[#4caf50] tw-rounded-[var(--wh40k-radius-lg)] tw-pointer-events-none" aria-hidden="true"></span>
                        {{/if}}
                        {{#if origin.isSelected}}
                            <div class="selection-indicator tw-absolute tw-top-2 tw-right-2 tw-w-8 tw-h-8 tw-flex tw-items-center tw-justify-center tw-bg-[var(--wh40k-gold)] tw-rounded-full tw-shadow-[0_2px_8px_rgba(201,162,39,0.5)] tw-z-[4]">
                                <i class="fa-solid fa-check-circle tw-text-[1.2rem] tw-text-[color:var(--wh40k-bg-dark)]"></i>
                            </div>
                        {{/if}}
                        <img src="{{origin.img}}" alt="{{origin.name}}" class="card-img tw-w-full tw-aspect-[4/3] tw-object-cover tw-rounded-[var(--wh40k-radius-sm)] tw-border tw-border-[var(--wh40k-bronze)] tw-mb-[var(--wh40k-space-xs)]" />
                        <h4 class="card-name tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[0.78rem] tw-text-[color:var(--wh40k-text-light)] tw-text-center tw-leading-[1.2]">{{origin.name}}</h4>
                        {{#if origin.badges}}
                            <div class="card-badges tw-flex tw-gap-[var(--wh40k-space-xs)] tw-justify-center tw-mt-[var(--wh40k-space-xs)] tw-flex-wrap">
                                {{#if origin.hasChoices}}
                                    <span class="card-badge tw-py-[2px] tw-px-[5px] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.6rem] tw-font-semibold tw-uppercase tw-bg-[rgba(255,170,0,0.2)] tw-text-[#ffaa00] tw-border tw-border-[rgba(255,170,0,0.4)]">{{localize "WH40K.OriginPath.HasChoices"}}</span>
                                {{/if}}
                                {{#if origin.isAdvanced}}
                                    <span class="card-badge tw-py-[2px] tw-px-[5px] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.6rem] tw-font-semibold tw-uppercase tw-bg-[rgba(156,39,176,0.2)] tw-text-[#ce93d8] tw-border tw-border-[rgba(156,39,176,0.4)]">{{localize "WH40K.OriginPath.Advanced"}}</span>
                                {{/if}}
                                {{#if origin.xpCost}}
                                    <span class="card-badge tw-py-[2px] tw-px-[5px] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.6rem] tw-font-semibold tw-uppercase tw-bg-[rgba(33,150,243,0.2)] tw-text-[#64b5f6] tw-border tw-border-[rgba(33,150,243,0.4)]">{{origin.xpCost}} XP</span>
                                {{/if}}
                            </div>
                        {{/if}}
                        {{!-- Preview button for detailed view --}}
                        <button type="button" class="card-preview-btn tw-absolute tw-top-1 tw-left-1 tw-w-7 tw-h-7 tw-flex tw-items-center tw-justify-center tw-bg-[rgba(0,0,0,0.8)] tw-border tw-border-[var(--wh40k-gold)] tw-rounded-full tw-text-[color:var(--wh40k-gold)] tw-cursor-pointer tw-opacity-0 group-hover:tw-opacity-100 tw-transition-all tw-z-[3] hover:tw-bg-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-panel-bg-solid)] hover:tw-scale-110" data-action="viewOriginCard" data-origin-id="{{origin.id}}" data-origin-uuid="{{origin.uuid}}" data-tooltip="{{localize 'WH40K.OriginPath.ViewDetails'}}">
                            <i class="fa-solid fa-eye tw-text-[0.75rem]"></i>
                        </button>
                    </div>
                {{else}}
                    <p class="no-origins tw-col-span-full tw-text-center tw-text-[color:var(--wh40k-text-muted)] tw-py-8">{{localize "WH40K.OriginPath.NoOriginsAvailable"}}</p>
                {{/each}}
            </div>
            {{/if}}
        </section>

        {{!-- Selection Detail Panel (Right) --}}
        {{#if showSelectionPanel}}
        <aside class="selection-panel tw-flex tw-flex-col tw-gap-[var(--wh40k-space-md)] tw-bg-[var(--wh40k-panel-bg-solid)] tw-border-2 tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-md)] tw-p-[var(--wh40k-space-md)] tw-overflow-y-auto">
            {{#if selectedOrigin}}
                {{!-- Header --}}
                    <div class="selection-header tw-flex tw-items-start tw-gap-[var(--wh40k-space-md)]">
                        <img src="{{selectedOrigin.img}}" alt="{{selectedOrigin.name}}" class="selection-img tw-w-16 tw-h-16 tw-object-cover tw-border-2 tw-border-[var(--wh40k-gold)] tw-rounded-[var(--wh40k-radius-md)]" />
                        <div class="selection-info tw-flex-1">
                            <h3 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.1rem] tw-text-[color:var(--wh40k-gold)]">{{selectedOrigin.name}}</h3>
                            {{#if selectedOrigin.description}}
                                <div class="selection-description tw-mt-[var(--wh40k-space-xs)] tw-text-[0.8rem] tw-text-[color:var(--wh40k-text-muted)] tw-leading-[1.4]">{{{selectedOrigin.description}}}</div>
                            {{/if}}
                            {{#if selectedOrigin.requirementsText}}
                                <div class="selection-requirements tw-flex tw-items-center tw-gap-1 tw-mt-1 tw-text-[0.8rem] tw-text-[color:var(--wh40k-crimson)]">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    <span>{{selectedOrigin.requirementsText}}</span>
                                </div>
                            {{/if}}
                        </div>
                        <div class="selection-actions tw-flex tw-gap-[var(--wh40k-space-xs)]">
                        <button type="button" class="toolbar-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="viewOrigin" data-tooltip="{{localize 'WH40K.OriginPath.ViewDetails'}}">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                        {{#unless selectedOrigin.isConfirmed}}
                            <button type="button" class="toolbar-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(76,175,80,0.2)] tw-border tw-border-[#4caf50] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[#4caf50] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[#4caf50] hover:tw-border-[#4caf50] hover:tw-text-white" data-action="confirmSelection" data-tooltip="{{localize 'WH40K.OriginPath.ConfirmSelection'}}">
                                <i class="fa-solid fa-check"></i>
                            </button>
                        {{/unless}}
                    </div>
                </div>

                {{!-- Grants Section --}}
                {{#if selectedOrigin.grants}}
                    <div class="selection-section tw-border-t tw-border-t-[var(--wh40k-bronze)] tw-pt-[var(--wh40k-space-md)]">
                        <h4 class="section-title tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-m-0 tw-mb-[var(--wh40k-space-sm)] tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--wh40k-gold)] tw-uppercase tw-tracking-[0.5px]">
                            <i class="fa-solid fa-gift tw-text-[0.9rem]"></i>
                            {{localize "WH40K.OriginPath.Grants"}}
                        </h4>
                        <div class="grants-list tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)]">
                            {{!-- Characteristics --}}
                            {{#if selectedOrigin.grants.hasCharacteristics}}
                                <div class="grants-category">
                                    <span class="category-label tw-block tw-text-[0.7rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-1">{{localize "WH40K.Characteristics"}}</span>
                                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[150px] tw-overflow-y-auto tw-overflow-x-hidden">
                                        {{#each selectedOrigin.grants.characteristics as |char|}}
                                            <span class="grant-item characteristic tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[2px] tw-px-[8px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-leading-[1.3]
                                                {{#if char.positive}}tw-border tw-border-[rgba(76,175,80,0.3)] tw-text-[#4caf50]{{else}}negative tw-border tw-border-[rgba(231,76,60,0.3)] tw-text-[color:var(--wh40k-accent-red)]{{/if}}">
                                                {{char.short}}: {{#if char.positive}}+{{/if}}{{char.value}}
                                            </span>
                                        {{/each}}
                                    </div>
                                </div>
                            {{/if}}

                            {{!-- Skills (clickable) --}}
                            {{#if selectedOrigin.grants.hasSkills}}
                                <div class="grants-category">
                                    <span class="category-label tw-block tw-text-[0.7rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-1">{{localize "WH40K.Skills.Header"}}</span>
                                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[150px] tw-overflow-y-auto tw-overflow-x-hidden">
                                        {{#each selectedOrigin.grants.skills as |skill|}}
                                            <div class="grant-tag skill-tag tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3] tw-max-w-full tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap {{#if skill.uuid}}clickable tw-cursor-pointer hover:tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] hover:tw-border-[var(--wh40k-gold)] hover:tw--translate-y-[1px]{{/if}}"
                                                  {{#if skill.uuid}}data-action="openItem" data-uuid="{{skill.uuid}}"{{/if}}
                                                  data-wh40k-tooltip="generic"
                                                  data-wh40k-tooltip-data="{{skill.tooltipData}}"
                                                  data-tooltip="{{skill.displayName}} ({{skill.levelLabel}})">
                                                <i class="fa-solid fa-book-open tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[color:var(--wh40k-accent-info)]"></i>
                                                <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{skill.displayName}}</span>
                                                <span class="tag-level tw-text-[0.65rem] tw-opacity-80 tw-flex-shrink-0">{{skill.levelLabel}}</span>
                                                {{#if skill.uuid}}<i class="fa-solid fa-external-link tag-link tw-text-[0.65rem] tw-opacity-60 tw-text-[color:var(--wh40k-gold)]"></i>{{/if}}
                                            </div>
                                        {{/each}}
                                    </div>
                                </div>
                            {{/if}}

                            {{!-- Talents (clickable if they have uuid) --}}
                            {{#if selectedOrigin.grants.hasTalents}}
                                <div class="grants-category">
                                    <span class="category-label tw-block tw-text-[0.7rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-1">{{localize "WH40K.Talents"}}</span>
                                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[150px] tw-overflow-y-auto tw-overflow-x-hidden">
                                        {{#each selectedOrigin.grants.talents as |talent|}}
                                            <div class="grant-tag talent-tag tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3] tw-max-w-full tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap {{#if talent.hasItem}}clickable tw-cursor-pointer hover:tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] hover:tw-border-[var(--wh40k-gold)] hover:tw--translate-y-[1px]{{/if}}"
                                                  {{#if talent.uuid}}data-action="openItem" data-uuid="{{talent.uuid}}"{{/if}}
                                                  data-wh40k-tooltip="generic"
                                                  data-wh40k-tooltip-data="{{talent.tooltipData}}"
                                                  data-tooltip="{{talent.tooltip}}">
                                                <i class="fa-solid fa-star tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[#f39c12]"></i>
                                                <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{talent.name}}</span>
                                                {{#if talent.hasItem}}<i class="fa-solid fa-external-link tag-link tw-text-[0.65rem] tw-opacity-60 tw-text-[color:var(--wh40k-gold)]"></i>{{/if}}
                                            </div>
                                        {{/each}}
                                    </div>
                                </div>
                            {{/if}}

                            {{!-- Traits (clickable if they have uuid) --}}
                            {{#if selectedOrigin.grants.hasTraits}}
                                <div class="grants-category">
                                    <span class="category-label tw-block tw-text-[0.7rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-1">{{localize "WH40K.Traits"}}</span>
                                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[150px] tw-overflow-y-auto tw-overflow-x-hidden">
                                        {{#each selectedOrigin.grants.traits as |trait|}}
                                            <div class="grant-tag trait-tag tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3] tw-max-w-full tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap {{#if trait.hasItem}}clickable tw-cursor-pointer hover:tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] hover:tw-border-[var(--wh40k-gold)] hover:tw--translate-y-[1px]{{/if}}"
                                                  {{#if trait.uuid}}data-action="openItem" data-uuid="{{trait.uuid}}"{{/if}}
                                                  data-tooltip="{{trait.tooltip}}">
                                                <i class="fa-solid fa-dna tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[color:var(--wh40k-accent-psychic)]"></i>
                                                <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{trait.name}}{{#if trait.level}} ({{trait.level}}){{/if}}</span>
                                                {{#if trait.hasItem}}<i class="fa-solid fa-external-link tag-link tw-text-[0.65rem] tw-opacity-60 tw-text-[color:var(--wh40k-gold)]"></i>{{/if}}
                                            </div>
                                        {{/each}}
                                    </div>
                                </div>
                            {{/if}}

                            {{!-- Equipment --}}
                            {{#if selectedOrigin.grants.hasEquipment}}
                                <div class="grants-category">
                                    <span class="category-label tw-block tw-text-[0.7rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-1">{{localize "WH40K.EquipmentGranted"}}</span>
                                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[150px] tw-overflow-y-auto tw-overflow-x-hidden">
                                        {{#each selectedOrigin.grants.equipment as |item|}}
                                            <div class="grant-tag equipment-tag tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3] tw-max-w-full tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap">
                                                <i class="fa-solid fa-box tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[color:var(--wh40k-accent-green)]"></i>
                                                <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{item.name}}</span>
                                            </div>
                                        {{/each}}
                                    </div>
                                </div>
                            {{/if}}
                        </div>
                    </div>
                {{/if}}

                {{!-- Choices Section --}}
                {{#if selectedOrigin.hasChoices}}
                    <div class="selection-section choices-section tw-border-t tw-border-t-[var(--wh40k-bronze)] tw-pt-[var(--wh40k-space-md)]">
                        <h4 class="section-title tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-m-0 tw-mb-[var(--wh40k-space-sm)] tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--wh40k-gold)] tw-uppercase tw-tracking-[0.5px]">
                            <i class="fa-solid fa-list-check tw-text-[0.9rem]"></i>
                            {{localize "WH40K.OriginPath.ChoicesRequired"}}
                        </h4>
                        {{#each selectedOrigin.choices as |choice|}}
                            <div class="choice-item tw-rounded-[var(--wh40k-radius-sm)] tw-p-[var(--wh40k-space-sm)] tw-mb-[var(--wh40k-space-sm)]
                                {{#if choice.isComplete}}tw-border tw-border-[rgba(76,175,80,0.4)] tw-bg-[rgba(76,175,80,0.1)]{{else}}tw-border tw-border-[rgba(255,170,0,0.3)] tw-bg-[rgba(255,170,0,0.1)]{{/if}}">
                                <div class="choice-header tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-mb-[var(--wh40k-space-xs)]">
                                    {{#if choice.isComplete}}
                                        <i class="fa-solid fa-check-circle choice-complete-icon tw-text-[#4caf50]"></i>
                                    {{else}}
                                        <i class="fa-regular fa-circle choice-incomplete-icon tw-text-[color:var(--wh40k-text-muted)]"></i>
                                    {{/if}}
                                    <span class="choice-type-badge tw-text-[0.65rem] tw-py-[2px] tw-px-[6px] tw-bg-[rgba(255,170,0,0.2)] tw-border tw-border-[rgba(255,170,0,0.4)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[#ffaa00] tw-uppercase">{{choice.typeLabel}}</span>
                                    <span class="choice-label tw-flex-1 tw-font-semibold tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-light)]">{{choice.label}}</span>
                                    <span class="choice-count tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-muted)]">{{choice.count}}x</span>
                                </div>
                                {{#if choice.selection}}
                                    <div class="choice-selection tw-text-[0.8rem] tw-text-[#4caf50] tw-mb-[var(--wh40k-space-xs)]">
                                        <i class="fa-solid fa-check tw-mr-[var(--wh40k-space-xs)]"></i> {{choice.selection}}
                                    </div>
                                {{/if}}
                                <button type="button" class="choice-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(255,170,0,0.15)] tw-border tw-border-[rgba(255,170,0,0.4)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[#ffaa00] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[rgba(255,170,0,0.25)] hover:tw-border-[#ffaa00]" data-action="editChoice" data-choice-label="{{choice.label}}">
                                    <i class="fa-solid fa-pen"></i>
                                    {{#if choice.isComplete}}{{localize "WH40K.OriginPath.ChangeChoice"}}{{else}}{{localize "WH40K.OriginPath.MakeChoice"}}{{/if}}
                                </button>
                            </div>
                        {{/each}}
                    </div>
                {{/if}}

                {{!-- Roll Section --}}
                {{#if selectedOrigin.hasRolls}}
                    <div class="selection-section rolls-section tw-border-t tw-border-t-[var(--wh40k-bronze)] tw-pt-[var(--wh40k-space-md)]">
                        <h4 class="section-title tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-m-0 tw-mb-[var(--wh40k-space-sm)] tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--wh40k-gold)] tw-uppercase tw-tracking-[0.5px]">
                            <i class="fa-solid fa-dice tw-text-[0.9rem]"></i>
                            {{localize "WH40K.OriginPath.StartingStats"}}
                        </h4>
                        {{#if selectedOrigin.rolls.wounds}}
                            <div class="roll-item tw-flex tw-items-center tw-justify-between tw-gap-[var(--wh40k-space-sm)] tw-p-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-mb-[var(--wh40k-space-xs)] {{#if selectedOrigin.rolls.wounds.hasValue}}tw-border tw-border-[rgba(76,175,80,0.3)] tw-bg-[rgba(76,175,80,0.05)]{{else}}tw-border tw-border-transparent{{/if}}">
                                <div class="roll-info tw-flex-1">
                                    <div class="roll-label tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--wh40k-text-light)]">
                                        <i class="fa-solid fa-heart tw-mr-[var(--wh40k-space-xs)]"></i> {{localize "WH40K.Wounds"}}
                                    </div>
                                    {{#if selectedOrigin.rolls.wounds.hasValue}}
                                        <div class="roll-result tw-text-[0.9rem] tw-font-semibold tw-text-[color:var(--wh40k-gold)]">{{selectedOrigin.rolls.wounds.value}} <span class="roll-breakdown tw-text-[0.75rem] tw-font-normal tw-text-[color:var(--wh40k-text-muted)]">({{selectedOrigin.rolls.wounds.breakdown}})</span></div>
                                    {{else}}
                                        <div class="roll-formula tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-muted)] tw-font-mono">{{selectedOrigin.rolls.wounds.formula}}</div>
                                    {{/if}}
                                </div>
                                <div class="roll-actions tw-flex tw-gap-[var(--wh40k-space-xs)]">
                                    <button type="button" class="roll-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-gold)] tw-border-0 tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-scale-105 hover:tw-shadow-[0_2px_8px_rgba(var(--wh40k-gold-rgb),0.4)]" data-action="rollStat" data-stat-type="wounds" data-tooltip="{{localize 'WH40K.OriginPath.RollTooltip'}}">
                                        <i class="fa-solid fa-dice"></i>
                                        {{#if selectedOrigin.rolls.wounds.hasValue}}{{localize "WH40K.OriginPath.Reroll"}}{{else}}{{localize "WH40K.Roll.Roll"}}{{/if}}
                                    </button>
                                    <button type="button" class="manual-btn tw-flex tw-items-center tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-gold)] tw-border-0 tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-scale-105" data-action="manualStat" data-stat-type="wounds" data-tooltip="{{localize 'WH40K.OriginPath.ManualTooltip'}}">
                                        <i class="fa-solid fa-keyboard"></i>
                                    </button>
                                </div>
                            </div>
                        {{/if}}
                        {{#if selectedOrigin.rolls.fate}}
                            <div class="roll-item tw-flex tw-items-center tw-justify-between tw-gap-[var(--wh40k-space-sm)] tw-p-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-mb-[var(--wh40k-space-xs)] {{#if selectedOrigin.rolls.fate.hasValue}}tw-border tw-border-[rgba(76,175,80,0.3)] tw-bg-[rgba(76,175,80,0.05)]{{else}}tw-border tw-border-transparent{{/if}}">
                                <div class="roll-info tw-flex-1">
                                    <div class="roll-label tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--wh40k-text-light)]">
                                        <i class="fa-solid fa-star tw-mr-[var(--wh40k-space-xs)]"></i> {{localize "WH40K.Fate"}}
                                    </div>
                                    {{#if selectedOrigin.rolls.fate.hasValue}}
                                        <div class="roll-result tw-text-[0.9rem] tw-font-semibold tw-text-[color:var(--wh40k-gold)]">{{selectedOrigin.rolls.fate.value}} <span class="roll-breakdown tw-text-[0.75rem] tw-font-normal tw-text-[color:var(--wh40k-text-muted)]">({{selectedOrigin.rolls.fate.breakdown}})</span></div>
                                    {{else}}
                                        <div class="roll-formula tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-muted)] tw-font-mono">{{selectedOrigin.rolls.fate.formula}}</div>
                                    {{/if}}
                                </div>
                                <div class="roll-actions tw-flex tw-gap-[var(--wh40k-space-xs)]">
                                    <button type="button" class="roll-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-gold)] tw-border-0 tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-scale-105 hover:tw-shadow-[0_2px_8px_rgba(var(--wh40k-gold-rgb),0.4)]" data-action="rollStat" data-stat-type="fate" data-tooltip="{{localize 'WH40K.OriginPath.RollTooltip'}}">
                                        <i class="fa-solid fa-dice"></i>
                                        {{#if selectedOrigin.rolls.fate.hasValue}}{{localize "WH40K.OriginPath.Reroll"}}{{else}}{{localize "WH40K.Roll.Roll"}}{{/if}}
                                    </button>
                                    <button type="button" class="manual-btn tw-flex tw-items-center tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-gold)] tw-border-0 tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-scale-105" data-action="manualStat" data-stat-type="fate" data-tooltip="{{localize 'WH40K.OriginPath.ManualTooltip'}}">
                                        <i class="fa-solid fa-keyboard"></i>
                                    </button>
                                </div>
                            </div>
                        {{/if}}
                        {{#if selectedOrigin.rolls.thrones}}
                            <div class="roll-item tw-flex tw-items-center tw-justify-between tw-gap-[var(--wh40k-space-sm)] tw-p-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-mb-[var(--wh40k-space-xs)] {{#if selectedOrigin.rolls.thrones.hasValue}}tw-border tw-border-[rgba(76,175,80,0.3)] tw-bg-[rgba(76,175,80,0.05)]{{else}}tw-border tw-border-transparent{{/if}}">
                                <div class="roll-info tw-flex-1">
                                    <div class="roll-label tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--wh40k-text-light)]">
                                        <i class="fa-solid fa-coins tw-mr-[var(--wh40k-space-xs)]"></i> Throne Gelt
                                    </div>
                                    {{#if selectedOrigin.rolls.thrones.hasValue}}
                                        <div class="roll-result tw-text-[0.9rem] tw-font-semibold tw-text-[color:var(--wh40k-gold)]">{{selectedOrigin.rolls.thrones.value}} <span class="roll-breakdown tw-text-[0.75rem] tw-font-normal tw-text-[color:var(--wh40k-text-muted)]">({{selectedOrigin.rolls.thrones.breakdown}})</span></div>
                                    {{else}}
                                        <div class="roll-formula tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-muted)] tw-font-mono">{{selectedOrigin.rolls.thrones.formula}}</div>
                                    {{/if}}
                                </div>
                                <div class="roll-actions tw-flex tw-gap-[var(--wh40k-space-xs)]">
                                    <button type="button" class="roll-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-gold)] tw-border-0 tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-scale-105 hover:tw-shadow-[0_2px_8px_rgba(var(--wh40k-gold-rgb),0.4)]" data-action="rollStat" data-stat-type="thrones" data-tooltip="{{localize 'WH40K.OriginPath.RollTooltip'}}">
                                        <i class="fa-solid fa-dice"></i>
                                        {{#if selectedOrigin.rolls.thrones.hasValue}}{{localize "WH40K.OriginPath.Reroll"}}{{else}}{{localize "WH40K.Roll.Roll"}}{{/if}}
                                    </button>
                                    <button type="button" class="manual-btn tw-flex tw-items-center tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-gold)] tw-border-0 tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-scale-105" data-action="manualStat" data-stat-type="thrones" data-tooltip="{{localize 'WH40K.OriginPath.ManualTooltip'}}">
                                        <i class="fa-solid fa-keyboard"></i>
                                    </button>
                                </div>
                            </div>
                        {{/if}}
                    </div>
                {{/if}}

                {{#if selectedOrigin.resources.showInfluence}}
                    <div class="selection-section rolls-section tw-border-t tw-border-t-[var(--wh40k-bronze)] tw-pt-[var(--wh40k-space-md)]">
                        <h4 class="section-title tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-m-0 tw-mb-[var(--wh40k-space-sm)] tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--wh40k-gold)] tw-uppercase tw-tracking-[0.5px]">
                            <i class="fa-solid fa-user-tie tw-text-[0.9rem]"></i>
                            Starting Resources
                        </h4>
                        <div class="roll-item tw-flex tw-items-center tw-justify-between tw-gap-[var(--wh40k-space-sm)] tw-p-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-mb-[var(--wh40k-space-xs)] {{#if selectedOrigin.resources.influenceRolled}}tw-border tw-border-[rgba(76,175,80,0.3)] tw-bg-[rgba(76,175,80,0.05)]{{else}}tw-border tw-border-transparent{{/if}}">
                            <div class="roll-info tw-flex-1">
                                <div class="roll-label tw-text-[0.85rem] tw-font-semibold tw-text-[color:var(--wh40k-text-light)]">
                                    <i class="fa-solid fa-user-tie tw-mr-[var(--wh40k-space-xs)]"></i> Influence
                                </div>
                                {{#if selectedOrigin.resources.influenceRolled}}
                                    <div class="roll-result tw-text-[0.9rem] tw-font-semibold tw-text-[color:var(--wh40k-gold)]">{{selectedOrigin.resources.influenceRolled}}</div>
                                {{else}}
                                    <div class="roll-formula tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-muted)] tw-font-mono">1d5 + Fel Bonus + {{selectedOrigin.resources.influenceMod}}</div>
                                {{/if}}
                            </div>
                            <div class="roll-actions tw-flex tw-gap-[var(--wh40k-space-xs)]">
                                <button type="button" class="roll-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-gold)] tw-border-0 tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-scale-105" data-action="rollInfluence">
                                    <i class="fa-solid fa-dice"></i>
                                    {{#if selectedOrigin.resources.influenceRolled}}Reroll{{else}}Roll{{/if}}
                                </button>
                                <button type="button" class="manual-btn tw-flex tw-items-center tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[var(--wh40k-gold)] tw-border-0 tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-text-[0.8rem] tw-font-semibold tw-cursor-pointer hover:tw-scale-105" data-action="manualInfluence">
                                    <i class="fa-solid fa-keyboard"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                {{/if}}

                {{!-- Confirm Selection Button --}}
                {{#unless selectedOrigin.isConfirmed}}
                    <div class="selection-confirm tw-mt-auto tw-pt-[var(--wh40k-space-md)] tw-border-t-2 tw-border-t-[var(--wh40k-bronze)]">
                        <button type="button" class="confirm-selection-btn tw-w-full tw-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-sm)] tw-p-[var(--wh40k-space-md)] tw-bg-[linear-gradient(135deg,var(--wh40k-gold),var(--wh40k-gold-dark))] tw-border-2 tw-border-[var(--wh40k-gold)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[rgba(0,0,0,0.9)] tw-font-[var(--wh40k-font-header)] tw-text-[1rem] tw-font-bold tw-uppercase tw-tracking-[1px] tw-cursor-pointer tw-shadow-[0_4px_12px_rgba(var(--wh40k-gold-rgb),0.3)] hover:tw-bg-[linear-gradient(135deg,var(--wh40k-gold-light),var(--wh40k-gold))] hover:tw--translate-y-[2px] hover:tw-shadow-[0_6px_20px_rgba(var(--wh40k-gold-rgb),0.5)]" data-action="confirmSelection" data-tooltip="{{localize 'WH40K.OriginPath.ConfirmSelectionHint'}}">
                            <i class="fa-solid fa-check tw-text-[1.1rem]"></i>
                            <span>{{localize "WH40K.OriginPath.ConfirmSelection"}}</span>
                        </button>
                    </div>
                {{/unless}}
            {{else}}
                {{!-- Empty State --}}
                <div class="selection-empty tw-flex tw-flex-col tw-items-center tw-justify-center tw-h-full tw-text-[color:var(--wh40k-text-muted)] tw-text-center tw-p-[var(--wh40k-space-xl)]">
                    <i class="fa-solid fa-hand-pointer tw-text-[3rem] tw-mb-[var(--wh40k-space-md)] tw-opacity-50"></i>
                    <p class="tw-m-0 tw-text-[0.9rem]">{{localize "WH40K.OriginPath.SelectOriginPrompt"}}</p>
                </div>
            {{/if}}
        </aside>
        {{/if}}
    </main>

    {{!-- Preview Panel --}}
    <section class="preview-panel tw-bg-[var(--wh40k-panel-bg-solid)] tw-border-t-2 tw-border-t-[var(--wh40k-gold)] tw-p-[var(--wh40k-space-md)]">
        <div class="preview-header tw-flex tw-justify-between tw-items-center tw-mb-[var(--wh40k-space-md)]">
            <h3 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1rem] tw-text-[color:var(--wh40k-gold)] tw-uppercase tw-tracking-[1px]">
                <i class="fa-solid fa-eye tw-mr-[var(--wh40k-space-xs)]"></i>
                {{localize "WH40K.OriginPath.TotalBonuses"}}
            </h3>
        </div>
        <div class="preview-grid tw-grid tw-grid-cols-[repeat(auto-fit,minmax(200px,1fr))] tw-gap-[var(--wh40k-space-md)]">
            {{#if preview.characteristics.length}}
                <div class="preview-category">
                    <div class="category-title tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-[var(--wh40k-space-xs)]">{{localize "WH40K.Characteristics"}}</div>
                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[120px] tw-overflow-y-auto tw-overflow-x-hidden">
                        {{#each preview.characteristics as |char|}}
                            <span class="preview-item tw-py-[2px] tw-px-[6px] tw-bg-[rgba(0,0,0,0.3)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)]
                                {{#if (gt char.value 0)}}tw-border tw-border-[#4caf50] tw-text-[#4caf50]{{else}}negative tw-border tw-border-[color:var(--wh40k-accent-red)] tw-text-[color:var(--wh40k-accent-red)]{{/if}}
                                {{#if char.fromChoice}}from-choice tw-border-dashed{{/if}}">
                                {{char.short}}: {{#if (gt char.value 0)}}+{{/if}}{{char.value}}{{#if char.fromChoice}}*{{/if}}
                            </span>
                        {{/each}}
                    </div>
                </div>
            {{/if}}
            {{#if preview.skills.length}}
                <div class="preview-category">
                    <div class="category-title tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-[var(--wh40k-space-xs)]">{{localize "WH40K.Skills.Header"}}</div>
                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[120px] tw-overflow-y-auto tw-overflow-x-hidden">
                        {{#each preview.skills as |skill|}}
                            <div class="grant-tag skill-tag tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3] tw-max-w-full tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap {{#if skill.uuid}}clickable tw-cursor-pointer hover:tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] hover:tw-border-[var(--wh40k-gold)] hover:tw--translate-y-[1px]{{/if}} {{#if skill.fromChoice}}from-choice tw-border-dashed{{/if}}"
                                  {{#if skill.uuid}}data-action="openItem" data-uuid="{{skill.uuid}}"{{/if}}
                                  data-wh40k-tooltip="generic"
                                  data-wh40k-tooltip-data="{{skill.tooltipData}}"
                                  data-tooltip="{{skill.name}}">
                                <i class="fa-solid fa-book-open tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[color:var(--wh40k-accent-info)]"></i>
                                <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{skill.name}}</span>
                                {{#if skill.uuid}}<i class="fa-solid fa-external-link tag-link tw-text-[0.65rem] tw-opacity-60 tw-text-[color:var(--wh40k-gold)]"></i>{{/if}}
                            </div>
                        {{/each}}
                    </div>
                </div>
            {{/if}}
            {{#if preview.talents.length}}
                <div class="preview-category">
                    <div class="category-title tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-[var(--wh40k-space-xs)]">{{localize "WH40K.Talents"}}</div>
                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[120px] tw-overflow-y-auto tw-overflow-x-hidden">
                        {{#each preview.talents as |talent|}}
                            <div class="grant-tag talent-tag tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3] tw-max-w-full tw-overflow-hidden tw-text-ellipsis tw-whitespace-nowrap {{#if talent.uuid}}clickable tw-cursor-pointer hover:tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] hover:tw-border-[var(--wh40k-gold)] hover:tw--translate-y-[1px]{{/if}} {{#if talent.fromChoice}}from-choice tw-border-dashed{{/if}}"
                                  {{#if talent.uuid}}data-action="openItem" data-uuid="{{talent.uuid}}"{{/if}}
                                  data-wh40k-tooltip="generic"
                                  data-wh40k-tooltip-data="{{talent.tooltipData}}"
                                  data-tooltip="{{talent.name}}">
                                <i class="fa-solid fa-star tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[#f39c12]"></i>
                                <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{talent.name}}</span>
                                {{#if talent.uuid}}<i class="fa-solid fa-external-link tag-link tw-text-[0.65rem] tw-opacity-60 tw-text-[color:var(--wh40k-gold)]"></i>{{/if}}
                            </div>
                        {{/each}}
                    </div>
                </div>
            {{/if}}
            {{#if preview.aptitudes.length}}
                <div class="preview-category">
                    <div class="category-title tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-[var(--wh40k-space-xs)]">Aptitudes</div>
                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-max-h-[120px] tw-overflow-y-auto tw-overflow-x-hidden">
                        {{#each preview.aptitudes as |apt|}}
                            <span class="grant-tag aptitude-tag tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3]">
                                <i class="fa-solid fa-bullseye tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[color:var(--wh40k-gold)]"></i>
                                <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{apt}}</span>
                            </span>
                        {{/each}}
                    </div>
                </div>
            {{/if}}
            {{#if preview.wounds}}
                <div class="preview-category">
                    <div class="category-title tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-[var(--wh40k-space-xs)]">{{localize "WH40K.Wounds"}}</div>
                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)]">
                        <div class="grant-tag positive tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3]">
                            <i class="fa-solid fa-heart tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[color:var(--wh40k-gold)]"></i>
                            <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{preview.wounds}}</span>
                        </div>
                    </div>
                </div>
            {{/if}}
            {{#if preview.fate}}
                <div class="preview-category">
                    <div class="category-title tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-[var(--wh40k-space-xs)]">{{localize "WH40K.Fate"}}</div>
                    <div class="category-items tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)]">
                        <div class="grant-tag positive tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3]">
                            <i class="fa-solid fa-star tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[color:var(--wh40k-gold)]"></i>
                            <span class="tag-label tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{preview.fate}}</span>
                        </div>
                    </div>
                </div>
            {{/if}}
        </div>
    </section>

    {{!-- Footer --}}
    <footer class="builder-footer tw-flex tw-justify-between tw-items-center tw-p-[var(--wh40k-space-md)] tw-bg-[linear-gradient(180deg,rgba(0,0,0,0.8),var(--wh40k-bronze-dark))] tw-border-t-2 tw-border-t-[var(--wh40k-gold)]">
        <div class="footer-status tw-flex tw-gap-[var(--wh40k-space-md)]">
            <span class="status-item tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.85rem] {{#if status.stepsComplete}}complete{{else}}pending{{/if}}">
                <i class="fa-solid {{#if status.stepsComplete}}fa-check-circle tw-text-[#4caf50]{{else}}fa-circle-half-stroke tw-text-[#ffaa00]{{/if}} tw-text-[1rem]"></i>
                {{status.stepsCount}}/{{status.totalSteps}} {{localize "WH40K.OriginPath.Steps"}}
            </span>
            <span class="status-item tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.85rem] {{#if status.choicesComplete}}complete{{else}}pending{{/if}}">
                <i class="fa-solid {{#if status.choicesComplete}}fa-check-circle tw-text-[#4caf50]{{else}}fa-exclamation-triangle tw-text-[#ffaa00]{{/if}} tw-text-[1rem]"></i>
                {{#if status.choicesComplete}}
                    {{localize "WH40K.OriginPath.AllChoicesComplete"}}
                {{else}}
                    {{status.pendingChoices}} {{localize "WH40K.OriginPath.ChoicesPending"}}
                {{/if}}
            </span>
            {{#if status.pendingRolls}}
                <span class="status-item warning tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.85rem]">
                    <i class="fa-solid fa-dice tw-text-[#ff9800] tw-text-[1rem]"></i>
                    {{status.pendingRolls}} {{localize "WH40K.OriginPath.RollsPending"}}
                </span>
            {{/if}}
        </div>
        <div class="footer-actions tw-flex tw-gap-[var(--wh40k-space-sm)] tw-items-center">
            <button type="button" class="commit-btn tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-lg)] tw-bg-[linear-gradient(135deg,var(--wh40k-gold),#b8860b)] tw-border-2 tw-border-[var(--wh40k-gold)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-font-[var(--wh40k-font-header)] tw-text-[1rem] tw-font-semibold tw-uppercase tw-tracking-[1px] tw-cursor-pointer hover:tw--translate-y-[2px] hover:tw-shadow-[0_4px_15px_rgba(var(--wh40k-gold-rgb),0.5)] disabled:tw-opacity-50 disabled:tw-cursor-not-allowed disabled:tw-grayscale-[0.5]" data-action="commit" {{#unless status.canCommit}}disabled{{/unless}}>
                <i class="fa-solid fa-save"></i>
                {{localize "WH40K.OriginPath.CommitToCharacter"}}
            </button>
        </div>
    </footer>

</div>
