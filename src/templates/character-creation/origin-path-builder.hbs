{{!-- Origin Path Builder Template - Refactored Design --}}
<div class="tw-grid tw-grid-rows-[auto_auto_1fr_auto_auto] tw-h-full tw-gap-0">

 {{!-- Unified Header: Toolbar + Mode + Direction --}}
 <header class="tw-flex tw-justify-between tw-items-stretch tw-py-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-md)] tw-bg-[linear-gradient(180deg,var(--wh40k-bronze-dark),rgba(0,0,0,0.8))] tw-border-b-2 tw-border-b-[var(--wh40k-gold)]">
 <div class="tw-flex tw-gap-[var(--wh40k-space-sm)] tw-items-center">
 <button type="button" class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="randomize" data-tooltip="{{localize 'WH40K.OriginPath.RandomizeHint'}}">
 <i class="fa-solid fa-dice"></i>
 <span>{{localize "WH40K.OriginPath.Randomize"}}</span>
 </button>
 <button type="button" class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="reset" data-tooltip="{{localize 'WH40K.OriginPath.ResetHint'}}">
 <i class="fa-solid fa-rotate-left"></i>
 <span>{{localize "WH40K.OriginPath.Reset"}}</span>
 </button>
 </div>

 <div class="tw-flex-1 tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-xs)]">
 <h1 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.1rem] tw-text-[color:var(--wh40k-gold)] tw-uppercase tw-tracking-[2px]">{{journeyTitle}}</h1>

 {{!-- Mode and Direction Controls (inline with title) --}}
 <div class="tw-flex tw-gap-[var(--wh40k-space-md)] tw-items-center">
 {{!-- Guided/Free Mode Toggle --}}
 <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-p-[var(--wh40k-space-xs)] tw-bg-[rgba(0,0,0,0.3)] tw-rounded-[var(--wh40k-radius-sm)] tw-border tw-border-[var(--wh40k-bronze)]">
 <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-rounded-[var(--wh40k-radius-sm)] tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-[color:var(--wh40k-text-light)] {{#if guidedMode}}tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] tw-text-[color:var(--wh40k-gold)]{{/if}}" data-tooltip="{{localize 'WH40K.OriginPath.GuidedHint'}}">
 <input type="radio" name="mode" value="guided" {{#if guidedMode}}checked{{/if}} data-action="setMode">
 <i class="fa-solid fa-route"></i>
 <span>{{localize "WH40K.OriginPath.Guided"}}</span>
 </label>
 <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-rounded-[var(--wh40k-radius-sm)] tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-[color:var(--wh40k-text-light)] {{#unless guidedMode}}tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] tw-text-[color:var(--wh40k-gold)]{{/unless}}" data-tooltip="{{localize 'WH40K.OriginPath.FreeHint'}}">
 <input type="radio" name="mode" value="free" {{#unless guidedMode}}checked{{/unless}} data-action="setMode">
 <i class="fa-solid fa-unlock"></i>
 <span>{{localize "WH40K.OriginPath.Free"}}</span>
 </label>
 </div>

 {{!-- Direction Toggle (RT only — DH2e steps are independent) --}}
 {{#if hasDirectionToggle}}
 <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-p-[var(--wh40k-space-xs)] tw-bg-[rgba(0,0,0,0.3)] tw-rounded-[var(--wh40k-radius-sm)] tw-border tw-border-[var(--wh40k-bronze)]">
 <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-rounded-[var(--wh40k-radius-sm)] tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-[color:var(--wh40k-text-light)] {{#if isBackward}}tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] tw-text-[color:var(--wh40k-gold)]{{/if}}" data-tooltip="{{localize 'WH40K.OriginPath.DirectionBackwardHint'}}">
 <input type="radio" name="direction" value="backward" {{#if isBackward}}checked{{/if}} data-action="setDirection">
 <i class="fa-solid fa-arrow-left"></i>
 <span>{{localize "WH40K.OriginPath.DirectionBackward"}}</span>
 </label>
 <label class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-rounded-[var(--wh40k-radius-sm)] tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)] hover:tw-text-[color:var(--wh40k-text-light)] {{#if isForward}}tw-bg-[rgba(var(--wh40k-gold-rgb),0.15)] tw-text-[color:var(--wh40k-gold)]{{/if}}" data-tooltip="{{localize 'WH40K.OriginPath.DirectionForwardHint'}}">
 <input type="radio" name="direction" value="forward" {{#if isForward}}checked{{/if}} data-action="setDirection">
 <i class="fa-solid fa-arrow-right"></i>
 <span>{{localize "WH40K.OriginPath.DirectionForward"}}</span>
 </label>
 </div>
 {{/if}}
 </div>
 </div>

 <div class="tw-flex tw-gap-[var(--wh40k-space-sm)] tw-items-center">
 <button type="button" class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="export" data-tooltip="{{localize 'WH40K.OriginPath.ExportHint'}}">
 <i class="fa-solid fa-download"></i>
 </button>
 <button type="button" class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="import" data-tooltip="{{localize 'WH40K.OriginPath.ImportHint'}}">
 <i class="fa-solid fa-upload"></i>
 </button>
 </div>
 </header>

 {{!-- Step Navigation with Visual Progress --}}
 <nav class="tw-flex tw-justify-center tw-items-center tw-gap-0 tw-py-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-md)] tw-bg-[rgba(0,0,0,0.4)] tw-border-b tw-border-b-[var(--wh40k-bronze)] tw-overflow-x-auto">
 {{#each steps as |step|}}
 <div class="tw-group tw-flex tw-flex-col tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-min-w-[80px] tw-cursor-pointer tw-relative {{#if step.isActive}}tw-scale-105{{/if}} {{#if step.isDisabled}}tw-opacity-40 tw-cursor-not-allowed{{/if}}"
 data-action="goToStep"
 data-step-index="{{step.index}}"
 data-step-key="{{step.key}}"
 data-tooltip="{{step.label}}{{#if step.selection}}: {{step.selection.name}}{{/if}}">
 <div class="tw-w-10 tw-h-10 tw-flex tw-items-center tw-justify-center tw-rounded-full tw-border-2 tw-relative tw-overflow-hidden tw-text-[0.85rem] tw-font-semibold tw-transition-all {{#if step.isActive}}tw-bg-[linear-gradient(135deg,var(--wh40k-gold),rgb(184,147,35))] tw-border-[var(--wh40k-gold)] tw-shadow-[0_0_12px_rgba(201,162,39,0.6)] tw-animate-pulse-glow{{else if step.isComplete}}tw-border-[rgb(166,132,32)] tw-shadow-[0_2px_8px_rgba(201,162,39,0.3)] tw-text-[var(--wh40k-panel-bg-solid)]{{else if step.isLineage}}tw-bg-[linear-gradient(135deg,#9b4dca,#6b2d9b)] tw-border-[#ce93d8]{{else}}tw-border-[var(--wh40k-bronze)] tw-bg-[rgba(0,0,0,0.5)] tw-text-[color:var(--wh40k-text-muted)]{{/if}} group-hover:tw-border-[var(--wh40k-gold)] group-hover:tw-scale-105">
 {{#if step.isComplete}}
 {{!-- Complete state: show image if available, else checkmark icon --}}
 {{#if step.selection}}
 <img src="{{step.selection.img}}" alt="{{step.selection.name}}" class="tw-w-full tw-h-full tw-object-cover tw-rounded-full" />
 {{else}}
 <i class="fa-solid fa-check tw-text-[0.9rem] tw-text-[color:var(--wh40k-bg-dark)] tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-bg-[linear-gradient(135deg,var(--wh40k-gold),rgb(184,147,35))] tw-rounded-full"></i>
 {{/if}}
 {{else if step.selection}}
 <img src="{{step.selection.img}}" alt="{{step.selection.name}}" class="tw-w-full tw-h-full tw-object-cover tw-rounded-full" />
 {{else if (eq step.key"characteristics")}}
 <i class="fa-solid {{step.icon}}"></i>
 {{else}}
 {{add step.index 1}}
 {{/if}}
 </div>
 <span class="tw-text-[0.65rem] tw-uppercase tw-tracking-[0.5px] tw-text-center tw-transition-all {{#if step.isActive}}tw-text-[color:var(--wh40k-gold)] tw-font-semibold{{else if step.isComplete}}tw-text-[color:var(--wh40k-gold)]{{else if step.isLineage}}tw-text-[#ce93d8]{{else}}tw-text-[color:var(--wh40k-text-muted)]{{/if}} group-hover:tw-text-[color:var(--wh40k-text-light)]">{{step.shortLabel}}</span>
 </div>
 {{#unless @last}}
 <div class="tw-flex-[0_0_24px] tw-h-[3px] tw-rounded-[var(--wh40k-radius-sm)] tw-transition-all {{#if step.isComplete}}tw-bg-[linear-gradient(90deg,rgba(201,162,39,0.6),rgba(201,162,39,0.3))]{{else}}tw-bg-[linear-gradient(90deg,rgba(255,255,255,0.1),rgba(255,255,255,0.05))]{{/if}}"></div>
 {{/unless}}
 {{/each}}
 </nav>

 {{!-- Main Content --}}
 <main class="tw-grid tw-gap-[var(--wh40k-space-md)] tw-p-[var(--wh40k-space-md)] tw-overflow-hidden tw-min-h-0 {{#if showSelectionPanel}}tw-grid-cols-[1fr_350px]{{else}}tw-grid-cols-[1fr]{{/if}}">
 {{!-- Step Content (Left) --}}
 <section class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-md)] tw-overflow-y-auto tw-pr-[var(--wh40k-space-sm)]">
 <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)]">
 <div class="tw-w-12 tw-h-12 tw-flex tw-items-center tw-justify-center tw-bg-[linear-gradient(135deg,var(--wh40k-bronze-dark),var(--wh40k-bronze))] tw-border-2 tw-border-[var(--wh40k-gold)] tw-rounded-[var(--wh40k-radius-md)]">
 <i class="fa-solid {{currentStep.icon}} tw-text-[1.5rem] tw-text-[color:var(--wh40k-gold)]"></i>
 </div>
 <div class="tw-flex-1">
 {{#if showEquipment}}
 <h2 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.3rem] tw-text-[color:var(--wh40k-gold)]"><i class="fa-solid fa-box"></i> {{localize "WH40K.OriginPath.EquipmentTitle"}}</h2>
 <p class="tw-mt-[var(--wh40k-space-xs)] tw-mb-0 tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.OriginPath.EquipmentDesc"}}</p>
 {{else if currentStep.isCharacteristics}}
 <h2 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.3rem] tw-text-[color:var(--wh40k-gold)]"><i class="fa-solid fa-dice-d20"></i> {{localize "WH40K.CharacteristicSetup.Title"}}</h2>
 <p class="tw-mt-[var(--wh40k-space-xs)] tw-mb-0 tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.CharacteristicSetup.Instructions"}}</p>
 {{else if currentStep.isLineage}}
 <h2 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.3rem] tw-text-[color:var(--wh40k-gold)]">{{optionalStepLabel}} <span class="tw-text-[0.65rem] tw-font-normal tw-py-[2px] tw-px-[6px] tw-bg-[rgba(156,39,176,0.2)] tw-border tw-border-[rgba(156,39,176,0.4)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[#ce93d8] tw-uppercase tw-tracking-[0.5px] tw-align-middle tw-ml-[var(--wh40k-space-sm)]">{{localize "WH40K.OriginPath.Optional"}}</span></h2>
 <p class="tw-mt-[var(--wh40k-space-xs)] tw-mb-0 tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)]">{{optionalStepDesc}}</p>
 {{else}}
 <h2 class="tw-m-0 tw-font-[var(--wh40k-font-header)] tw-text-[1.3rem] tw-text-[color:var(--wh40k-gold)]">{{localize "WH40K.OriginPath.Step"}} {{add currentStep.index 1}}: {{currentStep.label}}</h2>
 <p class="tw-mt-[var(--wh40k-space-xs)] tw-mb-0 tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-muted)]">{{currentStep.description}}</p>
 {{/if}}
 </div>
 </div>

 {{#if showEquipment}}
 {{!-- Equip Acolyte — DH2e Stage 4 --}}
 <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3">
 <div class="tw-flex tw-flex-col tw-gap-1 tw-p-2 tw-border tw-border-white/10 tw-rounded">
 {{#if equipment.hasInfluence}}
 <div class="tw-flex tw-items-center tw-gap-1.5 tw-font-semibold {{#if equipment.atLimit}}tw-text-amber-400{{/if}}">
 <i class="fa-solid fa-hashtag"></i>
 <span>{{equipment.selectedCount}} / {{equipment.maxSelections}} {{localize "WH40K.OriginPath.EquipmentSelectedLabel"}}</span>
 </div>
 {{else}}
 <div class="tw-flex tw-items-center tw-gap-1.5 tw-font-semibold tw-text-amber-400">
 <i class="fa-solid fa-triangle-exclamation"></i>
 <span>{{localize "WH40K.OriginPath.EquipmentNoInfluence"}}</span>
 </div>
 {{/if}}
 {{#if equipment.selectedItems.length}}
 <ul class="tw-list-disc tw-pl-5 tw-m-0 tw-mt-1 tw-text-sm tw-leading-snug">
 {{#each equipment.selectedItems as |item|}}
 <li>{{item.name}}</li>
 {{/each}}
 </ul>
 {{/if}}
 <div class="tw-text-sm tw-italic tw-opacity-75">{{localize "WH40K.OriginPath.EquipmentRuleHint"}}</div>
 </div>

 <div class="tw-flex tw-items-center tw-gap-2">
 <input type="search" class="tw-flex-1 tw-px-2 tw-py-1 tw-text-sm"
 placeholder="{{localize 'WH40K.OriginPath.EquipmentSearchPlaceholder'}}" value="{{equipment.search}}" />
 <select class="tw-basis-44 tw-px-2 tw-py-1 tw-text-sm">
 {{#each equipment.typeOptions as |option|}}
 <option value="{{option.value}}" {{#if (eq option.value ../equipment.typeFilter)}}selected{{/if}}>{{option.label}}</option>
 {{/each}}
 </select>
 <button type="button" class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[var(--wh40k-space-xs)] tw-px-[var(--wh40k-space-sm)] tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[color:var(--wh40k-text-light)] tw-text-[0.8rem] tw-cursor-pointer hover:tw-bg-[var(--wh40k-bronze)] hover:tw-border-[var(--wh40k-gold)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="clearEquipment" data-tooltip="{{localize 'WH40K.OriginPath.EquipmentClearAll'}}">
 <i class="fa-solid fa-rotate-left"></i>
 <span>{{localize "WH40K.OriginPath.EquipmentClearAll"}}</span>
 </button>
 </div>

 <table class="tw-w-full tw-border-collapse tw-text-sm">
 <thead>
 <tr class="tw-text-xs tw-uppercase tw-opacity-75 tw-border-b tw-border-white/15">
 <th class="tw-w-8 tw-text-center tw-px-2 tw-py-1"></th>
 <th class="tw-w-6 tw-px-2 tw-py-1"></th>
 <th class="tw-text-left tw-px-2 tw-py-1">{{localize "WH40K.OriginPath.EquipmentColName"}}</th>
 <th class="tw-text-left tw-px-2 tw-py-1 tw-w-32">{{localize "WH40K.OriginPath.EquipmentColType"}}</th>
 <th class="tw-text-left tw-px-2 tw-py-1 tw-w-28">{{localize "WH40K.OriginPath.EquipmentColAvailability"}}</th>
 {{#if equipment.isHomebrew}}
 <th class="tw-text-right tw-px-2 tw-py-1 tw-w-16">{{localize "WH40K.OriginPath.EquipmentColRequisition"}}</th>
 <th class="tw-text-right tw-px-2 tw-py-1 tw-w-24">{{localize "WH40K.OriginPath.EquipmentColThroneGelt"}}</th>
 {{/if}}
 </tr>
 </thead>
 <tbody>
 {{#each equipment.items as |item|}}
 <tr class="tw-border-b tw-border-white/5 tw-cursor-pointer hover:tw-bg-white/5 {{#if item.isSelected}}tw-bg-amber-400/10{{/if}} {{#if item.isDisabled}}tw-opacity-40 tw-cursor-not-allowed{{/if}}"
 data-action="toggleEquipmentItem"
 data-uuid="{{item.uuid}}">
 <td class="tw-w-8 tw-text-center tw-px-2 tw-py-1">
 <input type="checkbox"
 
 {{#if item.isSelected}}checked{{/if}}
 {{#if item.isDisabled}}disabled{{/if}} />
 </td>
 <td class="tw-w-6 tw-px-2 tw-py-1">
 <img src="{{item.img}}" alt="{{item.name}}" width="16" height="16" class="tw-w-4 tw-h-4 tw-max-w-[16px] tw-max-h-[16px] tw-object-contain tw-block" />
 </td>
 <td class="tw-px-2 tw-py-1 tw-font-medium">{{item.name}}</td>
 <td class="tw-px-2 tw-py-1 tw-capitalize tw-opacity-85">{{item.type}}</td>
 <td class="tw-px-2 tw-py-1 tw-opacity-85">{{item.availabilityLabel}}</td>
 {{#if ../equipment.isHomebrew}}
 <td class="tw-px-2 tw-py-1 tw-text-right tw-tabular-nums tw-opacity-90">{{#if item.requisition}}{{item.requisition}}{{else}}—{{/if}}</td>
 <td class="tw-px-2 tw-py-1 tw-text-right tw-tabular-nums tw-opacity-90">{{#if item.throneGelt}}{{item.throneGelt}}₮{{else}}—{{/if}}</td>
 {{/if}}
 </tr>
 {{else}}
 <tr><td colspan="{{#if equipment.isHomebrew}}7{{else}}5{{/if}}" class="tw-text-center tw-py-3 tw-italic tw-opacity-70">{{localize "WH40K.OriginPath.EquipmentNoneAvailable"}}</td></tr>
 {{/each}}
 </tbody>
 </table>
 </div>
 {{else if showCharacteristics}}
 {{!-- Characteristic Setup (embedded) --}}
 <div >
 <div role="tablist" aria-label="{{localize 'WH40K.CharacteristicSetup.ModeAriaLabel'}}" class="tw-flex tw-gap-1 tw-mb-3 tw-p-1 tw-bg-black/20 tw-rounded-md tw-border tw-border-white/10">
 <button type="button" role="tab" aria-selected="{{#if charGen.isModePointBuy}}true{{else}}false{{/if}}"
 class="tw-flex-1 tw-px-3 tw-py-1.5 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-rounded tw-border-0 tw-cursor-pointer tw-transition-colors {{#if charGen.isModePointBuy}}tw-bg-gold/20 tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure{{else}}tw-bg-transparent tw-text-white/70 hover:tw-bg-white/5{{/if}}"
 data-action="setCharGenMode" data-mode="point-buy">
 {{localize "WH40K.CharacteristicSetup.Mode.PointBuy"}}
 </button>
 <button type="button" role="tab" aria-selected="{{#if charGen.isModeRoll}}true{{else}}false{{/if}}"
 class="tw-flex-1 tw-px-3 tw-py-1.5 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-rounded tw-border-0 tw-cursor-pointer tw-transition-colors {{#if charGen.isModeRoll}}tw-bg-gold/20 tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure{{else}}tw-bg-transparent tw-text-white/70 hover:tw-bg-white/5{{/if}}"
 data-action="setCharGenMode" data-mode="roll">
 {{localize "WH40K.CharacteristicSetup.Mode.Roll"}}
 </button>
 <button type="button" role="tab" aria-selected="{{#if charGen.isModeRollPoolHB}}true{{else}}false{{/if}}"
 class="tw-flex-1 tw-px-3 tw-py-1.5 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-rounded tw-border-0 tw-cursor-pointer tw-transition-colors {{#if charGen.isModeRollPoolHB}}tw-bg-gold/20 tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure{{else}}tw-bg-transparent tw-text-white/70 hover:tw-bg-white/5{{/if}}"
 data-action="setCharGenMode" data-mode="roll-pool-hb">
 {{localize "WH40K.CharacteristicSetup.Mode.RollPoolHB"}}
 </button>
 </div>

 {{#if charGen.isModePointBuy}}
 <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-2 tw-py-12 tw-px-6 tw-text-center tw-text-white/70 tw-border tw-border-dashed tw-border-white/20 tw-rounded-md">
 <i class="fa-solid fa-screwdriver-wrench tw-text-4xl tw-text-white/40"></i>
 <h3 class="tw-text-lg tw-font-semibold tw-text-white/85 tw-m-0">{{localize "WH40K.CharacteristicSetup.Mode.PointBuy"}}</h3>
 <p class="tw-m-0">{{localize "WH40K.CharacteristicSetup.Mode.NotImplemented"}}</p>
 </div>
 {{else if charGen.isModeRoll}}
