 {{#if preview.fate}}
 <div >
 <div class="tw-text-[0.75rem] tw-font-semibold tw-text-[color:var(--wh40k-text-muted)] tw-uppercase tw-tracking-[0.5px] tw-mb-[var(--wh40k-space-xs)]">{{localize "WH40K.Fate"}}</div>
 <div class="tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)]">
 <div class="tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-py-[4px] tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-sm)] tw-text-[0.75rem] tw-text-[color:var(--wh40k-text-light)] tw-border tw-border-transparent tw-leading-[1.3]">
 <i class="fa-solid fa-star tw-text-[0.7rem] tw-flex-shrink-0 tw-text-[color:var(--wh40k-gold)]"></i>
 <span class="tw-flex-1 tw-min-w-0 tw-overflow-hidden tw-text-ellipsis">{{preview.fate}}</span>
 </div>
 </div>
 </div>
 {{/if}}
 </div>
 </section>

 {{!-- Footer --}}
 <footer class="tw-flex tw-justify-between tw-items-center tw-p-[var(--wh40k-space-md)] tw-bg-[linear-gradient(180deg,rgba(0,0,0,0.8),var(--wh40k-bronze-dark))] tw-border-t-2 tw-border-t-[var(--wh40k-gold)]">
 <div class="tw-flex tw-gap-[var(--wh40k-space-md)]">
 <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.85rem]">
 <i class="fa-solid {{#if status.stepsComplete}}fa-check-circle tw-text-[#4caf50]{{else}}fa-circle-half-stroke tw-text-[#ffaa00]{{/if}} tw-text-[1rem]"></i>
 {{status.stepsCount}}/{{status.totalSteps}} {{localize "WH40K.OriginPath.Steps"}}
 </span>
 <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.85rem]">
 <i class="fa-solid {{#if status.choicesComplete}}fa-check-circle tw-text-[#4caf50]{{else}}fa-exclamation-triangle tw-text-[#ffaa00]{{/if}} tw-text-[1rem]"></i>
 {{#if status.choicesComplete}}
 {{localize "WH40K.OriginPath.AllChoicesComplete"}}
 {{else}}
 {{status.pendingChoices}} {{localize "WH40K.OriginPath.ChoicesPending"}}
 {{/if}}
 </span>
 {{#if status.pendingRolls}}
 <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[0.85rem]">
 <i class="fa-solid fa-dice tw-text-[#ff9800] tw-text-[1rem]"></i>
 {{status.pendingRolls}} {{localize "WH40K.OriginPath.RollsPending"}}
 </span>
 {{/if}}
 </div>
 <div class="tw-flex tw-gap-[var(--wh40k-space-sm)] tw-items-center">
 <button type="button" class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-[var(--wh40k-space-sm)] tw-px-[var(--wh40k-space-lg)] tw-bg-[linear-gradient(135deg,var(--wh40k-gold),#b8860b)] tw-border-2 tw-border-[var(--wh40k-gold)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--wh40k-panel-bg-solid)] tw-font-[var(--wh40k-font-header)] tw-text-[1rem] tw-font-semibold tw-uppercase tw-tracking-[1px] tw-cursor-pointer hover:tw--translate-y-[2px] hover:tw-shadow-[0_4px_15px_rgba(var(--wh40k-gold-rgb),0.5)] disabled:tw-opacity-50 disabled:tw-cursor-not-allowed disabled:tw-grayscale-[0.5]" data-action="commit" {{#unless status.canCommit}}disabled{{/unless}}>
 <i class="fa-solid fa-save"></i>
 {{localize "WH40K.OriginPath.CommitToCharacter"}}
 </button>
 </div>
 </footer>

</div>
