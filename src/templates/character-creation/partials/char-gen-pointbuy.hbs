{{!--
  Point-buy characteristic generation. Reads charGen.* from the root context:
    pointBuyPool / pointBuySpent / pointBuyRemaining / pointBuyOverspent
    pointBuyRows  - array of arrays of point-buy characteristic views, each:
      key short label base points originBonus total canIncrease canDecrease
  A flat 1 point per +1 above base is spent; the pool size comes from settings.
--}}
<div class="csd-pointbuy tw-flex tw-flex-col tw-gap-4">
 <section class="csd-section tw-bg-[rgba(255,255,255,0.03)] tw-rounded-[var(--wh40k-radius-lg)] tw-border tw-border-[rgba(36,107,131,0.3)] tw-p-4">
 <div class="csd-section-header-row tw-flex tw-items-center tw-justify-between tw-gap-3 tw-mb-3 tw-pb-2 tw-border-b tw-border-[rgba(36,107,131,0.3)]">
 <h3 class="csd-section-header tw-flex tw-items-center tw-gap-2 tw-m-0 tw-text-[1rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-gold">
 <i class="fa-solid fa-coins"></i>
 {{localize "WH40K.CharGen.PointBuyPoints"}}
 </h3>
 <div class="tw-flex tw-items-center tw-gap-3">
 <span class="csd-pointbuy-remaining tw-text-[1.1rem] tw-font-bold {{#if charGen.pointBuyOverspent}}tw-text-failure{{else}}{{themeClassFor 'accent'}}{{/if}}" aria-live="polite">
 {{localize "WH40K.CharGen.PointsRemaining"}}: {{charGen.pointBuyRemaining}} / {{charGen.pointBuyPool}}
 </span>
 <button type="button" class="csd-icon-btn tw-inline-flex tw-h-9 tw-w-9 tw-items-center tw-justify-center tw-rounded-[6px] tw-border tw-border-[rgba(36,107,131,0.45)] tw-bg-[rgba(36,107,131,0.2)] tw-text-[color:var(--csd-bone,#e8dcc4)] tw-transition-all hover:tw-border-[rgba(176,141,87,0.55)] hover:tw-bg-[rgba(176,141,87,0.18)] hover:tw-text-[color:var(--csd-gold,#b08d57)]" data-action="charReset" data-tooltip="{{localize 'WH40K.CharGen.PointBuyResetHint'}}">
 <i class="fa-solid fa-rotate-left"></i>
 </button>
 </div>
 </div>
 {{#if charGen.pointBuyOverspent}}
 <p class="tw-m-0 tw-mb-3 tw-text-sm tw-text-failure tw-font-semibold" role="alert">{{localize "WH40K.CharGen.PointBuyOverspent"}}</p>
 {{/if}}
 <div class="csd-char-grid tw-flex tw-flex-col tw-gap-3">
 {{#each charGen.pointBuyRows}}
 <div class="csd-char-row tw-flex tw-gap-3 tw-justify-center">
 {{#each this}}
 <div class="csd-char-slot csd-pointbuy-slot tw-flex-1 tw-bg-gradient-to-br tw-from-[rgba(36,107,131,0.15)] tw-to-[rgba(36,107,131,0.05)] tw-border-2 tw-border-[rgba(36,107,131,0.35)] tw-rounded-[var(--wh40k-radius-lg)] tw-p-3 {{#if (gt points 0)}}tw-border-[rgba(176,141,87,0.5)]{{/if}}"
 data-characteristic="{{key}}">
 <div class="csd-char-header tw-flex tw-items-baseline tw-gap-2 tw-mb-2 tw-pb-[0.35rem] tw-border-b tw-border-[rgba(36,107,131,0.2)]">
 {{!-- Full characteristic name (e.g. "Weapon Skill"), matching the Aptitudes section (#330). --}}
 <span class="csd-char-name tw-text-[0.85rem] tw-font-bold tw-uppercase tw-tracking-[0.03em] tw-text-[color:rgba(232,220,196,0.85)]">{{label}}</span>
 </div>
 <div class="csd-char-body tw-flex tw-flex-wrap tw-items-center tw-justify-center tw-gap-[0.4rem]">
 <div class="csd-char-base tw-flex tw-flex-col tw-items-center">
 <span class="csd-base-value tw-text-[1.1rem] tw-font-semibold tw-text-[color:var(--csd-bone,#e8dcc4)]">{{base}}</span>
 <span class="csd-base-label tw-text-[0.55rem] tw-uppercase tw-text-[color:rgba(232,220,196,0.5)]">{{localize "WH40K.CharacteristicSetup.Base"}}</span>
 </div>
 <span class="csd-char-plus tw-text-[1rem] tw-font-bold tw-text-[color:rgba(232,220,196,0.6)]">+</span>
 <div class="csd-pointbuy-controls tw-flex tw-flex-col tw-items-center tw-gap-1">
 <div class="tw-flex tw-items-center tw-gap-1">
 <button type="button" class="csd-pointbuy-dec tw-inline-flex tw-h-7 tw-w-7 tw-items-center tw-justify-center tw-rounded tw-border tw-border-[rgba(36,107,131,0.45)] tw-bg-[rgba(36,107,131,0.2)] tw-text-[color:var(--csd-bone,#e8dcc4)] tw-transition-all hover:tw-border-[rgba(176,141,87,0.55)] disabled:tw-opacity-30 disabled:tw-cursor-not-allowed" data-action="adjustPointBuy" data-characteristic="{{key}}" data-delta="-1" {{#unless canDecrease}}disabled{{/unless}} aria-label="{{localize 'WH40K.CharGen.DecreasePoints'}}">
 <i class="fa-solid fa-minus"></i>
 </button>
 <input type="number" class="csd-pointbuy-input tw-w-[44px] tw-h-[28px] tw-text-center tw-text-[1rem] tw-font-semibold tw-bg-[rgba(0,0,0,0.4)] tw-border tw-border-[rgba(176,141,87,0.5)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[color:var(--csd-bone,#e8dcc4)] focus:tw-outline-none focus:tw-border-[var(--csd-gold,#b08d57)]" value="{{points}}" data-characteristic="{{key}}" min="0" max="99" />
 <button type="button" class="csd-pointbuy-inc tw-inline-flex tw-h-7 tw-w-7 tw-items-center tw-justify-center tw-rounded tw-border tw-border-[rgba(36,107,131,0.45)] tw-bg-[rgba(36,107,131,0.2)] tw-text-[color:var(--csd-bone,#e8dcc4)] tw-transition-all hover:tw-border-[rgba(176,141,87,0.55)] disabled:tw-opacity-30 disabled:tw-cursor-not-allowed" data-action="adjustPointBuy" data-characteristic="{{key}}" data-delta="1" {{#unless canIncrease}}disabled{{/unless}} aria-label="{{localize 'WH40K.CharGen.IncreasePoints'}}">
 <i class="fa-solid fa-plus"></i>
 </button>
 </div>
 <span class="csd-base-label tw-text-[0.55rem] tw-uppercase tw-text-[color:rgba(232,220,196,0.5)]">{{localize "WH40K.CharGen.PointsShort"}}</span>
 </div>
 <span class="csd-char-plus tw-text-[1rem] tw-font-bold tw-text-[color:rgba(232,220,196,0.6)]">+</span>
 <div class="csd-char-origin tw-flex tw-min-h-[40px] tw-min-w-[52px] tw-flex-col tw-items-center tw-justify-center tw-rounded-[6px] tw-border-2 tw-border-[rgba(36,107,131,0.25)] tw-bg-[rgba(36,107,131,0.14)] tw-px-[0.35rem] tw-py-[0.2rem] {{#if hasOriginBonus}}has-origin tw-border-[rgba(176,141,87,0.45)] tw-bg-[rgba(176,141,87,0.12)]{{/if}}"
 {{#if hasOriginBonusTooltip}}data-wh40k-tooltip="generic" data-wh40k-tooltip-data="{{originBonusTooltipData}}" data-tooltip="{{originBonusTooltip}}"{{/if}}>
 <span class="csd-char-origin-value tw-text-[0.95rem] tw-font-bold tw-text-[color:var(--csd-bone,#e8dcc4)]">{{#if hasOriginBonus}}{{#if (gt originBonus 0)}}+{{/if}}{{originBonus}}{{else}}0{{/if}}</span>
 <span class="csd-char-origin-label tw-text-[0.5rem] tw-uppercase tw-tracking-[0.05em] tw-text-[color:rgba(232,220,196,0.55)]">{{localize "WH40K.CharGen.OriginShort"}}</span>
 </div>
 <span class="csd-char-equals tw-text-[1rem] tw-font-bold tw-text-[color:rgba(232,220,196,0.6)]">=</span>
 <div class="csd-char-total tw-flex tw-h-[36px] tw-min-w-[40px] tw-items-center tw-justify-center tw-rounded-[6px] tw-border-2 tw-border-[rgba(176,141,87,0.5)] tw-bg-[rgba(176,141,87,0.15)] tw-text-[1.3rem] tw-font-bold tw-text-[color:var(--csd-gold,#b08d57)]">
 {{total}}
 </div>
 </div>
 </div>
 {{/each}}
 </div>
 {{/each}}
 </div>
 </section>
 {{> "systems/wh40k-rpg/templates/character-creation/partials/char-gen-divination.hbs"}}
</div>
