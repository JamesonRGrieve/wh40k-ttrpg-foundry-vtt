{{!-- Origin Path Choice Dialog Template --}}
<div class="origin-choice-dialog-content">
    
    {{!-- Item Header --}}
    <div class="choice-header">
        <img src="{{itemImg}}" alt="{{itemName}}" class="item-img" />
        <div class="item-info">
            <h3 class="item-name">{{itemName}}</h3>
            <p class="choice-instruction">{{localize "WH40K.OriginPath.ChoicesRequired"}}</p>
        </div>
    </div>

    {{!-- Choices List --}}
    <div class="choices-list">
        {{#each choices as |choice|}}
            <div class="choice-group">
                <div class="choice-group-header">
                    <span class="choice-type-badge">{{choice.typeLabel}}</span>
                    <span class="choice-text">{{choice.label}}</span>
                    {{#if (gt choice.remaining 0)}}
                        <span class="choice-remaining">
                            ({{choice.remaining}} {{localize "WH40K.OriginPath.Remaining"}})
                        </span>
                    {{else}}
                        <i class="fa-solid fa-check-circle choice-complete"></i>
                    {{/if}}
                </div>
                
                {{!-- Card-based options --}}
                <div class="choice-options-cards">
                    {{#each choice.options as |option|}}
                        <div class="choice-card {{#if option.selected}}selected{{/if}} {{#if option.pendingSpec}}pending-spec{{/if}} {{#if option.disabled}}disabled{{/if}}"
                             data-action="toggleOption"
                             data-choice="{{../choiceKey}}"
                             data-option="{{option.value}}"
                             {{#if option.disabled}}disabled{{/if}}>

                            <div class="choice-card-header">
                                <span class="option-checkbox">
                                    {{#if option.selected}}
                                        <i class="fa-solid fa-check-square"></i>
                                    {{else if option.pendingSpec}}
                                        <i class="fa-solid fa-caret-down"></i>
                                    {{else}}
                                        <i class="fa-regular fa-square"></i>
                                    {{/if}}
                                </span>
                                <h4 class="option-label">
                                    {{option.label}}
                                    {{#if option.chosenSpecialization}}
                                        <span class="chosen-spec">({{option.chosenSpecialization}})</span>
                                    {{/if}}
                                </h4>
                                {{#if option.selected}}
                                    <i class="fa-solid fa-check choice-checkmark"></i>
                                {{/if}}
                            </div>

                            {{#if option.statBlock}}
                                <p class="option-stat-block">{{option.statBlock}}</p>
                            {{/if}}
                            {{#if option.description}}
                                <div class="option-description">{{{option.description}}}</div>
                            {{/if}}

                            {{!-- Specialization dropdown (shown when option selected or pending) --}}
                            {{#if option.hasSpecializations}}
                                {{#if (or option.pendingSpec option.selected)}}
                                    <div class="specialization-select" onclick="event.stopPropagation()">
                                        <label class="spec-label">
                                            <i class="fa-solid fa-crosshairs"></i>
                                            {{localize "WH40K.OriginPath.Choose"}}:
                                        </label>
                                        <select data-action="selectSpecialization"
                                                data-choice="{{../choiceKey}}"
                                                data-option="{{option.value}}">
                                            <option value="">-- Select --</option>
                                            {{#each option.specializations as |spec|}}
                                                <option value="{{spec}}" {{#if (eq spec ../chosenSpecialization)}}selected{{/if}}>{{spec}}</option>
                                            {{/each}}
                                        </select>
                                    </div>
                                {{/if}}
                            {{/if}}

                            {{!-- View Item Sheet Button (if applicable) --}}
                            {{#if option.uuid}}
                                <button type="button" class="view-item-btn" data-action="viewItem" data-uuid="{{option.uuid}}" data-tooltip="{{localize 'WH40K.OriginPath.ViewDetails'}}">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            {{/if}}
                        </div>
                    {{/each}}
                </div>
            </div>
        {{/each}}
    </div>

    {{!-- Footer Actions --}}
    <div class="choice-footer">
        <button type="button" class="cancel-button" data-action="cancel">
            <i class="fa-solid fa-times"></i>
            {{localize "WH40K.Cancel"}}
        </button>
        
        <button 
            type="submit" 
            class="confirm-button" 
            data-action="confirm"
            {{#unless allChoicesComplete}}disabled{{/unless}}>
            <i class="fa-solid fa-check"></i>
            {{localize "WH40K.OriginPath.ConfirmChoices"}}
        </button>
    </div>

</div>
