{{!-- Rogue Trader Roll Card - Modern Design --}}
{{#with rollData}}
{{#> systems/wh40k-rpg/templates/chat/partial/roll-card-shell.hbs
    overline=sheetName
    title=name
    subtitle=(iff type (concat type " • " (lookup difficulties difficulty)) "")
    playerRolledBadge=isManualRoll
    bgClass="tw-bg-[var(--wh40k-panel-bg-solid)]"
    gameSystem=../gameSystem}}
            {{!-- Modifiers Breakdown --}}
            {{> systems/wh40k-rpg/templates/chat/partial/modifier-breakdown.hbs baseTarget=baseTarget activeModifiers=activeModifiers modifiedTarget=modifiedTarget}}

            {{!-- Target-only display (no roll entered) --}}
            {{#if isTargetOnly}}
                <div class="tw-text-center tw-px-3 tw-py-2 tw-my-2 tw-bg-[rgba(201,162,39,0.08)] tw-border tw-border-dashed tw-border-[rgba(201,162,39,0.3)] tw-rounded-md tw-text-[0.8rem] tw-italic tw-text-[var(--wh40k-text-muted)]">
                    Target posted - awaiting physical dice roll
                </div>
            {{else}}
            {{!-- Result Display --}}
            {{#if success}}
                {{> systems/wh40k-rpg/templates/chat/partial/result-callout.hbs
                    variant="success"
                    label="Success"
                    value=roll.total
                    glowClass="tw-shadow-[0_0_20px_rgba(45,138,78,0.4),inset_0_0_30px_rgba(45,138,78,0.1)]"}}
                <div class="tw-flex tw-justify-center tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-rounded-md">
                    <span class="tw-text-[1.5rem] tw-font-bold tw-text-success">{{dos}}</span>
                    <span class="tw-text-[0.8rem] tw-uppercase tw-tracking-[0.1em] tw-opacity-80">Degrees of Success</span>
                </div>
            {{else}}
                {{> systems/wh40k-rpg/templates/chat/partial/result-callout.hbs
                    variant="danger"
                    label="Failure"
                    value=roll.total
                    glowClass="tw-shadow-[0_0_20px_rgba(168,50,50,0.4),inset_0_0_30px_rgba(168,50,50,0.1)]"}}
                <div class="tw-flex tw-justify-center tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-rounded-md">
                    <span class="tw-text-[1.5rem] tw-font-bold tw-text-failure">{{dof}}</span>
                    <span class="tw-text-[0.8rem] tw-uppercase tw-tracking-[0.1em] tw-opacity-80">Degrees of Failure</span>
                </div>
            {{/if}}

            {{/if}}{{!-- end isTargetOnly else --}}

            {{!-- Extended Test ladder (#59) --}}
            {{#if extendedTest}}
                {{> systems/wh40k-rpg/templates/chat/partial/extended-test-progress.hbs extendedTest=extendedTest}}
            {{/if}}

            {{!-- Re-roll + Fate controls. One button per available re-roll variant
                 (talent/trait re-rolls + global Spend Fate, from rerollOptions),
                 plus the Fate +1-DoS control. Shown for a resolved, auto-rolled
                 test that has at least one re-roll variant — so non-fate / spent-out
                 / target-only / manual rolls get no dead button. --}}
            {{#unless isTargetOnly}}
            {{#unless isManualRoll}}
            {{#if @root.rerollOptions.length}}
            <div class="tw-flex tw-flex-wrap tw-gap-1.5 tw-px-4 tw-py-2.5 tw-mt-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color)]">
                {{#if success}}{{#if @root.sourceFatePoints}}
                <button class="roll-control__fate-add-dos tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-2 tw-py-[5px] tw-bg-[var(--wh40k-powers-bg)] tw-border tw-border-[var(--wh40k-powers-border)] tw-rounded-md tw-text-[var(--wh40k-powers-secondary)] tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-whitespace-nowrap hover:tw-bg-[rgba(106,32,144,0.2)] hover:tw-border-[var(--wh40k-powers-primary)] hover:tw-shadow-[0_0_12px_rgba(106,32,144,0.4)] hover:-tw-translate-y-px active:tw-translate-y-0" data-roll-id="{{@root.id}}">
                    <span class="material-icons tw-text-[14px]">add_circle</span>
                    <span>{{localize "WH40K.FateAddDoS"}}</span>
                </button>
                {{/if}}{{/if}}
                {{> systems/wh40k-rpg/templates/chat/partial/reroll-controls.hbs rerollOptions=@root.rerollOptions rollId=@root.id}}
            </div>
            {{/if}}
            {{/unless}}
            {{/unless}}

        {{!-- Hidden dice data for Foundry --}}
        {{#unless isManualRoll}}
        <div class="tw-hidden">
            <div class="tw-hidden">{{{render}}}</div>
        </div>
        {{/unless}}
{{/systems/wh40k-rpg/templates/chat/partial/roll-card-shell.hbs}}
{{/with}}
