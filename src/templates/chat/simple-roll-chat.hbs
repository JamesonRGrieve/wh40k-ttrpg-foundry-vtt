{{!-- Rogue Trader Roll Card - Modern Design --}}
{{#with rollData}}
{{#> systems/wh40k-rpg/templates/chat/partial/roll-card-shell.hbs
    overline=sheetName
    title=name
    subtitle=(iff type (concat type " • " (lookup difficulties difficulty)) "")
    playerRolledBadge=isManualRoll
    bgClass="tw-bg-[var(--wh40k-panel-bg-solid)]"
    gameSystem=../gameSystem}}
            {{!-- Modifiers Breakdown --}}
            <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-[0.9rem]">
                <span class="tw-text-[var(--wh40k-text-muted)] tw-font-medium">Base</span>
                <span class="tw-font-semibold">{{baseTarget}}</span>
            </div>

            {{#each activeModifiers}}
                <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-[0.9rem] tw-pl-3 tw-border-l-2 tw-border-[var(--wh40k-border-color)] tw-ml-1">
                    <span class="tw-text-[var(--wh40k-text-muted)] tw-font-medium">{{@key}}</span>
                    <span class="tw-font-semibold {{#if (gt this 0)}}tw-text-success{{else if (lt this 0)}}tw-text-failure wh40k-roll-card__value--negative{{/if}}">
                        {{#if (gt this 0)}}+{{/if}}{{this}}
                    </span>
                </div>
            {{/each}}

            {{!-- Target Number --}}
            <div class="tw-flex tw-justify-between tw-items-center tw-px-3 tw-py-2 tw-my-2 tw-bg-[var(--wh40k-accent-overlay)] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-md">
                <span class="tw-text-[var(--wh40k-text-muted)] tw-font-semibold tw-uppercase tw-tracking-[0.05em]">Target</span>
                <span class="tw-text-[1.2rem] tw-font-bold tw-text-gold">{{modifiedTarget}}</span>
            </div>

            {{!-- Target-only display (no roll entered) --}}
            {{#if isTargetOnly}}
                <div class="tw-text-center tw-px-3 tw-py-2 tw-my-2 tw-bg-[rgba(201,162,39,0.08)] tw-border tw-border-dashed tw-border-[rgba(201,162,39,0.3)] tw-rounded-md tw-text-[0.8rem] tw-italic tw-text-[var(--wh40k-text-muted)]">
                    Target posted - awaiting physical dice roll
                </div>
            {{else}}
            {{!-- Result Display --}}
            {{#if success}}
                <div class="tw-relative tw-text-center tw-p-4 tw-my-3 tw-rounded-md tw-bg-[var(--wh40k-success-bg)] tw-border-2 tw-border-[var(--wh40k-success-primary)] tw-shadow-[0_0_20px_rgba(45,138,78,0.4),inset_0_0_30px_rgba(45,138,78,0.1)]">
                    <div class="tw-font-display tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.15em] tw-mb-1 tw-text-[var(--wh40k-success-secondary)]">Success</div>
                    <div class="tw-text-[2.5rem] tw-font-bold tw-leading-none tw-shadow-[0_2px_8px_var(--wh40k-shadow-medium)]">{{roll.total}}</div>
                </div>
                <div class="tw-flex tw-justify-center tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-rounded-md">
                    <span class="tw-text-[1.5rem] tw-font-bold tw-text-success">{{dos}}</span>
                    <span class="tw-text-[0.8rem] tw-uppercase tw-tracking-[0.1em] tw-opacity-80">Degrees of Success</span>
                </div>
            {{else}}
                <div class="tw-relative tw-text-center tw-p-4 tw-my-3 tw-rounded-md tw-bg-[var(--wh40k-danger-bg)] tw-border-2 tw-border-[var(--wh40k-danger-primary)] tw-shadow-[0_0_20px_rgba(168,50,50,0.4),inset_0_0_30px_rgba(168,50,50,0.1)]">
                    <div class="tw-font-display tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.15em] tw-mb-1 tw-text-[var(--wh40k-danger-secondary)]">Failure</div>
                    <div class="tw-text-[2.5rem] tw-font-bold tw-leading-none tw-shadow-[0_2px_8px_var(--wh40k-shadow-medium)]">{{roll.total}}</div>
                </div>
                <div class="tw-flex tw-justify-center tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-rounded-md">
                    <span class="tw-text-[1.5rem] tw-font-bold tw-text-failure">{{dof}}</span>
                    <span class="tw-text-[0.8rem] tw-uppercase tw-tracking-[0.1em] tw-opacity-80">Degrees of Failure</span>
                </div>
            {{/if}}

            {{/if}}{{!-- end isTargetOnly else --}}

        {{!-- Hidden dice data for Foundry --}}
        {{#unless isManualRoll}}
        <div class="tw-hidden">
            <div class="tw-hidden">{{{render}}}</div>
        </div>
        {{/unless}}
{{/systems/wh40k-rpg/templates/chat/partial/roll-card-shell.hbs}}
{{/with}}
