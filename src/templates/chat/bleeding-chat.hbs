{{!-- Rogue Trader Bleeding Card --}}
{{#> systems/wh40k-rpg/templates/chat/partial/modern-card-shell.hbs actorName=actor.name title="Bleeding!" subtitle="Critical Condition" gameSystem=gameSystem}}
    <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-[0.9rem]">
        <span class="tw-text-[color:var(--wh40k-text-muted)] tw-font-medium">Fatigue</span>
        <span class="tw-font-semibold tw-text-[color:var(--wh40k-text-dark)]">{{system.fatigue.value}} / {{system.fatigue.max}}</span>
    </div>

    <div class="tw-px-3 tw-py-2 tw-my-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-l-2 tw-border-gold tw-rounded-r-[4px] tw-text-[0.85rem] tw-leading-[1.5] tw-max-h-[150px] tw-overflow-y-auto">
        <p class="tw-m-0 tw-mb-2 last:tw-mb-0">Once per round as a Free Action, the character (or another who can reach them) can attempt a
            <strong>Difficult (–10) Medicae</strong>
            test to remove this condition.</p>
    </div>

    <div class="tw-p-3 tw-my-2 tw-bg-[var(--wh40k-wounds-bg)] tw-border tw-border-[var(--wh40k-wounds-border)] tw-rounded-md">
        <div class="tw-flex tw-justify-between tw-items-center tw-mb-2 tw-pb-2 tw-border-b tw-border-[var(--wh40k-wounds-border)]">
            <span class="tw-font-display tw-text-[0.9rem] tw-text-[color:var(--wh40k-wounds-secondary)] tw-uppercase tw-tracking-[0.1em]">Fatigue</span>
        </div>
        <div class="tw-text-center tw-text-[2rem] tw-font-bold tw-text-[color:var(--wh40k-wounds-secondary)] tw-[text-shadow:0_0_10px_rgba(139,0,0,0.5)]">+1</div>
        <div class="tw-text-center tw-text-[0.8rem] tw-uppercase tw-tracking-[0.1em] tw-text-[color:var(--wh40k-text-muted)] tw-mt-1">Blood Loss</div>
    </div>

    <div class="tw-flex tw-gap-1.5 tw-px-4 tw-py-2.5 tw-mt-2 -tw-mx-4 -tw-mb-3 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color)]">
        <button
            class="roll-control__apply-damage tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-bg-[var(--wh40k-wounds-bg)] tw-border tw-border-[var(--wh40k-wounds-border)] tw-rounded-md tw-text-[color:var(--wh40k-wounds-secondary)] tw-text-[0.8rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all tw-duration-[var(--wh40k-transition-base)] tw-whitespace-nowrap hover:tw-bg-[rgba(139,0,0,0.2)] hover:tw-border-[var(--wh40k-wounds-primary)] hover:tw-shadow-[0_0_12px_rgba(139,0,0,0.4)]"
            data-uuid="{{actor.uuid}}"
            data-damage="0"
            data-fatigue="1"
        >
            <span class="material-icons tw-text-[16px]">api</span>
            <span>Apply Fatigue</span>
        </button>
    </div>
{{/systems/wh40k-rpg/templates/chat/partial/modern-card-shell.hbs}}
