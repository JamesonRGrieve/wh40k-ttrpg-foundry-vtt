{{! Rogue Trader Damage Roll Card - Rich Hit-by-Hit Display }}
<div class="wh40k-chat">
    <div class="wh40k-roll-card">
        {{! Header }}
        <div class="wh40k-roll-card__header">
            <div class="wh40k-roll-card__actor">Damage Roll</div>
            <h2 class="wh40k-roll-card__title">{{weaponName}}</h2>
        </div>

        {{! Body }}
        <div class="wh40k-roll-card__body">
            {{#if psychicEffect}}
                <div class="wh40k-roll-card__divider wh40k-roll-card__divider--ornate"></div>
                <div class="wh40k-roll-card__text">{{{psychicEffect}}}</div>
            {{/if}}

            {{#each hits as |hit|}}
                <div class="wh40k-roll-card__hit">
                    <div class="wh40k-roll-card__hit-header">
                        <span class="wh40k-roll-card__hit-number">{{inc @index}}</span>
                        <span class="wh40k-roll-card__hit-location">{{hit.location}}</span>
                    </div>

                    <div class="wh40k-roll-card__row">
                        <span class="wh40k-roll-card__label">Formula</span>
                        <span class="wh40k-roll-card__value">{{hit.damageRoll.formula}}</span>
                    </div>
                    <div class="wh40k-roll-card__row">
                        <span class="wh40k-roll-card__label">Base Damage</span>
                        <span class="wh40k-roll-card__value">{{hit.damageRoll.result}}</span>
                    </div>
                    {{#each modifiers}}
                        <div class="wh40k-roll-card__row wh40k-roll-card__row--modifier">
                            <span class="wh40k-roll-card__label">{{@key}}</span>
                            <span class="wh40k-roll-card__value">{{this}}</span>
                        </div>
                    {{/each}}

                    {{! Damage Display }}
                    <div class="wh40k-roll-card__damage">
                        <div class="wh40k-roll-card__damage-header">
                            <span class="wh40k-roll-card__damage-title">Damage</span>
                            <span class="wh40k-roll-card__damage-location">{{hit.location}}</span>
                        </div>
                        <div class="wh40k-roll-card__damage-value">{{hit.totalDamage}}</div>
                        <div class="wh40k-roll-card__damage-type">{{hit.damageType}}</div>
                    </div>

                    {{! Penetration }}
                    <div class="wh40k-roll-card__notice">
                        <span class="wh40k-roll-card__notice-label">Penetration</span>
                        <span class="wh40k-roll-card__notice-value">{{hit.totalPenetration}}</span>
                    </div>

                    {{! Effects }}
                    {{#each hit.effects as |effect|}}
                        <div class="wh40k-roll-card__effect">
                            <span class="wh40k-roll-card__effect-name">{{effect.name}}</span>
                            <span class="wh40k-roll-card__effect-desc">{{effect.effect}}</span>
                        </div>
                    {{/each}}

                    {{! Righteous Fury }}
                    {{#each hit.righteousFury as |fury|}}
                        {{#if fury.confirmed}}
                            <div class="wh40k-roll-card__fury wh40k-roll-card__fury--confirmed">
                                <div class="wh40k-roll-card__fury-title">⚡ Righteous Fury Confirmed! ⚡</div>
                                <div class="wh40k-roll-card__fury-bonus">
                                    <span class="wh40k-roll-card__fury-label">Bonus Damage:</span>
                                    <span class="wh40k-roll-card__fury-value">+{{fury.bonusDamage}}</span>
                                </div>
                                <div class="wh40k-roll-card__fury-effect">Critical Level {{fury.critRoll.total}}: {{fury.effect}}</div>
                            </div>
                        {{else}}
                            <div class="wh40k-roll-card__fury wh40k-roll-card__fury--not-confirmed">
                                <div class="wh40k-roll-card__fury-title">⚡ Righteous Fury (Not Confirmed)</div>
                                <div class="wh40k-roll-card__fury-text">
                                    Rolled
                                    {{fury.dieResult}}
                                    (threshold:
                                    {{fury.threshold}}), but failed confirmation roll.
                                </div>
                            </div>
                        {{/if}}
                    {{/each}}

                    {{! Assign Damage Button }}
                    {{#if @root.targetActor}}
                        <div class="wh40k-roll-card__controls">
                            <button
                                class="wh40k-roll-card__btn wh40k-roll-card__btn--damage roll-control__assign-damage"
                                data-location="{{hit.location}}"
                                data-total-damage="{{hit.totalDamage}}"
                                data-total-penetration="{{hit.totalPenetration}}"
                                data-total-fatigue="{{hit.totalFatigue}}"
                                data-target-uuid="{{@root.targetActor.uuid}}"
                                data-damage-type="{{hit.damageType}}"
                            >
                                <span class="material-icons">api</span>
                                <span>Assign Damage</span>
                            </button>
                        </div>
                    {{/if}}
                </div>
            {{/each}}
        </div>
    </div>
</div>