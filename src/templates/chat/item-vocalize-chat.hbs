{{! Rogue Trader Item Vocalize Card - Modern Comprehensive Design }}
<div class="wh40k-chat wh40k-vocalize-card tw-font-ui">
    <div class="wh40k-item-card wh40k-item-card--vocalize tw-relative tw-overflow-hidden tw-rounded-md">
        {{! Header with Image }}
        <div class="wh40k-item-card__header">
            {{#if img}}
                <img class="wh40k-item-card__image" src="{{img}}" alt="{{name}}" />
            {{else}}
                <div class="wh40k-item-card__image wh40k-item-card__image--placeholder">
                    <i class="fas fa-scroll"></i>
                </div>
            {{/if}}
            <div class="wh40k-item-card__title-group">
                <h2 class="wh40k-item-card__name">{{name}}</h2>
                <div class="wh40k-item-card__meta">
                    {{#if actor}}
                        <span class="wh40k-item-card__actor">{{actor}}</span>
                        <span class="wh40k-item-card__separator">•</span>
                    {{/if}}
                    <span class="wh40k-item-card__type">{{type}}</span>
                </div>
            </div>
            {{#if itemTypeLabel}}
                <span class="wh40k-meta-badge wh40k-meta-badge--{{itemType}}">
                    {{#if itemIcon}}<i class="{{itemIcon}}"></i>{{/if}}
                    {{itemTypeLabel}}
                </span>
            {{/if}}
        </div>

        {{! Body }}
        <div class="wh40k-item-card__body">
            {{! Quick Stats Row (if available) }}
            {{#if stats}}
                <div class="wh40k-item-card__quick-stats">
                    {{#each stats as |stat|}}
                        <div class="wh40k-quick-stat">
                            <span class="wh40k-quick-stat__label">{{stat.label}}</span>
                            <span class="wh40k-quick-stat__value">{{stat.value}}</span>
                        </div>
                    {{/each}}
                </div>
                <div class="wh40k-item-card__divider"></div>
            {{/if}}

            {{! Properties/Traits (if available) }}
            {{#if properties}}
                <div class="wh40k-item-card__properties">
                    {{#each properties as |prop|}}
                        <span class="wh40k-property-tag">
                            {{#if prop.icon}}<i class="{{prop.icon}}"></i>{{/if}}
                            {{prop.label}}
                        </span>
                    {{/each}}
                </div>
            {{/if}}

            {{! Description }}
            {{#if description}}
                <div class="wh40k-item-card__section">
                    <div class="wh40k-item-card__description">{{{description}}}</div>
                </div>
            {{/if}}

            {{! Special Effect }}
            {{#if effect}}
                <div class="wh40k-item-card__section wh40k-item-card__section--effect">
                    <h3 class="wh40k-item-card__section-title">
                        <i class="fas fa-sparkles"></i>
                        Effect
                    </h3>
                    <div class="wh40k-item-card__effect-text">{{{effect}}}</div>
                </div>
            {{/if}}

            {{! Benefit }}
            {{#if benefit}}
                <div class="wh40k-item-card__section wh40k-item-card__section--benefit">
                    <h3 class="wh40k-item-card__section-title">
                        <i class="fas fa-plus-circle"></i>
                        Benefit
                    </h3>
                    <div class="wh40k-item-card__benefit-text">{{{benefit}}}</div>
                </div>
            {{/if}}

            {{! Requirements }}
            {{#if requirements}}
                <div class="wh40k-item-card__requirements">
                    <span class="wh40k-requirements__label">
                        <i class="fas fa-exclamation-triangle"></i>
                        Requirements:
                    </span>
                    <span class="wh40k-requirements__text">{{requirements}}</span>
                </div>
            {{/if}}
        </div>

        {{! Footer }}
        {{#if source}}
            <div class="wh40k-item-card__footer">
                <i class="fas fa-book"></i>
                <span class="wh40k-item-card__source">{{source}}</span>
            </div>
        {{/if}}

        {{! Action Button (Open Sheet) }}
        {{#if itemUuid}}
            <div class="wh40k-item-card__actions">
                <button type="button" class="wh40k-item-card__btn wh40k-item-card__btn--sheet" data-uuid="{{itemUuid}}" data-action="openItemSheet">
                    <i class="fas fa-scroll-old"></i>
                    View Details
                </button>
            </div>
        {{/if}}
    </div>
</div>