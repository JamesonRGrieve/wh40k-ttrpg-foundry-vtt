{{! Condition Chat Card }}
<div class="wh40k-chat-card wh40k-condition-card wh40k-condition-card--{{nature}} tw-overflow-hidden tw-rounded-md">
    <header class="wh40k-card-header">
        <img src="{{img}}" alt="{{name}}" class="wh40k-card-icon" />
        <div class="wh40k-card-title-area">
            <h3 class="wh40k-card-title">{{name}}</h3>
            <div class="wh40k-card-subtitle">{{natureLabel}} Condition</div>
            <div class="wh40k-card-badges">
                <span class="wh40k-badge wh40k-badge--{{natureClass}}">
                    <i class="fas {{natureIcon}}"></i>
                    {{natureLabel}}
                </span>
                {{#if stackable}}
                    <span class="wh40k-badge wh40k-badge--stacks">
                        <i class="fas fa-layer-group"></i>
                        ×{{stacks}}
                    </span>
                {{/if}}
            </div>
        </div>
    </header>

    <div class="wh40k-card-body">
        <div class="wh40k-condition-meta">
            <span class="wh40k-meta-item wh40k-meta-item--applies">
                <i class="fas {{appliesToIcon}}"></i>
                {{appliesToLabel}}
            </span>
            {{#if isTemporary}}
                <span class="wh40k-meta-item wh40k-meta-item--duration">
                    <i class="fas fa-clock"></i>
                    {{durationDisplay}}
                </span>
            {{/if}}
        </div>

        {{#if effect}}
            <div class="wh40k-condition-effect">
                <h4>Effect</h4>
                {{{effect}}}
            </div>
        {{/if}}

        {{#if removal}}
            <div class="wh40k-condition-removal">
                <h4>Removal</h4>
                {{{removal}}}
            </div>
        {{/if}}

        {{#if notes}}
            <div class="wh40k-condition-notes">
                <strong>Notes:</strong>
                {{notes}}
            </div>
        {{/if}}

        {{#if description}}
            <div class="wh40k-condition-description">
                {{{description}}}
            </div>
        {{/if}}
    </div>

    {{#if sourceReference}}
        <footer class="wh40k-card-footer">
            <span class="wh40k-source-ref">
                <i class="fas fa-book"></i>
                {{sourceReference}}
            </span>
        </footer>
    {{/if}}
</div>