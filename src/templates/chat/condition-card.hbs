{{! Condition Chat Card }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
      cardClass=(concat "wh40k-condition-card wh40k-condition-card--" nature)
      outerExtraClass="tw-overflow-hidden tw-rounded-md"
      image=img
      imageAlt=name
      title=name
      subtitle=(concat natureLabel " Condition")
      badges=(array
          (object class=(concat "wh40k-badge--" natureClass) icon=natureIcon label=natureLabel)
          (iff stackable (object class="wh40k-badge--stacks" icon="fa-layer-group" label=(concat "×" stacks)))
      )
      footerLabel=sourceReference
      footerIcon="fa-book"}}
        <div class="wh40k-condition-meta">
            <span class="wh40k-meta-item wh40k-meta-item--applies">
                <i class="fas {{appliesToIcon}}"></i>
                {{appliesToLabel}}
            </span>
            {{#if isTemporary}}
                <span class="wh40k-meta-item wh40k-meta-item--duration">
                    <i class="fas fa-clock"></i>
                    {{durationDisplay}}
                </span>
            {{/if}}
        </div>

        {{#if effect}}
            <div class="wh40k-condition-effect">
                <h4>Effect</h4>
                {{{effect}}}
            </div>
        {{/if}}

        {{#if removal}}
            <div class="wh40k-condition-removal">
                <h4>Removal</h4>
                {{{removal}}}
            </div>
        {{/if}}

        {{#if notes}}
            <div class="wh40k-condition-notes">
                <strong>Notes:</strong>
                {{notes}}
            </div>
        {{/if}}

        {{#if description}}
            <div class="wh40k-condition-description">
                {{{description}}}
            </div>
        {{/if}}
{{/chat-card-shell}}
