{{!-- Rogue Trader Item Card Chat Template - Modern Design --}}
<div class="wh40k-chat tw-font-ui">
    <div class="wh40k-item-card tw-relative tw-overflow-hidden tw-rounded-md {{#if isWeapon}}wh40k-item-card--weapon{{/if}}{{#if isArmour}}wh40k-item-card--armour{{/if}}{{#if isTalent}}wh40k-item-card--talent{{/if}}{{#if isPsychicPower}}wh40k-item-card--power{{/if}}{{#if isShipComponent}}wh40k-item-card--component{{/if}}" data-item-id="{{item._id}}" data-item-uuid="{{item.uuid}}" {{#if actor}}data-actor-id="{{actor._id}}" data-actor-uuid="{{actor.uuid}}"{{/if}}>
        {{!-- Header --}}
        <div class="wh40k-item-card__header">
            <img class="wh40k-item-card__image" src="{{item.img}}" alt="{{item.name}}" />
            <div class="wh40k-item-card__title-group">
                <h2 class="wh40k-item-card__name">{{item.name}}</h2>
                <span class="wh40k-item-card__type">{{itemTypeLabel}}</span>
            </div>
        </div>
        
        {{!-- Body --}}
        <div class="wh40k-item-card__body">
            <div class="wh40k-item-card__divider"></div>
            
            {{#if item.system.category}}
                <div class="wh40k-item-card__field">
                    <span class="wh40k-item-card__label">Category</span>
                    <span class="wh40k-item-card__value">{{item.system.category}}</span>
                </div>
            {{/if}}

            {{#if item.system.requirements}}
                <div class="wh40k-item-card__field">
                    <span class="wh40k-item-card__label">Requirements</span>
                    <span class="wh40k-item-card__value">{{item.system.requirements}}</span>
                </div>
            {{/if}}

            {{#if item.system.effect}}
                <div class="wh40k-item-card__section">
                    <h3 class="wh40k-item-card__section-title">Effect</h3>
                    <div class="wh40k-item-card__description">{{{item.system.effect}}}</div>
                </div>
            {{/if}}

            {{#if item.system.benefit}}
                <div class="wh40k-item-card__section">
                    <h3 class="wh40k-item-card__section-title">Benefit</h3>
                    <div class="wh40k-item-card__description">{{{item.system.benefit}}}</div>
                </div>
            {{/if}}

            {{!-- Weapon Stats --}}
            {{#if isWeapon}}
                <div class="wh40k-item-card__stats">
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Class</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.class}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Type</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.type}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Damage</span>
                        <span class="wh40k-item-card__stat-value">{{#if item.system.damageLabel}}{{item.system.damageLabel}}{{else}}{{item.system.damage.formula}}{{#if item.system.damage.bonus}}+{{item.system.damage.bonus}}{{/if}} {{item.system.damage.type}}{{/if}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Pen</span>
                        <span class="wh40k-item-card__stat-value">{{#if item.system.damage.penetration}}{{item.system.damage.penetration}}{{else}}{{item.system.penetration}}{{/if}}</span>
                    </div>
                    {{#if item.system.range}}
                        <div class="wh40k-item-card__stat">
                            <span class="wh40k-item-card__stat-name">Range</span>
                            <span class="wh40k-item-card__stat-value">{{item.system.range}}</span>
                        </div>
                    {{/if}}
                    {{#if item.system.rof}}
                        <div class="wh40k-item-card__stat">
                            <span class="wh40k-item-card__stat-name">RoF</span>
                            <span class="wh40k-item-card__stat-value">{{item.system.rof}}</span>
                        </div>
                    {{/if}}
                    {{#if item.system.special}}
                        <div class="wh40k-item-card__stat wh40k-item-card__stat--full">
                            <span class="wh40k-item-card__stat-name">Special</span>
                            <span class="wh40k-item-card__stat-value">{{item.system.special}}</span>
                        </div>
                    {{/if}}
                </div>
            {{/if}}

            {{!-- Navigator Power Stats --}}
            {{#if isNavigatorPower}}
                <div class="wh40k-item-card__stats">
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Use Time</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.useTime}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Range</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.range}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Test</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.test}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Sustain</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.sustain}}</span>
                    </div>
                </div>
                {{#if item.system.novice}}
                    <div class="wh40k-item-card__section">
                        <h3 class="wh40k-item-card__section-title">Novice</h3>
                        <div class="wh40k-item-card__description">{{item.system.novice}}</div>
                    </div>
                {{/if}}
                {{#if item.system.adept}}
                    <div class="wh40k-item-card__section">
                        <h3 class="wh40k-item-card__section-title">Adept</h3>
                        <div class="wh40k-item-card__description">{{item.system.adept}}</div>
                    </div>
                {{/if}}
                {{#if item.system.master}}
                    <div class="wh40k-item-card__section">
                        <h3 class="wh40k-item-card__section-title">Master</h3>
                        <div class="wh40k-item-card__description">{{item.system.master}}</div>
                    </div>
                {{/if}}
            {{/if}}

            {{!-- Ship Component Stats --}}
            {{#if isShipComponent}}
                <div class="wh40k-item-card__stats">
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Type</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.componentType}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Hull</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.hullType}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Power</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.powerUsage}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">Space</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.spaceUsage}}</span>
                    </div>
                    <div class="wh40k-item-card__stat">
                        <span class="wh40k-item-card__stat-name">SP Cost</span>
                        <span class="wh40k-item-card__stat-value">{{item.system.spCost}}</span>
                    </div>
                </div>
            {{/if}}

            {{!-- Generic Description --}}
            {{#if item.system.description.value}}
                <div class="wh40k-item-card__section">
                    <div class="wh40k-item-card__description">{{{item.system.description.value}}}</div>
                </div>
            {{/if}}
        </div>

        {{!-- Properties/Qualities Tags --}}
        {{#if item.system.qualities}}
            <div class="wh40k-item-card__properties">
                {{#each item.system.qualities as |quality|}}
                    <span class="wh40k-item-card__property-tag">{{quality.name}}</span>
                {{/each}}
            </div>
        {{/if}}

        {{!-- Footer --}}
        {{#if item.system.source}}
            <div class="wh40k-item-card__footer">
                <span class="wh40k-item-card__source">{{item.system.source}}</span>
            </div>
        {{/if}}

        {{!-- Action Buttons --}}
        {{#if hasActions}}
            <div class="wh40k-item-card__actions">
                {{#if isRollable}}
                    <button type="button" class="wh40k-item-card__btn wh40k-item-card__btn--roll" data-item-id="{{item._id}}" data-item-uuid="{{item.uuid}}" data-action="roll">
                        <i class="fas fa-dice-d20"></i>
                        Roll
                    </button>
                {{/if}}
                {{#if isWeapon}}
                    <button type="button" class="wh40k-item-card__btn wh40k-item-card__btn--attack" data-item-id="{{item._id}}" data-item-uuid="{{item.uuid}}" data-action="attack">
                        <i class="fas fa-crosshairs"></i>
                        Attack
                    </button>
                    <button type="button" class="wh40k-item-card__btn wh40k-item-card__btn--damage" data-item-id="{{item._id}}" data-item-uuid="{{item.uuid}}" data-action="rollDamage">
                        <i class="fas fa-burst"></i>
                        Damage
                    </button>
                {{/if}}
                {{#if isUsable}}
                    <button type="button" class="wh40k-item-card__btn wh40k-item-card__btn--use" data-item-id="{{item._id}}" data-item-uuid="{{item.uuid}}" data-action="useItem">
                        <i class="fas fa-hand-sparkles"></i>
                        Use
                    </button>
                {{/if}}
            </div>
        {{/if}}
    </div>
</div>
