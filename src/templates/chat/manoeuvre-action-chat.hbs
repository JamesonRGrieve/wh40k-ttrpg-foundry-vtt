{{!-- Starship Manoeuvre Action Chat Card — issue #185 --}}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
    cardClass="wh40k-manoeuvre-action-card"
    outerExtraClass="tw-overflow-hidden tw-rounded-md tw-border-2 tw-border-bronze bc:tw-border-crimson-light dh1:tw-border-gold-raw-l5 dh2:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure"
    image=action.img
    imageAlt=action.name
    title=action.name
    subtitle=(localize "WH40K.Voidcraft.ManoeuvreAction.ChatSubtitle")
    gameSystem=gameSystem
    footerLabel=actorName
}}
    <div class="wh40k-manoeuvre-action-chat-body tw-p-3 tw-flex tw-flex-col tw-gap-2 tw-text-sm">
        {{#if action.typeAndAction}}
            <div class="tw-text-[0.85em] tw-uppercase tw-tracking-wide tw-text-[#8b6914] tw-font-semibold">{{action.typeAndAction}}</div>
        {{/if}}
        {{#if action.requirements}}
            <div class="tw-text-[0.85em]"><strong>{{localize "WH40K.Voidcraft.ManoeuvreAction.Requirements"}}:</strong> {{action.requirements}}</div>
        {{/if}}
        <div class="tw-flex tw-flex-wrap tw-gap-3 tw-text-[0.8em] tw-opacity-90">
            {{#if action.skill}}<span><strong>{{localize "WH40K.Voidcraft.ManoeuvreAction.Skill"}}:</strong> {{action.skill}}</span>{{/if}}
            {{#if action.modifier}}<span><strong>{{localize "WH40K.Voidcraft.ManoeuvreAction.Modifier"}}:</strong> {{action.modifier}}</span>{{/if}}
            {{#if action.duration}}<span><strong>{{localize "WH40K.Voidcraft.ManoeuvreAction.Duration"}}:</strong> {{action.duration}}</span>{{/if}}
        </div>
        {{#if action.description}}
            <div class="wh40k-manoeuvre-action-description tw-mt-1 tw-text-sm">{{{action.description}}}</div>
        {{/if}}
    </div>
{{/systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs}}
