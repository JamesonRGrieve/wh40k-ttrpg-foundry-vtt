{{! Movement Chat Card }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
      cardClass=(concat "wh40k-movement-card wh40k-movement-card--" movementType)
      outerExtraClass="tw-relative tw-overflow-hidden tw-rounded-md"
      iconClass=icon
      title=actor
      subtitle=(concat "Movement: " movementLabel)}}
        <div class="tw-flex tw-items-center tw-justify-between tw-gap-3 tw-mb-2">
            <div class="tw-flex tw-items-baseline tw-gap-1">
                <span class="tw-font-alt tw-text-2xl tw-font-bold tw-leading-none tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">{{distance}}</span>
                <span class="tw-text-[0.85rem] tw-font-semibold tw-lowercase tw-text-[color:var(--wh40k-text-muted)]">meters</span>
            </div>
            <div class="wh40k-badge tw-inline-flex tw-items-center tw-gap-1.5 tw-px-3 tw-py-1.5 tw-rounded-md tw-text-[0.75rem] tw-font-semibold tw-uppercase tw-tracking-[0.5px]">
                <i class="fas {{icon}}"></i>
                {{movementLabel}}
            </div>
        </div>

        {{#if description}}
            <div class="tw-px-3 tw-py-2 tw-bg-[rgba(138,122,106,0.08)] tw-border-l-[3px] tw-border-l-[rgba(138,122,106,0.3)] tw-rounded-md tw-text-sm tw-leading-[1.5] tw-text-[color:var(--wh40k-text-medium)]">
                {{{description}}}
            </div>
        {{/if}}
{{/chat-card-shell}}
