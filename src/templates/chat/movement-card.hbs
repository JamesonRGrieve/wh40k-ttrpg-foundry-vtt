{{! Movement Chat Card }}
<div class="wh40k-chat-card wh40k-movement-card wh40k-movement-card--{{movementType}}">
    <header class="wh40k-card-header">
        <div class="wh40k-card-icon-wrapper">
            <i class="fas {{icon}} wh40k-card-icon"></i>
        </div>
        <div class="wh40k-card-title-area">
            <h3 class="wh40k-card-title">{{actor}}</h3>
            <div class="wh40k-card-subtitle">Movement: {{movementLabel}}</div>
        </div>
    </header>

    <div class="wh40k-card-body">
        <div class="wh40k-movement-display">
            <div class="wh40k-movement-value">
                <span class="wh40k-movement-distance">{{distance}}</span>
                <span class="wh40k-movement-unit">meters</span>
            </div>
            <div class="wh40k-movement-type-badge wh40k-badge wh40k-badge--{{movementType}}">
                <i class="fas {{icon}}"></i>
                {{movementLabel}}
            </div>
        </div>

        {{#if description}}
            <div class="wh40k-movement-description">
                {{{description}}}
            </div>
        {{/if}}
    </div>
</div>