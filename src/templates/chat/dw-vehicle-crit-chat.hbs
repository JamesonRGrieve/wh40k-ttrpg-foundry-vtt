{{!-- Deathwatch Vehicle Critical Hit + Repair chat card (#170 — rites.md §"DAMAGING VEHICLES" / §"REPAIRING VEHICLES"). --}}
{{!-- data-wh40k-system anchors per-system Tailwind variants on the card; --}}
{{!-- the wh40k-rpg class lets utility cascade work outside the sheet root. --}}
<div class="wh40k-rpg wh40k-dw-vehicle-crit-card tw-p-4 tw-rounded-md tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dw:tw-border-bronze tw-bg-[rgba(20,18,12,0.88)]"
     data-wh40k-system="{{gameSystem}}">

    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
        <i class="fas fa-truck-monster tw-text-[1.1rem] dw:tw-text-bronze"></i>
        <div class="tw-font-display tw-uppercase tw-tracking-[0.12em] tw-text-[0.95rem] tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze">
            {{localize headerKey}}
        </div>
    </div>

    <div class="tw-text-[0.9rem] tw-mb-3 tw-text-[color:var(--wh40k-text-bright)]">
        <strong>{{localize resultKey}}</strong>
        {{#if description}}
            <div class="tw-text-[0.85rem] tw-italic tw-text-[color:var(--wh40k-text-muted)] tw-mt-1">{{description}}</div>
        {{/if}}
    </div>

    {{!-- Roll math --}}
    {{#unless skipRoll}}
        <div class="wh40k-dw-vehicle-crit-roll tw-flex tw-justify-between tw-gap-3 tw-text-[0.85rem] tw-mb-3 tw-px-2 tw-py-2 tw-rounded-sm tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dw:tw-border-bronze tw-bg-[rgba(0,0,0,0.18)]">
            <span class="tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.DW.Vehicle.Crit.Roll"}}</span>
            <span class="tw-font-bold tw-tabular-nums tw-text-[color:var(--wh40k-text-bright)]">
                d10 = {{rolled}} <i class="fas fa-plus tw-mx-1 dw:tw-text-bronze"></i> {{overIntegrity}} <i class="fas fa-arrow-right tw-mx-2 dw:tw-text-bronze"></i> {{finalRoll}}
            </span>
        </div>
    {{/unless}}

    {{!-- Repair difficulty --}}
    {{#if repairDifficultyKey}}
        <div class="wh40k-dw-vehicle-repair-row tw-flex tw-justify-between tw-gap-3 tw-text-[0.85rem] tw-px-2 tw-py-2 tw-rounded-sm tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dw:tw-border-bronze tw-bg-[rgba(0,0,0,0.18)]">
            <span class="tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.DW.Vehicle.RepairLabel"}}</span>
            <span class="tw-font-bold tw-tabular-nums tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze">
                {{localize repairDifficultyKey}}
            </span>
        </div>
    {{/if}}
</div>
