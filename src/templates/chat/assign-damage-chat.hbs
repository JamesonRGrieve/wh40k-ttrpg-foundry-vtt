{{! Rogue Trader Assign Damage Card - Modern Design }}
<div class="wh40k-chat tw-font-ui">
    <div class="wh40k-roll-card tw-relative tw-overflow-hidden tw-rounded-md">
        {{! Header }}
        <div class="wh40k-roll-card__header">
            <div class="wh40k-roll-card__actor">{{this.actor.name}}</div>
            {{#if hasDamage}}<h2 class="wh40k-roll-card__title">{{this.hit.location}} Hit</h2>{{else}}<h2 class="wh40k-roll-card__title">Damage Applied</h2>{{/if}}
        </div>

        {{! Body }}
        <div class="wh40k-roll-card__body">
            {{! Current Status }}
            <div class="wh40k-roll-card__row">
                <span class="wh40k-roll-card__label">Wounds</span>
                <span class="wh40k-roll-card__value">{{this.actor.system.wounds.value}} / {{this.actor.system.wounds.max}}</span>
            </div>
            <div class="wh40k-roll-card__row">
                <span class="wh40k-roll-card__label">Fatigue</span>
                <span class="wh40k-roll-card__value">{{this.actor.system.fatigue.value}} / {{this.actor.system.fatigue.max}}</span>
            </div>
            <div class="wh40k-roll-card__row">
                <span class="wh40k-roll-card__label">Critical Wounds</span>
                <span class="wh40k-roll-card__value">{{this.actor.system.wounds.critical}}</span>
            </div>

            <div class="wh40k-roll-card__divider"></div>

            {{! Damage Taken }}
            {{#if this.hasDamage}}
                <div class="wh40k-roll-card__damage">
                    <div class="wh40k-roll-card__damage-header">
                        <span class="wh40k-roll-card__damage-title">Wounds Taken</span>
                        <span class="wh40k-roll-card__damage-location">{{this.hit.location}}</span>
                    </div>
                    <div class="wh40k-roll-card__damage-value">{{this.damageTaken}}</div>
                    <div class="wh40k-roll-card__damage-type">{{this.hit.damageType}}</div>
                </div>
            {{/if}}

            {{#if this.hasFatigueDamage}}
                <div class="wh40k-roll-card__notice">
                    <span class="wh40k-roll-card__notice-label">Fatigue</span>
                    <span class="wh40k-roll-card__notice-value">+{{this.fatigueTaken}}</span>
                </div>
            {{/if}}

            {{#if this.hasCriticalDamage}}
                <div class="wh40k-roll-card__fury">
                    <div class="wh40k-roll-card__fury-title">⚠ Critical Damage: {{this.criticalDamageTaken}} ⚠</div>
                    <div class="wh40k-roll-card__fury-effect">{{this.criticalEffect}}</div>
                </div>
            {{/if}}
        </div>
    </div>
</div>