{{!-- Deathwatch Kill-team Cohesion chat card (#162 — core.md §"COHESION"). --}}
{{!-- data-wh40k-system anchors per-system Tailwind variants on the card; --}}
{{!-- the wh40k-rpg class lets utility cascade work outside the sheet root. --}}
<div class="wh40k-rpg wh40k-dw-cohesion-card tw-p-4 tw-rounded-md tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dw:tw-border-bronze tw-bg-[rgba(20,18,12,0.88)]"
     data-wh40k-system="{{gameSystem}}">

    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
        <i class="fas fa-shield-halved tw-text-[1.1rem] dw:tw-text-bronze"></i>
        <div class="tw-font-display tw-uppercase tw-tracking-[0.12em] tw-text-[0.95rem] tw-text-[color:var(--wh40k-text-bright)] dw:tw-text-bronze">
            {{localize headerKey}}
        </div>
    </div>

    <div class="tw-text-[0.9rem] tw-mb-3 tw-text-[color:var(--wh40k-text-bright)]">
        <strong>{{localize outcomeKey}}</strong>
        {{#if rolled}}
            — <span class="tw-tabular-nums">d10 = {{rolled}} {{#if (lte rolled cohesionBefore)}}≤{{else}}&gt;{{/if}} {{cohesionBefore}}</span>
        {{/if}}
    </div>

    {{!-- Pool transition --}}
    <div class="tw-flex tw-justify-between tw-gap-3 tw-text-[0.85rem] tw-mb-3 tw-px-2 tw-py-2 tw-rounded-sm tw-border tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dw:tw-border-bronze tw-bg-[rgba(0,0,0,0.18)]">
        <span class="tw-text-[color:var(--wh40k-text-muted)]">{{localize "WH40K.DW.Cohesion.Pool"}}</span>
        <span class="tw-font-bold tw-tabular-nums tw-text-[color:var(--wh40k-text-bright)]">
            {{cohesionBefore}} <i class="fas fa-arrow-right tw-mx-2 dw:tw-text-bronze"></i> {{cohesionAfter}} / {{cohesionMax}}
        </span>
    </div>

    {{#if sourceKey}}
        <div class="tw-text-xs tw-italic tw-text-[color:var(--wh40k-text-muted)]">
            {{localize sourceKey}}
        </div>
    {{/if}}
</div>
