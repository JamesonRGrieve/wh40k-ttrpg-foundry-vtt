{{! Critical Injury Chat Card }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
      cardClass=(concat "wh40k-injury-card wh40k-injury-card--" damageType)
      outerExtraClass="tw-overflow-hidden tw-rounded-md"
      image=img
      imageAlt=name
      title=name
      badges=(array
          (object class=(concat "wh40k-badge--" severityClass) icon="fa-chart-line" label=severityLabel)
          (iff permanent (object class="tw-bg-[rgb(from_var(--wh40k-accent-psychic)_r_g_b_/_0.2)] tw-text-[#713b87] tw-border tw-border-[rgb(from_var(--wh40k-accent-psychic)_r_g_b_/_0.3)]" icon="fa-infinity" label="Permanent"))
      )
      footerLabel=sourceReference
      footerIcon="fa-book"}}
        <div class="tw-flex tw-gap-2 tw-mb-2 tw-p-1.5 tw-bg-black/[0.03] tw-rounded-md tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-red)] bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
            <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs,2px)] tw-text-[13px] tw-font-semibold">
                <i class="fas {{damageTypeIcon}} tw-text-[var(--wh40k-accent-red)]"></i>
                {{damageTypeLabel}}
            </span>
            <span class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs,2px)] tw-text-[13px] tw-font-semibold">
                <i class="fas {{bodyPartIcon}} tw-text-[var(--wh40k-accent-red)]"></i>
                {{bodyPartLabel}}
            </span>
        </div>

        <div class="tw-px-2 tw-py-2 tw-bg-[rgba(254,245,231,0.5)] tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-red)] tw-rounded-md tw-leading-relaxed">
            {{{effect}}}
        </div>

        {{#if notes}}
            <div class="tw-mt-2 tw-p-1.5 tw-bg-black/[0.03] tw-rounded-md tw-text-[13px] tw-leading-relaxed">
                <strong class="tw-font-semibold tw-text-[#5a5a5a]">Notes:</strong>
                {{notes}}
            </div>
        {{/if}}

        {{#if description}}
            <div class="tw-mt-2 tw-pt-2 tw-border-t tw-border-black/10 tw-text-[14px] tw-leading-relaxed">
                {{{description}}}
            </div>
        {{/if}}
{{/chat-card-shell}}
