{{! Critical Injury Chat Card }}
<div class="wh40k-chat-card wh40k-injury-card wh40k-injury-card--{{damageType}}">
    <header class="wh40k-card-header">
        <img src="{{img}}" alt="{{name}}" class="wh40k-card-icon" />
        <div class="wh40k-card-title-area">
            <h3 class="wh40k-card-title">{{name}}</h3>
            <div class="wh40k-card-badges">
                <span class="wh40k-badge wh40k-badge--{{severityClass}}">
                    <i class="fas fa-chart-line"></i>
                    {{severityLabel}}
                </span>
                {{#if permanent}}
                    <span class="wh40k-badge wh40k-badge--permanent">
                        <i class="fas fa-infinity"></i>
                        Permanent
                    </span>
                {{/if}}
            </div>
        </div>
    </header>

    <div class="wh40k-card-body">
        <div class="wh40k-injury-meta">
            <span class="wh40k-meta-item">
                <i class="fas {{damageTypeIcon}}"></i>
                {{damageTypeLabel}}
            </span>
            <span class="wh40k-meta-item">
                <i class="fas {{bodyPartIcon}}"></i>
                {{bodyPartLabel}}
            </span>
        </div>

        <div class="wh40k-injury-effect">
            {{{effect}}}
        </div>

        {{#if notes}}
            <div class="wh40k-injury-notes">
                <strong>Notes:</strong>
                {{notes}}
            </div>
        {{/if}}

        {{#if description}}
            <div class="wh40k-injury-description">
                {{{description}}}
            </div>
        {{/if}}
    </div>

    {{#if sourceReference}}
        <footer class="wh40k-card-footer">
            <span class="wh40k-source-ref">
                <i class="fas fa-book"></i>
                {{sourceReference}}
            </span>
        </footer>
    {{/if}}
</div>