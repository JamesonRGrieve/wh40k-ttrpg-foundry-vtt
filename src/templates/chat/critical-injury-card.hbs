{{! Critical Injury Chat Card }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
      cardClass=(concat "wh40k-injury-card wh40k-injury-card--" damageType)
      outerExtraClass="tw-overflow-hidden tw-rounded-md"
      image=img
      imageAlt=name
      title=name
      badges=(array
          (object class=(concat "wh40k-badge--" severityClass) icon="fa-chart-line" label=severityLabel)
          (iff permanent (object class="wh40k-badge--permanent" icon="fa-infinity" label="Permanent"))
      )
      footerLabel=sourceReference
      footerIcon="fa-book"}}
        <div class="wh40k-injury-meta">
            <span class="wh40k-meta-item">
                <i class="fas {{damageTypeIcon}}"></i>
                {{damageTypeLabel}}
            </span>
            <span class="wh40k-meta-item">
                <i class="fas {{bodyPartIcon}}"></i>
                {{bodyPartLabel}}
            </span>
        </div>

        <div class="wh40k-injury-effect">
            {{{effect}}}
        </div>

        {{#if notes}}
            <div class="wh40k-injury-notes">
                <strong>Notes:</strong>
                {{notes}}
            </div>
        {{/if}}

        {{#if description}}
            <div class="wh40k-injury-description">
                {{{description}}}
            </div>
        {{/if}}
{{/chat-card-shell}}
