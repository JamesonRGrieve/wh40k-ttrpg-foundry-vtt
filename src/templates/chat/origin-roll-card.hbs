{{!-- Origin Roll Chat Card Template --}}
<div class="tw-overflow-hidden tw-rounded-lg tw-border-2 tw-border-gold-raw bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure tw-shadow-md"{{#if gameSystem}} data-wh40k-system="{{gameSystem}}"{{/if}} style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);">

    {{!-- Header --}}
    <div class="tw-flex tw-items-center tw-justify-between tw-p-3 tw-border-b tw-border-gold-raw" style="background: rgba(201, 160, 99, 0.1);">
        <div class="tw-flex tw-items-center tw-gap-3">
            <img src="{{actorImg}}" alt="{{actor}}" class="tw-w-10 tw-h-10 tw-rounded-full tw-border-2 tw-border-gold-raw" />
            <div class="tw-flex tw-flex-col">
                <h3 class="tw-m-0 tw-text-base" style="color: #e0e0e0;">{{actor}}</h3>
                <p class="tw-m-0 tw-text-sm tw-flex tw-items-center tw-gap-1 tw-text-gold-raw">
                    <i class="fa-solid fa-scroll"></i>
                    {{origin}}
                </p>
            </div>
        </div>
        <div class="tw-w-12 tw-h-12 tw-flex tw-items-center tw-justify-center tw-rounded-full tw-text-xl"
             style="{{#if (eq rollType 'wounds')}}background: radial-gradient(circle, #8b0000 0%, #4a0000 100%); color: #ff6b6b; box-shadow: 0 0 15px rgba(255, 107, 107, 0.3);{{else}}background: radial-gradient(circle, #ffd700 0%, #b8860b 100%); color: #fff; box-shadow: 0 0 15px rgba(255, 215, 0, 0.3);{{/if}}">
            <i class="fa-solid {{#if (eq rollType 'wounds')}}fa-heart{{else}}fa-star{{/if}}"></i>
        </div>
    </div>

    {{!-- Roll Title --}}
    <div class="tw-flex tw-items-center tw-justify-between tw-p-3" style="background: rgba(0, 0, 0, 0.2);">
        <h4 class="tw-m-0 tw-text-md" style="color: #e0e0e0;">Rolling for {{rollTypeLabel}}</h4>
        <span class="tw-text-sm" style="color: #888;">{{timestamp}}</span>
    </div>

    {{!-- Formula --}}
    <div class="tw-p-3" style="background: rgba(0, 0, 0, 0.3); border-top: 1px solid rgba(201, 160, 99, 0.3); border-bottom: 1px solid rgba(201, 160, 99, 0.3);">
        <label class="tw-inline-block tw-mr-2 tw-font-bold tw-text-gold-raw">Formula:</label>
        <code class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-md" style="font-family: 'Courier New', monospace; color: #ffd700; background: rgba(0, 0, 0, 0.4);">{{formula}}</code>
    </div>

    {{!-- Result --}}
    <div class="tw-p-6 tw-text-center tw-relative tw-overflow-hidden"
         style="{{#if (eq rollType 'wounds')}}background: linear-gradient(135deg, rgba(139, 0, 0, 0.2) 0%, transparent 100%);{{/if}}{{#if (eq rollType 'fate')}}background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, transparent 100%);{{/if}}">
        <div class="tw-flex tw-flex-col tw-items-center tw-gap-2 tw-relative">
            <span class="tw-font-bold tw-text-gold-raw" style="font-size: 3.5rem; text-shadow: 0 0 20px rgba(201, 160, 99, 0.5); animation: numberPulse 2s ease-in-out infinite;">{{result}}</span>
            <span class="tw-text-md tw-uppercase" style="color: #e0e0e0; letter-spacing: 2px;">{{rollTypeLabel}}</span>
        </div>
        <div class="tw-mt-4 tw-pt-4 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-relative tw-text-gold-raw" style="border-top: 1px solid rgba(201, 160, 99, 0.3); font-family: 'Courier New', monospace;">
            <i class="fa-solid fa-calculator"></i>
            <span>{{breakdown}}</span>
        </div>
    </div>

    {{!-- Footer --}}
    <div class="tw-p-3 tw-text-center tw-border-t tw-border-gold-raw" style="background: rgba(201, 160, 99, 0.1);">
        <p class="tw-m-0 tw-italic tw-flex tw-items-center tw-justify-center tw-gap-2 tw-text-gold-raw">
            {{#if (eq rollType 'wounds')}}
                <i class="fa-solid fa-shield-heart" style="color: #ffd700;"></i>
                Added to character's starting Wounds
            {{else}}
                <i class="fa-solid fa-hand-sparkles" style="color: #ffd700;"></i>
                Fate guides your path through the void
            {{/if}}
        </p>
    </div>

</div>

<style>
@keyframes numberPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}
</style>
