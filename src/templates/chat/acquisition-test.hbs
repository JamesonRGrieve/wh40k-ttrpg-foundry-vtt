{{! Profit Factor Acquisition Chat Card }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
    cardClass="wh40k-acquisition-card"
    outerExtraClass="tw-overflow-hidden tw-rounded-md"
    title=actor.name
    subtitle="Profit Factor Acquisition"
    iconClass="fa-coins"
    gameSystem=gameSystem
}}
    {{#if item}}
        <p class="tw-m-0 tw-mb-1 tw-text-sm"><strong>Item:</strong> {{item.name}}</p>
    {{/if}}
    <p class="tw-m-0 tw-mb-1 tw-text-sm"><strong>Roll:</strong> {{roll}} vs {{target}}</p>
    {{#if success}}
        <p class="tw-m-0 tw-text-success-l20 tw-font-bold"><i class="fas fa-check-circle"></i> <strong>SUCCESS</strong> ({{dos}} DoS)</p>
    {{else}}
        <p class="tw-m-0 tw-text-failure-l10 tw-font-bold"><i class="fas fa-times-circle"></i> <strong>FAILURE</strong> ({{dos}} DoF)</p>
    {{/if}}
    <p class="tw-m-0 tw-mt-1 tw-text-xs tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-opacity-70 tw-font-semibold tw-uppercase tw-tracking-wide">Acquisition Test</p>
{{/systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs}}
