<div class="tw-p-2">
    <h3>{{actor.name}} - Profit Factor Acquisition</h3>
    {{#if item}}
        <p><strong>Item:</strong> {{item.name}}</p>
    {{/if}}
    <p><strong>Roll:</strong> {{roll}} vs {{target}}</p>
    {{#if success}}
        <p class="tw-text-success-l20 tw-font-bold"><i class="fas fa-check-circle"></i> <strong>SUCCESS</strong> ({{dos}} DoS)</p>
    {{else}}
        <p class="tw-text-failure-l10 tw-font-bold"><i class="fas fa-times-circle"></i> <strong>FAILURE</strong> ({{dos}} DoF)</p>
    {{/if}}
</div>
