{{! Talent Roll Chat Card }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
    cardClass="wh40k-talent-roll-card"
    outerExtraClass="tw-overflow-hidden tw-rounded-md"
    image=item.img
    imageAlt=item.name
    title=item.name
    subtitle="Talent Roll"
    gameSystem=gameSystem
    footerLabel=actor
}}
    {{#if rollDescription}}
    <p class="tw-italic tw-text-sm tw-mb-2">{{rollDescription}}</p>
    {{/if}}

    <div class="tw-p-7 tw-border-[3px] tw-border-solid tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure tw-rounded-md tw-text-center tw-animate-slideDown tw-shadow-[0_0_20px_rgba(201,162,39,0.3)]" style="background: linear-gradient(135deg, var(--wh40k-panel-bg-solid) 0%, var(--wh40k-input-bg) 100%)">
        <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-text-2xl tw-font-bold">
            <span>{{roll.total}}</span>
            <span class="tw-text-sm tw-uppercase tw-opacity-70">vs</span>
            <span>{{targetValue}}</span>
        </div>
        <div class="tw-mt-2">
            {{#if success}}
            <span class="tw-text-success-l20 tw-font-bold"><i class="fas fa-check-circle"></i> Success!</span>
            {{else}}
            <span class="tw-text-failure-l10 tw-font-bold"><i class="fas fa-times-circle"></i> Failure!</span>
            {{/if}}
            <span class="tw-text-sm tw-opacity-80">({{degrees}} Degrees)</span>
        </div>
    </div>

    {{#if item.system.effect}}
    <div class="tw-mt-2 tw-text-sm">
        <strong>Effect:</strong> {{{item.system.effect}}}
    </div>
    {{/if}}
{{/systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs}}
