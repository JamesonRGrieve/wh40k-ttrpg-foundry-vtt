{{!-- Rogue Trader Psychic Action Card - Modern Design --}}
<div class="wh40k-chat tw-font-ui">
    <div class="wh40k-roll-card tw-relative tw-overflow-hidden tw-rounded-md">
        {{!-- Header --}}
        <div class="wh40k-roll-card__header">
            {{#if label}}<div class="wh40k-roll-card__actor">{{label}}</div>{{/if}}
            {{#with rollData}}
                <h2 class="wh40k-roll-card__title">{{name}}</h2>
                {{#if action}}<div class="wh40k-roll-card__subtitle">{{action}}</div>{{/if}}
                {{#if effectString}}<div class="wh40k-roll-card__subtitle">{{effectString}}</div>{{/if}}
            {{/with}}
        </div>
        
        {{!-- Body --}}
        <div class="wh40k-roll-card__body">
            {{#with rollData}}
                {{!-- Modifiers Breakdown --}}
                <div class="wh40k-roll-card__row">
                    <span class="wh40k-roll-card__label">Base</span>
                    <span class="wh40k-roll-card__value">{{baseTarget}}</span>
                </div>
                
                {{#each activeModifiers}}
                    <div class="wh40k-roll-card__row wh40k-roll-card__row--modifier">
                        <span class="wh40k-roll-card__label">{{@key}}</span>
                        <span class="wh40k-roll-card__value {{#if (gt this 0)}}wh40k-roll-card__value--positive{{else if (lt this 0)}}wh40k-roll-card__value--negative{{/if}}">
                            {{#if (gt this 0)}}+{{/if}}{{this}}
                        </span>
                    </div>
                {{/each}}
                
                {{!-- Target Number --}}
                <div class="wh40k-roll-card__target">
                    <span class="wh40k-roll-card__label">Target</span>
                    <span class="wh40k-roll-card__value">{{modifiedTarget}}</span>
                </div>
                
                {{!-- Effects --}}
                {{#each @root.effectOutput as |effect|}}
                    <div class="wh40k-roll-card__effect">
                        <span class="wh40k-roll-card__effect-name">{{effect.name}}</span>
                        <span class="wh40k-roll-card__effect-desc">{{effect.effect}}</span>
                    </div>
                {{/each}}
                
                {{!-- Opposed Roll --}}
                {{#if isOpposed}}
                    <div class="wh40k-roll-card__row">
                        <span class="wh40k-roll-card__label">Opposed {{opposedChar}}</span>
                        <span class="wh40k-roll-card__value">{{opposedRoll.total}} vs {{opposedTarget}} {{#if opposedSuccess}}({{opposedDos}} DoS){{/if}}</span>
                    </div>
                {{/if}}
                
                {{!-- Degrees & Result --}}
                {{#if success}}
                    <div class="wh40k-roll-card__degrees wh40k-roll-card__degrees--success">
                        <span class="wh40k-roll-card__degrees-count">{{dos}}</span>
                        <span class="wh40k-roll-card__degrees-label">Degrees of Success</span>
                    </div>
                    <div class="wh40k-roll-card__result wh40k-roll-card__result--success">
                        <div class="wh40k-roll-card__result-label">Power Manifested</div>
                        <div class="wh40k-roll-card__result-roll">{{roll.total}}</div>
                    </div>
                {{else}}
                    <div class="wh40k-roll-card__degrees wh40k-roll-card__degrees--failure">
                        <span class="wh40k-roll-card__degrees-count">{{dof}}</span>
                        <span class="wh40k-roll-card__degrees-label">Degrees of Failure</span>
                    </div>
                    <div class="wh40k-roll-card__result wh40k-roll-card__result--failure">
                        <div class="wh40k-roll-card__result-label">Power Failed</div>
                        <div class="wh40k-roll-card__result-roll">{{roll.total}}</div>
                    </div>
                {{/if}}
                
                {{!-- Controls --}}
                <div class="wh40k-roll-card__controls">
                    {{#if success}}
                        <button class="wh40k-roll-card__btn wh40k-roll-card__btn--damage roll-control__hide-control" data-toggle="{{@root.id}}">
                            <span class="material-icons">bolt</span>
                            <span>Effect</span>
                        </button>
                    {{else}}
                        <button class="wh40k-roll-card__btn wh40k-roll-card__btn--disabled">
                            <span class="material-icons">bolt</span>
                            <span>Effect</span>
                        </button>
                    {{/if}}
                    <button class="wh40k-roll-card__btn wh40k-roll-card__btn--fate roll-control__fate-reroll" data-roll-id="{{@root.id}}">
                        <span class="material-icons">casino</span>
                        <span>Re-roll</span>
                    </button>
                </div>
            {{/with}}
            
            {{!-- Collapsible Effect --}}
            {{#if rollData.success}}
                <div id="{{@root.id}}" class="wh40k-roll-card__collapse" hidden>
                    <div class="wh40k-roll-card__divider wh40k-roll-card__divider--ornate"></div>
                    <div class="wh40k-roll-card__text">{{{psychicEffect}}}</div>
                </div>
            {{/if}}
        </div>
    </div>
</div>
