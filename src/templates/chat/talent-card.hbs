{{! Rogue Trader Talent Chat Card }}
<div class="wh40k-chat wh40k-talent-card tw-font-ui">
    <div class="wh40k-card tw-relative tw-overflow-hidden tw-rounded-md">
        {{! Header }}
        <div class="wh40k-card-header wh40k-talent-header">
            <img class="wh40k-card-icon" src="{{talent.img}}" alt="{{talent.name}}" />
            <div class="wh40k-card-title-group">
                <h3 class="wh40k-card-title">{{talent.name}}</h3>
                <div class="wh40k-card-badges">
                    <span class="wh40k-badge wh40k-badge-tier {{tierColor talent.tier}}">
                        <i class="fas fa-layer-group"></i>
                        {{talent.tierLabel}}
                    </span>
                    <span class="wh40k-badge wh40k-badge-category">
                        <i class="fas {{talentIcon talent.category}}"></i>
                        {{talent.category}}
                    </span>
                    {{#if talent.isPassive}}
                        <span class="wh40k-badge wh40k-badge-passive">
                            <i class="fas fa-circle"></i>
                            Passive
                        </span>
                    {{else}}
                        <span class="wh40k-badge wh40k-badge-active">
                            <i class="fas fa-bolt"></i>
                            Active
                        </span>
                    {{/if}}
                </div>
            </div>
        </div>

        {{! Body }}
        <div class="wh40k-card-body">
            {{! Prerequisites Section }}
            {{#if talent.hasPrerequisites}}
                <div class="wh40k-card-section wh40k-prerequisites">
                    <h4 class="wh40k-section-title">
                        <i class="fas fa-tasks"></i>
                        Prerequisites
                    </h4>
                    <div class="wh40k-section-content">
                        {{talent.prerequisitesLabel}}
                    </div>
                </div>
            {{/if}}

            {{! Benefit Section }}
            <div class="wh40k-card-section wh40k-benefit">
                <h4 class="wh40k-section-title">
                    <i class="fas fa-star"></i>
                    Benefit
                </h4>
                <div class="wh40k-section-content wh40k-benefit-text">
                    {{{talent.benefit}}}
                </div>
            </div>

            {{! Specialization (if present) }}
            {{#if talent.specialization}}
                <div class="wh40k-card-section wh40k-specialization">
                    <h4 class="wh40k-section-title">
                        <i class="fas fa-tag"></i>
                        Specialization
                    </h4>
                    <div class="wh40k-section-content">
                        {{talent.specialization}}
                        {{#if talent.stackable}}
                            {{#if talent.rank}}
                                <span class="wh40k-rank">(Rank {{talent.rank}})</span>
                            {{/if}}
                        {{/if}}
                    </div>
                </div>
            {{/if}}
        </div>

        {{! Footer }}
        <div class="wh40k-card-footer wh40k-talent-footer">
            <div class="wh40k-footer-row">
                {{#if talent.aptitudes.length}}
                    <div class="wh40k-footer-item">
                        <strong>Aptitudes:</strong>
                        <div class="wh40k-aptitudes-list">
                            {{#each talent.aptitudes as |apt|}}
                                <span class="wh40k-badge wh40k-badge-aptitude">{{apt}}</span>
                            {{/each}}
                        </div>
                    </div>
                {{/if}}

                <div class="wh40k-footer-item">
                    <strong>Cost:</strong>
                    {{talent.costLabel}}
                </div>
            </div>

            <div class="wh40k-footer-timestamp">
                <i class="far fa-clock"></i>
                {{timestamp}}
            </div>
        </div>
    </div>
</div>