{{!-- Push the Limit Operate-test result chat card (#101 — without.md p. 62). --}}
{{!-- data-wh40k-system anchors per-system Tailwind variants on the card; --}}
{{!-- the wh40k-rpg class lets utility cascade work outside the sheet root. --}}
<div class="wh40k-rpg wh40k-push-the-limit-card tw-p-4 tw-rounded-md tw-border tw-border-amber-500 tw-bg-[rgba(28,16,8,0.9)]"
     data-wh40k-system="{{gameSystem}}">
    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
        <i class="fas fa-tachometer-alt tw-text-[1.1rem] tw-text-amber-300"></i>
        <div class="tw-font-display tw-uppercase tw-tracking-[0.12em] tw-text-[0.95rem] tw-text-amber-200">
            {{localize "WH40K.WithoutTalents.PushTheLimit.ChatTitle"}}
        </div>
    </div>

    <div class="tw-text-[0.95rem] tw-mb-3 tw-text-[#e8e4d9]">
        <strong class="tw-text-amber-200">{{actorName}}</strong>
        — {{#if invoked}}<span class="tw-text-amber-300">{{localize "WH40K.WithoutTalents.PushTheLimit.InvokedTag"}}</span>{{else}}<span class="tw-text-stone-400">{{localize "WH40K.WithoutTalents.PushTheLimit.NotInvokedTag"}}</span>{{/if}}
    </div>

    <ul class="tw-list-none tw-p-0 tw-m-0 tw-flex tw-flex-col tw-gap-1 tw-text-[0.85rem] tw-mb-3">
        {{#if invoked}}
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-amber-300">{{localize "WH40K.WithoutTalents.PushTheLimit.BonusLabel"}}</span>
            <span class="tw-font-bold tw-tabular-nums tw-text-emerald-300">+{{modifier}}</span>
        </li>
        {{/if}}
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-amber-300">{{localize "WH40K.WithoutTalents.PushTheLimit.DegreesLabel"}}</span>
            <span class="tw-font-bold tw-tabular-nums tw-text-amber-100">{{degrees}}</span>
        </li>
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-amber-300">{{localize "WH40K.WithoutTalents.PushTheLimit.OutcomeLabel"}}</span>
            <span class="tw-font-bold {{#if success}}tw-text-emerald-300{{else}}tw-text-rose-300{{/if}}">
                {{#if success}}{{localize "WH40K.WithoutTalents.PushTheLimit.Success"}}{{else}}{{localize "WH40K.WithoutTalents.PushTheLimit.Failure"}}{{/if}}
            </span>
        </li>
    </ul>

    {{#if triggersCritical}}
    <div class="tw-p-2 tw-rounded-sm tw-border tw-border-rose-500/60 tw-bg-[rgba(127,29,29,0.3)] tw-text-[0.85rem] tw-text-rose-100">
        <div class="tw-text-xs tw-uppercase tw-tracking-[0.08em] tw-text-rose-300 tw-mb-1">
            <i class="fas fa-skull-crossbones tw-mr-1"></i>{{localize "WH40K.WithoutTalents.PushTheLimit.CriticalLabel"}}
        </div>
        <div>{{localize criticalTableKey}}</div>
    </div>
    {{/if}}
</div>
