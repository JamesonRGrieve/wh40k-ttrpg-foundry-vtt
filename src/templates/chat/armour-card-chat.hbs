{{!--
  Rogue Trader Armour Chat Card - Modern Compact Design
  For vocalizing armour items to chat with coverage and protection info.
--}}
<div class="wh40k-chat">
  <div class="wh40k-armour-card" data-item-id="{{item._id}}" data-item-uuid="{{item.uuid}}" {{#if actor}}data-actor-id="{{actor._id}}" data-actor-uuid="{{actor.uuid}}"{{/if}}>
    
    {{!-- Header --}}
    <div class="wh40k-armour-card__header">
      <img class="wh40k-armour-card__image" src="{{item.img}}" alt="{{item.name}}" />
      <div class="wh40k-armour-card__title">
        <h2 class="wh40k-armour-card__name">{{item.name}}</h2>
        <div class="wh40k-armour-card__meta">
          <span class="wh40k-armour-card__type">{{item.system.typeLabel}}</span>
          {{#if (ne item.system.craftsmanship "common")}}
          <span class="wh40k-armour-card__divider">•</span>
          <span class="wh40k-armour-card__craft wh40k-armour-card__craft--{{item.system.craftsmanship}}">{{item.system.craftsmanshipLabel}}</span>
          {{/if}}
        </div>
      </div>
    </div>
    
    {{!-- Coverage Visual --}}
    <div class="wh40k-armour-card__coverage">
      {{#each item.system.locationArray as |loc|}}
      <div class="wh40k-armour-card__location {{#if loc.covered}}wh40k-armour-card__location--covered{{/if}}">
        <span class="wh40k-armour-card__location-label">{{loc.abbr}}</span>
        <span class="wh40k-armour-card__location-ap">{{loc.ap}}</span>
      </div>
      {{/each}}
    </div>
    
    {{!-- Stats --}}
    <div class="wh40k-armour-card__stats">
      <div class="wh40k-armour-card__stat">
        <span class="wh40k-armour-card__stat-label">Coverage</span>
        <span class="wh40k-armour-card__stat-value">{{item.system.coverageLabel}}</span>
      </div>
      <div class="wh40k-armour-card__stat">
        <span class="wh40k-armour-card__stat-label">Max AP</span>
        <span class="wh40k-armour-card__stat-value">{{item.system.maxAP}}</span>
      </div>
      {{#if item.system.maxAgility}}
      <div class="wh40k-armour-card__stat">
        <span class="wh40k-armour-card__stat-label">Max Ag</span>
        <span class="wh40k-armour-card__stat-value">{{item.system.maxAgility}}</span>
      </div>
      {{/if}}
      {{#if item.system.weight}}
      <div class="wh40k-armour-card__stat">
        <span class="wh40k-armour-card__stat-label">Weight</span>
        <span class="wh40k-armour-card__stat-value">{{item.system.weightLabel}}</span>
      </div>
      {{/if}}
    </div>
    
    {{!-- Properties --}}
    {{#if item.system.hasProperties}}
    <div class="wh40k-armour-card__properties">
      {{#each item.system.propertiesArray as |prop|}}
      <span class="wh40k-armour-card__property" data-tooltip="{{prop.description}}">
        {{prop.label}}
      </span>
      {{/each}}
    </div>
    {{/if}}
    
    {{!-- Description (if exists) --}}
    {{#if item.system.description.value}}
    <div class="wh40k-armour-card__description">
      {{{item.system.description.value}}}
    </div>
    {{/if}}
    
    {{!-- Footer --}}
    {{#if item.system.source}}
    <div class="wh40k-armour-card__footer">
      <span class="wh40k-armour-card__source">{{item.system.source}}</span>
    </div>
    {{/if}}
    
  </div>
</div>
