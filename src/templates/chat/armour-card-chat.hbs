{{!--
  Rogue Trader Armour Chat Card - Modern Compact Design
  For vocalizing armour items to chat with coverage and protection info.
--}}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
    cardClass="wh40k-armour-card"
    outerExtraClass="tw-overflow-hidden tw-rounded-md tw-font-ui"
    image=item.img
    imageAlt=item.name
    title=item.name
    subtitle=(iff (ne item.system.craftsmanship "common")
        (concat item.system.typeLabel " • " item.system.craftsmanshipLabel)
        item.system.typeLabel)
    gameSystem=gameSystem
    footerLabel=item.system.source
}}
    {{!-- Coverage Visual --}}
    <div class="tw-flex tw-flex-wrap tw-gap-1 tw-pb-2 tw-mb-2 tw-border-b tw-border-[var(--wh40k-border-color-light)] bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure">
      {{#each item.system.locationArray as |loc|}}
      <div class="tw-flex tw-flex-col tw-items-center tw-gap-0.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-text-xs {{#if loc.covered}}tw-bg-[var(--wh40k-accent-overlay)] tw-border-[var(--wh40k-bronze)] tw-text-[var(--wh40k-text-dark)]{{else}}tw-bg-transparent tw-border-[var(--wh40k-border-color-light)] tw-text-[var(--wh40k-text-muted)] tw-opacity-50{{/if}}">
        <span class="tw-font-semibold tw-uppercase tw-tracking-wide">{{loc.abbr}}</span>
        <span class="tw-font-bold">{{loc.ap}}</span>
      </div>
      {{/each}}
    </div>

    {{!-- Stats --}}
    <div class="tw-grid tw-grid-cols-2 tw-gap-1">
      <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-sm">
        <span class="tw-text-[var(--wh40k-text-muted)] tw-font-medium">Coverage</span>
        <span class="tw-font-semibold tw-text-[var(--wh40k-text-dark)]">{{item.system.coverageLabel}}</span>
      </div>
      <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-sm">
        <span class="tw-text-[var(--wh40k-text-muted)] tw-font-medium">Max AP</span>
        <span class="tw-font-semibold tw-text-[var(--wh40k-text-dark)]">{{item.system.maxAP}}</span>
      </div>
      {{#if item.system.maxAgility}}
      <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-sm">
        <span class="tw-text-[var(--wh40k-text-muted)] tw-font-medium">Max Ag</span>
        <span class="tw-font-semibold tw-text-[var(--wh40k-text-dark)]">{{item.system.maxAgility}}</span>
      </div>
      {{/if}}
      {{#if item.system.weight}}
      <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-sm">
        <span class="tw-text-[var(--wh40k-text-muted)] tw-font-medium">Weight</span>
        <span class="tw-font-semibold tw-text-[var(--wh40k-text-dark)]">{{item.system.weightLabel}}</span>
      </div>
      {{/if}}
    </div>

    {{!-- Properties --}}
    {{#if item.system.hasProperties}}
    <div class="tw-flex tw-flex-wrap tw-gap-1.5 tw-mt-2 tw-pt-2 tw-border-t tw-border-[var(--wh40k-border-color-light)]">
      {{#each item.system.propertiesArray as |prop|}}
      <span class="tw-inline-block tw-px-2 tw-py-0.5 tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-wide tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded tw-text-[var(--wh40k-bronze)]" data-tooltip="{{prop.description}}">
        {{prop.label}}
      </span>
      {{/each}}
    </div>
    {{/if}}

    {{!-- Description (if exists) --}}
    {{#if item.system.description.value}}
    <div class="tw-mt-2 tw-pt-2 tw-text-sm tw-leading-relaxed tw-text-[var(--wh40k-text-dark)] tw-border-t tw-border-[var(--wh40k-border-color-light)]">
      {{{item.system.description.value}}}
    </div>
    {{/if}}
{{/systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs}}
