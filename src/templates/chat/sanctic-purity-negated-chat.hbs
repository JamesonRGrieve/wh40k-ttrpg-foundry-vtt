{{!-- Sanctic Purity / Emperor's Anathema "Phenomena Negated" chat card (#131). --}}
{{!-- data-wh40k-system anchors per-system Tailwind variants on the card. --}}
<div class="wh40k-rpg wh40k-spc-card tw-p-4 tw-rounded-md tw-border tw-border-[rgba(201,162,39,0.35)] dh2:tw-border-gold tw-bg-[rgba(15,12,8,0.85)] dh2:tw-bg-amber-900/30"
     data-wh40k-system="{{gameSystem}}">
    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
        <i class="fas fa-shield-cross tw-text-[#c9a227] dh2:tw-text-gold tw-text-[1.1rem]"></i>
        <div class="tw-font-display tw-uppercase tw-tracking-[0.12em] tw-text-[0.95rem] tw-text-gold dh2:tw-text-gold">
            {{localize "WH40K.SancticPurity.NegatedChatTitle"}}
        </div>
    </div>
    <div class="tw-text-[0.9rem] tw-mb-3 tw-text-[#e8e4d9]">
        {{localize "WH40K.SancticPurity.NegatedChatBody"}}
    </div>
    <ul class="tw-list-none tw-p-0 tw-m-0 tw-flex tw-flex-col tw-gap-1 tw-text-[0.85rem]">
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-[#9a9a8a]">{{actorName}}</span>
            <span class="tw-font-bold tw-tabular-nums tw-text-gold dh2:tw-text-gold">
                <i class="fas fa-coins"></i> -{{fateCost}}
            </span>
        </li>
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-[#9a9a8a]">{{localize "WH40K.SancticPurity.EmperorsAnathema"}}</span>
            <span class="tw-font-bold tw-tabular-nums">{{fateBefore}} &rarr; {{fateAfter}}</span>
        </li>
    </ul>
</div>
