{{!--
    Re-roll variant buttons (shared across simple / action / psychic roll cards).

    Renders one button per available re-roll variant from
    `ActionData.rerollOptions` — talent/trait re-rolls (e.g. Keen Intuition) AND
    the global Spend-Fate re-roll — replacing the former single Spend-Fate
    button. Each card embeds this inside its existing fate-controls wrapper (which
    keeps the separate "+1 DoS" control + the target-only / manual guards). The
    shared handler `_variantReroll` in basic-action-manager reads the variant off
    the `data-variant-*` attributes. The card root carries `.wh40k-rpg` (added by
    the renderChatMessageHTML hook) so these `tw-` utilities resolve.

    Params: rerollOptions (RerollOption[]), rollId.
--}}
{{#each rerollOptions}}
<button class="roll-control__variant-reroll tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-2 tw-py-[5px] tw-bg-[var(--wh40k-powers-bg)] tw-border tw-border-[var(--wh40k-powers-border)] tw-rounded-md tw-text-[var(--wh40k-powers-secondary)] tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-whitespace-nowrap hover:tw-bg-[rgba(106,32,144,0.2)] hover:tw-border-[var(--wh40k-powers-primary)] hover:tw-shadow-[0_0_12px_rgba(106,32,144,0.4)] hover:-tw-translate-y-px active:tw-translate-y-0 disabled:tw-opacity-40 disabled:tw-cursor-not-allowed" {{#if disabled}}disabled{{/if}} data-roll-id="{{../rollId}}" data-variant-id="{{id}}" data-variant-kind="{{kind}}" data-variant-modifier="{{modifier}}">
    <span class="material-icons tw-text-[14px]">casino</span>
    <span>{{#if modifier}}{{localize "WH40K.Reroll.WithModifier" label=label modifier=modifier}}{{else}}{{label}}{{/if}}</span>
</button>
{{/each}}
