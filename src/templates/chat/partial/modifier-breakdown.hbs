{{!--
    Modifier breakdown — Base + each active modifier + Target row.
    Used inside the body of action-roll and psychic-action chat cards.

    Hash params:
        baseTarget       — required, the base value before modifiers
        activeModifiers  — required, object/map of label → numeric delta
        modifiedTarget   — required, the final target number after modifiers
        baseLabel        — optional, default "Base"
        targetLabel      — optional, default "Target"
--}}
<div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-[0.9rem]">
    <span class="tw-text-[var(--wh40k-card-muted)] tw-font-medium">{{#if baseLabel}}{{baseLabel}}{{else}}Base{{/if}}</span>
    <span class="tw-font-semibold tw-text-[var(--wh40k-card-text)]">{{baseTarget}}</span>
</div>

{{#each activeModifiers}}
    <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-[0.9rem] tw-pl-3 tw-border-l-2 tw-border-l-[var(--wh40k-border-color)] tw-ml-1">
        <span class="tw-text-[var(--wh40k-card-muted)] tw-font-medium">{{@key}}</span>
        <span class="tw-font-semibold {{#if (gt this 0)}}tw-text-[var(--wh40k-success-secondary)]{{else if (lt this 0)}}wh40k-roll-card__value--negative tw-text-[var(--wh40k-danger-secondary)]{{else}}tw-text-[var(--wh40k-card-text)]{{/if}}">
            {{#if (gt this 0)}}+{{/if}}{{this}}
        </span>
    </div>
{{/each}}

<div class="tw-flex tw-justify-between tw-items-center tw-px-3 tw-py-2 tw-my-2 tw-bg-[var(--wh40k-accent-overlay)] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-md">
    <span class="tw-text-[var(--wh40k-card-muted)] tw-font-semibold tw-uppercase tw-tracking-[0.05em]">{{#if targetLabel}}{{targetLabel}}{{else}}Target{{/if}}</span>
    <span class="tw-text-[1.2rem] tw-font-bold tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">{{modifiedTarget}}</span>
</div>
