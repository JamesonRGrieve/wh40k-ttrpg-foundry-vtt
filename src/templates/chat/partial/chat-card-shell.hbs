{{!--
    Chat card shell — outer wrapper, header (image | icon | custom),
    body container, optional footer. Used by the simple `wh40k-chat-card`
    family (talent / trait / condition / critical-injury / movement / etc).

    Block-partial usage:
        Block partial with body content supplied through the partial-block slot.

    Required hash params:
        cardClass        — class for the outer card div (e.g. "wh40k-talent-card")
        title            — display title text

    Optional hash params:
        outerExtraClass  — extra Tailwind classes on the outer card div
        image            — image src URL (renders <img>); skip for icon variant
        imageAlt         — alt text (defaults to title)
        iconClass        — Font Awesome class (e.g. "fa-tag") for icon-wrapper variant
        subtitle         — secondary line under the title
        badges           — array of badge entries: { class, icon, label }
        footerLabel      — single-string footer (e.g. source reference)
        footerIcon       — Font Awesome class for footer icon
        legacyClasses    — bool; when true emit legacy classes alongside new BEM
                           ones for back-compat with already-rendered chat
                           messages (default true).

    Body content is delivered via the partial-block slot.

    Inline-partial slots (override via {{#*inline "<name>"}}…{{/inline}}):
        header           — replaces the entire header block
        footer           — replaces the entire footer block
--}}
<div class="wh40k-chat-card {{cardClass}}{{#if outerExtraClass}} {{outerExtraClass}}{{/if}}"{{#if gameSystem}} data-wh40k-system="{{gameSystem}}"{{/if}}>
    {{#if (or image iconClass title badges)}}
    <header class="wh40k-card__header{{#unless (eq legacyClasses false)}} wh40k-card-header{{/unless}} tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)] tw-p-3 tw-border-b tw-border-[rgba(0,0,0,0.1)] dh2e:tw-border-bronze rt:tw-border-accent-dynasty bc:tw-border-crimson dw:tw-border-bronze ow:tw-border-brass im:tw-border-crimson-light dh1e:tw-border-gold-raw">
        {{#if image}}
            <img class="wh40k-card__icon{{#unless (eq legacyClasses false)}} wh40k-card-icon{{/unless}} tw-w-12 tw-h-12 tw-rounded-full tw-border-2 tw-border-[rgba(255,255,255,0.8)] tw-object-cover tw-shrink-0" src="{{image}}" alt="{{#if imageAlt}}{{imageAlt}}{{else}}{{title}}{{/if}}" />
        {{else if iconClass}}
            <div class="wh40k-card__icon-wrapper{{#unless (eq legacyClasses false)}} wh40k-card-icon-wrapper{{/unless}} tw-w-10 tw-h-10 tw-flex tw-items-center tw-justify-center tw-rounded-full tw-shrink-0">
                <i class="fas {{iconClass}} wh40k-card__icon{{#unless (eq legacyClasses false)}} wh40k-card-icon{{/unless}}"></i>
            </div>
        {{/if}}
        <div class="wh40k-card__title-area{{#unless (eq legacyClasses false)}} wh40k-card-title-area{{/unless}} tw-flex-1 tw-min-w-0">
            <h3 class="wh40k-card__title{{#unless (eq legacyClasses false)}} wh40k-card-title{{/unless}} tw-m-0 tw-text-[18px] tw-font-bold">{{title}}</h3>
            {{#if subtitle}}
                <div class="wh40k-card__subtitle{{#unless (eq legacyClasses false)}} wh40k-card-subtitle{{/unless}} tw-text-[12px] tw-uppercase tw-tracking-[0.5px] tw-opacity-90">{{subtitle}}</div>
            {{/if}}
            {{#if badges.length}}
                <div class="wh40k-card__badges{{#unless (eq legacyClasses false)}} wh40k-card-badges{{/unless}} tw-flex tw-gap-[var(--wh40k-space-xs)] tw-mt-[var(--wh40k-space-xs)] tw-flex-wrap">
                    {{#each badges as |badge|}}
                        {{#if badge.label}}
                        <span class="wh40k-badge{{#if badge.class}} {{badge.class}}{{/if}}">
                            {{#if badge.icon}}<i class="fas {{badge.icon}}"></i>{{/if}}
                            {{badge.label}}
                        </span>
                        {{/if}}
                    {{/each}}
                </div>
            {{/if}}
        </div>
    </header>
    {{/if}}

    <div class="wh40k-card__body{{#unless (eq legacyClasses false)}} wh40k-card-body{{/unless}} tw-p-3">
        {{> @partial-block}}
    </div>

    {{#if footerLabel}}
    <footer class="wh40k-card__footer{{#unless (eq legacyClasses false)}} wh40k-card-footer{{/unless}} tw-px-3 tw-py-2 tw-border-t tw-border-[#d4c5a6] dh2e:tw-border-bronze rt:tw-border-accent-dynasty bc:tw-border-crimson dw:tw-border-bronze ow:tw-border-brass im:tw-border-crimson-light dh1e:tw-border-gold-raw">
        <span class="wh40k-card__source{{#unless (eq legacyClasses false)}} wh40k-source-ref{{/unless}} tw-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-text-[11px] tw-text-[#7a7a7a]">
            {{#if footerIcon}}<i class="fas {{footerIcon}}"></i>{{/if}}
            {{footerLabel}}
        </span>
    </footer>
    {{/if}}
</div>
