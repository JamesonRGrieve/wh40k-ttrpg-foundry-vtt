{{! Rich chat card for trait vocalization }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
    cardClass=(concat 'wh40k-chat-card--trait ' (traitCategoryColor category))
    outerExtraClass="tw-overflow-hidden tw-rounded-md"
    title=trait.name
    iconClass=(traitIcon category)
    gameSystem=gameSystem
    badges=(array
        (hash class=(concat 'wh40k-badge--category ' (traitCategoryColor category)) icon=(traitIcon category) label=categoryLabel)
        (hash class="wh40k-badge--level" label=(iff hasLevel (concat 'Level ' level) ''))
        (hash class="wh40k-badge--variable" icon="fa-adjust" label=(iff isVariable 'Variable' '')))
    footerLabel=timestamp
    footerIcon="fa-clock"
}}
    {{#if requirements}}
    <section class="wh40k-card-section wh40k-card-section--requirements">
        <h4 class="wh40k-card-section-title">
            <i class="fas fa-lock"></i>
            Requirements
        </h4>
        <p class="wh40k-card-section-content">{{requirements}}</p>
    </section>
    {{/if}}

    <section class="wh40k-card-section wh40k-card-section--benefit bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure">
        <h4 class="wh40k-card-section-title">
            <i class="fas fa-sparkles"></i>
            Effect
        </h4>
        <div class="wh40k-card-section-content wh40k-prose">
            {{{benefit}}}
        </div>
    </section>

    {{#if notes}}
    <section class="wh40k-card-section wh40k-card-section--notes">
        <h4 class="wh40k-card-section-title">
            <i class="fas fa-sticky-note"></i>
            Notes
        </h4>
        <p class="wh40k-card-section-content">{{notes}}</p>
    </section>
    {{/if}}
{{/systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs}}
