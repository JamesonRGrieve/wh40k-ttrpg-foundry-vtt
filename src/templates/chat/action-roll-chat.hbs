{{!-- Rogue Trader Action Roll Card - Modern Design --}}
<div class="tw-font-ui">
    <div class="tw-relative tw-overflow-hidden tw-rounded-md tw-border-2 tw-border-gold tw-bg-[var(--wh40k-card-bg)] tw-shadow-[0_4px_12px_var(--wh40k-shadow-medium),inset_0_1px_0_var(--wh40k-accent-overlay)]">
        {{!-- Header --}}
        <div class="tw-relative tw-px-4 tw-py-3 tw-bg-[linear-gradient(90deg,var(--wh40k-accent-overlay)_0%,transparent_100%)] tw-border-b tw-border-[var(--wh40k-border-color)]">
            {{#if label}}<div class="tw-text-[0.75rem] tw-text-[var(--wh40k-card-muted)] tw-uppercase tw-tracking-[0.1em] tw-mb-1">{{label}}</div>{{/if}}
            {{#with rollData}}
                <h2 class="tw-font-display tw-text-[1.1rem] tw-font-semibold tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-uppercase tw-tracking-[0.05em] tw-m-0 tw-shadow-[0_2px_4px_var(--wh40k-shadow-medium)]">{{name}}</h2>
                {{#if action}}<div class="tw-text-[0.85rem] tw-text-[var(--wh40k-card-text)] tw-mt-0.5 tw-opacity-90">{{action}}</div>{{/if}}
                {{#if effectString}}<div class="tw-text-[0.85rem] tw-text-[var(--wh40k-card-text)] tw-mt-0.5 tw-opacity-90">{{effectString}}</div>{{/if}}
                {{#if isManualRoll}}
                    <div class="tw-inline-flex tw-items-center tw-gap-[var(--wh40k-space-xs)] tw-px-2.5 tw-py-[3px] tw-mt-1.5 tw-bg-[rgba(168,85,247,0.15)] tw-border tw-border-[rgba(168,85,247,0.4)] tw-rounded-[3px] tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-[#c084fc]"><i class="fas fa-hand-paper tw-text-[0.65rem]"></i> Player Rolled</div>
                {{/if}}
            {{/with}}
        </div>

        {{!-- Body --}}
        <div class="tw-px-4 tw-py-3">
            {{#with rollData}}
                {{!-- Weapon Qualities --}}
                {{#if weapon}}
                    {{#if weapon.system.effectiveSpecial.size}}
                        <div class="tw-mb-4 tw-p-3 tw-bg-[linear-gradient(135deg,rgba(75,192,115,0.08)_0%,rgba(75,192,115,0.03)_100%)] tw-border-l-[3px] tw-border-l-[rgba(75,192,115,0.5)] tw-rounded-md">
                            <div class="tw-flex tw-items-center tw-gap-1.5 tw-mb-2">
                                <i class="fas fa-star" style="color: #4bc073; font-size: 0.85rem;"></i>
                                <span class="tw-font-semibold tw-text-[0.85rem] tw-text-[var(--wh40k-card-text)] tw-uppercase tw-tracking-[0.5px]">Active Qualities</span>
                            </div>
                            <div class="tw-flex tw-flex-wrap tw-gap-1.5">
                                {{#each (specialQualities weapon.system.effectiveSpecial) as |quality|}}
                                    <span class="tw-inline-block tw-px-2.5 tw-py-1 tw-bg-[rgba(75,192,115,0.15)] tw-border tw-border-[rgba(75,192,115,0.3)] tw-rounded-md tw-text-[#4bc073] tw-text-[0.8rem] tw-font-semibold tw-cursor-help hover:tw-bg-[rgba(75,192,115,0.25)] hover:tw-border-[rgba(75,192,115,0.5)] hover:-tw-translate-y-px hover:tw-transition-all" data-tooltip="{{quality.description}}" title="{{quality.description}}">
                                        {{quality.label}}{{#if quality.level}} ({{quality.level}}){{/if}}
                                    </span>
                                {{/each}}
                            </div>
                        </div>
                    {{/if}}
                {{/if}}

                {{#unless ignoreModifiers}}
                    {{> systems/wh40k-rpg/templates/chat/partial/modifier-breakdown.hbs baseTarget=baseTarget activeModifiers=activeModifiers modifiedTarget=modifiedTarget}}
                {{/unless}}

                {{#if usesAmmo}}
                    <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-[0.9rem]">
                        <span class="tw-text-[var(--wh40k-card-muted)] tw-font-medium">Ammo Used</span>
                        <span class="tw-font-semibold tw-text-[var(--wh40k-card-text)]">{{ammoUsed}}</span>
                    </div>
                {{/if}}

                {{!-- Effects --}}
                {{#each @root.effectOutput as |effect|}}
                    <div class="tw-flex tw-items-start tw-gap-[var(--wh40k-space-sm)] tw-py-1.5 tw-text-[0.85rem]">
                        <span class="tw-font-semibold tw-text-gold tw-shrink-0">{{effect.name}}</span>
                        <span class="tw-text-[var(--wh40k-card-text)] tw-opacity-90">{{effect.effect}}</span>
                    </div>
                {{/each}}

                {{!-- Opposed Roll --}}
                {{#if isOpposed}}
                    <div class="tw-flex tw-justify-between tw-items-center tw-py-1 tw-text-[0.9rem]">
                        <span class="tw-text-[var(--wh40k-card-muted)] tw-font-medium">Opposed {{opposedChar}}</span>
                        <span class="tw-font-semibold tw-text-[var(--wh40k-card-text)]">{{opposedRoll.total}} vs {{opposedTarget}} {{#if opposedSuccess}}({{opposedDos}} DoS){{/if}}</span>
                    </div>
                {{/if}}

                {{!-- Degrees --}}
                {{#unless ignoreDegrees}}
                  {{#unless isTargetOnly}}
                    {{#if success}}
                        <div class="tw-flex tw-justify-center tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-rounded-md">
                            <span class="tw-text-[1.5rem] tw-font-bold tw-text-[var(--wh40k-success-secondary)]">{{dos}}</span>
                            <span class="tw-text-[0.8rem] tw-uppercase tw-tracking-[0.1em] tw-opacity-80">Degrees of Success</span>
                        </div>
                    {{else}}
                        <div class="tw-flex tw-justify-center tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-mt-2 tw-px-4 tw-py-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-rounded-md">
                            <span class="tw-text-[1.5rem] tw-font-bold tw-text-[var(--wh40k-danger-secondary)]">{{dof}}</span>
                            <span class="tw-text-[0.8rem] tw-uppercase tw-tracking-[0.1em] tw-opacity-80">Degrees of Failure</span>
                        </div>
                    {{/if}}
                  {{/unless}}
                {{/unless}}

                {{!-- Target-only display (no roll entered) --}}
                {{#if isTargetOnly}}
                    <div class="tw-text-center tw-px-3 tw-py-2 tw-my-2 tw-bg-[rgba(201,162,39,0.08)] tw-border tw-border-dashed tw-border-[rgba(201,162,39,0.3)] tw-rounded-md tw-text-[0.8rem] tw-italic tw-text-[var(--wh40k-card-muted)]">
                        Target posted - awaiting physical dice roll
                    </div>
                {{/if}}

                {{!-- Result Display --}}
                {{#unless ignoreSuccess}}
                  {{#unless isTargetOnly}}
                    {{#if success}}
                        <div class="tw-relative tw-text-center tw-p-4 tw-my-3 tw-rounded-md tw-bg-[var(--wh40k-success-bg)] tw-border-2 tw-border-[var(--wh40k-success-primary)] tw-shadow-[0_0_20px_var(--wh40k-card-success-glow),inset_0_0_30px_rgba(45,138,78,0.1)]">
                            <div class="tw-font-display tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.15em] tw-mb-1 tw-text-[var(--wh40k-success-secondary)]">Success</div>
                            <div class="tw-text-[2.5rem] tw-font-bold tw-leading-none tw-shadow-[0_2px_8px_var(--wh40k-shadow-medium)]">{{roll.total}}</div>
                        </div>
                        {{#if hitLocation}}
                            <div class="tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-4 tw-py-1.5 tw-text-gold tw-text-[0.85rem] tw-font-semibold tw-uppercase tw-tracking-[0.06em]">
                                <i class="fas fa-crosshairs tw-text-[0.75rem] tw-opacity-70"></i>
                                <span>{{hitLocation}}</span>
                            </div>
                        {{/if}}
                    {{else}}
                        <div class="tw-relative tw-text-center tw-p-4 tw-my-3 tw-rounded-md tw-bg-[var(--wh40k-danger-bg)] tw-border-2 tw-border-[var(--wh40k-danger-primary)] tw-shadow-[0_0_20px_var(--wh40k-card-fail-glow),inset_0_0_30px_rgba(168,50,50,0.1)]">
                            <div class="tw-font-display tw-text-[0.9rem] tw-font-semibold tw-uppercase tw-tracking-[0.15em] tw-mb-1 tw-text-[var(--wh40k-danger-secondary)]">Failure</div>
                            <div class="tw-text-[2.5rem] tw-font-bold tw-leading-none tw-shadow-[0_2px_8px_var(--wh40k-shadow-medium)]">{{roll.total}}</div>
                        </div>
                    {{/if}}
                  {{/unless}}
                {{/unless}}

                {{!-- Action Controls --}}
                {{#unless ignoreControls}}
                    <div class="tw-flex tw-flex-col tw-gap-1.5 tw-px-4 tw-py-2.5 tw-mt-2 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color)]">
                        {{#if showDamage}}
                            <button class="roll-control__roll-damage tw-flex-none tw-w-full tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-bg-[var(--wh40k-wounds-bg)] tw-border tw-border-[var(--wh40k-wounds-border)] tw-rounded-md tw-text-[var(--wh40k-wounds-secondary)] tw-text-[0.8rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-whitespace-nowrap hover:tw-bg-[rgba(139,0,0,0.2)] hover:tw-border-[var(--wh40k-wounds-primary)] hover:tw-shadow-[0_0_12px_rgba(139,0,0,0.4)] hover:-tw-translate-y-px active:tw-translate-y-0" data-roll-id="{{@root.id}}">
                                <span class="material-icons tw-text-[16px]">bolt</span>
                                <span>Roll Damage</span>
                            </button>
                        {{else}}
                            <button class="tw-flex-none tw-w-full tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-3 tw-py-2 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-md tw-text-gold tw-text-[0.8rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-not-allowed tw-whitespace-nowrap tw-opacity-40">
                                <span class="material-icons tw-text-[16px]">bolt</span>
                                <span>Damage</span>
                            </button>
                        {{/if}}
                        <div class="tw-flex tw-gap-1.5">
                            <button class="roll-control__refund tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-2 tw-py-[5px] tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-md tw-text-gold tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-whitespace-nowrap hover:tw-bg-[var(--wh40k-btn-bg-hover)] hover:tw-border-gold hover:tw-shadow-[0_0_12px_var(--wh40k-gold-glow)] hover:-tw-translate-y-px active:tw-translate-y-0" data-roll-id="{{@root.id}}">
                                <span class="material-icons tw-text-[14px]">deblur</span>
                                <span>{{localize "WH40K.FateRefund"}}</span>
                            </button>
                            {{#if success}}
                                <button class="roll-control__fate-add-dos tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-2 tw-py-[5px] tw-bg-[var(--wh40k-powers-bg)] tw-border tw-border-[var(--wh40k-powers-border)] tw-rounded-md tw-text-[var(--wh40k-powers-secondary)] tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-whitespace-nowrap hover:tw-bg-[rgba(106,32,144,0.2)] hover:tw-border-[var(--wh40k-powers-primary)] hover:tw-shadow-[0_0_12px_rgba(106,32,144,0.4)] hover:-tw-translate-y-px active:tw-translate-y-0" data-roll-id="{{@root.id}}">
                                    <span class="material-icons tw-text-[14px]">add_circle</span>
                                    <span>{{localize "WH40K.FateAddDoS"}}</span>
                                </button>
                            {{/if}}
                            <button class="roll-control__fate-reroll tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-px-2 tw-py-[5px] tw-bg-[var(--wh40k-powers-bg)] tw-border tw-border-[var(--wh40k-powers-border)] tw-rounded-md tw-text-[var(--wh40k-powers-secondary)] tw-text-[0.7rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-whitespace-nowrap hover:tw-bg-[rgba(106,32,144,0.2)] hover:tw-border-[var(--wh40k-powers-primary)] hover:tw-shadow-[0_0_12px_rgba(106,32,144,0.4)] hover:-tw-translate-y-px active:tw-translate-y-0" data-roll-id="{{@root.id}}">
                                <span class="material-icons tw-text-[14px]">casino</span>
                                <span>{{localize "WH40K.FateReroll"}}</span>
                            </button>
                        </div>
                    </div>
                {{/unless}}
            {{/with}}
        </div>
    </div>
</div>
