<div class="tw-flex tw-flex-col">
    <header class="tw-flex tw-flex-row tw-flex-wrap tw-items-center tw-gap-2 tw-p-2">
        <img class="tw-w-8 tw-h-8 tw-rounded tw-object-cover" src="{{item.img}}" alt="{{item.name}}"/>
        <h3 class="tw-flex-1 tw-m-0 tw-text-base tw-font-bold">{{item.name}}</h3>
        <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-text-gold">Ritual</span>
    </header>

    <section class="tw-p-2">
        <div class="tw-p-7 tw-bg-[linear-gradient(135deg,var(--wh40k-panel-bg-solid)_0%,var(--wh40k-input-bg)_100%)] tw-border-[3px] tw-border-solid tw-border-[var(--wh40k-gold)] tw-rounded-md tw-text-center tw-animate-slideDown tw-shadow-[0_0_20px_rgba(201,162,39,0.3)]">
            <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-text-2xl tw-font-bold">
                <span>{{roll.total}}</span>
                <span class="tw-text-sm tw-uppercase tw-opacity-70">vs</span>
                <span>{{targetValue}}</span>
            </div>
            <div class="tw-mt-2">
                {{#if success}}
                <span class="tw-text-success-l20 tw-font-bold"><i class="fas fa-pray"></i> Ritual Complete!</span>
                {{else}}
                <span class="tw-text-failure-l10 tw-font-bold"><i class="fas fa-skull"></i> Ritual Failed!</span>
                {{/if}}
                <span class="tw-text-sm tw-opacity-80">({{degrees}} Degrees)</span>
            </div>
        </div>

        {{#if item.system.description.value}}
        <div class="tw-mt-2 tw-text-sm">
            {{{item.system.description.value}}}
        </div>
        {{/if}}

        {{#if item.system.effect}}
        <div class="tw-mt-2 tw-text-sm">
            <strong>Effect:</strong> {{{item.system.effect}}}
        </div>
        {{/if}}

        {{#if item.system.duration}}
        <div class="tw-mt-1 tw-text-sm">
            <strong>Duration:</strong> {{item.system.duration}}
        </div>
        {{/if}}
    </section>

    <footer class="tw-p-2 tw-text-right tw-text-xs tw-opacity-80">
        <span>{{actor}}</span>
    </footer>
</div>
