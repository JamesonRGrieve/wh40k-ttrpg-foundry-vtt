{{!--
    Chat card for "Snap Out of It" (#66, core.md §"Shock And Snapping Out
    Of It").

    Emitted by CharacterSheet.#snapOutOfShock after a Willpower test
    (Challenging +0). On success the action decrements `system.shock.value`
    by 1; the card narrates the outcome either way.

    Root carries `data-wh40k-system="dh2"` so the bronze theme variant
    fires when the card renders into the chat log (chat messages are
    rendered outside the sheet root — see CLAUDE.md: chat templates
    need a `.wh40k-rpg` ancestor, which basic-action-manager's
    renderChatMessageHTML hook supplies).

    Hash params: actorName, willpower, roll, success, shockBefore, shockAfter.
--}}
<div data-wh40k-system="dh2"
     class="wh40k-shock-snap-chat tw-flex tw-flex-col tw-gap-2 tw-p-3 tw-rounded-md tw-border tw-border-solid {{#if success}}tw-border-emerald-900/70 tw-bg-emerald-900/[10%]{{else}}tw-border-red-900/70 tw-bg-red-900/[10%]{{/if}} dh2:tw-border-bronze">
    <header class="tw-flex tw-items-center tw-gap-2 tw-pb-2 tw-border-b tw-border-solid tw-border-[color:var(--wh40k-border-color-light)] dh2:tw-border-bronze">
        <i class="fa-solid fa-brain {{#if success}}tw-text-emerald-400{{else}}tw-text-red-400{{/if}} dh2:tw-text-bronze" aria-hidden="true"></i>
        <h3 class="tw-m-0 tw-font-display tw-uppercase tw-tracking-[0.1em] tw-text-[1rem] tw-text-white">
            {{localize "WH40K.Shock.ChatTitle"}}
        </h3>
    </header>
    <p class="tw-m-0 tw-text-[0.9rem] tw-italic tw-text-[var(--wh40k-text-muted,#cccccc)]">
        {{actorName}}
    </p>
    <dl class="tw-grid tw-grid-cols-2 tw-gap-x-3 tw-gap-y-1 tw-m-0 tw-text-[0.85rem]">
        <dt class="tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[var(--wh40k-text-muted,#a0a0a0)]">
            Willpower
        </dt>
        <dd class="tw-m-0 tw-text-white">{{willpower}}</dd>
        <dt class="tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[var(--wh40k-text-muted,#a0a0a0)]">
            Roll
        </dt>
        <dd class="tw-m-0 tw-text-white">{{roll}}</dd>
        <dt class="tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[var(--wh40k-text-muted,#a0a0a0)]">
            {{localize "WH40K.Shock.Header"}}
        </dt>
        <dd class="tw-m-0 tw-text-white">{{shockBefore}} → {{shockAfter}}</dd>
    </dl>
    <p class="tw-m-0 tw-text-[0.9rem] {{#if success}}tw-text-emerald-300{{else}}tw-text-red-300{{/if}}">
        {{#if success}}
            {{localize "WH40K.Shock.SuccessText"}}
        {{else}}
            {{localize "WH40K.Shock.FailureText"}}
        {{/if}}
    </p>
</div>
