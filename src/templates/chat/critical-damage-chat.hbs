{{!-- Critical Damage roll chat card (#108 — core.md §"Critical Damage"). --}}
{{!-- Surfaces the rolled (damageType × bodyPart × severity) Critical Effects --}}
{{!-- row plus the conditions / special damage it inflicts. --}}
{{!-- data-wh40k-system anchors per-system Tailwind variants on the card; --}}
{{!-- the wh40k-rpg class lets utility cascade work outside the sheet root. --}}
<div class="wh40k-rpg wh40k-critdmg-card tw-p-4 tw-rounded-md tw-border tw-border-red-700 tw-bg-[rgba(28,12,12,0.88)]"
     data-wh40k-system="{{gameSystem}}">
    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
        <i class="fas fa-skull-crossbones tw-text-[1.1rem] tw-text-red-400 dh2:tw-text-bronze rt:tw-text-amber-500"></i>
        <div class="tw-font-display tw-uppercase tw-tracking-[0.12em] tw-text-[0.95rem] tw-text-red-200">
            {{localize "WH40K.CriticalDamage.ChatTitle"}}
        </div>
    </div>

    <div class="tw-text-[0.95rem] tw-mb-3 tw-text-[#e8e4d9]">
        <strong class="tw-text-red-200">{{localize damageTypeKey}}</strong>
        — {{localize bodyPartKey}}
        <span class="tw-text-red-300">({{localize "WH40K.CriticalDamage.SeverityLabel"}} {{severityLabel}})</span>
    </div>

    <ul class="tw-list-none tw-p-0 tw-m-0 tw-flex tw-flex-col tw-gap-1 tw-text-[0.85rem] tw-mb-3">
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-red-300">{{localize "WH40K.CriticalDamage.DamageTypeLabel"}}</span>
            <span class="tw-font-bold tw-text-red-200">{{localize damageTypeKey}}</span>
        </li>
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-red-300">{{localize "WH40K.CriticalDamage.LocationLabel"}}</span>
            <span class="tw-font-bold tw-text-red-200">{{localize bodyPartKey}}</span>
        </li>
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-red-300">{{localize "WH40K.CriticalDamage.SeverityLabel"}}</span>
            <span class="tw-font-bold tw-text-red-200">{{severityLabel}}</span>
        </li>
    </ul>

    <div class="tw-p-2 tw-rounded-sm tw-border tw-border-[rgba(220,38,38,0.45)] tw-bg-[rgba(127,29,29,0.18)] tw-text-[0.85rem] tw-text-[#fee2e2]">
        <div class="tw-text-xs tw-uppercase tw-tracking-[0.08em] tw-text-red-300 tw-mb-1">
            {{localize "WH40K.CriticalDamage.EffectLabel"}}
        </div>
        {{#if effect}}
            <div>{{{effect}}}</div>
        {{else}}
            <div class="tw-italic tw-text-red-300">{{localize "WH40K.CriticalDamage.NoEffectText"}}</div>
        {{/if}}
    </div>

    {{#if riderLabels.length}}
        <div class="tw-mt-3">
            <div class="tw-text-xs tw-uppercase tw-tracking-[0.08em] tw-text-red-300 tw-mb-1">
                {{localize "WH40K.CriticalDamage.ConditionsLabel"}}
            </div>
            <div class="tw-flex tw-flex-wrap tw-gap-1.5">
                {{#each riderLabels}}
                    <span class="tw-px-2 tw-py-0.5 tw-rounded-full tw-text-[0.75rem] tw-font-semibold tw-uppercase tw-tracking-[0.06em] tw-border tw-border-red-600 tw-bg-[rgba(127,29,29,0.35)] tw-text-red-200">
                        {{localize this}}
                    </span>
                {{/each}}
            </div>
        </div>
    {{/if}}
</div>
