{{!--
  Reload Action Chat Card
  Shows reload information including action cost and Customised quality effects
--}}
<div class="tw-overflow-hidden tw-rounded-md tw-border tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure"{{#if gameSystem}} data-wh40k-system="{{gameSystem}}"{{/if}}>
  {{!-- Header --}}
  <div class="tw-flex tw-flex-col tw-p-2 tw-border-b">
    <div class="tw-flex tw-items-center tw-gap-1.5 tw-font-bold tw-text-base tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
      <i class="fa-solid fa-rotate-right"></i>
      <span>Reload</span>
    </div>
    <div class="tw-text-sm tw-opacity-80">
      {{weapon.name}}
    </div>
  </div>

  {{!-- Body --}}
  <div class="tw-p-2 tw-flex tw-flex-col tw-gap-2">
    {{!-- Ammo Status --}}
    <div class="tw-flex tw-flex-col tw-gap-1">
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-text-sm tw-font-bold">
        <i class="fa-solid fa-database"></i>
        <span>Ammunition</span>
      </div>
      <div class="tw-flex tw-items-center tw-gap-2">
        <span class="tw-font-mono">{{clipCurrent}}/{{clipMax}}</span>
        <div class="tw-flex-1 tw-h-1.5 tw-rounded-sm tw-bg-black/30 tw-overflow-hidden">
          <div class="tw-h-full tw-bg-gold-raw"
               style="width: {{multiply (divide clipCurrent clipMax) 100}}%"></div>
        </div>
      </div>
    </div>

    {{!-- Action Cost --}}
    <div class="tw-flex tw-flex-col tw-gap-1">
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-text-sm tw-font-bold">
        <i class="fa-solid fa-hourglass-half"></i>
        <span>Action Cost</span>
      </div>
      <div class="tw-flex tw-items-center tw-gap-2 tw-flex-wrap">
        {{#if hasCustomised}}
        <span class="tw-line-through tw-opacity-70">
          {{baseReloadTime}}
        </span>
        <i class="fa-solid fa-arrow-right"></i>
        {{/if}}
        <span class="{{#if hasCustomised}}tw-font-bold tw-text-success-l20{{/if}}">
          {{effectiveReloadTime}}
        </span>
        {{#if hasCustomised}}
        <span class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-flex tw-items-center tw-gap-1 tw-bg-gold-raw/20 tw-text-gold-raw" title="Customised quality halves reload time">
          <i class="fa-solid fa-wrench"></i>
          Customised
        </span>
        {{/if}}
      </div>
    </div>

    {{!-- Actions Spent --}}
    {{#if result.actionsSpent}}
    <div class="tw-flex tw-flex-col tw-gap-1">
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-text-sm tw-font-bold">
        <i class="fa-solid fa-bolt"></i>
        <span>Actions Spent</span>
      </div>
      <div class="tw-flex tw-items-center tw-gap-1 tw-flex-wrap">
        {{#if (gt result.actionsSpent.full 0)}}
        <span class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-bg-crimson/20 tw-text-crimson-light">
          {{result.actionsSpent.full}} Full Action{{#if (gt result.actionsSpent.full 1)}}s{{/if}}
        </span>
        {{/if}}
        {{#if (gt result.actionsSpent.half 0)}}
        <span class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-bg-warning/20 tw-text-warning">
          {{result.actionsSpent.half}} Half Action{{#if (gt result.actionsSpent.half 1)}}s{{/if}}
        </span>
        {{/if}}
        {{#unless (or (gt result.actionsSpent.full 0) (gt result.actionsSpent.half 0))}}
        <span class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-bg-success/20 tw-text-success-l20 tw-flex tw-items-center tw-gap-1">
          <i class="fa-solid fa-gift"></i>
          Free Action
        </span>
        {{/unless}}
      </div>
    </div>
    {{/if}}

    {{!-- Result Message --}}
    {{#if result.message}}
    <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-italic">
      <i class="fa-solid {{#if result.success}}fa-check-circle tw-text-success-l20{{else}}fa-exclamation-triangle tw-text-failure-l10{{/if}}"></i>
      <span>{{result.message}}</span>
    </div>
    {{/if}}
  </div>

  {{!-- Footer --}}
  <div class="tw-p-2 tw-border-t tw-flex tw-items-center tw-justify-end">
    <div class="tw-flex tw-items-center tw-gap-2 tw-text-xs">
      <img src="{{actor.img}}" alt="{{actor.name}}" class="tw-w-6 tw-h-6 tw-rounded-full" />
      <span>{{actor.name}}</span>
    </div>
  </div>
</div>
