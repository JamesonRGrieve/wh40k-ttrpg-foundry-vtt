{{!-- 
  Reload Action Chat Card
  Shows reload information including action cost and Customised quality effects
--}}
<div class="wh40k-chat-card wh40k-reload-card">
  {{!-- Header --}}
  <div class="wh40k-chat-card__header wh40k-reload-card__header">
    <div class="wh40k-chat-card__title">
      <i class="fa-solid fa-rotate-right"></i>
      <span>Reload</span>
    </div>
    <div class="wh40k-chat-card__subtitle">
      {{weapon.name}}
    </div>
  </div>

  {{!-- Body --}}
  <div class="wh40k-chat-card__body">
    {{!-- Ammo Status --}}
    <div class="wh40k-reload-status">
      <div class="wh40k-reload-status__label">
        <i class="fa-solid fa-database"></i>
        <span>Ammunition</span>
      </div>
      <div class="wh40k-reload-status__value">
        <span class="wh40k-reload-status__clip">{{clipCurrent}}/{{clipMax}}</span>
        <div class="wh40k-reload-status__bar">
          <div class="wh40k-reload-status__bar-fill" 
               style="width: {{multiply (divide clipCurrent clipMax) 100}}%"></div>
        </div>
      </div>
    </div>

    {{!-- Action Cost --}}
    <div class="wh40k-reload-cost">
      <div class="wh40k-reload-cost__label">
        <i class="fa-solid fa-hourglass-half"></i>
        <span>Action Cost</span>
      </div>
      <div class="wh40k-reload-cost__value">
        {{#if hasCustomised}}
        <span class="wh40k-reload-cost__original" style="text-decoration: line-through;">
          {{baseReloadTime}}
        </span>
        <i class="fa-solid fa-arrow-right"></i>
        {{/if}}
        <span class="wh40k-reload-cost__effective {{#if hasCustomised}}wh40k-reload-cost--modified{{/if}}">
          {{effectiveReloadTime}}
        </span>
        {{#if hasCustomised}}
        <span class="wh40k-reload-cost__badge" title="Customised quality halves reload time">
          <i class="fa-solid fa-wrench"></i>
          Customised
        </span>
        {{/if}}
      </div>
    </div>

    {{!-- Actions Spent --}}
    {{#if result.actionsSpent}}
    <div class="wh40k-reload-actions">
      <div class="wh40k-reload-actions__label">
        <i class="fa-solid fa-bolt"></i>
        <span>Actions Spent</span>
      </div>
      <div class="wh40k-reload-actions__value">
        {{#if (gt result.actionsSpent.full 0)}}
        <span class="wh40k-reload-action-badge wh40k-reload-action-badge--full">
          {{result.actionsSpent.full}} Full Action{{#if (gt result.actionsSpent.full 1)}}s{{/if}}
        </span>
        {{/if}}
        {{#if (gt result.actionsSpent.half 0)}}
        <span class="wh40k-reload-action-badge wh40k-reload-action-badge--half">
          {{result.actionsSpent.half}} Half Action{{#if (gt result.actionsSpent.half 1)}}s{{/if}}
        </span>
        {{/if}}
        {{#unless (or (gt result.actionsSpent.full 0) (gt result.actionsSpent.half 0))}}
        <span class="wh40k-reload-action-badge wh40k-reload-action-badge--free">
          <i class="fa-solid fa-gift"></i>
          Free Action
        </span>
        {{/unless}}
      </div>
    </div>
    {{/if}}

    {{!-- Result Message --}}
    {{#if result.message}}
    <div class="wh40k-reload-message">
      <i class="fa-solid {{#if result.success}}fa-check-circle{{else}}fa-exclamation-triangle{{/if}}"></i>
      <span>{{result.message}}</span>
    </div>
    {{/if}}
  </div>

  {{!-- Footer --}}
  <div class="wh40k-chat-card__footer">
    <div class="wh40k-chat-card__actor">
      <img src="{{actor.img}}" alt="{{actor.name}}" />
      <span>{{actor.name}}</span>
    </div>
  </div>
</div>
