{{! Skill Chat Card }}
<div class="wh40k-chat-card wh40k-chat-card--skill">
    <header class="wh40k-chat-header">
        <img class="wh40k-chat-icon" src="{{skill.img}}" alt="{{skill.name}}" />
        <div class="wh40k-chat-title">
            <h3>{{skill.name}}</h3>
            <div class="wh40k-chat-meta">
                <span class="wh40k-badge wh40k-badge--{{skill.system.skillType}}">
                    {{skill.system.skillTypeLabel}}
                </span>
                <span class="wh40k-badge wh40k-badge--characteristic">
                    {{skill.system.characteristicLabel}}
                    ({{skill.system.characteristicAbbr}})
                </span>
                {{#if skill.system.isBasic}}
                    <span class="wh40k-badge wh40k-badge--basic">
                        <i class="fas fa-check-circle"></i>
                        Can Use Untrained
                    </span>
                {{/if}}
            </div>
        </div>
    </header>

    {{#if skill.system.descriptor}}
        <div class="wh40k-chat-section">
            <p class="wh40k-chat-descriptor">{{skill.system.descriptor}}</p>
        </div>
    {{/if}}

    {{#if skill.system.uses}}
        <div class="wh40k-chat-section">
            <h4><i class="fas fa-list-check"></i> Uses</h4>
            <div class="wh40k-chat-content">{{{skill.system.uses}}}</div>
        </div>
    {{/if}}

    {{#if skill.system.specialRules}}
        <div class="wh40k-chat-section">
            <h4><i class="fas fa-book-open"></i> Special Rules</h4>
            <div class="wh40k-chat-content">{{{skill.system.specialRules}}}</div>
        </div>
    {{/if}}

    <footer class="wh40k-chat-footer">
        {{#if skill.system.useTime}}
            <span><strong>Time:</strong> {{skill.system.useTime}}</span>
        {{/if}}
        {{#if skill.system.aptitudes.length}}
            <span><strong>Aptitudes:</strong> {{join skill.system.aptitudes ", "}}</span>
        {{/if}}
        {{#if skill.system.hasSpecializations}}
            <div class="wh40k-specializations">
                <strong>Available Specializations:</strong>
                <span class="wh40k-spec-list">{{join skill.system.specializations ", "}}</span>
            </div>
        {{/if}}
    </footer>
</div>