{{! Navigator Power Chat Card }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
    cardClass="wh40k-navigator-power-card"
    outerExtraClass="tw-overflow-hidden tw-rounded-md tw-border-2 tw-border-bronze"
    image=item.img
    imageAlt=item.name
    title=item.name
    subtitle="Navigator Power"
    gameSystem=gameSystem
    footerLabel=actor
}}
    <div class="tw-p-7 tw-rounded-md tw-border-2 tw-border-gold tw-bg-[var(--wh40k-panel-bg-solid)] tw-shadow-[0_0_20px_rgba(201,162,39,0.3)] tw-text-center {{#if success}}tw-border-success{{else}}tw-border-failure{{/if}}">
        <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-text-2xl tw-font-bold">
            <span>{{roll.total}}</span>
            <span class="tw-text-sm tw-uppercase tw-opacity-70">vs</span>
            <span>{{targetValue}}</span>
        </div>
        <div class="tw-mt-2">
            {{#if success}}
            <span class="tw-text-success-l20 tw-font-bold"><i class="fas fa-eye"></i> Power Manifested!</span>
            {{else}}
            <span class="tw-text-failure-l10 tw-font-bold"><i class="fas fa-eye-slash"></i> Power Failed!</span>
            {{/if}}
            <span class="tw-text-sm tw-opacity-80">({{degrees}} Degrees)</span>
        </div>
    </div>

    {{#if item.system.description.value}}
    <div class="tw-mt-2 tw-text-sm">
        {{{item.system.description.value}}}
    </div>
    {{/if}}

    {{#if item.system.sideEffects}}
    <div class="tw-mt-2 tw-text-sm">
        <strong>Side Effects:</strong> {{{item.system.sideEffects}}}
    </div>
    {{/if}}

    {{#unless success}}
    <div class="tw-mt-3 tw-pt-2 tw-border-t tw-border-black/10 tw-text-right">
        <button class="tw-px-2 tw-py-1 tw-rounded tw-text-xs" data-action="rollNavigatorMutation">
            <i class="fas fa-dna"></i> Check Navigator Mutation
        </button>
    </div>
    {{/unless}}
{{/systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs}}
