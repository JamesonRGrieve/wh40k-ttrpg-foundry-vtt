{{! Order Roll Chat Card }}
{{#> systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs
    cardClass="wh40k-order-roll-card"
    outerExtraClass="tw-overflow-hidden tw-rounded-md tw-border-2 tw-border-bronze bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure"
    image=item.img
    imageAlt=item.name
    title=item.name
    subtitle="Ship Order"
    gameSystem=gameSystem
    footerLabel=actor
}}
    <div class="tw-p-7 tw-rounded-md tw-border-2 tw-bg-[var(--wh40k-panel-bg-solid)] tw-shadow-[0_0_20px_rgba(201,162,39,0.3)] tw-text-center {{#if success}}tw-border-success{{else}}tw-border-failure{{/if}}">
        <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-text-2xl tw-font-bold">
            <span>{{roll.total}}</span>
            <span class="tw-text-sm tw-uppercase tw-opacity-70">vs</span>
            <span>{{targetValue}}</span>
        </div>
        <div class="tw-mt-2">
            {{#if success}}
            <span class="tw-text-success-l20 tw-font-bold"><i class="fas fa-ship"></i> Order Executed!</span>
            {{else}}
            <span class="tw-text-failure-l10 tw-font-bold"><i class="fas fa-exclamation-triangle"></i> Order Failed!</span>
            {{/if}}
            <span class="tw-text-sm tw-opacity-80">({{degrees}} Degrees)</span>
        </div>
    </div>

    {{#if item.system.description.value}}
    <div class="tw-mt-2 tw-text-sm">
        {{{item.system.description.value}}}
    </div>
    {{/if}}

    {{#if item.system.effect}}
    <div class="tw-mt-2 tw-text-sm">
        <strong>Effect:</strong> {{{item.system.effect}}}
    </div>
    {{/if}}
{{/systems/wh40k-rpg/templates/chat/partial/chat-card-shell.hbs}}
