{{!-- Right Stuff Fate-spend chat card (#100, without.md L948-L980). --}}
{{!-- data-wh40k-system anchors per-system Tailwind variants on the card; --}}
{{!-- the wh40k-rpg class lets utility cascade work outside the sheet root. --}}
<div class="wh40k-rpg wh40k-right-stuff-card tw-p-4 tw-rounded-md tw-border tw-border-amber-500 tw-bg-[rgba(28,18,6,0.9)]"
     data-wh40k-system="{{gameSystem}}">
    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
        <i class="fas fa-star tw-text-[1.1rem] tw-text-amber-300"></i>
        <div class="tw-font-display tw-uppercase tw-tracking-[0.12em] tw-text-[0.95rem] tw-text-amber-200">
            {{localize "WH40K.RightStuff.ChatTitle"}}
        </div>
    </div>

    <div class="tw-text-[0.95rem] tw-mb-3 tw-text-[#e8e4d9]">
        <strong class="tw-text-amber-200">{{actorName}}</strong>
        — {{localize "WH40K.RightStuff.FateSpentTag"}}
    </div>

    <ul class="tw-list-none tw-p-0 tw-m-0 tw-flex tw-flex-col tw-gap-1 tw-text-[0.85rem] tw-mb-3">
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-amber-300">{{localize "WH40K.RightStuff.SkillLabel"}}</span>
            <span class="tw-font-bold tw-text-amber-100">{{localize skillKey}}</span>
        </li>
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-amber-300">{{localize "WH40K.RightStuff.AgilityBonusLabel"}}</span>
            <span class="tw-font-bold tw-tabular-nums tw-text-amber-100">{{agilityBonus}}</span>
        </li>
        <li class="tw-flex tw-justify-between tw-gap-3">
            <span class="tw-text-amber-300">{{localize "WH40K.RightStuff.DoSLabel"}}</span>
            <span class="tw-font-bold tw-tabular-nums tw-text-amber-100">{{degrees}}</span>
        </li>
    </ul>

    <div class="tw-p-2 tw-rounded-sm tw-border tw-border-[rgba(245,158,11,0.5)] tw-bg-[rgba(120,53,15,0.25)] tw-text-[0.85rem] tw-text-amber-100">
        <div class="tw-text-xs tw-uppercase tw-tracking-[0.08em] tw-text-amber-300 tw-mb-1">
            {{localize "WH40K.RightStuff.AutoSuccessLabel"}}
        </div>
        {{#if hasDegrees}}
            <div>{{localize "WH40K.RightStuff.AutoSuccessWithDoS"}}</div>
        {{else}}
            <div>{{localize "WH40K.RightStuff.AutoSuccessZeroDoS"}}</div>
        {{/if}}
    </div>
</div>
