{{!-- Only War Orders issuance chat card (#153). --}}
{{!-- data-wh40k-system anchors per-system Tailwind variants on the card; --}}
{{!-- the wh40k-rpg class lets utility cascade work outside the sheet root. --}}
<div class="wh40k-rpg wh40k-ow-orders-card tw-p-4 tw-rounded-md tw-border tw-border-brass tw-bg-[rgba(28,22,8,0.88)]"
     data-wh40k-system="{{gameSystem}}"
     data-order-id="{{orderId}}">

    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
        <i class="fas fa-bullhorn tw-text-[1.1rem] tw-text-brass"></i>
        <div class="tw-font-display tw-uppercase tw-tracking-[0.12em] tw-text-[0.95rem] tw-text-brass">
            {{localize "WH40K.OW.Orders.Chat.Title" order=(localize orderNameKey)}}
        </div>
    </div>

    {{!-- Action cost + kind --}}
    <div class="tw-flex tw-gap-2 tw-text-[0.78rem] tw-mb-3 tw-text-amber-200">
        <span class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-border tw-border-brass/60 tw-bg-[rgba(60,40,8,0.4)]">
            {{localize actionCostKey}}
        </span>
        <span class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-border tw-border-brass/60 tw-bg-[rgba(60,40,8,0.4)]">
            {{localize kindKey}}
        </span>
        {{#if sweeping}}
            <span class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-border tw-border-brass tw-bg-brass/20 tw-text-brass tw-font-semibold">
                {{localize "WH40K.OW.Orders.Kind.Sweeping"}}
            </span>
        {{/if}}
    </div>

    {{!-- Effect summary --}}
    {{#if effectKey}}
        <div class="tw-text-[0.85rem] tw-mb-3 tw-text-amber-50 tw-italic">
            {{localize effectKey}}
        </div>
    {{/if}}

    {{!-- Affected squad members --}}
    <div class="tw-p-2 tw-rounded-sm tw-border tw-border-brass/60 tw-bg-[rgba(60,40,8,0.22)]">
        <div class="tw-text-xs tw-uppercase tw-tracking-[0.08em] tw-text-brass tw-mb-1">
            {{localize "WH40K.OW.Orders.Chat.AffectedHeader"}}
        </div>
        {{#if affectedMembers.length}}
            <ul class="tw-list-none tw-p-0 tw-m-0 tw-flex tw-flex-wrap tw-gap-1.5">
                {{#each affectedMembers}}
                    <li class="tw-px-2 tw-py-0.5 tw-rounded-sm tw-bg-brass/30 tw-text-amber-50 tw-text-xs tw-tracking-[0.04em]"
                        data-member-id="{{this.id}}">
                        {{this.name}}
                    </li>
                {{/each}}
            </ul>
        {{else}}
            <div class="tw-text-xs tw-italic tw-text-amber-300/80">
                {{localize "WH40K.OW.Orders.Chat.NoMembers"}}
            </div>
        {{/if}}
    </div>
</div>
