{{!-- Rogue Trader Combat Action Card — vocalized to chat --}}
{{#> systems/wh40k-rpg/templates/chat/partial/modern-card-shell.hbs
        title=name
        actorName=actor
        subtitle="Combat Action"
        image=img
        imageIcon="fa-fist-raised"
        actionType=actionType
        footerLabel=source
        footerIcon="fa-book"
        gameSystem=gameSystem}}
    {{#if (or attackModifier subtypes)}}
    <div class="tw-flex tw-gap-3 tw-flex-wrap tw-mb-2">
        {{#if attackModifier}}
        <div class="tw-flex tw-flex-col tw-gap-0.5 tw-px-2.5 tw-py-1.5 tw-bg-[var(--wh40k-accent-overlay)] tw-rounded-sm tw-border tw-border-[var(--wh40k-border-color-light)] {{#if (gt attackModifier 0)}}tw-border-[var(--wh40k-success-primary)]{{else}}tw-border-[var(--wh40k-danger-primary)]{{/if}}">
            <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[var(--wh40k-text-muted)]">Attack</span>
            <span class="tw-text-sm tw-font-bold tw-text-[var(--wh40k-bronze)] tw-font-alt">{{attackModifier}}</span>
        </div>
        {{/if}}
        {{#if subtypes}}
        <div class="tw-flex tw-flex-col tw-gap-0.5 tw-px-2.5 tw-py-1.5 tw-bg-[var(--wh40k-accent-overlay)] tw-rounded-sm tw-border tw-border-[var(--wh40k-border-color-light)]">
            <span class="tw-text-[0.65rem] tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[var(--wh40k-text-muted)]">Type</span>
            <span class="tw-text-sm tw-font-bold tw-text-[var(--wh40k-bronze)] tw-font-alt">{{subtypes}}</span>
        </div>
        {{/if}}
    </div>
    <div class="tw-h-px tw-bg-gradient-to-r tw-from-transparent tw-via-[var(--wh40k-border-color)] tw-to-transparent tw-my-2.5"></div>
    {{/if}}

    {{#if description}}
    <div class="tw-my-2.5 tw-p-2.5 tw-bg-[var(--wh40k-panel-bg)] tw-rounded-md tw-border tw-border-[var(--wh40k-border-color-light)]">
        <div class="tw-text-sm tw-leading-relaxed tw-text-[var(--wh40k-text-dark)]">{{{description}}}</div>
    </div>
    {{/if}}

    {{#if summary}}
    <div class="tw-my-2.5 tw-p-2.5 tw-bg-[var(--wh40k-panel-bg)] tw-rounded-md tw-border tw-border-[var(--wh40k-border-color-light)]">
        <div class="tw-text-sm tw-leading-relaxed tw-text-[var(--wh40k-text-dark)]">{{{summary}}}</div>
    </div>
    {{/if}}

    {{#if itemUuid}}
    <div class="tw-flex tw-gap-1 tw-p-2.5 tw-mt-2 -tw-mx-4 -tw-mb-3 tw-justify-center tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-t tw-border-[var(--wh40k-border-color-light)]">
        <button type="button" class="tw-flex tw-flex-1 tw-items-center tw-justify-center tw-gap-1.5 tw-px-4 tw-py-2 tw-bg-gradient-to-br tw-from-[var(--wh40k-bronze)] tw-to-[var(--wh40k-bronze-dark)] tw-border tw-border-[var(--wh40k-bronze)] tw-rounded-md tw-text-white tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-cursor-pointer tw-transition-all hover:tw-translate-y-[-2px] hover:tw-shadow-[0_4px_12px_rgba(0,0,0,0.3)]" data-uuid="{{itemUuid}}" data-action="openItemSheet">
            <i class="fas fa-scroll-old tw-text-[12px]"></i>
            View Details
        </button>
    </div>
    {{/if}}
{{/systems/wh40k-rpg/templates/chat/partial/modern-card-shell.hbs}}
