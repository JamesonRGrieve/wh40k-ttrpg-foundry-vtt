{{!--
  Rogue Trader Weapon Chat Card - Modern Compact Design
  For vocalizing weapon items to chat with full stats and action buttons.
--}}
<div class="wh40k-chat">
  <div class="wh40k-weapon-card" data-item-id="{{item._id}}" data-item-uuid="{{item.uuid}}" {{#if actor}}data-actor-id="{{actor._id}}" data-actor-uuid="{{actor.uuid}}"{{/if}}>
    
    {{!-- Header --}}
    <div class="wh40k-weapon-card__header">
      <img class="wh40k-weapon-card__image" src="{{item.img}}" alt="{{item.name}}" />
      <div class="wh40k-weapon-card__title">
        <h2 class="wh40k-weapon-card__name">{{item.name}}</h2>
        <div class="wh40k-weapon-card__meta">
          <span class="wh40k-weapon-card__class">{{item.system.classLabel}}</span>
          <span class="wh40k-weapon-card__divider">•</span>
          <span class="wh40k-weapon-card__type">{{item.system.typeLabel}}</span>
          {{#if (ne item.system.craftsmanship "common")}}
          <span class="wh40k-weapon-card__divider">•</span>
          <span class="wh40k-weapon-card__craft wh40k-weapon-card__craft--{{item.system.craftsmanship}}">{{item.system.craftsmanshipLabel}}</span>
          {{/if}}
        </div>
      </div>
    </div>
    
    {{!-- Stats Grid --}}
    <div class="wh40k-weapon-card__stats">
      {{!-- Row 1: Damage & Pen --}}
      <div class="wh40k-weapon-card__stat wh40k-weapon-card__stat--damage">
        <span class="wh40k-weapon-card__stat-label">Damage</span>
        <span class="wh40k-weapon-card__stat-value">{{item.system.damageLabel}}</span>
      </div>
      <div class="wh40k-weapon-card__stat wh40k-weapon-card__stat--pen">
        <span class="wh40k-weapon-card__stat-label">Pen</span>
        <span class="wh40k-weapon-card__stat-value">{{item.system.damage.penetration}}</span>
      </div>
      
      {{!-- Row 2: Range & RoF (ranged only) --}}
      {{#if item.system.isRangedWeapon}}
      <div class="wh40k-weapon-card__stat wh40k-weapon-card__stat--range">
        <span class="wh40k-weapon-card__stat-label">Range</span>
        <span class="wh40k-weapon-card__stat-value">{{item.system.rangeLabel}}</span>
      </div>
      <div class="wh40k-weapon-card__stat wh40k-weapon-card__stat--rof">
        <span class="wh40k-weapon-card__stat-label">RoF</span>
        <span class="wh40k-weapon-card__stat-value">{{item.system.rateOfFireLabel}}</span>
      </div>
      {{/if}}
      
      {{!-- Clip (if uses ammo) --}}
      {{#if item.system.usesAmmo}}
      <div class="wh40k-weapon-card__stat wh40k-weapon-card__stat--clip">
        <span class="wh40k-weapon-card__stat-label">Clip</span>
        <span class="wh40k-weapon-card__stat-value">{{item.system.clip.value}}/{{item.system.clip.max}}</span>
      </div>
      <div class="wh40k-weapon-card__stat wh40k-weapon-card__stat--reload">
        <span class="wh40k-weapon-card__stat-label">Reload</span>
        <span class="wh40k-weapon-card__stat-value">{{item.system.reloadLabel}}</span>
      </div>
      {{/if}}
    </div>
    
    {{!-- Craftsmanship Modifiers --}}
    {{#if (or item.system.craftsmanshipModifiers.toHit item.system.craftsmanshipModifiers.damage)}}
    <div class="wh40k-weapon-card__craft-mods">
      <i class="fas fa-hammer"></i>
      {{#if item.system.craftsmanshipModifiers.toHit}}
      <span class="wh40k-weapon-card__mod {{#if (gt item.system.craftsmanshipModifiers.toHit 0)}}wh40k-weapon-card__mod--positive{{else}}wh40k-weapon-card__mod--negative{{/if}}">
        {{#if (gt item.system.craftsmanshipModifiers.toHit 0)}}+{{/if}}{{item.system.craftsmanshipModifiers.toHit}} to Hit
      </span>
      {{/if}}
      {{#if item.system.craftsmanshipModifiers.damage}}
      <span class="wh40k-weapon-card__mod wh40k-weapon-card__mod--positive">
        +{{item.system.craftsmanshipModifiers.damage}} Damage
      </span>
      {{/if}}
    </div>
    {{/if}}
    
    {{!-- Qualities --}}
    {{#if item.system.effectiveSpecial.size}}
    <div class="wh40k-weapon-card__qualities">
      {{#each item.system.qualitiesArray as |quality|}}
      <span class="wh40k-weapon-card__quality" data-tooltip="{{quality.description}}">
        {{quality.label}}{{#if quality.level}} ({{quality.level}}){{/if}}
      </span>
      {{/each}}
    </div>
    {{/if}}
    
    {{!-- Description (if exists) --}}
    {{#if item.system.description.value}}
    <div class="wh40k-weapon-card__description">
      {{{item.system.description.value}}}
    </div>
    {{/if}}
    
    {{!-- Action Buttons --}}
    {{#if hasActions}}
    <div class="wh40k-weapon-card__actions">
      <button type="button" class="wh40k-weapon-card__btn wh40k-weapon-card__btn--attack" data-action="attack" data-item-uuid="{{item.uuid}}">
        <i class="fas fa-crosshairs"></i>
        Attack
      </button>
      <button type="button" class="wh40k-weapon-card__btn wh40k-weapon-card__btn--damage" data-action="rollDamage" data-item-uuid="{{item.uuid}}">
        <i class="fas fa-burst"></i>
        Damage
      </button>
      {{#if item.system.usesAmmo}}
      <button type="button" class="wh40k-weapon-card__btn wh40k-weapon-card__btn--reload" data-action="reload" data-item-uuid="{{item.uuid}}">
        <i class="fas fa-rotate-right"></i>
        Reload
      </button>
      {{/if}}
    </div>
    {{/if}}
    
    {{!-- Footer --}}
    {{#if item.system.source}}
    <div class="wh40k-weapon-card__footer">
      <span class="wh40k-weapon-card__source">{{item.system.source}}</span>
    </div>
    {{/if}}
    
  </div>
</div>
