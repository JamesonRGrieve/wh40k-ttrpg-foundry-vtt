{{!--
  Quick Actions Bar Partial
  Standardized action buttons for items

  Usage:
  {{> "systems/wh40k-rpg/templates/components/quick-actions-bar.hbs"
      item=item
      compact=false
      inSheet=false}}

  @param {Item} item - The item to generate actions for
  @param {Boolean} compact - Use compact mode (icons only)
  @param {Boolean} inSheet - Rendering in item sheet vs character sheet
--}}

{{#if item}}
<div class="tw-flex tw-flex-wrap tw-gap-[var(--wh40k-item-spacing-xs)] tw-p-[var(--wh40k-item-spacing-sm)] tw-bg-[var(--wh40k-item-panel-bg)] tw-border-t tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure {{#if compact}}tw-gap-[var(--wh40k-item-spacing-xs)] tw-p-[var(--wh40k-item-spacing-xs)]{{/if}}">
  {{!-- Weapon Actions --}}
  {{#if (eq item.type "weapon")}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="itemRoll"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Attack'}}">
      <i class="fa-solid fa-crosshairs"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Attack"}}</span>{{/unless}}
    </button>
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="rollDamage"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Damage'}}">
      <i class="fa-solid fa-burst"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Damage"}}</span>{{/unless}}
    </button>
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(100,100,120,0.25)] tw-border-[rgba(100,100,120,0.4)] tw-text-[color:var(--color-text-secondary)]"
            data-action="reloadWeapon"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Reload'}}">
      <i class="fa-solid fa-rotate-right"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Reload"}}</span>{{/unless}}
    </button>
  {{/if}}

  {{!-- Armour Actions --}}
  {{#if (eq item.type "armour")}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="toggleEquip"
            data-item-id="{{item.id}}"
            title="{{#if system.equipped}}{{localize 'WH40K.Action.Unequip'}}{{else}}{{localize 'WH40K.Action.Equip'}}{{/if}}">
      <i class="fa-solid {{#if system.equipped}}fa-user-check{{else}}fa-user-plus{{/if}}"></i>
      {{#unless compact}}
      <span>{{#if system.equipped}}{{localize "WH40K.Action.Unequip"}}{{else}}{{localize "WH40K.Action.Equip"}}{{/if}}</span>
      {{/unless}}
    </button>
  {{/if}}

  {{!-- Talent Actions --}}
  {{#if (eq item.type "talent")}}
    {{#if system.isRollable}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="itemRoll"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Roll'}}">
      <i class="fa-solid fa-dice-d20"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Roll"}}</span>{{/unless}}
    </button>
    {{/if}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(100,100,120,0.25)] tw-border-[rgba(100,100,120,0.4)] tw-text-[color:var(--color-text-secondary)]"
            data-action="toggleFavorite"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Favorite'}}">
      <i class="fa-solid fa-star"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Favorite"}}</span>{{/unless}}
    </button>
  {{/if}}

  {{!-- Trait Actions --}}
  {{#if (eq item.type "trait")}}
    {{#if system.rollable}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="itemRoll"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Roll'}}">
      <i class="fa-solid fa-dice-d20"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Roll"}}</span>{{/unless}}
    </button>
    {{/if}}
  {{/if}}

  {{!-- Consumable Actions --}}
  {{#if (or (eq item.type "consumable") (eq item.type "drug") (and (eq item.type "gear") system.consumable))}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="useItem"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Use'}}">
      <i class="fa-solid fa-flask"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Use"}}</span>{{/unless}}
    </button>
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(100,100,120,0.25)] tw-border-[rgba(100,100,120,0.4)] tw-text-[color:var(--color-text-secondary)]"
            data-action="adjustQuantity"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Adjust'}}">
      <i class="fa-solid fa-sliders"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Adjust"}}</span>{{/unless}}
    </button>
  {{/if}}

  {{!-- Condition Actions: GM-only. Conditions are GM-imposed game state; players see them as read-only. --}}
  {{#if (eq item.type "condition")}}
    {{#if @root.isGM}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(100,100,120,0.25)] tw-border-[rgba(100,100,120,0.4)] tw-text-[color:var(--color-text-secondary)]"
            data-action="stackCondition"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Stack'}}">
      <i class="fa-solid fa-plus"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Stack"}}</span>{{/unless}}
    </button>
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(100,100,120,0.25)] tw-border-[rgba(100,100,120,0.4)] tw-text-[color:var(--color-text-secondary)]"
            data-action="reduceCondition"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Reduce'}}">
      <i class="fa-solid fa-minus"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Reduce"}}</span>{{/unless}}
    </button>
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(239,68,68,0.2)] tw-border-[rgba(239,68,68,0.3)] tw-text-[#fca5a5]"
            data-action="removeCondition"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Remove'}}">
      <i class="fa-solid fa-xmark"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Remove"}}</span>{{/unless}}
    </button>
    {{/if}}
  {{/if}}

  {{!-- Critical Injury Actions --}}
  {{#if (eq item.type "criticalInjury")}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="rollSeverity"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.RollSeverity'}}">
      <i class="fa-solid fa-dice"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.RollSeverity"}}</span>{{/unless}}
    </button>
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(100,100,120,0.25)] tw-border-[rgba(100,100,120,0.4)] tw-text-[color:var(--color-text-secondary)]"
            data-action="treatInjury"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Treat'}}">
      <i class="fa-solid fa-kit-medical"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Treat"}}</span>{{/unless}}
    </button>
  {{/if}}

  {{!-- Psychic Power Actions --}}
  {{#if (or (eq item.type "psychicPower") (eq item.type "navigatorPower"))}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="manifestPower"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Manifest'}}">
      <i class="fa-solid fa-brain"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Manifest"}}</span>{{/unless}}
    </button>
  {{/if}}

  {{!-- Ammunition Actions --}}
  {{#if (eq item.type "ammunition")}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-gradient-to-br tw-from-[var(--wh40k-gold)] tw-to-[var(--wh40k-gold-dark)] tw-border-[var(--wh40k-gold-dark)] tw-text-white"
            data-action="loadAmmo"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Load'}}">
      <i class="fa-solid fa-arrow-up-from-bracket"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Load"}}</span>{{/unless}}
    </button>
  {{/if}}

  {{!-- Universal Actions --}}
  {{#unless inSheet}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(100,100,120,0.25)] tw-border-[rgba(100,100,120,0.4)] tw-text-[color:var(--color-text-secondary)]"
            data-action="postToChat"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.PostToChat'}}">
      <i class="fa-solid fa-comment"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.PostToChat"}}</span>{{/unless}}
    </button>
  {{/unless}}

  {{#if inSheet}}
    {{#if item.isOwner}}
    <button type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(100,100,120,0.25)] tw-border-[rgba(100,100,120,0.4)] tw-text-[color:var(--color-text-secondary)]"
            data-action="editItem"
            data-item-id="{{item.id}}"
            title="{{localize 'WH40K.Action.Edit'}}">
      <i class="fa-solid fa-pen-to-square"></i>
      {{#unless compact}}<span>{{localize "WH40K.Action.Edit"}}</span>{{/unless}}
    </button>
    {{/if}}
  {{/if}}

  {{#unless inSheet}}
    {{#if item.isOwner}}
      {{!-- Suppress delete for condition items unless the user is the GM (conditions are GM-imposed game state). --}}
      {{#if (eq item.type "condition")}}
        {{#if @root.isGM}}
        <button type="button"
                class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(239,68,68,0.2)] tw-border-[rgba(239,68,68,0.3)] tw-text-[#fca5a5]"
                data-action="deleteItem"
                data-item-id="{{item.id}}"
                title="{{localize 'WH40K.Action.Delete'}}">
          <i class="fa-solid fa-trash"></i>
          {{#unless compact}}<span>{{localize "WH40K.Action.Delete"}}</span>{{/unless}}
        </button>
        {{/if}}
      {{else}}
        <button type="button"
                class="tw-inline-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-item-spacing-xs)] tw-px-3 tw-py-[6px] tw-text-[var(--wh40k-item-font-size-sm)] tw-font-medium tw-rounded-[var(--wh40k-item-radius-sm)] tw-border tw-cursor-pointer tw-whitespace-nowrap tw-select-none tw-bg-[rgba(239,68,68,0.2)] tw-border-[rgba(239,68,68,0.3)] tw-text-[#fca5a5]"
                data-action="deleteItem"
                data-item-id="{{item.id}}"
                title="{{localize 'WH40K.Action.Delete'}}">
          <i class="fa-solid fa-trash"></i>
          {{#unless compact}}<span>{{localize "WH40K.Action.Delete"}}</span>{{/unless}}
        </button>
      {{/if}}
    {{/if}}
  {{/unless}}
</div>
{{/if}}
