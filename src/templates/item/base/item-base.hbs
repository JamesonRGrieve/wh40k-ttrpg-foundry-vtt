{{!-- Item-Base Physical Item Sheet Template --}}
{{!-- Base template for physical items (weapons, armour, gear, cybernetics, etc.) --}}
<div class="wh40k-item-sheet wh40k-physical-sheet wh40k-{{item.type}}-sheet">
  <form autocomplete="off">

    {{!-- HEADER: Image + Name + Badges (Class, Type, Craftsmanship) --}}
    {{> systems/wh40k-rpg/templates/item/panel/item-header.hbs variant="physical"}}

    {{!-- STAT BAR: Quick-reference metrics --}}
    {{> @partial-block name="stats"}}

    {{!-- TAB NAVIGATION --}}
    <nav class="tw-flex tw-border-b-2 tw-border-[var(--wh40k-border-color)] tw-bg-[var(--wh40k-panel-bg-translucent)] tw-flex-shrink-0" data-group="primary">
      <button type="button" class="wh40k-item-tab active tw-px-[var(--wh40k-space-lg)] tw-py-[var(--wh40k-space-sm)] tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-sm)] tw-uppercase tw-tracking-[0.1em] tw-text-[color:var(--wh40k-text-muted)] tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-transparent tw-mb-[-2px] tw-cursor-pointer tw-no-underline hover:tw-text-[color:var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="stats" data-group="primary">
        <i class="fas fa-chart-bar tw-mr-[var(--wh40k-space-xs)]"></i>
        <span>Stats</span>
      </button>
      <button type="button" class="wh40k-item-tab tw-px-[var(--wh40k-space-lg)] tw-py-[var(--wh40k-space-sm)] tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-sm)] tw-uppercase tw-tracking-[0.1em] tw-text-[color:var(--wh40k-text-muted)] tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-transparent tw-mb-[-2px] tw-cursor-pointer tw-no-underline hover:tw-text-[color:var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="properties" data-group="primary">
        <i class="fas fa-cogs tw-mr-[var(--wh40k-space-xs)]"></i>
        <span>Properties</span>
      </button>
      <button type="button" class="wh40k-item-tab tw-px-[var(--wh40k-space-lg)] tw-py-[var(--wh40k-space-sm)] tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-sm)] tw-uppercase tw-tracking-[0.1em] tw-text-[color:var(--wh40k-text-muted)] tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-transparent tw-mb-[-2px] tw-cursor-pointer tw-no-underline hover:tw-text-[color:var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="description" data-group="primary">
        <i class="fas fa-scroll tw-mr-[var(--wh40k-space-xs)]"></i>
        <span>Info</span>
      </button>
      <button type="button" class="wh40k-item-tab tw-px-[var(--wh40k-space-lg)] tw-py-[var(--wh40k-space-sm)] tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-sm)] tw-uppercase tw-tracking-[0.1em] tw-text-[color:var(--wh40k-text-muted)] tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-transparent tw-mb-[-2px] tw-cursor-pointer tw-no-underline hover:tw-text-[color:var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="effects" data-group="primary">
        <i class="fas fa-magic tw-mr-[var(--wh40k-space-xs)]"></i>
        <span>Effects</span>
      </button>
    </nav>

    {{!-- TAB CONTENT --}}
    <section class="tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-[var(--wh40k-space-md)]">

      {{!-- STATS TAB --}}
      <div class="tab active" data-tab="stats" data-group="primary">
        {{> @partial-block name="stats-tab"}}
      </div>

      {{!-- PROPERTIES TAB --}}
      <div class="tab" data-tab="properties" data-group="primary">
        {{!-- Acquisition Section (Weight, Availability, Craftsmanship) --}}
        {{> systems/wh40k-rpg/templates/item/panel/acquisition-panel.hbs}}

        {{!-- Type-specific properties --}}
        {{> @partial-block name="properties-tab"}}
      </div>

      {{!-- DESCRIPTION TAB --}}
      <div class="tab" data-tab="description" data-group="primary">
        {{> systems/wh40k-rpg/templates/item/panel/description-panel.hbs}}
        {{> systems/wh40k-rpg/templates/item/panel/source-panel.hbs}}
      </div>

      {{!-- EFFECTS TAB --}}
      <div class="tab" data-tab="effects" data-group="primary">
        {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
      </div>

    </section>
  </form>
</div>
