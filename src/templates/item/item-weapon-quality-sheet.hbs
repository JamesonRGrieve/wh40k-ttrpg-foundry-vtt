{{!
  Rogue Trader Weapon Quality Item Sheet - V2 Redesign
  Clean reference-card style for weapon quality definitions
}}
<div class="tw-flex tw-flex-col tw-h-full">
    <form autocomplete="off">

        {{! ═══════════════════════════════════════════════════════════════════
         HEADER: Simple quality identity
    ═══════════════════════════════════════════════════════════════════ }}
        <header class="tw-flex tw-items-center tw-gap-2 tw-p-3 tw-bg-gradient-to-br tw-from-orange-500/15 tw-to-transparent tw-border-b-2 tw-border-solid tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure">
            {{> systems/wh40k-rpg/templates/shared/editable-portrait.hbs src=item.img alt=item.name sizeClass="tw-w-14 tw-h-14" frameClass="tw-border-2 tw-border-solid tw-border-bronze tw-transition-transform hover:tw-scale-105" overlayIcon="fa-star" overlayBgClass="tw-bg-orange-500/70" overlayTextClass="tw-text-white" overlayIconClass="tw-text-xl" extraClass="tw-flex-shrink-0"}}

            <div class="tw-flex-1 tw-min-w-0">
                <input type="text" class="tw-w-full tw-px-2 tw-py-1 tw-bg-transparent tw-border-0 tw-border-b tw-border-solid tw-border-transparent tw-font-display tw-text-xl tw-font-semibold hover:tw-border-orange-500/60 focus:tw-border-orange-500/60 focus:tw-outline-none tw-transition-colors"
                       name="name" value="{{item.name}}" placeholder="Quality Name" />

                <div class="tw-flex tw-flex-wrap tw-gap-1.5 tw-mt-1.5 tw-pl-2">
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-md tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-bg-orange-500/15 tw-border tw-border-solid tw-border-orange-500/40 tw-text-orange-500" title="Item Type">
                        <i class="fas fa-star"></i>
                        Weapon Quality
                    </span>
                    {{#if system.hasLevel}}
                        <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-md tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-bg-blue-500/15 tw-border tw-border-solid tw-border-blue-500/40 tw-text-blue-500" title="Has Level">
                            <i class="fas fa-sort-numeric-up"></i>
                            Level
                            {{system.level}}
                        </span>
                    {{/if}}
                </div>
            </div>
        </header>

        {{! ═══════════════════════════════════════════════════════════════════
         STAT BAR: Quick reference stats
    ═══════════════════════════════════════════════════════════════════ }}
        <div class="tw-flex tw-flex-wrap tw-gap-0.5 tw-p-2 tw-bg-black/5 tw-border-b tw-border-solid tw-border-black/10">
            <div class="tw-flex tw-flex-col tw-items-center tw-flex-1 tw-min-w-[80px] tw-p-2 tw-bg-white/5 tw-rounded-md tw-border tw-border-solid tw-border-black/10">
                <div class="tw-text-base tw-text-orange-500/80 tw-mb-1">
                    <i class="fas fa-fingerprint"></i>
                </div>
                <div class="tw-flex tw-flex-col tw-items-center tw-gap-0.5">
                    <span class="tw-text-2xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-gray-500">Identifier</span>
                    <span class="tw-font-display tw-text-sm tw-font-semibold">{{system.identifier}}</span>
                </div>
            </div>

            <div class="tw-flex tw-flex-col tw-items-center tw-flex-1 tw-min-w-[80px] tw-p-2 tw-bg-white/5 tw-rounded-md tw-border tw-border-solid tw-border-black/10">
                <div class="tw-text-base tw-text-orange-500/80 tw-mb-1">
                    <i class="fas fa-sort-numeric-up"></i>
                </div>
                <div class="tw-flex tw-flex-col tw-items-center tw-gap-0.5">
                    <span class="tw-text-2xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-gray-500">Has Level</span>
                    <span class="tw-font-display tw-text-sm tw-font-semibold">{{#if system.hasLevel}}Yes{{else}}No{{/if}}</span>
                </div>
            </div>

            {{#if system.hasLevel}}
                <div class="tw-flex tw-flex-col tw-items-center tw-flex-1 tw-min-w-[80px] tw-p-2 tw-bg-white/5 tw-rounded-md tw-border tw-border-solid tw-border-black/10">
                    <div class="tw-text-base tw-text-orange-500/80 tw-mb-1">
                        <i class="fas fa-hashtag"></i>
                    </div>
                    <div class="tw-flex tw-flex-col tw-items-center tw-gap-0.5">
                        <span class="tw-text-2xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-gray-500">Level</span>
                        <span class="tw-font-display tw-text-sm tw-font-semibold">{{system.level}}</span>
                    </div>
                </div>
            {{/if}}
        </div>

        {{! ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ }}
        <nav class="wh40k-tabs tw-flex tw-gap-0.5 tw-px-3 tw-bg-black/5 tw-border-b tw-border-solid tw-border-black/10" data-group="primary">
            <button type="button" class="wh40k-tab active tw-flex tw-items-center tw-gap-1.5 tw-px-4 tw-py-2.5 tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-solid tw-border-transparent tw-text-sm tw-font-medium tw-text-gray-500 tw-cursor-pointer tw-transition-all [&.active]:tw-text-orange-500 [&.active]:tw-border-orange-500 [&.active]:tw-bg-orange-500/8" data-tab="effect" data-group="primary">
                <i class="fas fa-bolt"></i>
                <span>Effect</span>
            </button>
            <button type="button" class="wh40k-tab tw-flex tw-items-center tw-gap-1.5 tw-px-4 tw-py-2.5 tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-solid tw-border-transparent tw-text-sm tw-font-medium tw-text-gray-500 tw-cursor-pointer tw-transition-all [&.active]:tw-text-orange-500 [&.active]:tw-border-orange-500 [&.active]:tw-bg-orange-500/8" data-tab="details" data-group="primary">
                <i class="fas fa-cog"></i>
                <span>Details</span>
            </button>
            <button type="button" class="wh40k-tab tw-flex tw-items-center tw-gap-1.5 tw-px-4 tw-py-2.5 tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-solid tw-border-transparent tw-text-sm tw-font-medium tw-text-gray-500 tw-cursor-pointer tw-transition-all [&.active]:tw-text-orange-500 [&.active]:tw-border-orange-500 [&.active]:tw-bg-orange-500/8" data-tab="description" data-group="primary">
                <i class="fas fa-book"></i>
                <span>Description</span>
            </button>
        </nav>

        {{! ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ }}
        <section class="wh40k-tab-content tw-flex-1 tw-overflow-y-auto tw-p-3">

            {{! EFFECT TAB (Primary) }}
            <div class="tab active" data-tab="effect" data-group="primary">

                <div class="tw-bg-white/5 tw-border tw-border-solid tw-border-orange-500/30 tw-rounded-md tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2.5 tw-bg-gradient-to-r tw-from-orange-500/12 tw-to-transparent tw-border-b tw-border-solid tw-border-orange-500/20">
                        <i class="fas fa-bolt tw-text-orange-500 tw-text-sm"></i>
                        <h3 class="tw-flex-1 tw-m-0 tw-font-display tw-text-base tw-font-semibold">Mechanical Effect</h3>
                    </div>
                    <div class="tw-p-0">
                        {{editor system.effect target="system.effect" button=true editable=editable engine="prosemirror"}}
                    </div>
                </div>

                {{#if system.hasLevel}}
                    <div class="tw-bg-white/5 tw-border tw-border-solid tw-border-black/10 tw-rounded-md tw-mb-3 tw-overflow-hidden">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2.5 tw-border-b tw-border-solid tw-border-black/10">
                            <i class="fas fa-info-circle tw-text-bronze tw-text-sm"></i>
                            <h3 class="tw-flex-1 tw-m-0 tw-font-display tw-text-base tw-font-semibold">Level Explanation</h3>
                        </div>
                        <div class="tw-p-3">
                            <p class="tw-m-0 tw-p-2.5 tw-bg-blue-500/8 tw-border-l-4 tw-border-solid tw-border-blue-500/50 tw-rounded-md tw-text-sm tw-leading-relaxed">
                                This quality has a numeric level (X). The level is displayed as
                                <strong class="tw-font-semibold">{{item.name}} ({{system.level}})</strong>
                                when applied to a weapon. The effect above should reference the level value where applicable.
                            </p>
                        </div>
                    </div>
                {{/if}}

            </div>

            {{! DETAILS TAB }}
            <div class="tab" data-tab="details" data-group="primary">

                <div class="tw-bg-white/5 tw-border tw-border-solid tw-border-black/10 tw-rounded-md tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2.5 tw-border-b tw-border-solid tw-border-black/10">
                        <i class="fas fa-cog tw-text-bronze tw-text-sm"></i>
                        <h3 class="tw-flex-1 tw-m-0 tw-font-display tw-text-base tw-font-semibold">Quality Properties</h3>
                    </div>
                    <div class="tw-p-3">

                        <div class="tw-flex tw-flex-col tw-gap-0.5 tw-mb-3">
                            <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-gray-500">Identifier</label>
                            <input type="text" class="tw-w-full tw-px-2 tw-py-1.5 tw-bg-white/5 tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-text-sm tw-font-body" name="system.identifier" value="{{source.identifier}}" placeholder="e.g., tearing, blast, unwieldy" />
                            <p class="tw-m-0 tw-mt-0.5 tw-text-xs tw-italic tw-text-gray-500">Unique identifier (lowercase, hyphenated)</p>
                        </div>

                        <div class="tw-flex tw-flex-col tw-gap-0.5 tw-mb-3">
                            <label class="tw-flex tw-items-center tw-gap-2 tw-cursor-pointer tw-rounded-md tw-p-1.5 hover:tw-bg-white/5 tw-transition-colors">
                                <input type="checkbox" class="tw-w-4 tw-h-4 tw-cursor-pointer" name="system.hasLevel" {{checked system.hasLevel}} />
                                <span class="tw-text-sm tw-font-medium">Quality Has Numeric Level</span>
                            </label>
                            <p class="tw-m-0 tw-ml-7 tw-text-xs tw-italic tw-text-gray-500">Check if this quality takes a level parameter (e.g., Blast (X), Tearing (X))</p>
                        </div>

                        {{#if system.hasLevel}}
                            <div class="tw-flex tw-flex-col tw-gap-0.5 tw-mb-3">
                                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-gray-500">Default Level</label>
                                <input type="number" class="tw-w-full tw-px-2 tw-py-1.5 tw-bg-white/5 tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-text-sm" name="system.level" value="{{source.level}}" data-dtype="Number" min="0" />
                                <p class="tw-m-0 tw-mt-0.5 tw-text-xs tw-italic tw-text-gray-500">Default level value for this quality</p>
                            </div>
                        {{/if}}

                    </div>
                </div>

                <div class="tw-bg-white/5 tw-border tw-border-solid tw-border-black/10 tw-rounded-md tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2.5 tw-border-b tw-border-solid tw-border-black/10">
                        <i class="fas fa-sticky-note tw-text-bronze tw-text-sm"></i>
                        <h3 class="tw-flex-1 tw-m-0 tw-font-display tw-text-base tw-font-semibold">Notes</h3>
                    </div>
                    <div class="tw-p-3">
                        <textarea class="tw-w-full tw-px-2 tw-py-1.5 tw-bg-white/5 tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-text-sm tw-font-body tw-resize-y" name="system.notes" rows="4" placeholder="Additional notes, legacy data, GM notes...">{{system.notes}}</textarea>
                    </div>
                </div>

            </div>

            {{! DESCRIPTION TAB }}
            <div class="tab" data-tab="description" data-group="primary">

                <div class="tw-bg-white/5 tw-border tw-border-solid tw-border-black/10 tw-rounded-md tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2.5 tw-border-b tw-border-solid tw-border-black/10">
                        <i class="fas fa-book tw-text-bronze tw-text-sm"></i>
                        <h3 class="tw-flex-1 tw-m-0 tw-font-display tw-text-base tw-font-semibold">Full Description</h3>
                    </div>
                    <div class="tw-p-0">
                        {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
                    </div>
                </div>

                <div class="tw-bg-white/5 tw-border tw-border-solid tw-border-black/10 tw-rounded-md tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2.5 tw-border-b tw-border-solid tw-border-black/10">
                        <i class="fas fa-book-open tw-text-bronze tw-text-sm"></i>
                        <h3 class="tw-flex-1 tw-m-0 tw-font-display tw-text-base tw-font-semibold">Source</h3>
                    </div>
                    <div class="tw-p-3">
                        <div class="tw-grid tw-grid-cols-[2fr_1fr] tw-gap-2 tw-mb-3">
                            <div class="tw-flex tw-flex-col tw-gap-0.5">
                                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-gray-500">Source Book</label>
                                <input type="text" class="tw-w-full tw-px-2 tw-py-1.5 tw-bg-white/5 tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-text-sm" name="system.source.book" value="{{source.source.book}}" placeholder="Rogue Trader Core" />
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-0.5">
                                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-gray-500">Page</label>
                                <input type="text" class="tw-w-full tw-px-2 tw-py-1.5 tw-bg-white/5 tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-text-sm" name="system.source.page" value="{{source.source.page}}" placeholder="127" />
                            </div>
                        </div>
                        <div class="tw-flex tw-flex-col tw-gap-0.5">
                            <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-gray-500">Custom Reference</label>
                            <input type="text" class="tw-w-full tw-px-2 tw-py-1.5 tw-bg-white/5 tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-text-sm" name="system.source.custom" value="{{source.source.custom}}" placeholder="Homebrew, Errata, etc." />
                        </div>
                    </div>
                </div>

            </div>

        </section>

    </form>
</div>
