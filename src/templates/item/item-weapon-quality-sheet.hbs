{{! 
  Rogue Trader Weapon Quality Item Sheet - V2 Redesign
  Clean reference-card style for weapon quality definitions
}}
<div class="wh40k-weapon-quality-sheet">
    <form autocomplete="off">

        {{! ═══════════════════════════════════════════════════════════════════
         HEADER: Simple quality identity
    ═══════════════════════════════════════════════════════════════════ }}
        <header class="wh40k-quality-header">
            <div class="wh40k-quality-header__image" data-action="editImage" data-edit="img">
                <img src="{{item.img}}" alt="{{item.name}}" />
                <div class="wh40k-quality-header__image-overlay">
                    <i class="fas fa-star"></i>
                </div>
            </div>

            <div class="wh40k-quality-header__info">
                <input type="text" class="wh40k-quality-header__name" name="name" value="{{item.name}}" placeholder="Quality Name" />

                <div class="wh40k-quality-header__meta">
                    <span class="wh40k-quality-badge wh40k-quality-badge--type" title="Item Type">
                        <i class="fas fa-star"></i>
                        Weapon Quality
                    </span>
                    {{#if system.hasLevel}}
                        <span class="wh40k-quality-badge wh40k-quality-badge--level" title="Has Level">
                            <i class="fas fa-sort-numeric-up"></i>
                            Level
                            {{system.level}}
                        </span>
                    {{/if}}
                </div>
            </div>
        </header>

        {{! ═══════════════════════════════════════════════════════════════════
         STAT BAR: Quick reference stats
    ═══════════════════════════════════════════════════════════════════ }}
        <div class="wh40k-quality-stats">
            <div class="wh40k-quality-stat">
                <div class="wh40k-quality-stat__icon">
                    <i class="fas fa-fingerprint"></i>
                </div>
                <div class="wh40k-quality-stat__content">
                    <span class="wh40k-quality-stat__label">Identifier</span>
                    <span class="wh40k-quality-stat__value">{{system.identifier}}</span>
                </div>
            </div>

            <div class="wh40k-quality-stat">
                <div class="wh40k-quality-stat__icon">
                    <i class="fas fa-sort-numeric-up"></i>
                </div>
                <div class="wh40k-quality-stat__content">
                    <span class="wh40k-quality-stat__label">Has Level</span>
                    <span class="wh40k-quality-stat__value">{{#if system.hasLevel}}Yes{{else}}No{{/if}}</span>
                </div>
            </div>

            {{#if system.hasLevel}}
                <div class="wh40k-quality-stat">
                    <div class="wh40k-quality-stat__icon">
                        <i class="fas fa-hashtag"></i>
                    </div>
                    <div class="wh40k-quality-stat__content">
                        <span class="wh40k-quality-stat__label">Level</span>
                        <span class="wh40k-quality-stat__value">{{system.level}}</span>
                    </div>
                </div>
            {{/if}}
        </div>

        {{! ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ }}
        <nav class="wh40k-tabs wh40k-tabs--quality wh40k-quality-tabs" data-group="primary">
            <button type="button" class="wh40k-tab wh40k-quality-tab active" data-tab="effect" data-group="primary">
                <i class="fas fa-bolt"></i>
                <span>Effect</span>
            </button>
            <button type="button" class="wh40k-tab wh40k-quality-tab" data-tab="details" data-group="primary">
                <i class="fas fa-cog"></i>
                <span>Details</span>
            </button>
            <button type="button" class="wh40k-tab wh40k-quality-tab" data-tab="description" data-group="primary">
                <i class="fas fa-book"></i>
                <span>Description</span>
            </button>
        </nav>

        {{! ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ }}
        <section class="wh40k-quality-content wh40k-tab-content wh40k-tab-content--quality">

            {{! EFFECT TAB (Primary) }}
            <div class="wh40k-quality-panel tab active" data-tab="effect" data-group="primary">

                <div class="wh40k-quality-section wh40k-quality-section--effect">
                    <div class="wh40k-quality-section__header">
                        <i class="fas fa-bolt"></i>
                        <h3>Mechanical Effect</h3>
                    </div>
                    <div class="wh40k-quality-section__body wh40k-quality-section__body--editor">
                        {{editor system.effect target="system.effect" button=true editable=editable engine="prosemirror"}}
                    </div>
                </div>

                {{#if system.hasLevel}}
                    <div class="wh40k-quality-section">
                        <div class="wh40k-quality-section__header">
                            <i class="fas fa-info-circle"></i>
                            <h3>Level Explanation</h3>
                        </div>
                        <div class="wh40k-quality-section__body">
                            <p class="wh40k-hint-text">
                                This quality has a numeric level (X). The level is displayed as
                                <strong>{{item.name}} ({{system.level}})</strong>
                                when applied to a weapon. The effect above should reference the level value where applicable.
                            </p>
                        </div>
                    </div>
                {{/if}}

            </div>

            {{! DETAILS TAB }}
            <div class="wh40k-quality-panel tab" data-tab="details" data-group="primary">

                <div class="wh40k-quality-section">
                    <div class="wh40k-quality-section__header">
                        <i class="fas fa-cog"></i>
                        <h3>Quality Properties</h3>
                    </div>
                    <div class="wh40k-quality-section__body">

                        <div class="wh40k-field">
                            <label>Identifier</label>
                            <input type="text" name="system.identifier" value="{{system.identifier}}" placeholder="e.g., tearing, blast, unwieldy" />
                            <p class="wh40k-field-hint">Unique identifier (lowercase, hyphenated)</p>
                        </div>

                        <div class="wh40k-field wh40k-field--checkbox">
                            <label>
                                <input type="checkbox" name="system.hasLevel" {{checked system.hasLevel}} />
                                <span>Quality Has Numeric Level</span>
                            </label>
                            <p class="wh40k-field-hint">Check if this quality takes a level parameter (e.g., Blast (X), Tearing (X))</p>
                        </div>

                        {{#if system.hasLevel}}
                            <div class="wh40k-field">
                                <label>Default Level</label>
                                <input type="number" name="system.level" value="{{system.level}}" data-dtype="Number" min="0" />
                                <p class="wh40k-field-hint">Default level value for this quality</p>
                            </div>
                        {{/if}}

                    </div>
                </div>

                <div class="wh40k-quality-section">
                    <div class="wh40k-quality-section__header">
                        <i class="fas fa-sticky-note"></i>
                        <h3>Notes</h3>
                    </div>
                    <div class="wh40k-quality-section__body">
                        <textarea name="system.notes" rows="4" placeholder="Additional notes, legacy data, GM notes...">{{system.notes}}</textarea>
                    </div>
                </div>

            </div>

            {{! DESCRIPTION TAB }}
            <div class="wh40k-quality-panel tab" data-tab="description" data-group="primary">

                <div class="wh40k-quality-section">
                    <div class="wh40k-quality-section__header">
                        <i class="fas fa-book"></i>
                        <h3>Full Description</h3>
                    </div>
                    <div class="wh40k-quality-section__body wh40k-quality-section__body--editor">
                        {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
                    </div>
                </div>

                <div class="wh40k-quality-section">
                    <div class="wh40k-quality-section__header">
                        <i class="fas fa-book-open"></i>
                        <h3>Source</h3>
                    </div>
                    <div class="wh40k-quality-section__body">
                        <div class="wh40k-field-row">
                            <div class="wh40k-field">
                                <label>Source Book</label>
                                <input type="text" name="system.source.book" value="{{system.source.book}}" placeholder="Rogue Trader Core" />
                            </div>
                            <div class="wh40k-field">
                                <label>Page</label>
                                <input type="text" name="system.source.page" value="{{system.source.page}}" placeholder="127" />
                            </div>
                        </div>
                        <div class="wh40k-field">
                            <label>Custom Reference</label>
                            <input type="text" name="system.source.custom" value="{{system.source.custom}}" placeholder="Homebrew, Errata, etc." />
                        </div>
                    </div>
                </div>

            </div>

        </section>

    </form>
</div>