{{!-- Skill Item Sheet - Imperial Gothic Redesign --}}
<div class="wh40k-item-sheet wh40k-skill-sheet tw-flex tw-flex-col tw-h-full">
    <form autocomplete="off" class="tw-flex tw-flex-col tw-flex-1 tw-min-h-0">
        {{!-- Header --}}
        <header class="wh40k-item-header tw-grid tw-gap-3 tw-px-4 tw-py-3 tw-shrink-0 tw-bg-[linear-gradient(180deg,rgba(212,175,55,0.15)_0%,transparent_100%)] tw-border-b-2 tw-border-gold-dark" style="grid-template-columns: 80px 1fr;">
            <div class="wh40k-item-image tw-w-20 tw-h-20 tw-rounded-md tw-overflow-hidden tw-cursor-pointer tw-shrink-0 tw-border-2 tw-border-[var(--wh40k-gold)] tw-shadow-[var(--wh40k-shadow-md),0_0_10px_rgba(212,175,55,0.3)] tw-transition-all hover:tw-scale-105 hover:tw-shadow-[var(--wh40k-shadow-lg),0_0_20px_rgba(212,175,55,0.5)]" data-edit="img">
                <img src="{{item.img}}" alt="{{item.name}}" class="tw-w-full tw-h-full tw-object-cover" />
            </div>
            <div class="wh40k-item-title tw-flex tw-flex-col tw-justify-center tw-gap-1 tw-min-w-0">
                <input type="text" class="wh40k-item-title__name tw-font-display tw-text-xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-bg-transparent tw-border-none tw-w-full tw-px-1 tw-py-0.5" name="name" value="{{item.name}}" placeholder="Skill Name" />
                <div class="wh40k-item-meta tw-flex tw-flex-wrap tw-gap-1 tw-mt-1 tw-items-center">
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-bg-[linear-gradient(135deg,rgba(41,128,185,0.15),rgba(41,128,185,0.12))] tw-border tw-border-[rgba(41,128,185,0.4)] tw-text-[var(--wh40k-accent-info)]">
                        <i class="fas fa-graduation-cap"></i> Skill
                    </span>
                    <select name="system.skillType" class="wh40k-meta-select tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs">
                        <option value="basic" {{#if (eq item.system.skillType "basic")}}selected{{/if}}>Basic</option>
                        <option value="advanced" {{#if (eq item.system.skillType "advanced")}}selected{{/if}}>Advanced</option>
                        <option value="specialist" {{#if (eq item.system.skillType "specialist")}}selected{{/if}}>Specialist</option>
                    </select>
                    <select name="system.characteristic" class="wh40k-meta-select tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs">
                        <option value="agility" {{#if (eq item.system.characteristic "agility")}}selected{{/if}}>Agility</option>
                        <option value="ballisticSkill" {{#if (eq item.system.characteristic "ballisticSkill")}}selected{{/if}}>Ballistic Skill</option>
                        <option value="fellowship" {{#if (eq item.system.characteristic "fellowship")}}selected{{/if}}>Fellowship</option>
                        <option value="intelligence" {{#if (eq item.system.characteristic "intelligence")}}selected{{/if}}>Intelligence</option>
                        <option value="perception" {{#if (eq item.system.characteristic "perception")}}selected{{/if}}>Perception</option>
                        <option value="strength" {{#if (eq item.system.characteristic "strength")}}selected{{/if}}>Strength</option>
                        <option value="toughness" {{#if (eq item.system.characteristic "toughness")}}selected{{/if}}>Toughness</option>
                        <option value="weaponSkill" {{#if (eq item.system.characteristic "weaponSkill")}}selected{{/if}}>Weapon Skill</option>
                        <option value="willpower" {{#if (eq item.system.characteristic "willpower")}}selected{{/if}}>Willpower</option>
                    </select>
                </div>

                {{!-- Badges Row --}}
                <div class="wh40k-skill-badges tw-flex tw-flex-wrap tw-gap-1 tw-mt-1">
                    {{!-- Skill Type Badge --}}
                    {{#if (eq item.system.skillType "basic")}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-font-semibold tw-uppercase tw-tracking-tight tw-bg-[linear-gradient(135deg,rgba(39,174,96,0.15),rgba(39,174,96,0.08))] tw-border tw-border-[rgba(39,174,96,0.4)] tw-text-[var(--wh40k-accent-green)]">
                        <i class="fas fa-circle-check"></i> Basic
                    </span>
                    {{else if (eq item.system.skillType "advanced")}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-font-semibold tw-uppercase tw-tracking-tight tw-bg-[linear-gradient(135deg,rgba(230,126,34,0.15),rgba(230,126,34,0.08))] tw-border tw-border-[rgba(230,126,34,0.4)] tw-text-[#e67e22]">
                        <i class="fas fa-star"></i> Advanced
                    </span>
                    {{else if (eq item.system.skillType "specialist")}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-font-semibold tw-uppercase tw-tracking-tight tw-bg-[linear-gradient(135deg,rgba(122,60,180,0.15),rgba(122,60,180,0.08))] tw-border tw-border-[rgba(122,60,180,0.4)] tw-text-purple-400">
                        <i class="fas fa-flask"></i> Specialist
                    </span>
                    {{/if}}

                    {{!-- Characteristic Badge --}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-font-semibold tw-uppercase tw-bg-[linear-gradient(135deg,rgba(212,175,55,0.15),rgba(212,175,55,0.08))] tw-border tw-border-[rgba(212,175,55,0.4)] tw-text-gold">
                        <i class="fas fa-dice-d20"></i> {{capitalize item.system.characteristicAbbr}}
                    </span>

                    {{!-- Descriptor Badge (if exists) --}}
                    {{#if item.system.descriptor}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-bg-[rgba(149,165,166,0.15)] tw-border tw-border-[rgba(149,165,166,0.3)] tw-text-[#95a5a6]" title="{{item.system.descriptor}}">
                        <i class="fas fa-tag"></i> {{item.system.descriptor}}
                    </span>
                    {{/if}}
                </div>
            </div>
        </header>

        {{!-- Body --}}
        <div class="wh40k-item-body tw-flex tw-flex-col tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-3 tw-gap-3">

            {{!-- Properties Panel --}}
            <section class="tw-bg-black/20 tw-border tw-border-white/[0.08] tw-rounded-md tw-p-3">
                <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-pb-2 tw-mb-3 tw-border-b tw-border-white/10">
                    <i class="fas fa-info-circle tw-text-[var(--wh40k-accent-info)]"></i> Properties
                </h3>

                <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-opacity-70">Characteristic</label>
                        <div class="tw-text-sm tw-bg-black/30 tw-border tw-border-white/[0.05] tw-rounded-sm tw-px-2.5 tw-py-1.5">{{item.system.characteristicLabel}}</div>
                    </div>

                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-opacity-70">Skill Type</label>
                        <div class="tw-text-sm tw-bg-black/30 tw-border tw-border-white/[0.05] tw-rounded-sm tw-px-2.5 tw-py-1.5">{{capitalize item.system.skillType}}</div>
                    </div>

                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-opacity-70">Use Time</label>
                        <input type="text" name="system.useTime" value="{{item.system.useTime}}" placeholder="Half Action" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
                    </div>

                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-opacity-70">Untrained Use</label>
                        <div class="tw-text-sm tw-bg-black/30 tw-border tw-border-white/[0.05] tw-rounded-sm tw-px-2.5 tw-py-1.5">
                            {{#if item.system.isBasic}}
                                <i class="fas fa-check tw-text-success"></i> Can use untrained
                            {{else}}
                                <i class="fas fa-times tw-text-crimson"></i> Cannot use untrained
                            {{/if}}
                        </div>
                    </div>
                </div>

                {{!-- Aptitudes --}}
                {{#if item.system.aptitudes.length}}
                <div class="tw-flex tw-flex-col tw-gap-1 tw-mt-4">
                    <label class="tw-text-xs tw-opacity-70">Aptitudes</label>
                    <div class="tw-flex tw-flex-wrap tw-gap-1">
                        {{#each item.system.aptitudes}}
                        <span class="tw-inline-flex tw-items-center tw-px-2 tw-py-0.5 tw-rounded-full tw-text-xs tw-bg-black/20 tw-border tw-border-white/10">{{this}}</span>
                        {{/each}}
                    </div>
                </div>
                {{else}}
                <div class="tw-flex tw-flex-col tw-gap-1 tw-mt-4">
                    <label class="tw-text-xs tw-opacity-70">Aptitudes</label>
                    <input type="text" name="system.aptitudes" value="" placeholder="Agility, General (comma-separated)" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
                </div>
                {{/if}}
            </section>

            {{!-- Descriptor Panel --}}
            {{#if item.system.descriptor}}
            <section class="tw-bg-[linear-gradient(135deg,rgba(41,128,185,0.08),rgba(41,128,185,0.05))] tw-border tw-border-[rgba(41,128,185,0.2)] tw-border-l-[3px] tw-border-l-[var(--wh40k-accent-info)] tw-rounded-r-md tw-p-3">
                <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-mb-2 tw-text-[var(--wh40k-accent-info)]">
                    <i class="fas fa-align-left"></i> Description
                </h3>
                <div class="tw-text-sm tw-italic tw-leading-relaxed tw-p-2">
                    {{item.system.descriptor}}
                </div>
            </section>
            {{/if}}

            {{!-- Specializations (for specialist skills) --}}
            {{#if (eq item.system.skillType "specialist")}}
            <section class="tw-bg-black/20 tw-border tw-border-white/[0.08] tw-rounded-md tw-p-3">
                <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-pb-2 tw-mb-3 tw-border-b tw-border-white/10">
                    <i class="fas fa-list-ul tw-text-purple-400"></i> Specializations
                </h3>

                {{#if item.system.specializations.length}}
                <div class="tw-flex tw-flex-wrap tw-gap-1 tw-mb-2">
                    {{#each item.system.specializations}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-bg-[rgba(122,60,180,0.15)] tw-border tw-border-[rgba(122,60,180,0.3)] tw-text-purple-400">
                        <i class="fas fa-chevron-right tw-text-xs"></i> {{this}}
                    </span>
                    {{/each}}
                </div>
                {{/if}}

                <input type="text"
                       class="tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm"
                       name="system.specializations"
                       value="{{join item.system.specializations ", "}}"
                       placeholder="Imperium, Koronus Expanse, War (comma-separated)" />
            </section>
            {{/if}}

            {{!-- Uses & Rules Panel --}}
            <section class="tw-bg-black/20 tw-border tw-border-white/[0.08] tw-rounded-md tw-p-3">
                <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-pb-2 tw-mb-3 tw-border-b tw-border-white/10">
                    <i class="fas fa-book-open tw-text-[var(--wh40k-accent-green)]"></i> Uses &amp; Rules
                </h3>
                <div class="editor tw-text-sm" data-edit="system.uses">
                    {{{item.system.uses}}}
                </div>
            </section>

            {{!-- Difficulty Examples Table --}}
            <section class="tw-bg-black/20 tw-border tw-border-white/[0.08] tw-rounded-md tw-p-3">
                <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-pb-2 tw-mb-3 tw-border-b tw-border-white/10">
                    <i class="fas fa-chart-line tw-text-[#e67e22]"></i> Example Difficulties
                </h3>

                {{#if item.system.exampleDifficulties.length}}
                <table class="tw-w-full tw-border-collapse">
                    <thead class="tw-bg-black/40">
                        <tr>
                            <th class="tw-px-2 tw-py-1 tw-text-left tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70 tw-border-b tw-border-white/10">Difficulty</th>
                            <th class="tw-px-2 tw-py-1 tw-text-center tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70 tw-border-b tw-border-white/10">Modifier</th>
                            <th class="tw-px-2 tw-py-1 tw-text-left tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70 tw-border-b tw-border-white/10">Example</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each item.system.exampleDifficulties}}
                        <tr class="tw-border-b tw-border-white/[0.05] hover:tw-bg-white/[0.03]">
                            <td class="tw-px-2 tw-py-1 tw-text-sm tw-font-semibold tw-text-[#e67e22]">{{this.difficulty}}</td>
                            <td class="tw-px-2 tw-py-1 tw-text-sm tw-text-center tw-font-bold {{#if (gt this.modifier 0)}}tw-text-success{{else if (lt this.modifier 0)}}tw-text-crimson{{else}}tw-opacity-70{{/if}}">
                                {{#if (gt this.modifier 0)}}+{{/if}}{{this.modifier}}
                            </td>
                            <td class="tw-px-2 tw-py-1 tw-text-sm">{{this.example}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                {{else}}
                <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-italic tw-opacity-70 tw-p-2">
                    <i class="fas fa-info-circle"></i> No example difficulties defined
                </div>
                {{/if}}
            </section>

            {{!-- Special Rules (optional) --}}
            {{#if item.system.specialRules}}
            <section class="tw-bg-[linear-gradient(135deg,rgba(122,60,180,0.08)_0%,rgba(142,68,173,0.05)_100%)] tw-border tw-border-[rgba(122,60,180,0.2)] tw-border-l-[3px] tw-border-l-purple-500 tw-rounded-r-md tw-p-3">
                <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-mb-2 tw-text-purple-400">
                    <i class="fas fa-exclamation-triangle"></i> Special Rules
                </h3>
                <div class="editor tw-text-sm" data-edit="system.specialRules">
                    {{{item.system.specialRules}}}
                </div>
            </section>
            {{/if}}

            {{!-- Roll Config (advanced settings) --}}
            <section class="tw-bg-black/[0.15] tw-border tw-border-white/[0.05] tw-rounded-md tw-p-3">
                <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-pb-2 tw-mb-3 tw-border-b tw-border-white/[0.08] tw-opacity-70">
                    <i class="fas fa-cog"></i> Roll Configuration
                </h3>

                <div class="tw-grid tw-grid-cols-3 tw-gap-3">
                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-opacity-70">Default Modifier</label>
                        <input type="number" name="system.rollConfig.defaultModifier" value="{{item.system.rollConfig.defaultModifier}}" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
                    </div>

                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-opacity-70">Untrained Penalty</label>
                        <input type="number" name="system.rollConfig.untrainedPenalty" value="{{item.system.rollConfig.untrainedPenalty}}" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
                    </div>

                    <div class="tw-flex tw-flex-col tw-gap-1 tw-justify-end">
                        <label class="tw-flex tw-items-center tw-gap-2 tw-cursor-pointer tw-text-sm">
                            <input type="checkbox" name="system.rollConfig.canBeUsedUntrained" {{checked item.system.rollConfig.canBeUsedUntrained}} />
                            Can Use Untrained
                        </label>
                    </div>
                </div>
            </section>

            {{!-- Footer: Source --}}
            <div class="tw-pt-4 tw-border-t tw-border-white/10">
                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70 tw-mb-1 tw-block">Source</label>
                <input type="text"
                       class="tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm"
                       name="system.source"
                       value="{{#if item.system.source}}{{item.system.source}}{{else}}Core Rulebook{{/if}}"
                       placeholder="Core Rulebook" />
            </div>
        </div>
    </form>
</div>
