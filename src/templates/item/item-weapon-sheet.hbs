{{!-- 
  Rogue Trader Weapon Item Sheet V3 - Modern Single-Page Redesign
  Features: Sticky header+stats, action cards in mosaic, collapsible sections, color-coded stats
--}}
<div class="wh40k-weapon-sheet-v3 tw-flex tw-flex-col tw-h-full">
    
    {{!-- ═══════════════════════════════════════════════════════════════════
         STICKY HEADER AREA (Header + Stats)
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-weapon-sticky-header">
      
      {{!-- HEADER WITH EDIT TOGGLE --}}
      <header class="wh40k-weapon-header">
        <div class="wh40k-item-image wh40k-item-image--sm" data-action="editImage">
          <img src="{{item.img}}" alt="{{item.name}}" />
        </div>

        <div class="wh40k-item-title">
          <input type="text" class="wh40k-item-title__name {{#unless inEditMode}}wh40k-input--readonly{{/unless}}" 
                 name="name" value="{{item.name}}" placeholder="Weapon Name" 
                 {{#unless inEditMode}}readonly{{/unless}} />
          
          <div class="wh40k-item-meta wh40k-weapon-meta">
            <span class="wh40k-meta-badge wh40k-meta-badge--weapon-class" title="Weapon Class: {{system.classLabel}}">
              <i class="fa-solid fa-{{#if system.isMeleeWeapon}}sword{{else}}gun{{/if}}"></i>
              {{system.classLabel}}
            </span>
            <span class="wh40k-meta-badge wh40k-meta-badge--weapon-type" title="Weapon Type: {{system.typeLabel}}">
              <i class="fa-solid {{system.typeIcon}}"></i>
              {{system.typeLabel}}
            </span>
            {{#if (ne system.craftsmanship "common")}}
            <span class="wh40k-meta-badge wh40k-meta-badge--craft wh40k-meta-badge--{{system.craftsmanship}}" title="Craftsmanship">
              {{system.craftsmanshipLabel}}
            </span>
            {{/if}}
          </div>
        </div>

        <div class="wh40k-weapon-header-actions">
          {{#if isOwnedByActor}}
          {{/if}}
          
          {{#if canEdit}}
          <button type="button" class="wh40k-edit-toggle {{#if inEditMode}}active tw-animate-glow-pulse{{/if}}"
                  data-action="toggleEditMode"
                  data-tooltip="{{#if inEditMode}}Exit Edit Mode{{else}}Edit Mode{{/if}}">
            <i class="fa-solid {{#if inEditMode}}fa-lock-open{{else}}fa-pen-to-square{{/if}}"></i>
          </button>
          {{/if}}
        </div>
      </header>

      {{!-- ICONIC STAT MOSAIC --}}
      <div class="wh40k-weapon-mosaic">
        {{!-- Attack Action Card (if owned by actor) --}}
        {{#if isOwnedByActor}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--action wh40k-iconic-stat--attack wh40k-iconic-stat--medium"
             data-action="rollAttack"
             data-tooltip="Roll Attack">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-crosshairs"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value">Attack</span>
            <span class="wh40k-iconic-stat__label">d100</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
        </div>
        {{/if}}
        
        {{!-- Damage Card (clickable to roll if owned) --}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--damage wh40k-iconic-stat--large {{#if hasModificationEffects}}wh40k-iconic-stat--modified{{/if}} {{#if isOwnedByActor}}wh40k-iconic-stat--clickable{{/if}}"
             {{#if isOwnedByActor}}data-action="rollDamage"{{/if}}
             data-tooltip="{{#if isOwnedByActor}}Click to Roll Damage{{else}}Damage{{/if}}">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-skull"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value">{{fullDamageFormula}}</span>
            <span class="wh40k-iconic-stat__label">Damage</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
          {{#if hasModificationEffects}}<span class="wh40k-iconic-stat__mod-star tw-animate-star-twinkle tw-absolute tw-top-1 tw-right-1.5 tw-text-[0.6rem] tw-text-[var(--wh40k-gold)] tw-z-[3] tw-pointer-events-none" aria-hidden="true">★</span>{{/if}}
        </div>

        {{!-- Penetration - Arrow (Medium) --}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--pen wh40k-iconic-stat--medium {{#if hasModificationEffects}}wh40k-iconic-stat--modified{{/if}}"
             data-tooltip="Penetration">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-location-arrow"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value">{{effectivePenetration}}</span>
            <span class="wh40k-iconic-stat__label">Penetration</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
          {{#if hasModificationEffects}}<span class="wh40k-iconic-stat__mod-star tw-animate-star-twinkle tw-absolute tw-top-1 tw-right-1.5 tw-text-[0.6rem] tw-text-[var(--wh40k-gold)] tw-z-[3] tw-pointer-events-none" aria-hidden="true">★</span>{{/if}}
        </div>

        {{!-- To Hit - Crosshairs (Medium, conditional) --}}
        {{#if (ne effectiveToHit 0)}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--tohit wh40k-iconic-stat--medium"
             data-tooltip="To Hit Modifier">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-bullseye"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value {{#if (gt effectiveToHit 0)}}wh40k-iconic-stat__value--positive{{else}}wh40k-iconic-stat__value--negative{{/if}}">
              {{#if (gt effectiveToHit 0)}}+{{/if}}{{effectiveToHit}}
            </span>
            <span class="wh40k-iconic-stat__label">To Hit</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
        </div>
        {{/if}}
        
        {{!-- Range - Crosshairs/Target (Medium, ranged only) --}}
        {{#if system.isRangedWeapon}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--range wh40k-iconic-stat--medium"
             data-tooltip="Range">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-ruler"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value">{{system.rangeLabel}}</span>
            <span class="wh40k-iconic-stat__label">Range</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
        </div>
        
        {{!-- Rate of Fire - Burst (Small) --}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--rof wh40k-iconic-stat--small"
             data-tooltip="Rate of Fire">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-burst"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value">{{system.rateOfFireLabel}}</span>
            <span class="wh40k-iconic-stat__label">RoF</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
        </div>
        {{/if}}
        
        {{!-- Clip - Magazine (clickable to decrement if owned) --}}
        {{#if system.usesAmmo}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--clip wh40k-iconic-stat--small wh40k-iconic-stat--ammo-{{system.ammoStatus}} {{#if (or (eq system.ammoStatus "critical") (eq system.ammoStatus "empty"))}}tw-animate-clip-pulse{{/if}} {{#if isOwnedByActor}}wh40k-iconic-stat--clickable{{/if}}"
             {{#if isOwnedByActor}}data-action="expendAmmo"{{/if}}
             data-tooltip="{{#if isOwnedByActor}}Click to Spend Ammo{{else}}Ammunition{{/if}}">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-gun"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value">{{system.clip.value}}/{{system.effectiveClipMax}}</span>
            <span class="wh40k-iconic-stat__label">Clip</span>
          </div>
          <div class="wh40k-iconic-stat__progress" style="--progress: {{system.ammoPercentage}}%"></div>
          <div class="wh40k-iconic-stat__glow"></div>
        </div>
        
        {{!-- Reload Action Card (if owned by actor and uses ammo) --}}
        {{#if isOwnedByActor}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--action wh40k-iconic-stat--reload wh40k-iconic-stat--small {{#if (eq system.clip.value system.effectiveClipMax)}}wh40k-iconic-stat--disabled{{/if}}"
             data-action="reload"
             data-tooltip="Reload ({{system.reloadLabel}})">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-rotate-right"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value">Reload</span>
            <span class="wh40k-iconic-stat__label">{{system.reloadLabel}}</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
        </div>
        {{/if}}
        {{/if}}
        
        {{!-- Weight - Scale (Small) --}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--weight wh40k-iconic-stat--small"
             data-tooltip="Weight">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-scale-balanced"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value">{{effectiveWeight}}<small>kg</small></span>
            <span class="wh40k-iconic-stat__label">Weight</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
        </div>
        
        {{!-- Individual Quality Cards --}}
        {{#each qualitiesArray}}
        <div class="wh40k-iconic-stat wh40k-iconic-stat--quality wh40k-iconic-stat--small"
             data-action="openQuality"
             data-identifier="{{identifier}}"
             data-wh40k-tooltip="quality"
             data-wh40k-tooltip-data="{{@root.prepareQualityTooltip identifier level}}">
          <div class="wh40k-iconic-stat__shape">
            <i class="fa-solid fa-star"></i>
          </div>
          <div class="wh40k-iconic-stat__content">
            <span class="wh40k-iconic-stat__value wh40k-iconic-stat__value--quality">{{label}}</span>
          </div>
          <div class="wh40k-iconic-stat__glow"></div>
        </div>
        {{/each}}
      </div>
      
      {{!-- Body Toggle Button --}}
      <button type="button" class="wh40k-body-toggle" data-action="toggleBody" title="{{#if bodyCollapsed}}Show Details{{else}}Hide Details{{/if}}">
        <span class="wh40k-body-toggle__label">{{#if bodyCollapsed}}Show Details{{else}}Hide Details{{/if}}</span>
        <i class="fa-solid {{#if bodyCollapsed}}fa-chevron-down{{else}}fa-chevron-up{{/if}} wh40k-body-toggle__icon"></i>
      </button>
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         SCROLLABLE BODY
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-weapon-body {{#if bodyCollapsed}}collapsed{{/if}}">
      
      {{!-- LOADED AMMO BANNER (if loaded) --}}
      {{#if (and system.usesAmmo hasLoadedAmmo)}}
      <div class="wh40k-loaded-ammo-card tw-animate-[slide-in-up_0.4s_ease-out]">
        <div class="wh40k-loaded-ammo-card__header">
          <i class="fa-solid fa-circle-dot"></i>
          <span class="wh40k-loaded-ammo-card__name">{{loadedAmmoLabel}}</span>
          {{#if isOwnedByActor}}
          <button type="button" class="wh40k-btn wh40k-btn--icon wh40k-btn--ghost" data-action="ejectAmmo" title="Eject">
            <i class="fa-solid fa-eject"></i>
          </button>
          {{/if}}
        </div>
        {{#if loadedAmmoData.modifiers}}
        <div class="wh40k-loaded-ammo-card__effects">
          {{#if (ne loadedAmmoData.modifiers.damage 0)}}
          <span class="wh40k-ammo-mod {{#if (gt loadedAmmoData.modifiers.damage 0)}}wh40k-ammo-mod--positive{{else}}wh40k-ammo-mod--negative{{/if}}">
            Dmg {{#if (gt loadedAmmoData.modifiers.damage 0)}}+{{/if}}{{loadedAmmoData.modifiers.damage}}
          </span>
          {{/if}}
          {{#if (ne loadedAmmoData.modifiers.penetration 0)}}
          <span class="wh40k-ammo-mod {{#if (gt loadedAmmoData.modifiers.penetration 0)}}wh40k-ammo-mod--positive{{else}}wh40k-ammo-mod--negative{{/if}}">
            Pen {{#if (gt loadedAmmoData.modifiers.penetration 0)}}+{{/if}}{{loadedAmmoData.modifiers.penetration}}
          </span>
          {{/if}}
          {{#if (gt loadedAmmoData.addedQualities.length 0)}}
          <span class="wh40k-ammo-mod wh40k-ammo-mod--quality">+{{join loadedAmmoData.addedQualities ", "}}</span>
          {{/if}}
        </div>
        {{/if}}
      </div>
      {{/if}}

      {{!-- MODIFICATIONS CARDS (Integrated) --}}
      {{#if modificationsData.length}}
      <div class="wh40k-mods-inline">
        {{#each modificationsData as |mod|}}
        <div class="wh40k-mod-chip tw-animate-slide-in-up {{#unless mod.active}}wh40k-mod-chip--inactive{{/unless}}">
          <i class="fa-solid {{mod.categoryIcon}}"></i>
          <span>{{mod.name}}</span>
          <button type="button" class="wh40k-mod-chip__toggle" 
                  data-action="toggleModificationActive" 
                  data-mod-index="{{mod.index}}"
                  title="{{#if mod.active}}Deactivate{{else}}Activate{{/if}}">
            <i class="fa-solid {{#if mod.active}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{/if}}
      
      {{!-- ─────────────────────────────────────────────────────────────────
           COLLAPSIBLE SECTIONS
      ───────────────────────────────────────────────────────────────── --}}
      
      {{!-- COMBAT STATISTICS --}}
      <section class="wh40k-section">
        <header class="wh40k-section__header" data-action="toggleSection" data-section="combat">
          <i class="fa-solid fa-swords"></i>
          <span>Combat Statistics</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up" data-section-content="combat">
          <div class="wh40k-form-grid wh40k-form-grid--2col">
            {{!-- Damage Formula --}}
            <div class="wh40k-float-field">
              <input type="text" name="system.damage.formula" value="{{source.damage.formula}}" 
                     placeholder=" " id="damage-formula" 
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="damage-formula">Damage Dice</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            
            {{!-- Damage Bonus --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.damage.bonus" value="{{source.damage.bonus}}" 
                     placeholder=" " id="damage-bonus"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="damage-bonus">Bonus</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            
            {{!-- Penetration --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.damage.penetration" value="{{source.damage.penetration}}" 
                     placeholder=" " id="penetration"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="penetration">Penetration</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            
            {{!-- Damage Type --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.damage.type" id="damage-type"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions damageTypes selected=source.damage.type labelAttr="label"}}
              </select>
              <label for="damage-type">Damage Type</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>
            
            {{!-- Weapon Class --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.class" id="weapon-class"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions weaponClasses selected=source.class labelAttr="label"}}
              </select>
              <label for="weapon-class">Weapon Class</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>
            
            {{!-- Weapon Type --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.type" id="weapon-type"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions weaponTypes selected=source.type labelAttr="label"}}
              </select>
              <label for="weapon-type">Weapon Type</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>
          </div>
          
          {{!-- Toggle Switches Row --}}
          <div class="wh40k-toggle-row">
            <label class="wh40k-toggle-switch {{#unless inEditMode}}wh40k-toggle-switch--readonly{{/unless}}">
              <input type="checkbox" name="system.twoHanded" {{checked system.twoHanded}} 
                     {{#unless inEditMode}}disabled{{/unless}} />
              <span class="wh40k-toggle-switch__slider"></span>
              <span class="wh40k-toggle-switch__label"><i class="fa-solid fa-hands"></i> Two-Handed</span>
            </label>
            <label class="wh40k-toggle-switch {{#unless inEditMode}}wh40k-toggle-switch--readonly{{/unless}}">
              <input type="checkbox" name="system.melee" {{checked system.melee}} 
                     {{#unless inEditMode}}disabled{{/unless}} />
              <span class="wh40k-toggle-switch__slider"></span>
              <span class="wh40k-toggle-switch__label"><i class="fa-solid fa-sword"></i> Can Melee</span>
            </label>
          </div>
        </div>
      </section>
      
      {{!-- RANGED ATTACK (if ranged) --}}
      {{#if system.isRangedWeapon}}
      <section class="wh40k-section">
        <header class="wh40k-section__header" data-action="toggleSection" data-section="ranged">
          <i class="fa-solid fa-crosshairs"></i>
          <span>Ranged Attack</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up" data-section-content="ranged">
          <div class="wh40k-form-grid wh40k-form-grid--2col">
            {{!-- Range --}}
            <div class="wh40k-float-field">
              <input type="number" name="system.attack.range.value" value="{{source.attack.range.value}}" 
                     placeholder=" " id="range-value"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="range-value">Range (m)</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            
            {{!-- Special Range --}}
            <div class="wh40k-float-field">
              <input type="text" name="system.attack.range.special" value="{{source.attack.range.special}}" 
                     placeholder=" " id="range-special"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="range-special">Special</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
          </div>
          
          {{!-- Rate of Fire --}}
          <div class="wh40k-rof-grid">
            <label class="wh40k-checkbox {{#unless inEditMode}}wh40k-checkbox--readonly{{/unless}}">
              <input type="checkbox" name="system.attack.rateOfFire.single" {{checked system.attack.rateOfFire.single}}
                     {{#unless inEditMode}}disabled{{/unless}} />
              <span>Single (S)</span>
            </label>
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.attack.rateOfFire.semi" value="{{source.attack.rateOfFire.semi}}" 
                     min="0" placeholder=" " id="rof-semi"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="rof-semi">Semi</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.attack.rateOfFire.full" value="{{source.attack.rateOfFire.full}}" 
                     min="0" placeholder=" " id="rof-full"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="rof-full">Full</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
          </div>
        </div>
      </section>
      {{/if}}
      
      {{!-- AMMUNITION (if uses ammo) --}}
      {{#if system.usesAmmo}}
      <section class="wh40k-section">
        <header class="wh40k-section__header" data-action="toggleSection" data-section="ammunition">
          <i class="fa-solid fa-box-archive"></i>
          <span>Ammunition</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up" data-section-content="ammunition">
          <div class="wh40k-form-grid wh40k-form-grid--3col">
            {{!-- Current --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.clip.value" value="{{source.clip.value}}" 
                     min="0" placeholder=" " id="clip-current"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="clip-current">Current</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            
            {{!-- Max --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.clip.max" value="{{source.clip.max}}" 
                     min="0" placeholder=" " id="clip-max"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="clip-max">Max</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            
            {{!-- Reload Time --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.reload" id="reload-time"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions reloadTimes selected=source.reload labelAttr="label"}}
              </select>
              <label for="reload-time">Reload</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>
          </div>
          
          {{!-- Ammo Dropzone --}}
          {{#unless hasLoadedAmmo}}
          <div class="wh40k-ammo-dropzone">
            <i class="fa-solid fa-bullseye"></i>
            <p>Standard Ammunition</p>
            <p class="wh40k-hint">Drag special ammo here to load</p>
          </div>
          {{/unless}}
        </div>
      </section>
      {{/if}}
      
      {{!-- ACQUISITION --}}
      <section class="wh40k-section">
        <header class="wh40k-section__header" data-action="toggleSection" data-section="acquisition">
          <i class="fa-solid fa-coins"></i>
          <span>Acquisition</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up" data-section-content="acquisition">
          <div class="wh40k-form-grid wh40k-form-grid--2col">
            {{!-- Availability --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.availability" id="availability"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions availabilities selected=source.availability labelAttr="label"}}
              </select>
              <label for="availability">Availability</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>
            
            {{!-- Craftsmanship --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.craftsmanship" id="craftsmanship"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions craftsmanships selected=source.craftsmanship labelAttr="label"}}
              </select>
              <label for="craftsmanship">Craftsmanship</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>
            
            {{!-- Weight --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.weight" value="{{source.weight}}" 
                     step="0.1" min="0" placeholder=" " id="weight"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="weight">Weight (kg)</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            
            {{!-- Source --}}
            <div class="wh40k-float-field">
              <input type="text" name="system.source" value="{{source.source}}" 
                     placeholder=" " id="source"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="source">Source</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
          </div>
        </div>
      </section>
      
      {{!-- DESCRIPTION --}}
      <section class="wh40k-section">
        <header class="wh40k-section__header" data-action="toggleSection" data-section="description">
          <i class="fa-solid fa-scroll"></i>
          <span>Description</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle"></i>
        </header>
        <div class="wh40k-section__body wh40k-section__body--prose tw-animate-slide-in-up" data-section-content="description">
          {{#if inEditMode}}
          <div class="wh40k-description-editor">
            {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
          </div>
          {{else}}
          <div class="wh40k-prose wh40k-prose--clickable {{#if canEdit}}wh40k-prose--editable{{/if}}" 
               {{#if canEdit}}data-action="toggleEditMode" title="Click to edit"{{/if}}>
            {{#if system.description.value}}
            {{{system.description.value}}}
            {{else}}
            <p class="wh40k-prose__placeholder"><i class="fa-solid fa-pen"></i> Click to add description...</p>
            {{/if}}
          </div>
          {{/if}}
          
          {{!-- Notes --}}
          <div class="tw-flex tw-flex-col tw-gap-1 tw-px-3 tw-py-2.5 tw-w-full">
            <label class="tw-text-sm tw-font-medium">Notes</label>
            <textarea name="system.notes" rows="2" placeholder="Personal notes..."
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}} tw-w-full tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-p-1.5 tw-text-sm tw-font-body tw-resize-y"
                      {{#unless inEditMode}}readonly{{/unless}}>{{system.notes}}</textarea>
          </div>
        </div>
      </section>
      
      {{!-- MODIFICATIONS SECTION (for adding/managing) --}}
      {{#if inEditMode}}
      <section class="wh40k-section">
        <header class="wh40k-section__header" data-action="toggleSection" data-section="modifications">
          <i class="fa-solid fa-wrench"></i>
          <span>Modifications</span>
          {{#if modificationsData.length}}
          <span class="tw-inline-flex tw-items-center tw-justify-center tw-min-w-[22px] tw-h-[22px] tw-px-1.5 tw-ml-1.5 tw-bg-gold bc:tw-bg-crimson-light dh1e:tw-bg-gold-raw-l5 dh2e:tw-bg-gold-raw dw:tw-bg-accent-combat ow:tw-bg-brass-l20 rt:tw-bg-gold im:tw-bg-failure tw-rounded-full tw-font-ui tw-text-xs tw-font-bold tw-text-[#1a1a1a]">{{modificationsData.length}}</span>
          {{/if}}
          <i class="fa-solid fa-chevron-down wh40k-section__toggle"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up" data-section-content="modifications">
          {{#if modificationsData.length}}
          <div class="wh40k-mods-list" data-drop-zone="modifications">
            {{#each modificationsData as |mod|}}
            <div class="wh40k-mod-card {{#unless mod.active}}wh40k-mod-card--inactive{{/unless}}" data-mod-index="{{mod.index}}">
              <div class="wh40k-mod-card__info">
                <i class="fa-solid {{mod.categoryIcon}}"></i>
                <span class="wh40k-mod-card__name">{{mod.name}}</span>
              </div>
              {{#if mod.hasEffects}}
              <div class="wh40k-mod-card__effects">
                {{#each mod.effects}}
                <span class="wh40k-mod-effect">{{this}}</span>
                {{/each}}
              </div>
              {{/if}}
              <div class="wh40k-mod-card__actions">
                <button type="button" class="wh40k-btn wh40k-btn--icon wh40k-btn--ghost" 
                        data-action="viewModification" data-mod-index="{{mod.index}}" title="View">
                  <i class="fa-solid fa-eye"></i>
                </button>
                <button type="button" class="wh40k-btn wh40k-btn--icon wh40k-btn--ghost wh40k-btn--danger" 
                        data-action="removeModification" data-mod-index="{{mod.index}}" title="Remove">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </div>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="wh40k-empty-state wh40k-mod-dropzone" data-drop-zone="modifications">
            <i class="fa-solid fa-wrench"></i>
            <p>No modifications</p>
            <p class="wh40k-hint">Drag modifications from compendium</p>
          </div>
          {{/if}}
        </div>
      </section>
      {{/if}}
      
      {{!-- ACTIVE EFFECTS (collapsed by default in view mode) --}}
      {{#if effects.length}}
      <section class="wh40k-section wh40k-section--effects">
        <header class="wh40k-section__header" data-action="toggleSection" data-section="effects">
          <i class="fa-solid fa-wand-magic-sparkles"></i>
          <span>Active Effects</span>
          <span class="tw-inline-flex tw-items-center tw-justify-center tw-min-w-[22px] tw-h-[22px] tw-px-1.5 tw-ml-1.5 tw-bg-gold bc:tw-bg-crimson-light dh1e:tw-bg-gold-raw-l5 dh2e:tw-bg-gold-raw dw:tw-bg-accent-combat ow:tw-bg-brass-l20 rt:tw-bg-gold im:tw-bg-failure tw-rounded-full tw-font-ui tw-text-xs tw-font-bold tw-text-[#1a1a1a]">{{effects.length}}</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up" data-section-content="effects">
          {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
        </div>
      </section>
      {{/if}}
      
    </div>


</div>
