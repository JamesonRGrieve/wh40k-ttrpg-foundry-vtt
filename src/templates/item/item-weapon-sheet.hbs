{{!--
  Rogue Trader Weapon Item Sheet V3 - Modern Single-Page Redesign
  Features: Sticky header+stats, action cards in mosaic, collapsible sections, color-coded stats
--}}
<div class="wh40k-weapon-sheet-v3 tw-flex tw-flex-col tw-h-full">

    {{!-- ═══════════════════════════════════════════════════════════════════
         STICKY HEADER AREA (Header + Stats)
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="tw-sticky tw-top-0 tw-z-[20] tw-flex-shrink-0 tw-px-3 tw-pb-3 tw-bg-[linear-gradient(150deg,rgba(10,12,18,0.98)_0%,rgba(36,26,20,0.95)_100%)] tw-border-b tw-border-[rgba(212,175,55,0.2)] tw-shadow-[0_4px_20px_rgba(0,0,0,0.5)]">

      {{!-- HEADER WITH EDIT TOGGLE --}}
      <header class="tw-grid tw-grid-cols-[48px_1fr_auto] tw-items-center tw-gap-[10px] tw-px-3 tw-py-[10px]">
        {{> systems/wh40k-rpg/templates/shared/editable-portrait.hbs src=item.img alt=item.name sizeClass="tw-w-[50px] tw-h-[50px]" frameClass="tw-border-2 tw-border-[var(--wh40k-gold)] tw-shadow-[var(--wh40k-shadow-md),0_0_10px_rgba(212,175,55,0.3)] tw-transition-all hover:tw-scale-105" overlay=false editAttr=false extraClass="tw-shrink-0"}}

        <div class="tw-flex tw-flex-col tw-justify-center tw-gap-1 tw-min-w-0">
          <input type="text" class="tw-font-heading tw-text-[1.1rem] tw-font-semibold tw-text-[rgba(240,232,220,0.95)] wh40k-input--readonly {{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                 name="name" value="{{item.name}}" placeholder="Weapon Name"
                 {{#unless inEditMode}}readonly{{/unless}} />

          <div class="tw-flex tw-flex-wrap tw-gap-1 tw-mt-1 tw-items-center">
            <span class="tw-inline-flex tw-items-center tw-gap-[3px] tw-px-2 tw-py-[2px] tw-bg-[linear-gradient(135deg,rgba(182,62,46,0.25),rgba(182,62,46,0.12))] tw-border tw-border-[rgba(182,62,46,0.5)] tw-rounded-sm tw-text-xs tw-text-[rgba(246,151,139,0.95)]" title="Weapon Class: {{system.classLabel}}">
              {{#if system.isMeleeWeapon}}<i class="fa-solid fa-sword tw-text-[10px] tw-opacity-70"></i>{{else}}<i class="fa-solid fa-gun tw-text-[10px] tw-opacity-70"></i>{{/if}}
              {{system.classLabel}}
            </span>
            <span class="tw-inline-flex tw-items-center tw-gap-[3px] tw-px-2 tw-py-[2px] tw-bg-[linear-gradient(135deg,rgba(58,93,132,0.35),rgba(58,93,132,0.15))] tw-border tw-border-[rgba(98,142,185,0.45)] tw-rounded-sm tw-text-xs tw-text-[rgba(178,208,234,0.95)]" title="Weapon Type: {{system.typeLabel}}">
              <i class="fa-solid {{system.typeIcon}} tw-text-[10px] tw-opacity-70"></i>
              {{system.typeLabel}}
            </span>
            {{#if (ne system.craftsmanship "common")}}
            <span class="tw-inline-flex tw-items-center tw-gap-[3px] tw-px-2 tw-py-[2px] tw-bg-[rgba(181,166,66,0.15)] tw-border tw-border-[rgba(181,166,66,0.4)] tw-rounded-sm tw-text-xs tw-text-[var(--wh40k-color-brass)]" title="Craftsmanship">
              {{system.craftsmanshipLabel}}
            </span>
            {{/if}}
          </div>
        </div>

        <div class="tw-flex tw-items-center tw-gap-[6px]">
          {{#if isOwnedByActor}}
          {{/if}}

          {{#if canEdit}}
          <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-[6px] tw-bg-[rgba(14,18,26,0.6)] tw-border tw-border-[rgba(212,175,55,0.2)] tw-text-[rgba(214,221,235,0.6)] tw-cursor-pointer tw-transition-all hover:tw-bg-[rgba(20,24,34,0.7)] hover:tw-border-[rgba(212,175,55,0.4)] hover:tw-text-[color:var(--wh40k-gold)] {{#if inEditMode}}active tw-animate-glow-pulse tw-bg-[linear-gradient(135deg,rgba(80,46,28,0.6),rgba(28,24,20,0.5))] tw-border-[rgba(212,175,55,0.5)] tw-text-[color:var(--wh40k-gold)]{{/if}}"
                  data-action="toggleEditMode"
                  data-tooltip="{{#if inEditMode}}Exit Edit Mode{{else}}Edit Mode{{/if}}">
            <i class="fa-solid {{#if inEditMode}}fa-lock-open{{else}}fa-pen-to-square{{/if}}"></i>
          </button>
          {{/if}}
        </div>
      </header>

      {{!-- ICONIC STAT MOSAIC --}}
      <div class="tw-grid tw-grid-cols-6 tw-auto-rows-[minmax(60px,auto)] [grid-auto-flow:dense] tw-gap-[var(--wh40k-space-sm)] tw-p-3">
        {{!-- Attack Action Card (if owned by actor) --}}
        {{#if isOwnedByActor}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-cursor-pointer tw-border-[rgba(115,177,113,0.5)] tw-bg-[linear-gradient(145deg,rgba(74,132,72,0.25),rgba(12,16,24,0.7))]"
             data-action="rollAttack"
             data-tooltip="Roll Attack">
          <div class="tw-relative tw-z-[2] tw-text-[1.3rem] tw-mb-1 tw-transition-transform">
            <i class="fa-solid fa-crosshairs"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1rem] tw-font-bold tw-text-[color:var(--wh40k-green-bright)] tw-leading-[1.1]">Attack</span>
            <span class="tw-text-[0.6rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">d100</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
        </div>
        {{/if}}

        {{!-- Damage Card (clickable to roll if owned) --}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[10px_8px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] [grid-column:span_2] [grid-row:span_2] tw-border-[rgba(182,62,46,0.4)] tw-bg-[linear-gradient(145deg,rgba(182,62,46,0.15),rgba(12,16,24,0.7))] {{#if isOwnedByActor}}tw-cursor-pointer{{/if}}"
             {{#if isOwnedByActor}}data-action="rollDamage"{{/if}}
             data-tooltip="{{#if isOwnedByActor}}Click to Roll Damage{{else}}Damage{{/if}}">
          <div class="tw-relative tw-z-[2] tw-text-[2rem] tw-mb-2 tw-transition-transform">
            <i class="fa-solid fa-skull"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1.4rem] tw-font-bold tw-text-[color:var(--wh40k-red-bright)] tw-leading-[1.1]">{{fullDamageFormula}}</span>
            <span class="tw-text-[0.7rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">Damage</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
          {{#if hasModificationEffects}}<span class="tw-animate-star-twinkle tw-absolute tw-top-1 tw-right-1.5 tw-text-[0.6rem] tw-text-[var(--wh40k-gold)] tw-z-[3] tw-pointer-events-none" aria-hidden="true">★</span>{{/if}}
        </div>

        {{!-- Penetration - Arrow (Medium) --}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-border-[rgba(212,175,55,0.4)] tw-bg-[linear-gradient(145deg,rgba(212,175,55,0.12),rgba(12,16,24,0.7))]"
             data-tooltip="Penetration">
          <div class="tw-relative tw-z-[2] tw-text-[1.3rem] tw-mb-1 tw-transition-transform">
            <i class="fa-solid fa-location-arrow"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1rem] tw-font-bold tw-text-[color:var(--wh40k-gold)] tw-leading-[1.1]">{{effectivePenetration}}</span>
            <span class="tw-text-[0.6rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">Penetration</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
          {{#if hasModificationEffects}}<span class="tw-animate-star-twinkle tw-absolute tw-top-1 tw-right-1.5 tw-text-[0.6rem] tw-text-[var(--wh40k-gold)] tw-z-[3] tw-pointer-events-none" aria-hidden="true">★</span>{{/if}}
        </div>

        {{!-- To Hit - Crosshairs (Medium, conditional) --}}
        {{#if (ne effectiveToHit 0)}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-border-[rgba(74,132,72,0.4)] tw-bg-[linear-gradient(145deg,rgba(74,132,72,0.12),rgba(12,16,24,0.7))]"
             data-tooltip="To Hit Modifier">
          <div class="tw-relative tw-z-[2] tw-text-[1.3rem] tw-mb-1 tw-transition-transform">
            <i class="fa-solid fa-bullseye"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1rem] tw-font-bold tw-leading-[1.1] {{#if (gt effectiveToHit 0)}}tw-text-[color:var(--wh40k-green-bright)]{{else}}tw-text-[color:var(--wh40k-red-bright)]{{/if}}">
              {{#if (gt effectiveToHit 0)}}+{{/if}}{{effectiveToHit}}
            </span>
            <span class="tw-text-[0.6rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">To Hit</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
        </div>
        {{/if}}

        {{!-- Range - Crosshairs/Target (Medium, ranged only) --}}
        {{#if system.isRangedWeapon}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-border-[rgba(58,93,132,0.4)] tw-bg-[linear-gradient(145deg,rgba(58,93,132,0.15),rgba(12,16,24,0.7))]"
             data-tooltip="Range">
          <div class="tw-relative tw-z-[2] tw-text-[1.3rem] tw-mb-1 tw-transition-transform">
            <i class="fa-solid fa-ruler"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1rem] tw-font-bold tw-text-[rgba(178,208,234,0.95)] tw-leading-[1.1]">{{system.rangeLabel}}</span>
            <span class="tw-text-[0.6rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">Range</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
        </div>

        {{!-- Rate of Fire - Burst (Small) --}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-border-[rgba(143,76,38,0.4)] tw-bg-[linear-gradient(145deg,rgba(143,76,38,0.15),rgba(12,16,24,0.7))]"
             data-tooltip="Rate of Fire">
          <div class="tw-relative tw-z-[2] tw-text-[1.3rem] tw-mb-1 tw-transition-transform">
            <i class="fa-solid fa-burst"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1rem] tw-font-bold tw-text-[rgba(212,140,80,0.9)] tw-leading-[1.1]">{{system.rateOfFireLabel}}</span>
            <span class="tw-text-[0.6rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">RoF</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
        </div>
        {{/if}}

        {{!-- Clip - Magazine (clickable to decrement if owned) --}}
        {{#if system.usesAmmo}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-border-[rgba(74,132,72,0.4)] tw-bg-[linear-gradient(145deg,rgba(74,132,72,0.1),rgba(12,16,24,0.7))] wh40k-iconic-stat--ammo-{{system.ammoStatus}} {{#if (or (eq system.ammoStatus "critical") (eq system.ammoStatus "empty"))}}tw-animate-clip-pulse{{/if}} {{#if isOwnedByActor}}tw-cursor-pointer{{/if}}"
             {{#if isOwnedByActor}}data-action="expendAmmo"{{/if}}
             data-tooltip="{{#if isOwnedByActor}}Click to Spend Ammo{{else}}Ammunition{{/if}}">
          <div class="tw-relative tw-z-[2] tw-text-[1.3rem] tw-mb-1 tw-transition-transform">
            <i class="fa-solid fa-gun"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1rem] tw-font-bold tw-text-[rgba(240,232,220,0.95)] tw-leading-[1.1]">{{system.clip.value}}/{{system.effectiveClipMax}}</span>
            <span class="tw-text-[0.6rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">Clip</span>
          </div>
          <div class="tw-absolute tw-bottom-0 tw-left-0 tw-right-0 tw-h-[4px] tw-bg-[rgba(0,0,0,0.3)] tw-overflow-hidden" style="--progress: {{system.ammoPercentage}}%"></div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
        </div>

        {{!-- Reload Action Card (if owned by actor and uses ammo) --}}
        {{#if isOwnedByActor}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-cursor-pointer tw-border-[rgba(58,93,132,0.4)] tw-bg-[linear-gradient(145deg,rgba(58,93,132,0.2),rgba(12,16,24,0.7))] {{#if (eq system.clip.value system.effectiveClipMax)}}tw-opacity-40 tw-pointer-events-none{{/if}}"
             data-action="reload"
             data-tooltip="Reload ({{system.reloadLabel}})">
          <div class="tw-relative tw-z-[2] tw-text-[1.3rem] tw-mb-1 tw-transition-transform">
            <i class="fa-solid fa-rotate-right"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1rem] tw-font-bold tw-text-[rgba(178,208,234,0.95)] tw-leading-[1.1]">Reload</span>
            <span class="tw-text-[0.6rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">{{system.reloadLabel}}</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
        </div>
        {{/if}}
        {{/if}}

        {{!-- Weight - Scale (Small) --}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-border-[rgba(148,160,178,0.3)] tw-bg-[linear-gradient(145deg,rgba(148,160,178,0.08),rgba(12,16,24,0.7))]"
             data-tooltip="Weight">
          <div class="tw-relative tw-z-[2] tw-text-[1.3rem] tw-mb-1 tw-transition-transform">
            <i class="fa-solid fa-scale-balanced"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-font-display tw-text-[1rem] tw-font-bold tw-text-[rgba(240,232,220,0.95)] tw-leading-[1.1]">{{effectiveWeight}}<small>kg</small></span>
            <span class="tw-text-[0.6rem] tw-font-bold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(202,210,222,0.6)]">Weight</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
        </div>

        {{!-- Individual Quality Cards --}}
        {{#each qualitiesArray}}
        <div class="tw-relative tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-[8px_6px] tw-rounded-[var(--wh40k-radius-lg)] tw-border-2 tw-overflow-hidden tw-transition-all tw-aspect-square tw-min-h-[60px] tw-cursor-pointer tw-border-[rgba(58,93,132,0.4)] tw-bg-[linear-gradient(145deg,rgba(58,93,132,0.15),rgba(12,16,24,0.6))]"
             data-action="openQuality"
             data-identifier="{{identifier}}"
             data-wh40k-tooltip="quality"
             data-wh40k-tooltip-data="{{@root.prepareQualityTooltip identifier level}}">
          <div class="tw-relative tw-z-[2] tw-text-[0.9rem] tw-mb-[2px] tw-transition-transform">
            <i class="fa-solid fa-star"></i>
          </div>
          <div class="tw-relative tw-z-[2] tw-flex tw-flex-col tw-items-center tw-gap-[2px]">
            <span class="tw-text-[0.7rem] tw-font-semibold tw-text-center tw-text-[rgba(178,208,234,0.95)] tw-leading-[1.2] tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis tw-max-w-full">{{label}}</span>
          </div>
          <div class="tw-absolute tw-inset-0 tw-rounded-[inherit] tw-opacity-0 tw-transition-opacity tw-pointer-events-none tw-z-0"></div>
        </div>
        {{/each}}
      </div>

      {{!-- Body Toggle Button --}}
      <button type="button" class="tw-flex tw-items-center tw-justify-center tw-gap-[var(--wh40k-space-sm)] tw-w-full tw-py-2 tw-px-4 tw-mt-2 tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.4),rgba(16,20,28,0.3))] tw-border tw-border-[rgba(212,175,55,0.25)] tw-rounded-[6px] tw-text-[rgba(214,221,235,0.8)] tw-text-[0.8rem] tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-cursor-pointer tw-transition-all hover:tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.55),rgba(16,20,28,0.4))] hover:tw-border-[rgba(212,175,55,0.4)] hover:tw-text-[color:var(--wh40k-gold)]" data-action="toggleBody" title="{{#if bodyCollapsed}}Show Details{{else}}Hide Details{{/if}}">
        <span>{{#if bodyCollapsed}}Show Details{{else}}Hide Details{{/if}}</span>
        <i class="fa-solid {{#if bodyCollapsed}}fa-chevron-down{{else}}fa-chevron-up{{/if}} wh40k-body-toggle__icon tw-text-[0.75rem] tw-transition-transform"></i>
      </button>
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         SCROLLABLE BODY
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-weapon-body tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-p-[10px_12px_60px] tw-transition-all {{#if bodyCollapsed}}collapsed{{/if}}">

      {{!-- LOADED AMMO BANNER (if loaded) --}}
      {{#if (and system.usesAmmo hasLoadedAmmo)}}
      <div class="tw-mb-[10px] tw-p-[8px_12px] tw-bg-[linear-gradient(135deg,rgba(74,132,72,0.15),rgba(18,22,30,0.1))] tw-border tw-border-[rgba(115,177,113,0.3)] tw-border-l-[3px] tw-border-l-[rgba(115,177,113,0.6)] tw-rounded-[6px] tw-animate-[slide-in-up_0.4s_ease-out]">
        <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)]">
          <i class="fa-solid fa-circle-dot"></i>
          <span class="tw-flex-1 tw-font-semibold tw-text-[0.85rem] tw-text-[rgba(178,234,176,0.95)]">{{loadedAmmoLabel}}</span>
          {{#if isOwnedByActor}}
          <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-px-1 tw-py-1 tw-bg-transparent tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-md tw-text-[color:var(--wh40k-text-dark)] tw-text-sm tw-cursor-pointer hover:tw-border-[var(--wh40k-gold)] hover:tw-text-gold" data-action="ejectAmmo" title="Eject">
            <i class="fa-solid fa-eject"></i>
          </button>
          {{/if}}
        </div>
        {{#if loadedAmmoData.modifiers}}
        <div class="tw-flex tw-flex-wrap tw-gap-[6px] tw-mt-[6px]">
          {{#if (ne loadedAmmoData.modifiers.damage 0)}}
          <span class="tw-inline-flex tw-py-[2px] tw-px-2 tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.7rem] tw-font-semibold {{#if (gt loadedAmmoData.modifiers.damage 0)}}tw-text-[color:var(--wh40k-green-bright)]{{else}}tw-text-[color:var(--wh40k-red-bright)]{{/if}}">
            Dmg {{#if (gt loadedAmmoData.modifiers.damage 0)}}+{{/if}}{{loadedAmmoData.modifiers.damage}}
          </span>
          {{/if}}
          {{#if (ne loadedAmmoData.modifiers.penetration 0)}}
          <span class="tw-inline-flex tw-py-[2px] tw-px-2 tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.7rem] tw-font-semibold {{#if (gt loadedAmmoData.modifiers.penetration 0)}}tw-text-[color:var(--wh40k-green-bright)]{{else}}tw-text-[color:var(--wh40k-red-bright)]{{/if}}">
            Pen {{#if (gt loadedAmmoData.modifiers.penetration 0)}}+{{/if}}{{loadedAmmoData.modifiers.penetration}}
          </span>
          {{/if}}
          {{#if (gt loadedAmmoData.addedQualities.length 0)}}
          <span class="tw-inline-flex tw-py-[2px] tw-px-2 tw-bg-[rgba(0,0,0,0.2)] tw-rounded-[var(--wh40k-radius-md)] tw-text-[0.7rem] tw-font-semibold tw-text-[rgba(178,208,234,0.95)]">+{{join loadedAmmoData.addedQualities ", "}}</span>
          {{/if}}
        </div>
        {{/if}}
      </div>
      {{/if}}

      {{!-- MODIFICATIONS CARDS (Integrated) --}}
      {{#if modificationsData.length}}
      <div class="tw-flex tw-flex-wrap tw-gap-[6px] tw-mb-[10px]">
        {{#each modificationsData as |mod|}}
        <div class="tw-inline-flex tw-items-center tw-gap-[6px] tw-py-1 tw-px-[8px] tw-pl-[10px] tw-bg-[linear-gradient(135deg,rgba(143,76,38,0.2),rgba(143,76,38,0.08))] tw-border tw-border-[rgba(212,140,80,0.35)] tw-rounded-[16px] tw-text-[0.75rem] tw-font-medium tw-text-[rgba(246,208,163,0.95)] tw-transition-all tw-animate-slide-in-up {{#unless mod.active}}tw-opacity-50 tw-line-through{{/unless}}">
          <i class="fa-solid {{mod.categoryIcon}}"></i>
          <span>{{mod.name}}</span>
          <button type="button" class="tw-flex tw-items-center tw-justify-center tw-w-5 tw-h-5 tw-bg-transparent tw-border-none tw-text-[color:var(--wh40k-green)] tw-cursor-pointer tw-p-0"
                  data-action="toggleModificationActive"
                  data-mod-index="{{mod.index}}"
                  title="{{#if mod.active}}Deactivate{{else}}Activate{{/if}}">
            <i class="fa-solid {{#if mod.active}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{!-- ─────────────────────────────────────────────────────────────────
           COLLAPSIBLE SECTIONS
      ───────────────────────────────────────────────────────────────── --}}

      {{!-- COMBAT STATISTICS --}}
      <section class="tw-mb-2 tw-bg-[rgba(12,16,24,0.5)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-[var(--wh40k-radius-lg)] tw-overflow-hidden">
        <header class="tw-group tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-2 tw-px-3 tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.35),rgba(16,20,28,0.15))] tw-border-b tw-border-[rgba(255,255,255,0.05)] tw-cursor-pointer tw-transition-[background] tw-select-none hover:tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.45),rgba(16,20,28,0.2))]" data-action="toggleSection" data-section="combat">
          <i class="fa-solid fa-swords"></i>
          <span>Combat Statistics</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle tw-text-[0.7rem] tw-text-[rgba(214,221,235,0.5)] tw-transition-transform group-hover:tw-text-[color:var(--wh40k-gold)]"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up tw-p-[10px_12px] tw-transition-all" data-section-content="combat">
          <div class="tw-grid tw-grid-cols-2 tw-gap-[var(--wh40k-space-sm)]">
            {{!-- Damage Formula --}}
            <div class="wh40k-float-field">
              <input type="text" name="system.damage.formula" value="{{source.damage.formula}}"
                     placeholder=" " id="damage-formula"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="damage-formula">Damage Dice</label>
              <span class="wh40k-float-field__bar"></span>
            </div>

            {{!-- Damage Bonus --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.damage.bonus" value="{{source.damage.bonus}}"
                     placeholder=" " id="damage-bonus"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="damage-bonus">Bonus</label>
              <span class="wh40k-float-field__bar"></span>
            </div>

            {{!-- Penetration --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.damage.penetration" value="{{source.damage.penetration}}"
                     placeholder=" " id="penetration"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="penetration">Penetration</label>
              <span class="wh40k-float-field__bar"></span>
            </div>

            {{!-- Damage Type --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.damage.type" id="damage-type"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions damageTypes selected=source.damage.type labelAttr="label"}}
              </select>
              <label for="damage-type">Damage Type</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>

            {{!-- Weapon Class --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.class" id="weapon-class"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions weaponClasses selected=source.class labelAttr="label"}}
              </select>
              <label for="weapon-class">Weapon Class</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>

            {{!-- Weapon Type --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.type" id="weapon-type"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions weaponTypes selected=source.type labelAttr="label"}}
              </select>
              <label for="weapon-type">Weapon Type</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>
          </div>

          {{!-- Toggle Switches Row --}}
          <div class="tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-lg)] tw-mt-3 tw-pt-3 tw-border-t tw-border-[rgba(255,255,255,0.06)]">
            <label class="wh40k-toggle-switch {{#unless inEditMode}}wh40k-toggle-switch--readonly{{/unless}}">
              <input type="checkbox" name="system.twoHanded" {{checked system.twoHanded}}
                     {{#unless inEditMode}}disabled{{/unless}} />
              <span class="wh40k-toggle-switch__slider"></span>
              <span class="wh40k-toggle-switch__label"><i class="fa-solid fa-hands"></i> Two-Handed</span>
            </label>
            <label class="wh40k-toggle-switch {{#unless inEditMode}}wh40k-toggle-switch--readonly{{/unless}}">
              <input type="checkbox" name="system.melee" {{checked system.melee}}
                     {{#unless inEditMode}}disabled{{/unless}} />
              <span class="wh40k-toggle-switch__slider"></span>
              <span class="wh40k-toggle-switch__label"><i class="fa-solid fa-sword"></i> Can Melee</span>
            </label>
          </div>
        </div>
      </section>

      {{!-- RANGED ATTACK (if ranged) --}}
      {{#if system.isRangedWeapon}}
      <section class="tw-mb-2 tw-bg-[rgba(12,16,24,0.5)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-[var(--wh40k-radius-lg)] tw-overflow-hidden">
        <header class="tw-group tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-2 tw-px-3 tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.35),rgba(16,20,28,0.15))] tw-border-b tw-border-[rgba(255,255,255,0.05)] tw-cursor-pointer tw-transition-[background] tw-select-none hover:tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.45),rgba(16,20,28,0.2))]" data-action="toggleSection" data-section="ranged">
          <i class="fa-solid fa-crosshairs"></i>
          <span>Ranged Attack</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle tw-text-[0.7rem] tw-text-[rgba(214,221,235,0.5)] tw-transition-transform group-hover:tw-text-[color:var(--wh40k-gold)]"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up tw-p-[10px_12px] tw-transition-all" data-section-content="ranged">
          <div class="tw-grid tw-grid-cols-2 tw-gap-[var(--wh40k-space-sm)]">
            {{!-- Range --}}
            <div class="wh40k-float-field">
              <input type="number" name="system.attack.range.value" value="{{source.attack.range.value}}"
                     placeholder=" " id="range-value"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="range-value">Range (m)</label>
              <span class="wh40k-float-field__bar"></span>
            </div>

            {{!-- Special Range --}}
            <div class="wh40k-float-field">
              <input type="text" name="system.attack.range.special" value="{{source.attack.range.special}}"
                     placeholder=" " id="range-special"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="range-special">Special</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
          </div>

          {{!-- Rate of Fire --}}
          <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)] tw-mt-2">
            <label class="tw-flex tw-items-center tw-gap-[6px] tw-cursor-pointer {{#unless inEditMode}}tw-opacity-70 tw-pointer-events-none tw-cursor-default{{/unless}}">
              <input type="checkbox" name="system.attack.rateOfFire.single" {{checked system.attack.rateOfFire.single}}
                     {{#unless inEditMode}}disabled{{/unless}} />
              <span>Single (S)</span>
            </label>
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.attack.rateOfFire.semi" value="{{source.attack.rateOfFire.semi}}"
                     min="0" placeholder=" " id="rof-semi"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="rof-semi">Semi</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.attack.rateOfFire.full" value="{{source.attack.rateOfFire.full}}"
                     min="0" placeholder=" " id="rof-full"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="rof-full">Full</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
          </div>
        </div>
      </section>
      {{/if}}

      {{!-- AMMUNITION (if uses ammo) --}}
      {{#if system.usesAmmo}}
      <section class="tw-mb-2 tw-bg-[rgba(12,16,24,0.5)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-[var(--wh40k-radius-lg)] tw-overflow-hidden">
        <header class="tw-group tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-2 tw-px-3 tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.35),rgba(16,20,28,0.15))] tw-border-b tw-border-[rgba(255,255,255,0.05)] tw-cursor-pointer tw-transition-[background] tw-select-none hover:tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.45),rgba(16,20,28,0.2))]" data-action="toggleSection" data-section="ammunition">
          <i class="fa-solid fa-box-archive"></i>
          <span>Ammunition</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle tw-text-[0.7rem] tw-text-[rgba(214,221,235,0.5)] tw-transition-transform group-hover:tw-text-[color:var(--wh40k-gold)]"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up tw-p-[10px_12px] tw-transition-all" data-section-content="ammunition">
          <div class="tw-grid tw-grid-cols-3 tw-gap-[var(--wh40k-space-sm)]">
            {{!-- Current --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.clip.value" value="{{source.clip.value}}"
                     min="0" placeholder=" " id="clip-current"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="clip-current">Current</label>
              <span class="wh40k-float-field__bar"></span>
            </div>

            {{!-- Max --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.clip.max" value="{{source.clip.max}}"
                     min="0" placeholder=" " id="clip-max"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="clip-max">Max</label>
              <span class="wh40k-float-field__bar"></span>
            </div>

            {{!-- Reload Time --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.reload" id="reload-time"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions reloadTimes selected=source.reload labelAttr="label"}}
              </select>
              <label for="reload-time">Reload</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>
          </div>

          {{!-- Ammo Dropzone --}}
          {{#unless hasLoadedAmmo}}
          <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-4 tw-mt-2 tw-bg-[rgba(0,0,0,0.15)] tw-border-2 tw-border-dashed tw-border-[rgba(255,255,255,0.1)] tw-rounded-[6px] tw-text-center tw-transition-all">
            <i class="fa-solid fa-bullseye"></i>
            <p>Standard Ammunition</p>
            <p class="tw-text-[0.7rem] tw-italic tw-mt-1 tw-text-[color:var(--wh40k-text-muted)]">Drag special ammo here to load</p>
          </div>
          {{/unless}}
        </div>
      </section>
      {{/if}}

      {{!-- ACQUISITION --}}
      <section class="tw-mb-2 tw-bg-[rgba(12,16,24,0.5)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-[var(--wh40k-radius-lg)] tw-overflow-hidden">
        <header class="tw-group tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-2 tw-px-3 tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.35),rgba(16,20,28,0.15))] tw-border-b tw-border-[rgba(255,255,255,0.05)] tw-cursor-pointer tw-transition-[background] tw-select-none hover:tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.45),rgba(16,20,28,0.2))]" data-action="toggleSection" data-section="acquisition">
          <i class="fa-solid fa-coins"></i>
          <span>Acquisition</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle tw-text-[0.7rem] tw-text-[rgba(214,221,235,0.5)] tw-transition-transform group-hover:tw-text-[color:var(--wh40k-gold)]"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up tw-p-[10px_12px] tw-transition-all" data-section-content="acquisition">
          <div class="tw-grid tw-grid-cols-2 tw-gap-[var(--wh40k-space-sm)]">
            {{!-- Availability --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.availability" id="availability"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions availabilities selected=source.availability labelAttr="label"}}
              </select>
              <label for="availability">Availability</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>

            {{!-- Craftsmanship --}}
            <div class="wh40k-float-field wh40k-float-field--select">
              <select name="system.craftsmanship" id="craftsmanship"
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                      {{#unless inEditMode}}disabled{{/unless}}>
                {{selectOptions craftsmanships selected=source.craftsmanship labelAttr="label"}}
              </select>
              <label for="craftsmanship">Craftsmanship</label>
              <i class="fa-solid fa-chevron-down wh40k-float-field__arrow"></i>
            </div>

            {{!-- Weight --}}
            <div class="wh40k-float-field wh40k-float-field--narrow">
              <input type="number" name="system.weight" value="{{source.weight}}"
                     step="0.1" min="0" placeholder=" " id="weight"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="weight">Weight (kg)</label>
              <span class="wh40k-float-field__bar"></span>
            </div>

            {{!-- Source --}}
            <div class="wh40k-float-field">
              <input type="text" name="system.source" value="{{source.source}}"
                     placeholder=" " id="source"
                     class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                     {{#unless inEditMode}}readonly{{/unless}} />
              <label for="source">Source</label>
              <span class="wh40k-float-field__bar"></span>
            </div>
          </div>
        </div>
      </section>

      {{!-- DESCRIPTION --}}
      <section class="tw-mb-2 tw-bg-[rgba(12,16,24,0.5)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-[var(--wh40k-radius-lg)] tw-overflow-hidden">
        <header class="tw-group tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-2 tw-px-3 tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.35),rgba(16,20,28,0.15))] tw-border-b tw-border-[rgba(255,255,255,0.05)] tw-cursor-pointer tw-transition-[background] tw-select-none hover:tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.45),rgba(16,20,28,0.2))]" data-action="toggleSection" data-section="description">
          <i class="fa-solid fa-scroll"></i>
          <span>Description</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle tw-text-[0.7rem] tw-text-[rgba(214,221,235,0.5)] tw-transition-transform group-hover:tw-text-[color:var(--wh40k-gold)]"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up tw-p-0 tw-transition-all" data-section-content="description">
          {{#if inEditMode}}
          <div class="tw-p-0">
            {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
          </div>
          {{else}}
          <div class="tw-p-[10px_12px] tw-text-[0.85rem] tw-leading-[1.5] tw-text-[color:var(--wh40k-text-medium)] tw-min-h-[60px] tw-transition-all {{#if canEdit}}tw-cursor-pointer tw-border tw-border-transparent tw-rounded-[var(--wh40k-radius-md)] tw-m-2 tw-p-[8px_10px] hover:tw-bg-[rgba(212,175,55,0.08)] hover:tw-border-[rgba(212,175,55,0.25)]{{/if}}"
               {{#if canEdit}}data-action="toggleEditMode" title="Click to edit"{{/if}}>
            {{#if system.description.value}}
            {{{system.description.value}}}
            {{else}}
            <p class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-text-[rgba(214,221,235,0.4)] tw-italic tw-m-0"><i class="fa-solid fa-pen"></i> Click to add description...</p>
            {{/if}}
          </div>
          {{/if}}

          {{!-- Notes --}}
          <div class="tw-flex tw-flex-col tw-gap-1 tw-px-3 tw-py-2.5 tw-w-full">
            <label class="tw-text-sm tw-font-medium">Notes</label>
            <textarea name="system.notes" rows="2" placeholder="Personal notes..."
                      class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}} tw-w-full tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-p-1.5 tw-text-sm tw-font-body tw-resize-y"
                      {{#unless inEditMode}}readonly{{/unless}}>{{system.notes}}</textarea>
          </div>
        </div>
      </section>

      {{!-- MODIFICATIONS SECTION (for adding/managing) --}}
      {{#if inEditMode}}
      <section class="tw-mb-2 tw-bg-[rgba(12,16,24,0.5)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-[var(--wh40k-radius-lg)] tw-overflow-hidden">
        <header class="tw-group tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-2 tw-px-3 tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.35),rgba(16,20,28,0.15))] tw-border-b tw-border-[rgba(255,255,255,0.05)] tw-cursor-pointer tw-transition-[background] tw-select-none hover:tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.45),rgba(16,20,28,0.2))]" data-action="toggleSection" data-section="modifications">
          <i class="fa-solid fa-wrench"></i>
          <span>Modifications</span>
          {{#if modificationsData.length}}
          <span class="tw-inline-flex tw-items-center tw-justify-center tw-min-w-[22px] tw-h-[22px] tw-px-1.5 tw-ml-1.5 tw-bg-gold bc:tw-bg-crimson-light dh1e:tw-bg-gold-raw-l5 dh2e:tw-bg-gold-raw dw:tw-bg-accent-combat ow:tw-bg-brass-l20 rt:tw-bg-gold im:tw-bg-failure tw-rounded-full tw-font-ui tw-text-xs tw-font-bold tw-text-[#1a1a1a]">{{modificationsData.length}}</span>
          {{/if}}
          <i class="fa-solid fa-chevron-down wh40k-section__toggle tw-text-[0.7rem] tw-text-[rgba(214,221,235,0.5)] tw-transition-transform group-hover:tw-text-[color:var(--wh40k-gold)]"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up tw-p-[10px_12px] tw-transition-all" data-section-content="modifications">
          {{#if modificationsData.length}}
          <div class="tw-flex tw-flex-col tw-gap-[6px]" data-drop-zone="modifications">
            {{#each modificationsData as |mod|}}
            <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-2 tw-px-[10px] tw-bg-[rgba(0,0,0,0.2)] tw-border tw-border-[rgba(255,255,255,0.08)] tw-rounded-[6px] tw-transition-all hover:tw-border-[rgba(212,175,55,0.25)] {{#unless mod.active}}tw-opacity-50{{/unless}}" data-mod-index="{{mod.index}}">
              <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-flex-1 tw-min-w-0">
                <i class="fa-solid {{mod.categoryIcon}}"></i>
                <span class="tw-font-medium tw-text-[0.85rem] tw-text-[color:var(--wh40k-text-dark)] tw-whitespace-nowrap tw-overflow-hidden tw-text-ellipsis">{{mod.name}}</span>
              </div>
              {{#if mod.hasEffects}}
              <div class="tw-flex tw-flex-wrap tw-gap-[var(--wh40k-space-xs)] tw-w-full">
                {{#each mod.effects}}
                <span class="tw-py-[2px] tw-px-[6px] tw-bg-[rgba(58,93,132,0.15)] tw-rounded-[3px] tw-text-[0.65rem] tw-font-semibold tw-text-[rgba(178,208,234,0.9)]">{{this}}</span>
                {{/each}}
              </div>
              {{/if}}
              <div class="tw-flex tw-gap-[2px]">
                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-px-1 tw-py-1 tw-bg-transparent tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-md tw-text-[color:var(--wh40k-text-dark)] tw-text-sm tw-cursor-pointer hover:tw-border-[var(--wh40k-gold)] hover:tw-text-gold"
                        data-action="viewModification" data-mod-index="{{mod.index}}" title="View">
                  <i class="fa-solid fa-eye"></i>
                </button>
                <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-px-1 tw-py-1 tw-bg-transparent tw-border tw-border-[var(--wh40k-red-dark)] tw-rounded-md tw-text-[color:var(--wh40k-text-dark)] tw-text-sm tw-cursor-pointer hover:tw-bg-[var(--wh40k-red-dark)] hover:tw-border-[var(--wh40k-red)] hover:tw-text-white"
                        data-action="removeModification" data-mod-index="{{mod.index}}" title="Remove">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </div>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-center tw-opacity-70" data-drop-zone="modifications">
            <i class="fa-solid fa-wrench"></i>
            <p>No modifications</p>
            <p class="tw-text-[0.7rem] tw-italic tw-mt-1 tw-text-[color:var(--wh40k-text-muted)]">Drag modifications from compendium</p>
          </div>
          {{/if}}
        </div>
      </section>
      {{/if}}

      {{!-- ACTIVE EFFECTS (collapsed by default in view mode) --}}
      {{#if effects.length}}
      <section class="tw-mb-2 tw-bg-[rgba(12,16,24,0.5)] tw-border tw-border-[rgba(255,255,255,0.06)] tw-rounded-[var(--wh40k-radius-lg)] tw-overflow-hidden">
        <header class="tw-group tw-flex tw-items-center tw-gap-[var(--wh40k-space-sm)] tw-py-2 tw-px-3 tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.35),rgba(16,20,28,0.15))] tw-border-b tw-border-[rgba(255,255,255,0.05)] tw-cursor-pointer tw-transition-[background] tw-select-none hover:tw-bg-[linear-gradient(135deg,rgba(62,34,22,0.45),rgba(16,20,28,0.2))]" data-action="toggleSection" data-section="effects">
          <i class="fa-solid fa-wand-magic-sparkles"></i>
          <span>Active Effects</span>
          <span class="tw-inline-flex tw-items-center tw-justify-center tw-min-w-[22px] tw-h-[22px] tw-px-1.5 tw-ml-1.5 tw-bg-gold bc:tw-bg-crimson-light dh1e:tw-bg-gold-raw-l5 dh2e:tw-bg-gold-raw dw:tw-bg-accent-combat ow:tw-bg-brass-l20 rt:tw-bg-gold im:tw-bg-failure tw-rounded-full tw-font-ui tw-text-xs tw-font-bold tw-text-[#1a1a1a]">{{effects.length}}</span>
          <i class="fa-solid fa-chevron-down wh40k-section__toggle tw-text-[0.7rem] tw-text-[rgba(214,221,235,0.5)] tw-transition-transform group-hover:tw-text-[color:var(--wh40k-gold)]"></i>
        </header>
        <div class="wh40k-section__body tw-animate-slide-in-up tw-p-[10px_12px] tw-transition-all" data-section-content="effects">
          {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
        </div>
      </section>
      {{/if}}

    </div>


</div>
