<div class="wh40k-item-sheet ship-weapon tw-flex tw-flex-col tw-h-full tw-overflow-hidden tw-bg-[var(--wh40k-sheet-bg)] tw-text-[var(--wh40k-text-dark)]">
    <form autocomplete="off" class="tw-flex tw-flex-col tw-flex-1 tw-min-h-0 tw-overflow-hidden">
        {{!-- Item Header (canonical partial) --}}
        {{> systems/wh40k-rpg/templates/item/panel/item-header.hbs
            namePlaceholder="Weapon Name"
            typeLabelKey="WH40K.ShipWeapon"
            typeIcon="fa-crosshairs"}}

        <!-- Tab Navigation -->
        <nav class="wh40k-tabs tw-flex tw-flex-shrink-0 tw-border-b tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure" data-group="primary">
            <a class="wh40k-tab active tw-cursor-pointer tw-uppercase" data-tab="details" data-group="primary">
                <i class="fas fa-info-circle"></i> {{localize "WH40K.Item.Tabs.Details"}}
            </a>
            <a class="wh40k-tab tw-cursor-pointer tw-uppercase" data-tab="effects" data-group="primary">
                <i class="fas fa-magic"></i> {{localize "WH40K.Item.Tabs.Effects"}}
            </a>
        </nav>

        <!-- Tab Content -->
        <section class="wh40k-tab-content tw-flex-1 tw-overflow-y-auto tw-min-h-0">
            <!-- Details Tab -->
            <div class="tab active" data-tab="details" data-group="primary">
                <!-- Weapon Properties -->
                <div class="wh40k-panel tw-mb-3 tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-lg tw-overflow-hidden">
                    <div class="wh40k-panel__header tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3><i class="fas fa-crosshairs"></i> Weapon Properties</h3>
                    </div>
                    <div class="wh40k-panel__content tw-p-3">
                        <div class="form-group">
                            <label>{{localize "WH40K.ShipWeapon.Type"}}</label>
                            <select name="system.weaponType">
                                {{selectOptions weaponTypes selected=source.weaponType}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>{{localize "WH40K.ShipLocation"}}</label>
                            <select name="system.location">
                                {{selectOptions locations selected=source.location}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>{{localize "WH40K.HullType"}}</label>
                            <select name="system.hullType" multiple>
                                {{selectOptions hullTypes selected=source.hullType}}
                            </select>
                            <p class="hint">Hold Ctrl/Cmd to select multiple hull types</p>
                        </div>

                        <div class="form-group">
                            <label>{{localize "WH40K.Availability"}}</label>
                            <select name="system.availability">
                                {{selectOptions availabilities selected=source.availability}}
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Weapon Stats -->
                <div class="wh40k-panel tw-mb-3 tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-lg tw-overflow-hidden">
                    <div class="wh40k-panel__header tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3><i class="fas fa-dice-d20"></i> Weapon Statistics</h3>
                    </div>
                    <div class="wh40k-panel__content tw-p-3">
                        <div class="form-row tw-flex tw-gap-2">
                            <div class="form-group">
                                <label>Strength</label>
                                <input type="number" name="system.strength" value="{{source.strength}}" />
                            </div>
                            <div class="form-group">
                                <label>Damage</label>
                                <input type="text" name="system.damage" value="{{source.damage}}" placeholder="1d10+2" />
                            </div>
                        </div>

                        <div class="form-row tw-flex tw-gap-2">
                            <div class="form-group">
                                <label>Crit Rating</label>
                                <input type="number" name="system.crit" value="{{source.crit}}" />
                            </div>
                            <div class="form-group">
                                <label>Range (VU)</label>
                                <input type="number" name="system.range" value="{{source.range}}" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Resource Requirements -->
                <div class="wh40k-panel tw-mb-3 tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-lg tw-overflow-hidden">
                    <div class="wh40k-panel__header tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3><i class="fas fa-battery-half"></i> Resource Requirements</h3>
                    </div>
                    <div class="wh40k-panel__content tw-p-3">
                        <div class="form-row tw-flex tw-gap-2">
                            <div class="form-group">
                                <label>Power</label>
                                <input type="number" name="system.power" value="{{source.power}}" />
                            </div>
                            <div class="form-group">
                                <label>Space</label>
                                <input type="number" name="system.space" value="{{source.space}}" />
                            </div>
                            <div class="form-group">
                                <label>Ship Points</label>
                                <input type="number" name="system.shipPoints" value="{{source.shipPoints}}" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Special Qualities -->
                <div class="wh40k-panel tw-mb-3 tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-lg tw-overflow-hidden">
                    <div class="wh40k-panel__header tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3><i class="fas fa-star"></i> Special Qualities</h3>
                    </div>
                    <div class="wh40k-panel__content tw-p-3">
                        <p class="hint">Enter special qualities as comma-separated values (e.g., "guided, accurate")</p>
                        <input type="text" name="system.special" value="{{join system.special ','}}" placeholder="guided, accurate, etc." />
                    </div>
                </div>

                <!-- Notes -->
                <div class="wh40k-panel tw-mb-3 tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-lg tw-overflow-hidden">
                    <div class="wh40k-panel__header tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3><i class="fas fa-sticky-note"></i> Notes</h3>
                    </div>
                    <div class="wh40k-panel__content tw-p-3">
                        <textarea name="system.notes" rows="4">{{system.notes}}</textarea>
                    </div>
                </div>

                <!-- Description -->
                <div class="wh40k-panel tw-mb-3 tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-lg tw-overflow-hidden">
                    <div class="wh40k-panel__header tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3><i class="fas fa-scroll"></i> Description</h3>
                    </div>
                    <div class="wh40k-panel__content tw-p-3">
                        {{#if inEditMode}}
                          {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
                        {{else}}
                          <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.description.value}}}</div>
                        {{/if}}
                    </div>
                </div>
            </div>

            <!-- Effects Tab -->
            <div class="tab" data-tab="effects" data-group="primary">
                {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
            </div>
        </section>
    </form>
</div>
