<div class="wh40k-item-sheet ship-weapon">
    <form autocomplete="off">
        <!-- Item Header -->
        <header class="wh40k-item-header">
            <div class="wh40k-item-image" data-action="editImage">
                <img src="{{item.img}}" alt="{{item.name}}" title="{{item.name}}" />
            </div>
            
            <div class="wh40k-item-title">
                <input type="text" class="wh40k-item-title__name" name="name" value="{{item.name}}" placeholder="Weapon Name" />
                <div class="wh40k-item-title__type">
                    <i class="fas fa-crosshairs"></i>
                    <span>{{localize "WH40K.ShipWeapon"}}</span>
                </div>
            </div>
        </header>

        <!-- Tab Navigation -->
        <nav class="wh40k-tabs" data-group="primary">
            <a class="wh40k-tab active" data-tab="details" data-group="primary">
                <i class="fas fa-info-circle"></i> {{localize "WH40K.Item.Tabs.Details"}}
            </a>
            <a class="wh40k-tab" data-tab="effects" data-group="primary">
                <i class="fas fa-magic"></i> {{localize "WH40K.Item.Tabs.Effects"}}
            </a>
        </nav>

        <!-- Tab Content -->
        <section class="wh40k-tab-content">
            <!-- Details Tab -->
            <div class="tab active" data-tab="details" data-group="primary">
                <!-- Weapon Properties -->
                <div class="wh40k-panel">
                    <div class="wh40k-panel__header">
                        <h3><i class="fas fa-crosshairs"></i> Weapon Properties</h3>
                    </div>
                    <div class="wh40k-panel__content">
                        <div class="form-group">
                            <label>{{localize "WH40K.ShipWeapon.Type"}}</label>
                            <select name="system.weaponType">
                                {{selectOptions weaponTypes selected=system.weaponType}}
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label>{{localize "WH40K.ShipLocation"}}</label>
                            <select name="system.location">
                                {{selectOptions locations selected=system.location}}
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label>{{localize "WH40K.HullType"}}</label>
                            <select name="system.hullType" multiple>
                                {{selectOptions hullTypes selected=system.hullType}}
                            </select>
                            <p class="hint">Hold Ctrl/Cmd to select multiple hull types</p>
                        </div>
                        
                        <div class="form-group">
                            <label>{{localize "WH40K.Availability"}}</label>
                            <select name="system.availability">
                                {{selectOptions availabilities selected=system.availability}}
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Weapon Stats -->
                <div class="wh40k-panel">
                    <div class="wh40k-panel__header">
                        <h3><i class="fas fa-dice-d20"></i> Weapon Statistics</h3>
                    </div>
                    <div class="wh40k-panel__content">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Strength</label>
                                <input type="number" name="system.strength" value="{{system.strength}}" />
                            </div>
                            <div class="form-group">
                                <label>Damage</label>
                                <input type="text" name="system.damage" value="{{system.damage}}" placeholder="1d10+2" />
                            </div>
                        </div>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label>Crit Rating</label>
                                <input type="number" name="system.crit" value="{{system.crit}}" />
                            </div>
                            <div class="form-group">
                                <label>Range (VU)</label>
                                <input type="number" name="system.range" value="{{system.range}}" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Resource Requirements -->
                <div class="wh40k-panel">
                    <div class="wh40k-panel__header">
                        <h3><i class="fas fa-battery-half"></i> Resource Requirements</h3>
                    </div>
                    <div class="wh40k-panel__content">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Power</label>
                                <input type="number" name="system.power" value="{{system.power}}" />
                            </div>
                            <div class="form-group">
                                <label>Space</label>
                                <input type="number" name="system.space" value="{{system.space}}" />
                            </div>
                            <div class="form-group">
                                <label>Ship Points</label>
                                <input type="number" name="system.shipPoints" value="{{system.shipPoints}}" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Special Qualities -->
                <div class="wh40k-panel">
                    <div class="wh40k-panel__header">
                        <h3><i class="fas fa-star"></i> Special Qualities</h3>
                    </div>
                    <div class="wh40k-panel__content">
                        <p class="hint">Enter special qualities as comma-separated values (e.g., "guided, accurate")</p>
                        <input type="text" name="system.special" value="{{join system.special ','}}" placeholder="guided, accurate, etc." />
                    </div>
                </div>

                <!-- Notes -->
                <div class="wh40k-panel">
                    <div class="wh40k-panel__header">
                        <h3><i class="fas fa-sticky-note"></i> Notes</h3>
                    </div>
                    <div class="wh40k-panel__content">
                        <textarea name="system.notes" rows="4">{{system.notes}}</textarea>
                    </div>
                </div>
                
                <!-- Description -->
                <div class="wh40k-panel">
                    <div class="wh40k-panel__header">
                        <h3><i class="fas fa-scroll"></i> Description</h3>
                    </div>
                    <div class="wh40k-panel__content">
                        {{#if inEditMode}}
                          {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
                        {{else}}
                          <div class="wh40k-description-content">{{{system.description.value}}}</div>
                        {{/if}}
                    </div>
                </div>
            </div>

            <!-- Effects Tab -->
            <div class="tab" data-tab="effects" data-group="primary">
                {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
            </div>
        </section>
    </form>
</div>
