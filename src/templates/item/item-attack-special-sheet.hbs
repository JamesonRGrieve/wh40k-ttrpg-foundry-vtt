{{! Rogue Trader Attack Special Sheet - Modern Design }}
<form class="tw-flex tw-flex-col tw-h-full tw-overflow-hidden" autocomplete="off">
    {{! Header }}
    <div class="tw-flex tw-items-center tw-gap-4 tw-p-4 tw-border-b-2 tw-border-[rgba(212,175,55,0.3)] tw-bg-[linear-gradient(135deg,rgba(212,175,55,0.15)_0%,rgba(44,36,23,0.95)_100%)]">
        <div class="tw-relative tw-shrink-0">
            {{> systems/wh40k-rpg/templates/shared/editable-portrait.hbs imgOnly=true src=item.img alt=item.name title=item.name sizeClass="tw-h-16 tw-w-16" roundedClass="tw-rounded-lg" action=false imgClass="tw-border-2 tw-border-[rgba(212,175,55,0.3)] tw-transition-transform hover:tw-scale-105"}}
        </div>
        <div class="tw-flex-1 tw-min-w-0">
            <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[rgba(202,210,222,0.7)]">Name</label>
                <input class="tw-w-full tw-border-0 tw-bg-transparent tw-px-2 tw-py-1 tw-text-base tw-font-semibold" name="name" type="text" value="{{item.name}}" />
            </div>
        </div>
    </div>

    {{! Main Fields }}
    <div class="tw-p-4 tw-border-b tw-border-[rgba(0,0,0,0.1)]">
        <div class="tw-flex tw-gap-4 tw-mb-3">
            <div class="tw-flex tw-items-center tw-gap-2">
                <input name="system.hasLevel" type="checkbox" data-dtype="Boolean" {{checked item.system.hasLevel}} />
                <label>Has Level</label>
            </div>
            <div class="tw-flex tw-items-center tw-gap-2">
                <input name="system.enabled" type="checkbox" data-dtype="Boolean" {{checked item.system.enabled}} />
                <label>Enabled</label>
            </div>
        </div>

        <div class="tw-flex tw-gap-4">
            <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[rgba(202,210,222,0.7)]">Level</label>
                {{#if item.system.hasLevel}}
                    <input name="system.level" type="number" data-dtype="Number" value="{{item.system.level}}" />
                {{else}}
                    <input type="text" value="N/A" disabled />
                {{/if}}
            </div>
            <div class="tw-flex tw-flex-col tw-gap-1 tw-flex-1">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[rgba(202,210,222,0.7)]">Source</label>
                <input name="system.source" type="text" value="{{item.system.source}}" />
            </div>
        </div>
    </div>

    {{! Description }}
    <div class="tw-p-4 tw-border-t tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure">
        <div class="tw-flex tw-flex-col tw-gap-1">
            <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-[rgba(202,210,222,0.7)]">Description</label>
            <textarea class="tw-w-full tw-p-2 tw-rounded tw-border tw-border-[rgba(255,255,255,0.1)] tw-bg-[rgba(0,0,0,0.2)] tw-text-[var(--color-text-primary)]" name="system.description.value">{{item.system.description.value}}</textarea>
        </div>
    </div>
</form>