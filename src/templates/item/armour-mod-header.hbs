{{! Armour Modification Sheet Header }}
<header class="wh40k-item-sheet__header wh40k-armour-mod-header">
    <div class="wh40k-item-sheet__portrait tw-relative">
        <img class="wh40k-item-sheet__portrait-img" src="{{item.img}}" data-action="editImage" alt="{{item.name}}" title="{{item.name}}" />
        <div class="wh40k-item-sheet__portrait-icon tw-absolute tw-bottom-[-8px] tw-right-[-8px] tw-w-9 tw-h-9 tw-flex tw-items-center tw-justify-center tw-rounded-full tw-border-2 tw-border-[#2c2417] tw-shadow-[0_2px_8px_rgba(0,0,0,0.4)]" style="background: linear-gradient(135deg, var(--wh40k-color-gold) 0%, #b8962f 100%)">
            <i class="fas {{icon}} tw-text-xl tw-text-[#2c2417]"></i>
        </div>
    </div>

    <div class="wh40k-item-sheet__header-info">
        <input
            class="wh40k-item-sheet__name-input"
            name="name"
            type="text"
            value="{{item.name}}"
            placeholder="{{localize 'WH40K.Modification.NamePlaceholder'}}"
        />

        <div class="wh40k-item-sheet__type-badge">
            <i class="fas fa-wrench"></i>
            <span>{{localize "TYPES.Item.armourModification"}}</span>
        </div>

        <div class="wh40k-armour-mod-summary tw-flex tw-flex-wrap tw-gap-2 tw-mt-3">
            {{#if restrictionsSummary}}
                <div class="wh40k-summary-badge wh40k-summary-badge--restrictions tw-inline-flex tw-items-center tw-gap-1.5 tw-px-3 tw-py-1.5 tw-rounded-md tw-text-xs tw-font-semibold tw-border tw-border-[rgba(52,152,219,0.4)]" style="background: rgba(52,152,219,0.1)">
                    <i class="fas fa-filter tw-text-[var(--wh40k-accent-info)]"></i>
                    <span>{{restrictionsSummary}}</span>
                </div>
            {{/if}}

            {{#if modifiersSummary}}
                <div class="wh40k-summary-badge wh40k-summary-badge--modifiers tw-inline-flex tw-items-center tw-gap-1.5 tw-px-3 tw-py-1.5 tw-rounded-md tw-text-xs tw-font-semibold tw-border tw-border-[rgba(46,204,113,0.4)]" style="background: rgba(46,204,113,0.1)">
                    <i class="fas fa-chart-line tw-text-[var(--wh40k-accent-green-bright)]"></i>
                    <span>{{modifiersSummary}}</span>
                </div>
            {{/if}}
        </div>
    </div>
</header>