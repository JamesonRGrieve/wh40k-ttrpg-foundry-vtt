{{!--
  Rogue Trader Armour Item Sheet - V2 Complete Redesign
  Matches weapon sheet pattern with modern ApplicationV2 structure
--}}
<div class="tw-flex tw-flex-col tw-h-full tw-overflow-hidden">

    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: Compact armour identity with inline stats
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-shrink-0 tw-border-b-2 tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, transparent 100%)">
      {{> systems/wh40k-rpg/templates/shared/editable-portrait.hbs src=item.img alt=item.name sizeClass="tw-w-16 tw-h-16" frameClass="tw-border-2 tw-border-[#8b6914] hover:tw-scale-105 hover:tw-shadow-md" editAttr=false overlayBgClass="tw-bg-black/60" overlayTextClass="" overlayIconClass="" extraClass="tw-shrink-0"}}

      <div class="tw-flex tw-flex-col tw-gap-1 tw-min-w-0 tw-flex-1">
        <input type="text" class="tw-font-display tw-text-xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-bg-transparent tw-border-none tw-w-full tw-p-1 tw-border-b tw-border-b-transparent hover:tw-border-b-gold focus:tw-border-b-gold focus:tw-outline-none" name="name" value="{{item.name}}" placeholder="Armour Name" />

        <div class="tw-flex tw-flex-wrap tw-gap-1 tw-items-center tw-mt-1">
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-bg-[rgba(201,162,39,0.2)] tw-border tw-border-[rgba(201,162,39,0.4)] tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure" title="Armour Type">
            <i class="fas {{item.system.typeIcon}}"></i>
            {{item.system.typeLabel}}
          </span>
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-bg-[rgba(46,204,113,0.2)] tw-border tw-border-[rgba(46,204,113,0.4)] tw-text-[var(--wh40k-accent-green-bright)] tw-font-mono" title="Maximum Armour Points">
            AP {{item.system.maxAP}}
          </span>
          {{#if (ne item.system.craftsmanship "common")}}
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-bg-[rgba(139,105,20,0.2)] tw-border tw-border-[rgba(139,105,20,0.4)] tw-text-[rgba(255,255,255,0.8)]" title="Craftsmanship">
            <i class="fas fa-hammer"></i>
            {{item.system.craftsmanshipLabel}}
          </span>
          {{/if}}
          {{#if item.system.maxAgility}}
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-bg-[rgba(52,152,219,0.2)] tw-border tw-border-[rgba(52,152,219,0.4)] tw-text-[var(--wh40k-accent-info)]" title="Maximum Agility Bonus">
            <i class="fas fa-person-running"></i>
            Max Ag {{item.system.maxAgility}}
          </span>
          {{/if}}
        </div>
      </div>

      <div class="tw-flex tw-items-center tw-gap-2 tw-shrink-0">
        {{!-- Edit Mode Toggle (only for actor-owned items) --}}
        {{#if isOwnedByActor}}
        {{#if canEdit}}
        <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-md tw-cursor-pointer tw-border tw-border-solid tw-border-[rgba(255,255,255,0.2)] tw-bg-[rgba(255,255,255,0.1)] tw-text-[rgba(255,255,255,0.7)] tw-transition-all hover:tw-bg-[rgba(201,162,39,0.2)] hover:tw-border-[rgba(201,162,39,0.4)] hover:tw-text-gold {{#if inEditMode}}tw-bg-[rgba(46,204,113,0.2)] tw-border-[rgba(46,204,113,0.4)] tw-text-[var(--wh40k-accent-green-bright)]{{/if}}"
                data-action="toggleEditMode" title="{{#if inEditMode}}Exit Edit Mode{{else}}Enter Edit Mode{{/if}}">
          <i class="fas {{#if inEditMode}}fa-lock-open{{else}}fa-pen-to-square{{/if}}"></i>
        </button>
        {{/if}}
        {{/if}}

        {{!-- Equipped Toggle --}}
        <label class="tw-flex tw-items-center tw-gap-1 tw-cursor-pointer" title="Toggle Equipped">
          <input type="checkbox" name="system.equipped" {{checked item.system.equipped}} class="tw-sr-only" />
          <span class="tw-inline-flex tw-items-center tw-justify-center tw-w-6 tw-h-6 {{#if item.system.equipped}}tw-text-[var(--wh40k-accent-green-bright)]{{else}}tw-text-[rgba(255,255,255,0.3)]{{/if}}">
            <i class="fas {{#if item.system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
          </span>
          <span class="tw-text-xs tw-font-semibold tw-uppercase {{#if item.system.equipped}}tw-text-[var(--wh40k-accent-green-bright)]{{else}}tw-text-[rgba(255,255,255,0.5)]{{/if}}">{{#if item.system.equipped}}Worn{{else}}Stowed{{/if}}</span>
        </label>
      </div>
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         STATS BAR: Primary armour stats at a glance (simplified)
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="tw-flex tw-flex-wrap tw-gap-2 tw-p-2 tw-shrink-0 tw-bg-black/40 tw-border-b tw-border-[rgba(201,162,39,0.3)]">
      {{!-- Weight --}}
      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-weight-hanging"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Weight</span>
          <span class="tw-font-semibold">{{system.weight}}kg</span>
        </div>
      </div>

      {{!-- Max Agility (if limited) --}}
      {{#if system.maxAgility}}
      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-person-running"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Max Ag</span>
          <span class="tw-font-semibold">{{system.maxAgility}}</span>
        </div>
      </div>
      {{/if}}

      {{!-- Head AP --}}
      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-head-side-brain"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Head</span>
          <span class="tw-font-semibold">{{system.armourPoints.head}}</span>
        </div>
      </div>

      {{!-- Body AP --}}
      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-shield"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Body</span>
          <span class="tw-font-semibold">{{system.armourPoints.body}}</span>
        </div>
      </div>

      {{!-- Arms AP (average) --}}
      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-hand-fist"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Arms</span>
          <span class="tw-font-semibold">{{system.armourPoints.leftArm}}/{{system.armourPoints.rightArm}}</span>
        </div>
      </div>

      {{!-- Legs AP (average) --}}
      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-boot"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Legs</span>
          <span class="tw-font-semibold">{{system.armourPoints.leftLeg}}/{{system.armourPoints.rightLeg}}</span>
        </div>
      </div>
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ --}}
    <nav class="wh40k-tabs tw-flex tw-shrink-0 tw-bg-black/40 tw-border-b tw-border-[rgba(201,162,39,0.3)]" data-group="primary">
      <button type="button" class="wh40k-tab active tw-flex tw-items-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-border-b-[3px] tw-border-b-gold bc:tw-border-b-crimson-light dh1e:tw-border-b-gold-raw-l5 dh2e:tw-border-b-gold-raw dw:tw-border-b-accent-combat ow:tw-border-b-brass-l20 rt:tw-border-b-gold im:tw-border-b-failure tw-bg-[rgba(201,162,39,0.1)] tw-gap-1 tw-px-4 tw-py-2 tw-text-sm tw-cursor-pointer tw-border-none tw-bg-transparent" data-tab="protection" data-group="primary">
        <i class="fas fa-shield-halved"></i>
        <span>Protection</span>
      </button>
      <button type="button" class="wh40k-tab tw-flex tw-items-center tw-gap-1 tw-px-4 tw-py-2 tw-text-sm tw-cursor-pointer tw-border-none tw-bg-transparent tw-text-[rgba(255,255,255,0.6)] tw-border-b-[3px] tw-border-b-transparent hover:tw-text-[rgba(255,255,255,0.9)] hover:tw-bg-[rgba(201,162,39,0.1)]" data-tab="mods" data-group="primary">
        <i class="fas fa-wrench"></i>
        <span>Mods</span>
      </button>
      <button type="button" class="wh40k-tab tw-flex tw-items-center tw-gap-1 tw-px-4 tw-py-2 tw-text-sm tw-cursor-pointer tw-border-none tw-bg-transparent tw-text-[rgba(255,255,255,0.6)] tw-border-b-[3px] tw-border-b-transparent hover:tw-text-[rgba(255,255,255,0.9)] hover:tw-bg-[rgba(201,162,39,0.1)]" data-tab="description" data-group="primary">
        <i class="fas fa-book"></i>
        <span>Description</span>
      </button>
      <button type="button" class="wh40k-tab tw-flex tw-items-center tw-gap-1 tw-px-4 tw-py-2 tw-text-sm tw-cursor-pointer tw-border-none tw-bg-transparent tw-text-[rgba(255,255,255,0.6)] tw-border-b-[3px] tw-border-b-transparent hover:tw-text-[rgba(255,255,255,0.9)] hover:tw-bg-[rgba(201,162,39,0.1)]" data-tab="effects" data-group="primary">
        <i class="fas fa-magic"></i>
        <span>Effects</span>
      </button>
    </nav>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-tab-content scrollable tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-2">

      {{!-- PROTECTION TAB --}}
      <div class="tab active" data-tab="protection" data-group="primary">

        {{!-- Armour Points Grid (only in edit mode) --}}
        {{#if inEditMode}}
        <div class="tw-mb-3 tw-bg-[rgba(255,255,255,0.03)] tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-lg tw-overflow-hidden">
          <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[rgba(201,162,39,0.2)]" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, rgba(201,162,39,0.05) 100%)">
            <i class="fas fa-shield-halved tw-opacity-70"></i>
            <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Armour Points by Location</h3>
          </div>
          <div class="tw-p-3">
            <div class="tw-grid tw-grid-cols-3 tw-gap-3">
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium"><i class="fas fa-head-side-brain"></i> Head</label>
                <input type="number" name="system.armourPoints.head" value="{{item.system.armourPoints.head}}"
                       data-dtype="Number" min="0" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium"><i class="fas fa-shield"></i> Body</label>
                <input type="number" name="system.armourPoints.body" value="{{item.system.armourPoints.body}}"
                       data-dtype="Number" min="0" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium"><i class="fas fa-hand-fist"></i> L. Arm</label>
                <input type="number" name="system.armourPoints.leftArm" value="{{item.system.armourPoints.leftArm}}"
                       data-dtype="Number" min="0" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium"><i class="fas fa-hand-fist"></i> R. Arm</label>
                <input type="number" name="system.armourPoints.rightArm" value="{{item.system.armourPoints.rightArm}}"
                       data-dtype="Number" min="0" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium"><i class="fas fa-boot"></i> L. Leg</label>
                <input type="number" name="system.armourPoints.leftLeg" value="{{item.system.armourPoints.leftLeg}}"
                       data-dtype="Number" min="0" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium"><i class="fas fa-boot"></i> R. Leg</label>
                <input type="number" name="system.armourPoints.rightLeg" value="{{item.system.armourPoints.rightLeg}}"
                       data-dtype="Number" min="0" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
              </div>
            </div>
          </div>
        </div>
        {{/if}}

        {{!-- Base Properties --}}
        <div class="tw-mb-3 tw-bg-[rgba(255,255,255,0.03)] tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-lg tw-overflow-hidden">
          <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[rgba(201,162,39,0.2)]" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, rgba(201,162,39,0.05) 100%)">
            <i class="fas fa-cog tw-opacity-70"></i>
            <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Base Properties</h3>
          </div>
          <div class="tw-p-3">
            <div class="tw-grid tw-grid-cols-2 tw-gap-3">
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium">Armour Type</label>
                <select name="system.type" class="{{#unless inEditMode}}tw-bg-black/15 tw-border-white/5 tw-text-[color:var(--wh40k-text-medium)] tw-cursor-default tw-pointer-events-none{{/unless}} tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" {{#unless inEditMode}}disabled{{/unless}}>
                  <option value="flak" {{#if (eq item.system.type "flak")}}selected{{/if}}>Flak</option>
                  <option value="mesh" {{#if (eq item.system.type "mesh")}}selected{{/if}}>Mesh</option>
                  <option value="carapace" {{#if (eq item.system.type "carapace")}}selected{{/if}}>Carapace</option>
                  <option value="power" {{#if (eq item.system.type "power")}}selected{{/if}}>Power Armour</option>
                  <option value="light-power" {{#if (eq item.system.type "light-power")}}selected{{/if}}>Light Power</option>
                  <option value="storm-trooper" {{#if (eq item.system.type "storm-trooper")}}selected{{/if}}>Storm Trooper</option>
                  <option value="feudal-world" {{#if (eq item.system.type "feudal-world")}}selected{{/if}}>Feudal World</option>
                  <option value="primitive" {{#if (eq item.system.type "primitive")}}selected{{/if}}>Primitive</option>
                  <option value="xenos" {{#if (eq item.system.type "xenos")}}selected{{/if}}>Xenos</option>
                  <option value="void" {{#if (eq item.system.type "void")}}selected{{/if}}>Void Suit</option>
                  <option value="enforcer" {{#if (eq item.system.type "enforcer")}}selected{{/if}}>Enforcer</option>
                  <option value="hostile-environment" {{#if (eq item.system.type "hostile-environment")}}selected{{/if}}>Hostile Environment</option>
                </select>
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium">Max Agility Bonus</label>
                <input type="number" name="system.maxAgility" value="{{item.system.maxAgility}}"
                       data-dtype="Number" min="0" placeholder="No limit"
                       class="{{#unless inEditMode}}tw-bg-black/15 tw-border-white/5 tw-text-[color:var(--wh40k-text-medium)] tw-cursor-default tw-pointer-events-none{{/unless}} tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm"
                       {{#unless inEditMode}}readonly{{/unless}} />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium">Availability</label>
                <select name="system.availability" class="{{#unless inEditMode}}tw-bg-black/15 tw-border-white/5 tw-text-[color:var(--wh40k-text-medium)] tw-cursor-default tw-pointer-events-none{{/unless}} tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" {{#unless inEditMode}}disabled{{/unless}}>
                  <option value="ubiquitous" {{#if (eq item.system.availability "ubiquitous")}}selected{{/if}}>Ubiquitous</option>
                  <option value="abundant" {{#if (eq item.system.availability "abundant")}}selected{{/if}}>Abundant</option>
                  <option value="plentiful" {{#if (eq item.system.availability "plentiful")}}selected{{/if}}>Plentiful</option>
                  <option value="common" {{#if (eq item.system.availability "common")}}selected{{/if}}>Common</option>
                  <option value="average" {{#if (eq item.system.availability "average")}}selected{{/if}}>Average</option>
                  <option value="scarce" {{#if (eq item.system.availability "scarce")}}selected{{/if}}>Scarce</option>
                  <option value="rare" {{#if (eq item.system.availability "rare")}}selected{{/if}}>Rare</option>
                  <option value="very-rare" {{#if (eq item.system.availability "very-rare")}}selected{{/if}}>Very Rare</option>
                  <option value="extremely-rare" {{#if (eq item.system.availability "extremely-rare")}}selected{{/if}}>Extremely Rare</option>
                  <option value="near-unique" {{#if (eq item.system.availability "near-unique")}}selected{{/if}}>Near Unique</option>
                  <option value="unique" {{#if (eq item.system.availability "unique")}}selected{{/if}}>Unique</option>
                </select>
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium">Craftsmanship</label>
                <select name="system.craftsmanship" class="{{#unless inEditMode}}tw-bg-black/15 tw-border-white/5 tw-text-[color:var(--wh40k-text-medium)] tw-cursor-default tw-pointer-events-none{{/unless}} tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" {{#unless inEditMode}}disabled{{/unless}}>
                  <option value="poor" {{#if (eq item.system.craftsmanship "poor")}}selected{{/if}}>Poor</option>
                  <option value="common" {{#if (eq item.system.craftsmanship "common")}}selected{{/if}}>Common</option>
                  <option value="good" {{#if (eq item.system.craftsmanship "good")}}selected{{/if}}>Good</option>
                  <option value="best" {{#if (eq item.system.craftsmanship "best")}}selected{{/if}}>Best</option>
                </select>
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium">Weight (kg)</label>
                <input type="number" name="system.weight" value="{{item.system.weight}}"
                       data-dtype="Number" min="0" step="0.1"
                       class="{{#unless inEditMode}}tw-bg-black/15 tw-border-white/5 tw-text-[color:var(--wh40k-text-medium)] tw-cursor-default tw-pointer-events-none{{/unless}} tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm"
                       {{#unless inEditMode}}readonly{{/unless}} />
              </div>
              {{#unless hideThroneGelt}}
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-sm tw-font-medium">Cost (Thrones)</label>
                <input type="number" name="system.cost.dh2.homebrew.throneGelt" value="{{item.system.cost.dh2.homebrew.throneGelt}}"
                       data-dtype="Number" min="0"
                       class="{{#unless inEditMode}}tw-bg-black/15 tw-border-white/5 tw-text-[color:var(--wh40k-text-medium)] tw-cursor-default tw-pointer-events-none{{/unless}} tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm"
                       {{#unless inEditMode}}readonly{{/unless}} />
              </div>
              {{/unless}}
            </div>
          </div>
        </div>

        {{!-- Special Properties (consolidated from Properties tab) --}}
        <div class="tw-mb-3 tw-bg-[rgba(255,255,255,0.03)] tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-lg tw-overflow-hidden">
          <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[rgba(201,162,39,0.2)]" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, rgba(201,162,39,0.05) 100%)">
            <i class="fas fa-star tw-opacity-70"></i>
            <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Special Properties</h3>
            {{#if propertiesArray.length}}
            <span class="tw-ml-auto tw-inline-flex tw-items-center tw-justify-center tw-px-2 tw-py-0.5 tw-rounded-full tw-text-xs tw-font-semibold">{{propertiesArray.length}}</span>
            {{/if}}
          </div>
          <div class="tw-p-3">
            {{#if propertiesArray.length}}
            <div class="tw-flex tw-flex-wrap tw-gap-1 tw-mb-3">
              {{#each propertiesArray as |prop|}}
              <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-full tw-text-xs tw-font-semibold tw-bg-gradient-to-br tw-from-[rgba(201,162,39,0.2)] tw-to-[rgba(201,162,39,0.1)] tw-border tw-border-[rgba(201,162,39,0.4)]">
                <span class="tw-text-white tw-font-semibold">{{prop.label}}</span>
                {{#if ../inEditMode}}
                <button type="button" class="tw-cursor-pointer tw-border-none tw-bg-transparent tw-p-0 tw-leading-none tw-text-[rgba(255,255,255,0.5)] hover:tw-text-[var(--wh40k-accent-red)]"
                        data-action="removeProperty" data-property="{{prop.id}}"
                        title="Remove property">
                  <i class="fas fa-times"></i>
                </button>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{!-- Property descriptions (inline) --}}
            <div class="tw-mt-2 tw-flex tw-flex-col tw-gap-1 tw-pt-3 tw-border-t tw-border-[rgba(255,255,255,0.1)]">
              {{#each propertiesArray as |prop|}}
              {{#if prop.description}}
              <div class="tw-text-sm tw-py-2 tw-border-b tw-border-[rgba(255,255,255,0.1)] last:tw-border-b-0">
                <div class="tw-font-semibold tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-flex tw-items-center tw-gap-1 tw-mb-1">{{prop.label}}</div>
                <div class="tw-opacity-80 tw-pl-5 tw-leading-relaxed">{{prop.description}}</div>
              </div>
              {{/if}}
              {{/each}}
            </div>
            {{else}}
            <p class="tw-italic tw-opacity-70 tw-text-sm tw-m-0 tw-py-2">No special properties</p>
            {{/if}}

            {{!-- Add property control (only in edit mode) --}}
            {{#if inEditMode}}
            {{#if availableProperties}}
            <div class="tw-flex tw-gap-2 tw-mt-2">
              <select class="tw-flex-1 tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(255,255,255,0.15)] tw-text-white focus:tw-outline-none focus:tw-border-gold" name="new-property">
                <option value="">-- Add Property --</option>
                {{#each availableProperties as |prop key|}}
                <option value="{{key}}">{{prop.label}}</option>
                {{/each}}
              </select>
              <button type="button" class="tw-inline-flex tw-items-center tw-gap-1 tw-px-3 tw-py-1 tw-rounded-md tw-cursor-pointer tw-text-sm" data-action="addProperty">
                <i class="fas fa-plus"></i>
                Add
              </button>
            </div>
            {{/if}}
            {{/if}}
          </div>
        </div>

      </div>

      {{!-- MODIFICATIONS TAB --}}
      <div class="tab" data-tab="mods" data-group="primary">

        <div class="tw-mb-3 tw-bg-[rgba(255,255,255,0.03)] tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-lg tw-overflow-hidden">
          <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[rgba(201,162,39,0.2)]" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, rgba(201,162,39,0.05) 100%)">
            <i class="fas fa-wrench tw-opacity-70"></i>
            <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Modification Slots</h3>
            <span class="tw-ml-auto tw-inline-flex tw-items-center tw-justify-center tw-px-2 tw-py-0.5 tw-rounded-full tw-text-xs tw-font-semibold">
              {{modificationsArray.length}} / {{system.modificationSlots}}
            </span>
          </div>
          <div class="tw-p-3">
            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-3 tw-pb-3 tw-border-b tw-border-[rgba(255,255,255,0.1)]">
              <label class="tw-text-sm">Total Slots:</label>
              <input type="number" name="system.modificationSlots" value="{{source.modificationSlots}}"
                     data-dtype="Number" min="0" max="10" class="tw-w-16 tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
              <span class="tw-text-xs tw-opacity-70 tw-ml-auto">
                {{system.availableModSlots}} available
              </span>
            </div>

            {{#if modificationsArray.length}}
            <div class="tw-flex tw-flex-col tw-gap-1 tw-mb-3">
              {{#each modificationsArray as |mod idx|}}
              <div class="tw-flex tw-items-center tw-justify-between tw-gap-2 tw-px-2 tw-py-1 tw-rounded-sm tw-bg-[rgba(255,255,255,0.05)] tw-border tw-border-[rgba(255,255,255,0.1)]">
                <div class="tw-flex tw-items-center tw-gap-2 tw-flex-1">
                  <i class="fas fa-wrench tw-opacity-70"></i>
                  <span class="tw-text-sm tw-font-semibold tw-text-white">{{mod.name}}</span>
                </div>
                <div class="tw-flex tw-gap-1">
                  <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-rounded-md tw-cursor-pointer"
                          data-action="editMod" data-mod-index="{{idx}}"
                          title="Edit Modification">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-w-7 tw-h-7 tw-rounded-md tw-cursor-pointer"
                          data-action="removeMod" data-mod-index="{{idx}}"
                          title="Remove Modification">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              </div>
              {{/each}}
            </div>
            {{else}}
            <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-center tw-italic tw-rounded-md tw-border-2 tw-border-dashed tw-border-[rgba(255,255,255,0.1)] tw-text-[rgba(255,255,255,0.4)] tw-mb-3">
              <i class="fas fa-wrench tw-opacity-40 tw-text-3xl tw-mb-2"></i>
              <span class="tw-text-sm">No Modifications Installed</span>
              <p class="tw-m-0 tw-text-xs tw-opacity-70">Drag armour modification items here to install them.</p>
            </div>
            {{/if}}

            <button type="button" class="tw-inline-flex tw-items-center tw-justify-center tw-gap-1 tw-w-full tw-px-3 tw-py-2 tw-rounded-md tw-cursor-pointer tw-text-sm tw-mt-2" data-action="addModification">
              <i class="fas fa-plus"></i>
              Add Modification
            </button>
          </div>
        </div>

      </div>

      {{!-- DESCRIPTION TAB --}}
      <div class="tab" data-tab="description" data-group="primary">

        {{!-- Effect --}}
        <div class="tw-mb-3 tw-bg-[rgba(255,255,255,0.03)] tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-lg tw-overflow-hidden">
          <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[rgba(201,162,39,0.2)]" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, rgba(201,162,39,0.05) 100%)">
            <i class="fas fa-bolt tw-opacity-70"></i>
            <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Effect</h3>
          </div>
          <div class="tw-p-2">
            {{#if inEditMode}}
            {{editor system.effect target="system.effect" button=true editable=editable engine="prosemirror"}}
            {{else}}
            <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.effect}}}</div>
            {{/if}}
          </div>
        </div>

        {{!-- Description --}}
        <div class="tw-mb-3 tw-bg-[rgba(255,255,255,0.03)] tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-lg tw-overflow-hidden">
          <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[rgba(201,162,39,0.2)]" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, rgba(201,162,39,0.05) 100%)">
            <i class="fas fa-book tw-opacity-70"></i>
            <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Description</h3>
          </div>
          <div class="tw-p-2">
            {{#if inEditMode}}
            {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
            {{else}}
            <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.description.value}}}</div>
            {{/if}}
          </div>
        </div>

        {{!-- Notes --}}
        <div class="tw-mb-3 tw-bg-[rgba(255,255,255,0.03)] tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-lg tw-overflow-hidden">
          <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[rgba(201,162,39,0.2)]" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, rgba(201,162,39,0.05) 100%)">
            <i class="fas fa-sticky-note tw-opacity-70"></i>
            <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Notes</h3>
          </div>
          <div class="tw-p-3">
            <textarea name="system.notes" rows="4" placeholder="GM notes, acquisition details, etc." class="tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-resize-y">{{item.system.notes}}</textarea>
          </div>
        </div>

        {{!-- Source --}}
        <div class="tw-mb-3 tw-bg-[rgba(255,255,255,0.03)] tw-border tw-border-[rgba(201,162,39,0.2)] tw-rounded-lg tw-overflow-hidden">
          <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[rgba(201,162,39,0.2)]" style="background: linear-gradient(135deg, rgba(201,162,39,0.15) 0%, rgba(201,162,39,0.05) 100%)">
            <i class="fas fa-book-open tw-opacity-70"></i>
            <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Source</h3>
          </div>
          <div class="tw-p-3">
            <input type="text" name="system.source" value="{{item.system.source}}"
                   placeholder="Rogue Trader Core Rulebook, pg. 123" class="tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
          </div>
        </div>

      </div>

      {{!-- EFFECTS TAB --}}
      <div class="tab" data-tab="effects" data-group="primary">
        {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
      </div>

    </div>


</div>
