{{! Journal Entry Item Sheet }}
<form class="tw-flex tw-flex-col tw-h-full tw-overflow-hidden tw-bg-[var(--wh40k-sheet-bg)] tw-text-[var(--wh40k-text-dark)]" autocomplete="off">
    {{! Header }}
    <header class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-shrink-0">
        <div class="tw-flex tw-items-center tw-justify-center tw-w-12 tw-h-12 tw-shrink-0 tw-rounded-md">
            <span class="material-icons tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-text-2xl">auto_stories</span>
        </div>
        <div class="tw-flex tw-flex-col tw-gap-1 tw-min-w-0 tw-flex-1">
            <input class="tw-font-display tw-text-xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-bg-transparent tw-border-none tw-w-full tw-p-1" name="name" type="text" value="{{item.name}}" placeholder="Journal Entry Title" />
            <div class="tw-inline-flex tw-items-center tw-gap-1 tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">
                <span class="material-icons tw-text-sm">menu_book</span>
                <span>Journal Entry</span>
            </div>
        </div>
    </header>

    {{! Entry Details Panel }}
    <section class="tw-p-3">
        <h2 class="tw-flex tw-items-center tw-gap-2 tw-font-display tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-text-base tw-mt-0 tw-mb-3 tw-pb-2 tw-border-b tw-border-solid">
            <span class="material-icons tw-text-base">event</span>
            Entry Details
        </h2>
        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
            <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Date</label>
                <input class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.time" type="date" value="{{item.system.time}}" />
            </div>
            <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Location</label>
                <input class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.place" type="text" value="{{item.system.place}}" placeholder="Where this occurred..." />
            </div>
        </div>
    </section>

    {{! Entry Content Panel }}
    <section class="tw-flex-1 tw-p-3 tw-flex tw-flex-col tw-min-h-0">
        <h2 class="tw-flex tw-items-center tw-gap-2 tw-font-display tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-text-base tw-mt-0 tw-mb-3 tw-pb-2 tw-border-b tw-border-solid tw-shrink-0">
            <span class="material-icons tw-text-base">edit_note</span>
            Entry
        </h2>
        <div class="tw-flex-1 tw-flex tw-flex-col">
            <textarea
                class="tw-flex-1 tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-resize-none"
                name="system.description.value"
                placeholder="Record your thoughts, discoveries, and observations..."
            >{{item.system.description.value}}</textarea>
        </div>
    </section>
</form>
