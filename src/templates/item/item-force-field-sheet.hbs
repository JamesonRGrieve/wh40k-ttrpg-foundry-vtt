{{!--
  Rogue Trader Force Field Item Sheet - V2 Complete Redesign
  Matches weapon sheet pattern with modern ApplicationV2 structure
--}}
<div class="tw-flex tw-flex-col tw-h-full">
  <form autocomplete="off" class="tw-flex tw-flex-col tw-flex-1 tw-min-h-0">

    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: Compact force field identity with status
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-shrink-0">
      {{> systems/wh40k-rpg/templates/shared/editable-portrait.hbs src=item.img alt=item.name sizeClass="tw-w-16 tw-h-16" frameClass="" overlayBgClass="tw-bg-black/60" overlayTextClass="" overlayIconClass="" extraClass="tw-shrink-0"}}

      <div class="tw-flex tw-flex-col tw-gap-1 tw-min-w-0 tw-flex-1">
        <input type="text" class="tw-font-display tw-text-xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-bg-transparent tw-border-none tw-w-full tw-p-1" name="name" value="{{item.name}}" placeholder="Force Field Name" />

        <div class="tw-flex tw-flex-wrap tw-gap-1 tw-items-center">
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs"
                title="Status">
            <i class="fas {{#if system.overloaded}}fa-exclamation-triangle{{else if system.activated}}fa-shield{{else}}fa-shield-slash{{/if}}"></i>
            {{system.statusLabel}}
          </span>
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs" title="Protection Rating">
            <i class="fas fa-percent"></i>
            {{system.protectionRating}}%
          </span>
          {{#if (ne system.craftsmanship "common")}}
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs" title="Craftsmanship">
            <i class="fas fa-hammer"></i>
            {{system.craftsmanshipLabel}}
          </span>
          {{/if}}
        </div>
      </div>

      <div class="tw-shrink-0">
        <label class="tw-flex tw-items-center tw-gap-1 tw-cursor-pointer" title="Toggle Equipped">
          <input type="checkbox" name="system.equipped" {{checked system.equipped}} class="tw-sr-only" />
          <span class="tw-inline-flex tw-items-center tw-justify-center tw-w-6 tw-h-6 tw-text-xl tw-transition-colors {{#if system.equipped}}tw-text-[color:var(--wh40k-green-bright)]{{else}}tw-text-white/50{{/if}}">
            <i class="fas {{#if system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
          </span>
          <span class="tw-text-xs {{#if system.equipped}}tw-text-[color:var(--wh40k-green-bright)]{{else}}tw-text-[color:rgba(214,221,235,0.7)]{{/if}}">{{#if system.equipped}}Equipped{{else}}Stowed{{/if}}</span>
        </label>
      </div>
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         STAT BAR: Key force field statistics
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="tw-flex tw-flex-wrap tw-gap-2 tw-p-2 tw-shrink-0">
      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-shield-alt"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Rating</span>
          <span class="tw-font-semibold">{{system.protectionRating}}</span>
        </div>
      </div>

      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-bolt"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Overload</span>
          <span class="tw-font-semibold">{{system.overloadThreshold}}+</span>
        </div>
      </div>

      <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm">
        <div class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-weight-hanging"></i>
        </div>
        <div class="tw-flex tw-flex-col">
          <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Weight</span>
          <span class="tw-font-semibold">{{system.weight}}kg</span>
        </div>
      </div>
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ --}}
    <nav class="wh40k-tabs tw-flex tw-shrink-0" data-group="primary">
      <button type="button" class="wh40k-tab active tw-flex tw-items-center tw-gap-1 tw-px-4 tw-py-2 tw-text-sm tw-cursor-pointer tw-border-none tw-bg-transparent" data-tab="stats" data-group="primary">
        <i class="fas fa-chart-bar"></i>
        <span>Stats</span>
      </button>
      <button type="button" class="wh40k-tab tw-flex tw-items-center tw-gap-1 tw-px-4 tw-py-2 tw-text-sm tw-cursor-pointer tw-border-none tw-bg-transparent" data-tab="description" data-group="primary">
        <i class="fas fa-scroll"></i>
        <span>Info</span>
      </button>
      <button type="button" class="wh40k-tab tw-flex tw-items-center tw-gap-1 tw-px-4 tw-py-2 tw-text-sm tw-cursor-pointer tw-border-none tw-bg-transparent" data-tab="effects" data-group="primary">
        <i class="fas fa-magic"></i>
        <span>Effects</span>
      </button>
    </nav>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <section class="wh40k-tab-content tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-2">

      {{!-- STATS TAB --}}
      <div class="tab active" data-tab="stats" data-group="primary">

      {{!-- Status Controls --}}
      <div class="tw-mb-3">
        <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2">
          <i class="fas fa-toggle-on tw-opacity-70"></i>
          <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Status Controls</h3>
        </div>
        <div class="tw-p-3">
          <div class="tw-flex tw-flex-col tw-gap-2">
            <label class="tw-flex tw-items-center tw-gap-3 tw-cursor-pointer tw-p-2 tw-rounded-md">
              <input type="checkbox" name="system.activated" {{checked system.activated}} class="tw-w-3.5 tw-h-3.5 [accent-color:var(--wh40k-gold)]" />
              <span class="tw-inline-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-md tw-text-lg">
                <i class="fas fa-shield"></i>
              </span>
              <span class="tw-flex tw-flex-col">
                <strong class="tw-text-sm">Activated</strong>
                <small class="tw-text-xs tw-opacity-70">Force field is currently active and providing protection</small>
              </span>
            </label>

            <label class="tw-flex tw-items-center tw-gap-3 tw-cursor-pointer tw-p-2 tw-rounded-md">
              <input type="checkbox" name="system.overloaded" {{checked system.overloaded}} class="tw-w-3.5 tw-h-3.5 [accent-color:var(--wh40k-gold)]" />
              <span class="tw-inline-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-md tw-text-lg">
                <i class="fas fa-exclamation-triangle"></i>
              </span>
              <span class="tw-flex tw-flex-col">
                <strong class="tw-text-sm">Overloaded</strong>
                <small class="tw-text-xs tw-opacity-70">Force field has overloaded and is temporarily disabled</small>
              </span>
            </label>
          </div>
        </div>
      </div>

      {{!-- Protection Settings --}}
      <div class="tw-mb-3">
        <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2">
          <i class="fas fa-shield-halved tw-opacity-70"></i>
          <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Protection Settings</h3>
        </div>
        <div class="tw-p-3">
          <div class="tw-flex tw-gap-3 tw-mb-3">
            <div class="tw-flex tw-flex-col tw-gap-1 tw-flex-1">
              <label class="tw-text-sm tw-font-medium">
                Protection Rating
                <small class="tw-font-normal tw-opacity-70 tw-block">Roll equal to or under this to be protected</small>
              </label>
              <div class="tw-flex tw-items-center tw-gap-1">
                <input type="number" name="system.protectionRating" value="{{source.protectionRating}}"
                       data-dtype="Number" min="0" max="100" class="tw-flex-1 tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
                <span class="tw-text-sm tw-opacity-70">%</span>
              </div>
            </div>
            <div class="tw-flex tw-flex-col tw-gap-1 tw-flex-1">
              <label class="tw-text-sm tw-font-medium">
                Overload Threshold
                <small class="tw-font-normal tw-opacity-70 tw-block">Roll this or higher on hit to overload</small>
              </label>
              <div class="tw-flex tw-items-center tw-gap-1">
                <input type="number" name="system.overloadThreshold" value="{{source.overloadThreshold}}"
                       data-dtype="Number" min="0" max="100" class="tw-flex-1 tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
                <span class="tw-text-sm tw-opacity-70">+</span>
              </div>
            </div>
          </div>
          <div class="tw-flex tw-flex-col tw-gap-1">
            <label class="tw-text-sm tw-font-medium">
              Overload Duration
              <small class="tw-font-normal tw-opacity-70"> — How long does the field stay disabled?</small>
            </label>
            <input type="text" name="system.overloadDuration" value="{{source.overloadDuration}}"
                   placeholder="1d5 rounds" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
          </div>
        </div>
      </div>

      {{!-- Physical Properties --}}
      <div class="tw-mb-3">
        <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2">
          <i class="fas fa-cog tw-opacity-70"></i>
          <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Physical Properties</h3>
        </div>
        <div class="tw-p-3">
          <div class="tw-flex tw-gap-3 tw-mb-3">
            <div class="tw-flex tw-flex-col tw-gap-1 tw-flex-1">
              <label class="tw-text-sm tw-font-medium">Weight (kg)</label>
              <input type="number" name="system.weight" value="{{source.weight}}"
                     data-dtype="Number" min="0" step="0.1" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
            </div>
            {{#unless hideThroneGelt}}
            <div class="tw-flex tw-flex-col tw-gap-1 tw-flex-1">
              <label class="tw-text-sm tw-font-medium">Cost (Thrones)</label>
              <input type="number" name="system.cost.dh2.homebrew.throneGelt" value="{{source.cost.dh2.homebrew.throneGelt}}"
                     data-dtype="Number" min="0" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
            </div>
            {{/unless}}
          </div>
          <div class="tw-flex tw-gap-3">
            <div class="tw-flex tw-flex-col tw-gap-1 tw-flex-1">
              <label class="tw-text-sm tw-font-medium">Availability</label>
              <select name="system.availability" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm">
                <option value="ubiquitous" {{#if (eq system.availability "ubiquitous")}}selected{{/if}}>Ubiquitous</option>
                <option value="abundant" {{#if (eq system.availability "abundant")}}selected{{/if}}>Abundant</option>
                <option value="plentiful" {{#if (eq system.availability "plentiful")}}selected{{/if}}>Plentiful</option>
                <option value="common" {{#if (eq system.availability "common")}}selected{{/if}}>Common</option>
                <option value="average" {{#if (eq system.availability "average")}}selected{{/if}}>Average</option>
                <option value="scarce" {{#if (eq system.availability "scarce")}}selected{{/if}}>Scarce</option>
                <option value="rare" {{#if (eq system.availability "rare")}}selected{{/if}}>Rare</option>
                <option value="very-rare" {{#if (eq system.availability "very-rare")}}selected{{/if}}>Very Rare</option>
                <option value="extremely-rare" {{#if (eq system.availability "extremely-rare")}}selected{{/if}}>Extremely Rare</option>
                <option value="near-unique" {{#if (eq system.availability "near-unique")}}selected{{/if}}>Near Unique</option>
                <option value="unique" {{#if (eq system.availability "unique")}}selected{{/if}}>Unique</option>
              </select>
            </div>
            <div class="tw-flex tw-flex-col tw-gap-1 tw-flex-1">
              <label class="tw-text-sm tw-font-medium">Craftsmanship</label>
              <select name="system.craftsmanship" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm">
                <option value="poor" {{#if (eq system.craftsmanship "poor")}}selected{{/if}}>Poor</option>
                <option value="common" {{#if (eq system.craftsmanship "common")}}selected{{/if}}>Common</option>
                <option value="good" {{#if (eq system.craftsmanship "good")}}selected{{/if}}>Good</option>
                <option value="best" {{#if (eq system.craftsmanship "best")}}selected{{/if}}>Best</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      </div>

      {{!-- DESCRIPTION TAB --}}
      <div class="tab" data-tab="description" data-group="primary">

      {{!-- Effect --}}
      <div class="tw-mb-3">
        <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2">
          <i class="fas fa-bolt tw-opacity-70"></i>
          <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Effect</h3>
        </div>
        <div class="tw-p-2">
          {{#if inEditMode}}
          {{editor system.effect target="system.effect" button=true editable=editable engine="prosemirror"}}
          {{else}}
          <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.effect}}}</div>
          {{/if}}
        </div>
      </div>

      {{!-- Description --}}
      <div class="tw-mb-3">
        <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2">
          <i class="fas fa-book tw-opacity-70"></i>
          <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Description</h3>
        </div>
        <div class="tw-p-2">
          {{#if inEditMode}}
          {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
          {{else}}
          <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.description.value}}}</div>
          {{/if}}
        </div>
      </div>

      {{!-- Notes --}}
      <div class="tw-mb-3">
        <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2">
          <i class="fas fa-sticky-note tw-opacity-70"></i>
          <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Notes</h3>
        </div>
        <div class="tw-p-3">
          <textarea name="system.notes" rows="4" placeholder="GM notes, special rules, etc." class="tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-resize-y">{{system.notes}}</textarea>
        </div>
      </div>

      {{!-- Source --}}
      <div class="tw-mb-3">
        <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2">
          <i class="fas fa-book-open tw-opacity-70"></i>
          <h3 class="tw-m-0 tw-text-base tw-font-semibold tw-flex-1">Source</h3>
        </div>
        <div class="tw-p-3">
          <input type="text" name="system.source" value="{{source.source}}"
                 placeholder="Rogue Trader Core Rulebook, pg. 123" class="tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" />
        </div>
      </div>

      </div>

      {{!-- EFFECTS TAB --}}
      <div class="tab" data-tab="effects" data-group="primary">
        {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
      </div>

    </section>

  </form>
</div>
