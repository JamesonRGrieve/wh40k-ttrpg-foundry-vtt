{{!-- Armour Modification Restrictions Tab --}}
<div class="wh40k-tab-content wh40k-armour-mod-restrictions" data-tab="restrictions">
    <div class="wh40k-panel">
        <header class="wh40k-panel-header">
            <h3>
                <i class="fas fa-filter"></i>
                {{localize "WH40K.Modification.Restrictions"}}
            </h3>
        </header>
        
        <div class="wh40k-panel-body">
            <p class="wh40k-help-text">
                {{localize "WH40K.Modification.RestrictionsHelp"}}
            </p>
            
            <div class="wh40k-restriction-grid">
                {{#each armourTypesArray}}
                    <label class="wh40k-restriction-item {{#if selected}}selected{{/if}}">
                        <input type="checkbox" 
                               data-action="toggleArmourType" 
                               data-type="{{key}}"
                               {{checked selected}}
                               {{disabled (eq key "any")}}>
                        <span class="wh40k-restriction-label">{{label}}</span>
                        <i class="fas fa-check wh40k-restriction-check"></i>
                    </label>
                {{/each}}
            </div>
            
            {{#if (eq armourTypesArray.length 0)}}
                <p class="wh40k-empty-state">
                    <i class="fas fa-exclamation-triangle"></i>
                    No armour types configured
                </p>
            {{/if}}
        </div>
    </div>
    
    <div class="wh40k-panel wh40k-panel--source">
        <header class="wh40k-panel-header">
            <h3>
                <i class="fas fa-book"></i>
                {{localize "WH40K.Source.Book"}}
            </h3>
        </header>
        
        <div class="wh40k-panel-body">
            <div class="wh40k-field-row">
                <div class="wh40k-field">
                    <label class="wh40k-field-label">{{localize "WH40K.Availability.Label"}}</label>
                    <select name="system.availability" class="wh40k-field-select">
                        {{selectOptions dh.availabilities selected=source.availability labelAttr="label" blank=""}}
                    </select>
                </div>
                
                <div class="wh40k-field">
                    <label class="wh40k-field-label">{{localize "WH40K.Source.Book"}}</label>
                    <input type="text" 
                           name="system.source" 
                           value="{{source.source}}" 
                           class="wh40k-field-input"
                           placeholder="Core Rulebook, p. 123">
                </div>
            </div>
        </div>
    </div>
</div>
