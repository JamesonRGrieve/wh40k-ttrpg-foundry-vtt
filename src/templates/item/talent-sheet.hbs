{{!-- 
  Rogue Trader Talent Item Sheet V2 - Complete Redesign
  Modern tabbed interface with translucent gothic styling
  Font Awesome 6 Pro icons throughout
--}}
<div class="wh40k-talent-sheet-v2">
    
    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: Portrait, name, key badges, and quick actions
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="wh40k-talent-header">
      {{!-- Portrait --}}
      <div class="wh40k-talent-portrait" data-action="editImage">
        <img src="{{item.img}}" alt="{{item.name}}" />
        {{#if inEditMode}}
        <div class="wh40k-talent-portrait-overlay">
          <i class="fa-solid fa-camera"></i>
        </div>
        {{/if}}
      </div>
      
      {{!-- Title & Meta --}}
      <div class="wh40k-talent-title">
        {{#if inEditMode}}
        <input type="text" class="wh40k-talent-name" name="name" value="{{item.name}}" placeholder="Talent Name" />
        {{else}}
        <h1 class="wh40k-talent-name">{{item.name}}</h1>
        {{/if}}
        
        {{!-- Quick Badges --}}
        <div class="wh40k-talent-badges">
          {{!-- Type Badge --}}
          <span class="wh40k-badge wh40k-badge--type">
            <i class="fa-solid {{#if talentData.isPassive}}fa-circle-check{{else}}fa-bolt{{/if}}"></i>
            {{#if talentData.isPassive}}Passive{{else}}Active{{/if}}
          </span>
          
          {{!-- Tier Badge --}}
          {{#if (gt talentData.tier 0)}}
          <span class="wh40k-badge wh40k-badge--tier wh40k-badge--tier-{{talentData.tier}}">
            <i class="fa-solid fa-layer-group"></i>
            Tier {{talentData.tier}}
          </span>
          {{/if}}
          
          {{!-- Category Badge --}}
          <span class="wh40k-badge wh40k-badge--category">
            <i class="fa-solid fa-tag"></i>
            {{talentData.categoryLabel}}
          </span>
          
          {{!-- XP Cost Badge --}}
          {{#if (gt talentData.cost 0)}}
          <span class="wh40k-badge wh40k-badge--cost">
            <i class="fa-solid fa-coins"></i>
            {{talentData.cost}} XP
          </span>
          {{/if}}
          
          {{!-- Stackable Badge --}}
          {{#if talentData.stackable}}
          <span class="wh40k-badge wh40k-badge--stackable">
            <i class="fa-solid fa-layer-group"></i>
            Rank {{talentData.rank}}
          </span>
          {{/if}}
          
          {{!-- Rollable Badge --}}
          {{#if talentData.isRollable}}
          <span class="wh40k-badge wh40k-badge--rollable">
            <i class="fa-solid fa-dice-d20"></i>
            Rollable
          </span>
          {{/if}}
        </div>
      </div>
      
      {{!-- Action Buttons --}}
      <div class="wh40k-talent-actions">
        {{!-- Edit Mode Toggle (only for actor-owned items) --}}
        {{#if isOwnedByActor}}
        {{#if canEdit}}
        <button type="button" class="wh40k-action-btn wh40k-action-btn--edit {{#if inEditMode}}active{{/if}}" 
                data-action="toggleEditMode" title="{{#if inEditMode}}Exit Edit Mode{{else}}Enter Edit Mode{{/if}}">
          <i class="fa-solid {{#if inEditMode}}fa-lock-open{{else}}fa-pen-to-square{{/if}}"></i>
        </button>
        {{/if}}
        {{/if}}
        
        {{!-- Roll Button --}}
        {{#if talentData.isRollable}}
        <button type="button" class="wh40k-action-btn wh40k-action-btn--roll" data-action="rollTalent" title="Roll Talent">
          <i class="fa-solid fa-dice-d20"></i>
        </button>
        {{/if}}
        
        {{!-- Chat Button --}}
        <button type="button" class="wh40k-action-btn wh40k-action-btn--chat" data-action="postToChat" title="Post to Chat">
          <i class="fa-solid fa-comment"></i>
        </button>
      </div>
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         QUICK STATS BAR: Key info at a glance
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-talent-quickstats">
      {{!-- Prerequisites Summary --}}
      {{#if prerequisitesData.hasAny}}
      <div class="wh40k-quickstat wh40k-quickstat--prereqs">
        <i class="fa-solid fa-lock"></i>
        <span class="wh40k-quickstat-label">Prerequisites</span>
        <span class="wh40k-quickstat-value">{{prerequisitesData.label}}</span>
      </div>
      {{/if}}
      
      {{!-- Aptitudes --}}
      {{#if talentData.hasAptitudes}}
      <div class="wh40k-quickstat wh40k-quickstat--aptitudes">
        <i class="fa-solid fa-brain"></i>
        <span class="wh40k-quickstat-label">Aptitudes</span>
        <div class="wh40k-quickstat-tags">
          {{#each talentData.aptitudes}}
          <span class="wh40k-aptitude-tag">{{this}}</span>
          {{/each}}
        </div>
      </div>
      {{/if}}
      
      {{!-- Specialization --}}
      {{#if talentData.specialization}}
      <div class="wh40k-quickstat wh40k-quickstat--spec">
        <i class="fa-solid fa-bullseye"></i>
        <span class="wh40k-quickstat-label">Specialization</span>
        <span class="wh40k-quickstat-value">{{talentData.specialization}}</span>
      </div>
      {{/if}}
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         EFFECTS BANNER: Quick summary of talent effects (visible on all tabs)
    ═══════════════════════════════════════════════════════════════════ --}}
    {{#if (or modifiersData.hasAny situationalData.hasAny grantsData.hasAny)}}
    <div class="wh40k-effects-banner">
      <div class="wh40k-effects-banner__header">
        <i class="fa-solid fa-sparkles"></i>
        <span>Effects</span>
      </div>
      <div class="wh40k-effects-banner__pills">
        {{!-- Permanent Modifiers Pill --}}
        {{#if modifiersData.hasAny}}
        <div class="wh40k-effect-pill wh40k-effect-pill--modifiers" title="Permanent modifiers applied while talent is possessed">
          <i class="fa-solid fa-chart-line"></i>
          <span class="wh40k-effect-pill__label">Modifiers</span>
          <span class="wh40k-effect-pill__count">{{#if modifiersData.hasCharacteristics}}{{modifiersData.characteristics.length}}{{/if}}{{#if (and modifiersData.hasCharacteristics modifiersData.hasSkills)}}+{{/if}}{{#if modifiersData.hasSkills}}{{modifiersData.skills.length}}{{/if}}{{#if (and (or modifiersData.hasCharacteristics modifiersData.hasSkills) modifiersData.hasCombat)}}+{{/if}}{{#if modifiersData.hasCombat}}{{modifiersData.combat.length}}{{/if}}{{#if (and (or modifiersData.hasCharacteristics modifiersData.hasSkills modifiersData.hasCombat) modifiersData.hasResources)}}+{{/if}}{{#if modifiersData.hasResources}}{{modifiersData.resources.length}}{{/if}}</span>
        </div>
        {{/if}}
        
        {{!-- Situational Modifiers Pill --}}
        {{#if situationalData.hasAny}}
        <div class="wh40k-effect-pill wh40k-effect-pill--situational" title="Conditional bonuses that appear in roll dialogs">
          <i class="fa-solid fa-clock-rotate-left"></i>
          <span class="wh40k-effect-pill__label">Situational</span>
          <span class="wh40k-effect-pill__count">{{#if situationalData.hasCharacteristics}}{{situationalData.characteristics.length}}{{/if}}{{#if (and situationalData.hasCharacteristics situationalData.hasSkills)}}+{{/if}}{{#if situationalData.hasSkills}}{{situationalData.skills.length}}{{/if}}{{#if (and (or situationalData.hasCharacteristics situationalData.hasSkills) situationalData.hasCombat)}}+{{/if}}{{#if situationalData.hasCombat}}{{situationalData.combat.length}}{{/if}}</span>
        </div>
        {{/if}}
        
        {{!-- Grants Pill --}}
        {{#if grantsData.hasAny}}
        <div class="wh40k-effect-pill wh40k-effect-pill--grants" title="Skills, talents, and traits automatically granted">
          <i class="fa-solid fa-gift"></i>
          <span class="wh40k-effect-pill__label">Grants</span>
          <span class="wh40k-effect-pill__count">{{#if grantsData.hasSkills}}{{grantsData.skills.length}}{{/if}}{{#if (and grantsData.hasSkills grantsData.hasTalents)}}+{{/if}}{{#if grantsData.hasTalents}}{{grantsData.talents.length}}{{/if}}{{#if (and (or grantsData.hasSkills grantsData.hasTalents) grantsData.hasTraits)}}+{{/if}}{{#if grantsData.hasTraits}}{{grantsData.traits.length}}{{/if}}</span>
        </div>
        {{/if}}
      </div>
      <a class="wh40k-effects-banner__link" data-tab="effects" data-group="primary">
        <span>View Details</span>
        <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>
    {{/if}}

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ --}}
    <nav class="wh40k-talent-tabs" data-group="primary">
      <button type="button" class="wh40k-talent-tab {{#if (eq activeTab "overview")}}active{{/if}}" 
              data-tab="overview" data-group="primary">
        <i class="fa-solid fa-eye"></i>
        <span>Overview</span>
      </button>
      <button type="button" class="wh40k-talent-tab {{#if (eq activeTab "effects")}}active{{/if}}" 
              data-tab="effects" data-group="primary">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
        <span>Effects</span>
      </button>
      <button type="button" class="wh40k-talent-tab {{#if (eq activeTab "properties")}}active{{/if}}" 
              data-tab="properties" data-group="primary">
        <i class="fa-solid fa-sliders"></i>
        <span>Properties</span>
      </button>
      <button type="button" class="wh40k-talent-tab {{#if (eq activeTab "description")}}active{{/if}}" 
              data-tab="description" data-group="primary">
        <i class="fa-solid fa-book"></i>
        <span>Description</span>
      </button>
    </nav>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <section class="wh40k-talent-content">
      
      {{!-- ─────────────────────────────────────────────────────────────────
           OVERVIEW TAB: Benefit and effects summary
      ───────────────────────────────────────────────────────────────── --}}
      <div class="wh40k-talent-panel {{#if (eq activeTab "overview")}}active{{/if}}" data-tab="overview" data-group="primary">
        
        {{!-- Benefit Section (Editable with hover button) --}}
        <div class="wh40k-section wh40k-section--editable {{#if inEditMode}}wh40k-section--editing{{/if}}">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-star"></i>
            Benefit
            {{#if canEdit}}
            {{#unless inEditMode}}
            <button type="button" class="wh40k-header-btn wh40k-header-btn--hover" data-action="toggleEditMode" title="Edit Benefit">
              <i class="fa-solid fa-pen-to-square"></i>
            </button>
            {{else}}
            <button type="button" class="wh40k-header-btn wh40k-header-btn--done" data-action="toggleEditMode" title="Done Editing">
              <i class="fa-solid fa-check"></i>
            </button>
            {{/unless}}
            {{/if}}
          </h3>
          <div class="wh40k-section-body">
            {{#if inEditMode}}
            <div class="wh40k-editor-container">
              {{editor system.benefit target="system.benefit" button=true editable=canEdit engine="prosemirror"}}
            </div>
            {{else}}
              {{#if talentData.hasBenefit}}
              <div class="wh40k-benefit-text">
                {{{talentData.benefit}}}
              </div>
              {{else}}
              <div class="wh40k-empty-state wh40k-empty-state--compact wh40k-empty-state--clickable" data-action="toggleEditMode">
                <i class="fa-solid fa-file-lines"></i>
                <p>Click to add benefit description</p>
              </div>
              {{/if}}
            {{/if}}
          </div>
        </div>
        
        {{!-- Special Abilities Section --}}
        <div class="wh40k-section">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-bolt-lightning"></i>
            Special Abilities
            {{#if inEditMode}}
            <button type="button" class="wh40k-header-btn" data-action="openTalentEditor" data-section="grants" title="Edit Grants & Abilities">
              <i class="fa-solid fa-pen-to-square"></i>
            </button>
            {{/if}}
          </h3>
          <div class="wh40k-section-body">
            {{#if grantsData.hasSpecialAbilities}}
            <div class="wh40k-abilities-list">
              {{#each grantsData.specialAbilities}}
              <div class="wh40k-ability-card">
                <h4 class="wh40k-ability-name">
                  <i class="fa-solid fa-circle-dot"></i>
                  {{this.name}}
                </h4>
                <div class="wh40k-ability-description">
                  {{{this.description}}}
                </div>
              </div>
              {{/each}}
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--compact">
              <i class="fa-solid fa-bolt-lightning"></i>
              <p>No special abilities</p>
              {{#if inEditMode}}
              <button type="button" class="wh40k-btn-add-data" data-action="openTalentEditor" data-section="grants">
                <i class="fa-solid fa-plus"></i> Add Abilities & Grants
              </button>
              {{/if}}
            </div>
            {{/if}}
          </div>
        </div>
        
      </div>
      
      {{!-- ─────────────────────────────────────────────────────────────────
           PROPERTIES TAB: Configuration and details
      ───────────────────────────────────────────────────────────────── --}}
      <div class="wh40k-talent-panel {{#if (eq activeTab "properties")}}active{{/if}}" data-tab="properties" data-group="primary">
        
        {{!-- Basic Properties --}}
        <div class="wh40k-section">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-cog"></i>
            Basic Properties
          </h3>
          <div class="wh40k-section-body">
            <div class="wh40k-properties-grid">
              {{!-- Category --}}
              <div class="wh40k-property">
                <label class="wh40k-property-label">
                  <i class="fa-solid fa-tag"></i>
                  Category
                </label>
                {{#if inEditMode}}
                <select name="system.category" class="wh40k-property-select">
                  {{#each categoryOptions}}
                  <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
                {{else}}
                <div class="wh40k-property-value">{{talentData.categoryLabel}}</div>
                {{/if}}
              </div>
              
              {{!-- Tier --}}
              <div class="wh40k-property">
                <label class="wh40k-property-label">
                  <i class="fa-solid fa-layer-group"></i>
                  Tier
                </label>
                {{#if inEditMode}}
                <select name="system.tier" class="wh40k-property-select">
                  {{#each tierOptions}}
                  <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
                {{else}}
                <div class="wh40k-property-value">{{talentData.tierLabel}}</div>
                {{/if}}
              </div>
              
              {{!-- XP Cost --}}
              <div class="wh40k-property">
                <label class="wh40k-property-label">
                  <i class="fa-solid fa-coins"></i>
                  XP Cost
                </label>
                {{#if inEditMode}}
                <input type="number" name="system.cost" value="{{talentData.cost}}" min="0" class="wh40k-property-input" />
                {{else}}
                <div class="wh40k-property-value">{{talentData.cost}}</div>
                {{/if}}
              </div>
              
              {{!-- Type (Passive/Active) - Radio Buttons --}}
              <div class="wh40k-property wh40k-property--radio">
                <label class="wh40k-property-label">
                  <i class="fa-solid fa-circle-check"></i>
                  Type
                </label>
                {{#if inEditMode}}
                <div class="wh40k-radio-group">
                  <label class="wh40k-radio-label">
                    <input type="radio" name="system.isPassive" value="true" {{#if talentData.isPassive}}checked{{/if}} />
                    <span class="wh40k-radio-indicator"></span>
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Passive</span>
                  </label>
                  <label class="wh40k-radio-label">
                    <input type="radio" name="system.isPassive" value="false" {{#unless talentData.isPassive}}checked{{/unless}} />
                    <span class="wh40k-radio-indicator"></span>
                    <i class="fa-solid fa-bolt"></i>
                    <span>Active</span>
                  </label>
                </div>
                {{else}}
                <div class="wh40k-property-value">
                  <i class="fa-solid {{#if talentData.isPassive}}fa-circle-check{{else}}fa-bolt{{/if}}"></i>
                  {{#if talentData.isPassive}}Passive{{else}}Active{{/if}}
                </div>
                {{/if}}
              </div>
              
              {{!-- Stackable --}}
              <div class="wh40k-property wh40k-property--checkbox">
                <label class="wh40k-property-label">
                  <i class="fa-solid fa-layer-group"></i>
                  Stackable
                </label>
                {{#if inEditMode}}
                <label class="wh40k-checkbox-label">
                  <input type="checkbox" name="system.stackable" {{checked talentData.stackable}} />
                  <span>Can Take Multiple Times</span>
                </label>
                {{else}}
                <div class="wh40k-property-value">{{#if talentData.stackable}}Yes{{else}}No{{/if}}</div>
                {{/if}}
              </div>
              
              {{!-- Rank (if stackable) --}}
              {{#if talentData.stackable}}
              <div class="wh40k-property">
                <label class="wh40k-property-label">
                  <i class="fa-solid fa-hashtag"></i>
                  Current Rank
                </label>
                {{#if inEditMode}}
                <div class="wh40k-rank-controls">
                  <button type="button" class="wh40k-rank-btn" data-action="adjustRank" data-delta="-1">
                    <i class="fa-solid fa-minus"></i>
                  </button>
                  <input type="number" name="system.rank" value="{{talentData.rank}}" min="1" class="wh40k-property-input wh40k-property-input--rank" />
                  <button type="button" class="wh40k-rank-btn" data-action="adjustRank" data-delta="1">
                    <i class="fa-solid fa-plus"></i>
                  </button>
                </div>
                {{else}}
                <div class="wh40k-property-value">{{talentData.rank}}</div>
                {{/if}}
              </div>
              {{/if}}
            </div>
          </div>
        </div>
        
        {{!-- Specialization (with Has Specialization checkbox) --}}
        <div class="wh40k-section">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-bullseye"></i>
            Specialization (X)
          </h3>
          <div class="wh40k-section-body">
            {{#if inEditMode}}
            <div class="wh40k-specialization-edit">
              <label class="wh40k-checkbox-inline">
                <input type="checkbox" name="system.hasSpecialization" {{checked talentData.hasSpecialization}} />
                <span>This talent has a specialization (e.g., Peer (X), Weapon Training (X))</span>
              </label>
              {{#if talentData.hasSpecialization}}
              <div class="wh40k-specialization-field">
                <input type="text" name="system.specialization" value="{{talentData.specialization}}" 
                       class="wh40k-property-input wh40k-property-input--inline" placeholder="e.g., Las, Mechanicum, Nobility" />
              </div>
              {{/if}}
            </div>
            {{else if talentData.hasSpecialization}}
            <div class="wh40k-property-display">
              <span class="wh40k-specialization-badge">
                <i class="fa-solid fa-bullseye"></i>
                {{talentData.specialization}}
              </span>
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--compact">
              <i class="fa-solid fa-bullseye"></i>
              <p>Not a specialization talent</p>
            </div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Prerequisites --}}
        <div class="wh40k-section">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-lock"></i>
            Prerequisites
            {{#if inEditMode}}
            <button type="button" class="wh40k-header-btn" data-action="openTalentEditor" data-section="prerequisites" title="Edit Prerequisites">
              <i class="fa-solid fa-pen-to-square"></i>
            </button>
            {{/if}}
          </h3>
          <div class="wh40k-section-body">
            {{#if prerequisitesData.hasAny}}
            <div class="wh40k-prerequisites-display">
              {{#if prerequisitesData.hasText}}
              <div class="wh40k-prereq-text">{{prerequisitesData.text}}</div>
              {{/if}}
              
              {{#if prerequisitesData.hasCharacteristics}}
              <div class="wh40k-prereq-group">
                <span class="wh40k-prereq-group-label">Characteristics:</span>
                {{#each prerequisitesData.characteristics}}
                <span class="wh40k-prereq-tag">{{this.short}} {{this.value}}+</span>
                {{/each}}
              </div>
              {{/if}}
              
              {{#if prerequisitesData.hasSkills}}
              <div class="wh40k-prereq-group">
                <span class="wh40k-prereq-group-label">Skills:</span>
                {{#each prerequisitesData.skills}}
                <span class="wh40k-prereq-tag">{{this}}</span>
                {{/each}}
              </div>
              {{/if}}
              
              {{#if prerequisitesData.hasTalents}}
              <div class="wh40k-prereq-group">
                <span class="wh40k-prereq-group-label">Talents:</span>
                {{#each prerequisitesData.talents}}
                <span class="wh40k-prereq-tag">{{this}}</span>
                {{/each}}
              </div>
              {{/if}}
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--compact">
              <i class="fa-solid fa-unlock"></i>
              <p>No prerequisites — available to all characters</p>
              {{#if inEditMode}}
              <button type="button" class="wh40k-btn-add-data" data-action="openTalentEditor" data-section="prerequisites">
                <i class="fa-solid fa-plus"></i> Add Prerequisites
              </button>
              {{/if}}
            </div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Roll Configuration (if active talent) --}}
        {{#unless talentData.isPassive}}
        <div class="wh40k-section">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-dice-d20"></i>
            Roll Configuration
          </h3>
          <div class="wh40k-section-body">
            {{#if inEditMode}}
            <div class="wh40k-properties-grid">
              <div class="wh40k-property">
                <label class="wh40k-property-label">Characteristic</label>
                <input type="text" name="system.rollConfig.characteristic" 
                       value="{{rollConfigData.characteristic}}" 
                       class="wh40k-property-input" placeholder="e.g., willpower" />
              </div>
              <div class="wh40k-property">
                <label class="wh40k-property-label">Skill</label>
                <input type="text" name="system.rollConfig.skill" 
                       value="{{rollConfigData.skill}}" 
                       class="wh40k-property-input" placeholder="e.g., psyniscience" />
              </div>
              <div class="wh40k-property">
                <label class="wh40k-property-label">Modifier</label>
                <input type="number" name="system.rollConfig.modifier" 
                       value="{{rollConfigData.modifier}}" 
                       class="wh40k-property-input" />
              </div>
            </div>
            <div class="wh40k-property" style="margin-top: 12px;">
              <label class="wh40k-property-label">Roll Description</label>
              <input type="text" name="system.rollConfig.description" 
                     value="{{rollConfigData.description}}" 
                     class="wh40k-property-input" placeholder="Description for roll dialog" />
            </div>
            {{else if rollConfigData.isConfigured}}
            <div class="wh40k-roll-config-display">
              {{#if rollConfigData.characteristic}}
              <div class="wh40k-config-item">
                <i class="fa-solid fa-dumbbell"></i>
                <span>{{rollConfigData.characteristicLabel}} Test</span>
                {{#if (ne rollConfigData.modifier 0)}}
                <span class="wh40k-config-mod {{#if (gt rollConfigData.modifier 0)}}positive{{else}}negative{{/if}}">
                  {{#if (gt rollConfigData.modifier 0)}}+{{/if}}{{rollConfigData.modifier}}
                </span>
                {{/if}}
              </div>
              {{/if}}
              {{#if rollConfigData.skill}}
              <div class="wh40k-config-item">
                <i class="fa-solid fa-graduation-cap"></i>
                <span>{{rollConfigData.skillLabel}} Test</span>
                {{#if (ne rollConfigData.modifier 0)}}
                <span class="wh40k-config-mod {{#if (gt rollConfigData.modifier 0)}}positive{{else}}negative{{/if}}">
                  {{#if (gt rollConfigData.modifier 0)}}+{{/if}}{{rollConfigData.modifier}}
                </span>
                {{/if}}
              </div>
              {{/if}}
              {{#if rollConfigData.description}}
              <p class="wh40k-config-desc">{{rollConfigData.description}}</p>
              {{/if}}
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--compact">
              <i class="fa-solid fa-dice-d20"></i>
              <p>No roll configuration defined</p>
            </div>
            {{/if}}
          </div>
        </div>
        {{/unless}}
        
      </div>
      
      {{!-- ─────────────────────────────────────────────────────────────────
           EFFECTS TAB: Modifiers and mechanical effects
      ───────────────────────────────────────────────────────────────── --}}
      <div class="wh40k-talent-panel wh40k-talent-panel--effects {{#if (eq activeTab "effects")}}active{{/if}}" data-tab="effects" data-group="primary">
        
        {{!-- Permanent Modifiers --}}
        <div class="wh40k-section wh40k-section--effects" data-section-id="modifiers" data-has-data="{{modifiersData.hasAny}}" style="order: {{#each effectsSectionOrder}}{{#if (eq this "modifiers")}}{{@index}}{{/if}}{{/each}}">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-chart-line"></i>
            Permanent Modifiers
            {{#if inEditMode}}
            <button type="button" class="wh40k-header-btn" data-action="openTalentEditor" data-section="modifiers" title="Edit Modifiers">
              <i class="fa-solid fa-pen-to-square"></i>
            </button>
            {{/if}}
          </h3>
          <div class="wh40k-section-body">
            {{#if modifiersData.hasAny}}
            <p class="wh40k-hint-text">
              <i class="fa-solid fa-info-circle"></i>
              These modifiers are automatically applied while this talent is possessed.
            </p>
            <div class="wh40k-modifiers-grid">
              {{!-- Characteristic Modifiers --}}
              {{#if modifiersData.hasCharacteristics}}
              <div class="wh40k-modifier-group">
                <h4 class="wh40k-modifier-group-header">
                  <i class="fa-solid fa-dumbbell"></i>
                  Characteristics
                </h4>
                <div class="wh40k-modifier-list">
                  {{#each modifiersData.characteristics}}
                  <div class="wh40k-modifier-item">
                    <span class="wh40k-modifier-name">{{this.label}}</span>
                    <span class="wh40k-modifier-value {{#if this.positive}}positive{{else}}negative{{/if}}">
                      {{#if this.positive}}+{{/if}}{{this.value}}
                    </span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}
              
              {{!-- Skill Modifiers --}}
              {{#if modifiersData.hasSkills}}
              <div class="wh40k-modifier-group">
                <h4 class="wh40k-modifier-group-header">
                  <i class="fa-solid fa-graduation-cap"></i>
                  Skills
                </h4>
                <div class="wh40k-modifier-list">
                  {{#each modifiersData.skills}}
                  <div class="wh40k-modifier-item">
                    <span class="wh40k-modifier-name">{{this.label}}</span>
                    <span class="wh40k-modifier-value {{#if this.positive}}positive{{else}}negative{{/if}}">
                      {{#if this.positive}}+{{/if}}{{this.value}}
                    </span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}
              
              {{!-- Combat Modifiers --}}
              {{#if modifiersData.hasCombat}}
              <div class="wh40k-modifier-group">
                <h4 class="wh40k-modifier-group-header">
                  <i class="fa-solid fa-swords"></i>
                  Combat
                </h4>
                <div class="wh40k-modifier-list">
                  {{#each modifiersData.combat}}
                  <div class="wh40k-modifier-item">
                    <span class="wh40k-modifier-name">{{this.label}}</span>
                    <span class="wh40k-modifier-value {{#if this.positive}}positive{{else}}negative{{/if}}">
                      {{#if this.positive}}+{{/if}}{{this.value}}
                    </span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}
              
              {{!-- Resource Modifiers --}}
              {{#if modifiersData.hasResources}}
              <div class="wh40k-modifier-group">
                <h4 class="wh40k-modifier-group-header">
                  <i class="fa-solid fa-heart"></i>
                  Resources
                </h4>
                <div class="wh40k-modifier-list">
                  {{#each modifiersData.resources}}
                  <div class="wh40k-modifier-item">
                    <span class="wh40k-modifier-name">{{this.label}}</span>
                    <span class="wh40k-modifier-value {{#if this.positive}}positive{{else}}negative{{/if}}">
                      {{#if this.positive}}+{{/if}}{{this.value}}
                    </span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}
              
              {{!-- Other Modifiers --}}
              {{#if modifiersData.hasOther}}
              <div class="wh40k-modifier-group">
                <h4 class="wh40k-modifier-group-header">
                  <i class="fa-solid fa-ellipsis"></i>
                  Other
                </h4>
                <div class="wh40k-modifier-list">
                  {{#each modifiersData.other}}
                  <div class="wh40k-modifier-item">
                    <span class="wh40k-modifier-name">{{this.label}}</span>
                    <span class="wh40k-modifier-value {{#if this.positive}}positive{{else}}negative{{/if}}">
                      {{#if this.positive}}+{{/if}}{{this.value}}
                    </span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--compact">
              <i class="fa-solid fa-chart-line"></i>
              <p>No permanent modifiers</p>
              {{#if inEditMode}}
              <button type="button" class="wh40k-btn-add-data" data-action="openTalentEditor" data-section="modifiers">
                <i class="fa-solid fa-plus"></i> Add Modifiers
              </button>
              {{else}}
              <p class="wh40k-hint">This talent provides benefits through its special abilities or rules text.</p>
              {{/if}}
            </div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Situational Modifiers --}}
        <div class="wh40k-section wh40k-section--effects" data-section-id="situational" data-has-data="{{situationalData.hasAny}}" style="order: {{#each effectsSectionOrder}}{{#if (eq this "situational")}}{{@index}}{{/if}}{{/each}}">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-clock-rotate-left"></i>
            Situational Modifiers
            {{#if inEditMode}}
            <button type="button" class="wh40k-header-btn" data-action="openTalentEditor" data-section="situational" title="Edit Situational Modifiers">
              <i class="fa-solid fa-pen-to-square"></i>
            </button>
            {{/if}}
          </h3>
          <div class="wh40k-section-body">
            {{#if situationalData.hasAny}}
            <p class="wh40k-hint-text">
              <i class="fa-solid fa-info-circle"></i>
              These modifiers appear as optional checkboxes in roll dialogs when conditions apply.
            </p>
            <div class="wh40k-situational-list">
              {{#each situationalData.characteristics}}
              <div class="wh40k-situational-item">
                <div class="wh40k-situational-header">
                  <i class="{{this.icon}}"></i>
                  <span class="wh40k-situational-stat">{{this.label}}</span>
                  <span class="wh40k-situational-value {{#if this.positive}}positive{{else}}negative{{/if}}">
                    {{#if this.positive}}+{{/if}}{{this.value}}
                  </span>
                </div>
                <p class="wh40k-situational-condition">{{this.condition}}</p>
              </div>
              {{/each}}
              {{#each situationalData.skills}}
              <div class="wh40k-situational-item">
                <div class="wh40k-situational-header">
                  <i class="{{this.icon}}"></i>
                  <span class="wh40k-situational-stat">{{this.label}}</span>
                  <span class="wh40k-situational-value {{#if this.positive}}positive{{else}}negative{{/if}}">
                    {{#if this.positive}}+{{/if}}{{this.value}}
                  </span>
                </div>
                <p class="wh40k-situational-condition">{{this.condition}}</p>
              </div>
              {{/each}}
              {{#each situationalData.combat}}
              <div class="wh40k-situational-item">
                <div class="wh40k-situational-header">
                  <i class="{{this.icon}}"></i>
                  <span class="wh40k-situational-stat">{{this.label}}</span>
                  <span class="wh40k-situational-value {{#if this.positive}}positive{{else}}negative{{/if}}">
                    {{#if this.positive}}+{{/if}}{{this.value}}
                  </span>
                </div>
                <p class="wh40k-situational-condition">{{this.condition}}</p>
              </div>
              {{/each}}
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--compact">
              <i class="fa-solid fa-clock-rotate-left"></i>
              <p>No situational modifiers</p>
              {{#if inEditMode}}
              <button type="button" class="wh40k-btn-add-data" data-action="openTalentEditor" data-section="situational">
                <i class="fa-solid fa-plus"></i> Add Situational Modifiers
              </button>
              {{else}}
              <p class="wh40k-hint">This talent applies consistent bonuses without situational conditions.</p>
              {{/if}}
            </div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Grants Section --}}
        <div class="wh40k-section wh40k-section--effects" data-section-id="grants" data-has-data="{{grantsData.hasAny}}" style="order: {{#each effectsSectionOrder}}{{#if (eq this "grants")}}{{@index}}{{/if}}{{/each}}">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-gift"></i>
            Grants
            {{#if inEditMode}}
            <button type="button" class="wh40k-header-btn" data-action="openTalentEditor" data-section="grants" title="Edit Grants">
              <i class="fa-solid fa-pen-to-square"></i>
            </button>
            {{/if}}
          </h3>
          <div class="wh40k-section-body">
            {{#if grantsData.hasAny}}
            <p class="wh40k-hint-text">
              <i class="fa-solid fa-info-circle"></i>
              These skills, talents, and traits are automatically granted when this talent is acquired.
            </p>
            <div class="wh40k-grants-grid">
              {{!-- Skills Granted --}}
              {{#if grantsData.hasSkills}}
              <div class="wh40k-grants-category">
                <h4 class="wh40k-grants-category-header">
                  <i class="fa-solid fa-graduation-cap"></i>
                  Skills
                </h4>
                <div class="wh40k-grants-items">
                  {{#each grantsData.skills}}
                  <div class="wh40k-grant-tag wh40k-grant-tag--skill">
                    <span class="wh40k-grant-name">{{this.displayName}}</span>
                    <span class="wh40k-grant-level wh40k-grant-level--{{this.level}}">{{this.levelLabel}}</span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}
              
              {{!-- Talents Granted --}}
              {{#if grantsData.hasTalents}}
              <div class="wh40k-grants-category">
                <h4 class="wh40k-grants-category-header">
                  <i class="fa-solid fa-star"></i>
                  Talents
                </h4>
                <div class="wh40k-grants-items">
                  {{#each grantsData.talents}}
                  <div class="wh40k-grant-tag wh40k-grant-tag--talent {{#if this.hasLink}}wh40k-grant-tag--clickable{{/if}}"
                       {{#if this.hasLink}}data-action="viewGrantedItem" data-uuid="{{this.uuid}}"{{/if}}>
                    <span class="wh40k-grant-name">{{this.name}}</span>
                    {{#if this.specialization}}
                    <span class="wh40k-grant-spec">({{this.specialization}})</span>
                    {{/if}}
                    {{#if this.hasLink}}
                    <i class="fa-solid fa-external-link wh40k-grant-link"></i>
                    {{/if}}
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}
              
              {{!-- Traits Granted --}}
              {{#if grantsData.hasTraits}}
              <div class="wh40k-grants-category">
                <h4 class="wh40k-grants-category-header">
                  <i class="fa-solid fa-dna"></i>
                  Traits
                </h4>
                <div class="wh40k-grants-items">
                  {{#each grantsData.traits}}
                  <div class="wh40k-grant-tag wh40k-grant-tag--trait {{#if this.hasLink}}wh40k-grant-tag--clickable{{/if}}"
                       {{#if this.hasLink}}data-action="viewGrantedItem" data-uuid="{{this.uuid}}"{{/if}}>
                    <span class="wh40k-grant-name">{{this.name}}</span>
                    {{#if this.level}}
                    <span class="wh40k-grant-level">({{this.level}})</span>
                    {{/if}}
                    {{#if this.hasLink}}
                    <i class="fa-solid fa-external-link wh40k-grant-link"></i>
                    {{/if}}
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--compact">
              <i class="fa-solid fa-gift"></i>
              <p>No grants defined</p>
              {{#if inEditMode}}
              <button type="button" class="wh40k-btn-add-data" data-action="openTalentEditor" data-section="grants">
                <i class="fa-solid fa-plus"></i> Add Grants
              </button>
              {{else}}
              <p class="wh40k-hint">This talent does not automatically grant additional skills, talents, or traits.</p>
              {{/if}}
            </div>
            {{/if}}
          </div>
        </div>
        
      </div>
      
      {{!-- ─────────────────────────────────────────────────────────────────
           DESCRIPTION TAB: Benefit, notes, technical
      ───────────────────────────────────────────────────────────────── --}}
      <div class="wh40k-talent-panel {{#if (eq activeTab "description")}}active{{/if}}" data-tab="description" data-group="primary">
        
        {{!-- Benefit (Editable with hover button) --}}
        <div class="wh40k-section wh40k-section--editable {{#if inEditMode}}wh40k-section--editing{{/if}}">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-star"></i>
            Benefit
            {{#if canEdit}}
            {{#unless inEditMode}}
            <button type="button" class="wh40k-header-btn wh40k-header-btn--hover" data-action="toggleEditMode" title="Edit Benefit">
              <i class="fa-solid fa-pen-to-square"></i>
            </button>
            {{else}}
            <button type="button" class="wh40k-header-btn wh40k-header-btn--done" data-action="toggleEditMode" title="Done Editing">
              <i class="fa-solid fa-check"></i>
            </button>
            {{/unless}}
            {{/if}}
          </h3>
          <div class="wh40k-section-body">
            {{#if inEditMode}}
            <div class="wh40k-editor-container">
              {{editor system.benefit target="system.benefit" button=true editable=canEdit engine="prosemirror"}}
            </div>
            {{else}}
              {{#if talentData.hasBenefit}}
              <div class="wh40k-description-content">
                {{{talentData.benefit}}}
              </div>
              {{else}}
              <div class="wh40k-empty-state wh40k-empty-state--compact wh40k-empty-state--clickable" data-action="toggleEditMode">
                <i class="fa-solid fa-file-lines"></i>
                <p>Click to add benefit description</p>
              </div>
              {{/if}}
            {{/if}}
          </div>
        </div>
        
        {{!-- Notes --}}
        <div class="wh40k-section">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-sticky-note"></i>
            Notes
          </h3>
          <div class="wh40k-section-body">
            {{#if inEditMode}}
            <textarea name="system.notes" rows="4" class="wh40k-property-textarea" 
                      placeholder="GM notes, house rules, clarifications...">{{talentData.notes}}</textarea>
            {{else if talentData.notes}}
            <div class="wh40k-notes-content">
              {{talentData.notes}}
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--compact">
              <i class="fa-solid fa-sticky-note"></i>
              <p>No notes</p>
            </div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Identifier (for developers) --}}
        {{#if inEditMode}}
        <div class="wh40k-section">
          <h3 class="wh40k-section-header">
            <i class="fa-solid fa-code"></i>
            Technical
          </h3>
          <div class="wh40k-section-body">
            <div class="wh40k-property">
              <label class="wh40k-property-label">Identifier <span class="wh40k-hint">(for macros/scripts)</span></label>
              <input type="text" name="system.identifier" value="{{talentData.identifier}}" 
                     class="wh40k-property-input wh40k-property-input--mono" placeholder="camelCaseIdentifier" />
            </div>
          </div>
        </div>
        {{/if}}
        
      </div>
      
    </section>{{!-- .wh40k-talent-content --}}
    
    {{!-- ═══════════════════════════════════════════════════════════════════
         FOOTER: Source Reference
    ═══════════════════════════════════════════════════════════════════ --}}
    <footer class="wh40k-talent-footer">
      {{#if inEditMode}}
      <div class="wh40k-footer-edit">
        <div class="wh40k-footer-field">
          <label class="wh40k-footer-label">
            <i class="fa-solid fa-book"></i>
            Book
          </label>
          <input type="text" name="system.source.book" value="{{talentData.sourceBook}}" 
                 class="wh40k-footer-input" placeholder="Core Rulebook" />
        </div>
        <div class="wh40k-footer-field wh40k-footer-field--page">
          <label class="wh40k-footer-label">
            <i class="fa-solid fa-bookmark"></i>
            Page
          </label>
          <input type="text" name="system.source.page" value="{{talentData.sourcePage}}" 
                 class="wh40k-footer-input" placeholder="123" />
        </div>
      </div>
      {{else}}
      <div class="wh40k-footer-display">
        <i class="fa-solid fa-book-open"></i>
        {{#if talentData.source}}
        <span class="wh40k-footer-source">{{talentData.source}}</span>
        {{else}}
        <span class="wh40k-footer-source wh40k-footer-source--empty">No source specified</span>
        {{/if}}
      </div>
      {{/if}}
    </footer>

</div>{{!-- .wh40k-talent-sheet-v2 --}}
