{{!--
    Horizontal button-style tab navigation for item sheets.

    Hash params:
        tabs    — array of { tab, label, icon (FA class), active? }
--}}
<nav class="tw-flex tw-border-b-2 tw-border-[var(--wh40k-border-color)] tw-bg-[var(--wh40k-panel-bg-translucent)] tw-flex-shrink-0" data-group="primary">
    {{#each tabs}}
    <button type="button" class="wh40k-item-tab {{#if active}}active {{/if}}tw-px-[var(--wh40k-space-lg)] tw-py-[var(--wh40k-space-sm)] tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-sm)] tw-uppercase tw-tracking-[0.1em] tw-text-[color:var(--wh40k-text-muted)] tw-bg-transparent tw-border-0 tw-border-b-2 tw-border-transparent tw-mb-[-2px] tw-cursor-pointer tw-no-underline hover:tw-text-[color:var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="{{tab}}" data-group="primary">
        <i class="fas {{icon}} tw-mr-[var(--wh40k-space-xs)]"></i>
        <span>{{label}}</span>
    </button>
    {{/each}}
</nav>
