{{!-- 
  Rogue Trader Armour Item Sheet - V2 Complete Redesign
  Matches weapon sheet pattern with modern ApplicationV2 structure
--}}
<div class="wh40k-armour-sheet">
    
    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: Compact armour identity with inline stats
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="wh40k-armour-header">
      <div class="wh40k-armour-header__image" data-action="editImage">
        <img src="{{item.img}}" alt="{{item.name}}" />
        <div class="wh40k-armour-header__image-overlay">
          <i class="fas fa-edit"></i>
        </div>
      </div>
      
      <div class="wh40k-armour-header__info">
        <input type="text" class="wh40k-armour-header__name" name="name" value="{{item.name}}" placeholder="Armour Name" />
        
        <div class="wh40k-armour-header__meta">
          <span class="wh40k-armour-badge wh40k-armour-badge--type wh40k-armour-badge--{{item.system.type}}" title="Armour Type">
            <i class="fas {{item.system.typeIcon}}"></i>
            {{item.system.typeLabel}}
          </span>
          <span class="wh40k-armour-badge wh40k-armour-badge--protection wh40k-armour-badge--{{item.system.protectionLevel}}" title="Maximum Armour Points">
            AP {{item.system.maxAP}}
          </span>
          {{#if (ne item.system.craftsmanship "common")}}
          <span class="wh40k-armour-badge wh40k-armour-badge--craft wh40k-armour-badge--{{item.system.craftsmanship}}" title="Craftsmanship">
            <i class="fas fa-hammer"></i>
            {{item.system.craftsmanshipLabel}}
          </span>
          {{/if}}
          {{#if item.system.maxAgility}}
          <span class="wh40k-armour-badge wh40k-armour-badge--agility" title="Maximum Agility Bonus">
            <i class="fas fa-person-running"></i>
            Max Ag {{item.system.maxAgility}}
          </span>
          {{/if}}
        </div>
      </div>
      
      <div class="wh40k-armour-header__actions">
        {{!-- Edit Mode Toggle (only for actor-owned items) --}}
        {{#if isOwnedByActor}}
        {{#if canEdit}}
        <button type="button" class="wh40k-action-btn wh40k-action-btn--edit {{#if inEditMode}}active{{/if}}" 
                data-action="toggleEditMode" title="{{#if inEditMode}}Exit Edit Mode{{else}}Enter Edit Mode{{/if}}">
          <i class="fas {{#if inEditMode}}fa-lock-open{{else}}fa-pen-to-square{{/if}}"></i>
        </button>
        {{/if}}
        {{/if}}
        
        {{!-- Equipped Toggle --}}
        <label class="wh40k-toggle-equipped" title="Toggle Equipped">
          <input type="checkbox" name="system.equipped" {{checked item.system.equipped}} />
          <span class="wh40k-toggle-equipped__indicator">
            <i class="fas {{#if item.system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
          </span>
          <span class="wh40k-toggle-equipped__label">{{#if item.system.equipped}}Worn{{else}}Stowed{{/if}}</span>
        </label>
      </div>
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         STATS BAR: Primary armour stats at a glance (simplified)
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-armour-stats">
      {{!-- Weight --}}
      <div class="wh40k-armour-stat wh40k-armour-stat--weight">
        <div class="wh40k-armour-stat__icon">
          <i class="fas fa-weight-hanging"></i>
        </div>
        <div class="wh40k-armour-stat__content">
          <span class="wh40k-armour-stat__label">Weight</span>
          <span class="wh40k-armour-stat__value">{{system.weight}}kg</span>
        </div>
      </div>
      
      {{!-- Max Agility (if limited) --}}
      {{#if system.maxAgility}}
      <div class="wh40k-armour-stat wh40k-armour-stat--agility">
        <div class="wh40k-armour-stat__icon">
          <i class="fas fa-person-running"></i>
        </div>
        <div class="wh40k-armour-stat__content">
          <span class="wh40k-armour-stat__label">Max Ag</span>
          <span class="wh40k-armour-stat__value">{{system.maxAgility}}</span>
        </div>
      </div>
      {{/if}}
      
      {{!-- Head AP --}}
      <div class="wh40k-armour-stat wh40k-armour-stat--location">
        <div class="wh40k-armour-stat__icon">
          <i class="fas fa-head-side-brain"></i>
        </div>
        <div class="wh40k-armour-stat__content">
          <span class="wh40k-armour-stat__label">Head</span>
          <span class="wh40k-armour-stat__value">{{system.armourPoints.head}}</span>
        </div>
      </div>
      
      {{!-- Body AP --}}
      <div class="wh40k-armour-stat wh40k-armour-stat--location">
        <div class="wh40k-armour-stat__icon">
          <i class="fas fa-shield"></i>
        </div>
        <div class="wh40k-armour-stat__content">
          <span class="wh40k-armour-stat__label">Body</span>
          <span class="wh40k-armour-stat__value">{{system.armourPoints.body}}</span>
        </div>
      </div>
      
      {{!-- Arms AP (average) --}}
      <div class="wh40k-armour-stat wh40k-armour-stat--location">
        <div class="wh40k-armour-stat__icon">
          <i class="fas fa-hand-fist"></i>
        </div>
        <div class="wh40k-armour-stat__content">
          <span class="wh40k-armour-stat__label">Arms</span>
          <span class="wh40k-armour-stat__value">{{system.armourPoints.leftArm}}/{{system.armourPoints.rightArm}}</span>
        </div>
      </div>
      
      {{!-- Legs AP (average) --}}
      <div class="wh40k-armour-stat wh40k-armour-stat--location">
        <div class="wh40k-armour-stat__icon">
          <i class="fas fa-boot"></i>
        </div>
        <div class="wh40k-armour-stat__content">
          <span class="wh40k-armour-stat__label">Legs</span>
          <span class="wh40k-armour-stat__value">{{system.armourPoints.leftLeg}}/{{system.armourPoints.rightLeg}}</span>
        </div>
      </div>
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ --}}
    <nav class="wh40k-tabs wh40k-tabs--armour wh40k-armour-tabs" data-group="primary">
      <button type="button" class="wh40k-tab wh40k-armour-tab active" data-tab="protection" data-group="primary">
        <i class="fas fa-shield-halved"></i>
        <span>Protection</span>
      </button>
      <button type="button" class="wh40k-tab wh40k-armour-tab" data-tab="mods" data-group="primary">
        <i class="fas fa-wrench"></i>
        <span>Mods</span>
      </button>
      <button type="button" class="wh40k-tab wh40k-armour-tab" data-tab="description" data-group="primary">
        <i class="fas fa-book"></i>
        <span>Description</span>
      </button>
      <button type="button" class="wh40k-tab wh40k-armour-tab" data-tab="effects" data-group="primary">
        <i class="fas fa-magic"></i>
        <span>Effects</span>
      </button>
    </nav>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-armour-content wh40k-tab-content wh40k-tab-content--armour scrollable">
      
      {{!-- PROTECTION TAB --}}
      <div class="wh40k-armour-panel tab active" data-tab="protection" data-group="primary">
        
        {{!-- Armour Points Grid (only in edit mode) --}}
        {{#if inEditMode}}
        <div class="wh40k-armour-section">
          <div class="wh40k-armour-section__header">
            <i class="fas fa-shield-halved"></i>
            <h3>Armour Points by Location</h3>
          </div>
          <div class="wh40k-armour-section__body">
            <div class="wh40k-armour-ap-grid">
              <div class="wh40k-armour-ap-field">
                <label><i class="fas fa-head-side-brain"></i> Head</label>
                <input type="number" name="system.armourPoints.head" value="{{item.system.armourPoints.head}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="wh40k-armour-ap-field">
                <label><i class="fas fa-shield"></i> Body</label>
                <input type="number" name="system.armourPoints.body" value="{{item.system.armourPoints.body}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="wh40k-armour-ap-field">
                <label><i class="fas fa-hand-fist"></i> L. Arm</label>
                <input type="number" name="system.armourPoints.leftArm" value="{{item.system.armourPoints.leftArm}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="wh40k-armour-ap-field">
                <label><i class="fas fa-hand-fist"></i> R. Arm</label>
                <input type="number" name="system.armourPoints.rightArm" value="{{item.system.armourPoints.rightArm}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="wh40k-armour-ap-field">
                <label><i class="fas fa-boot"></i> L. Leg</label>
                <input type="number" name="system.armourPoints.leftLeg" value="{{item.system.armourPoints.leftLeg}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="wh40k-armour-ap-field">
                <label><i class="fas fa-boot"></i> R. Leg</label>
                <input type="number" name="system.armourPoints.rightLeg" value="{{item.system.armourPoints.rightLeg}}" 
                       data-dtype="Number" min="0" />
              </div>
            </div>
          </div>
        </div>
        {{/if}}

        {{!-- Base Properties --}}
        <div class="wh40k-armour-section">
          <div class="wh40k-armour-section__header">
            <i class="fas fa-cog"></i>
            <h3>Base Properties</h3>
          </div>
          <div class="wh40k-armour-section__body">
            <div class="wh40k-field-grid wh40k-field-grid--2col">
              <div class="wh40k-field">
                <label>Armour Type</label>
                <select name="system.type" class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}" {{#unless inEditMode}}disabled{{/unless}}>
                  <option value="flak" {{#if (eq item.system.type "flak")}}selected{{/if}}>Flak</option>
                  <option value="mesh" {{#if (eq item.system.type "mesh")}}selected{{/if}}>Mesh</option>
                  <option value="carapace" {{#if (eq item.system.type "carapace")}}selected{{/if}}>Carapace</option>
                  <option value="power" {{#if (eq item.system.type "power")}}selected{{/if}}>Power Armour</option>
                  <option value="light-power" {{#if (eq item.system.type "light-power")}}selected{{/if}}>Light Power</option>
                  <option value="storm-trooper" {{#if (eq item.system.type "storm-trooper")}}selected{{/if}}>Storm Trooper</option>
                  <option value="feudal-world" {{#if (eq item.system.type "feudal-world")}}selected{{/if}}>Feudal World</option>
                  <option value="primitive" {{#if (eq item.system.type "primitive")}}selected{{/if}}>Primitive</option>
                  <option value="xenos" {{#if (eq item.system.type "xenos")}}selected{{/if}}>Xenos</option>
                  <option value="void" {{#if (eq item.system.type "void")}}selected{{/if}}>Void Suit</option>
                  <option value="enforcer" {{#if (eq item.system.type "enforcer")}}selected{{/if}}>Enforcer</option>
                  <option value="hostile-environment" {{#if (eq item.system.type "hostile-environment")}}selected{{/if}}>Hostile Environment</option>
                </select>
              </div>
              <div class="wh40k-field">
                <label>Max Agility Bonus</label>
                <input type="number" name="system.maxAgility" value="{{item.system.maxAgility}}" 
                       data-dtype="Number" min="0" placeholder="No limit"
                       class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                       {{#unless inEditMode}}readonly{{/unless}} />
              </div>
              <div class="wh40k-field">
                <label>Availability</label>
                <select name="system.availability" class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}" {{#unless inEditMode}}disabled{{/unless}}>
                  <option value="ubiquitous" {{#if (eq item.system.availability "ubiquitous")}}selected{{/if}}>Ubiquitous</option>
                  <option value="abundant" {{#if (eq item.system.availability "abundant")}}selected{{/if}}>Abundant</option>
                  <option value="plentiful" {{#if (eq item.system.availability "plentiful")}}selected{{/if}}>Plentiful</option>
                  <option value="common" {{#if (eq item.system.availability "common")}}selected{{/if}}>Common</option>
                  <option value="average" {{#if (eq item.system.availability "average")}}selected{{/if}}>Average</option>
                  <option value="scarce" {{#if (eq item.system.availability "scarce")}}selected{{/if}}>Scarce</option>
                  <option value="rare" {{#if (eq item.system.availability "rare")}}selected{{/if}}>Rare</option>
                  <option value="very-rare" {{#if (eq item.system.availability "very-rare")}}selected{{/if}}>Very Rare</option>
                  <option value="extremely-rare" {{#if (eq item.system.availability "extremely-rare")}}selected{{/if}}>Extremely Rare</option>
                  <option value="near-unique" {{#if (eq item.system.availability "near-unique")}}selected{{/if}}>Near Unique</option>
                  <option value="unique" {{#if (eq item.system.availability "unique")}}selected{{/if}}>Unique</option>
                </select>
              </div>
              <div class="wh40k-field">
                <label>Craftsmanship</label>
                <select name="system.craftsmanship" class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}" {{#unless inEditMode}}disabled{{/unless}}>
                  <option value="poor" {{#if (eq item.system.craftsmanship "poor")}}selected{{/if}}>Poor</option>
                  <option value="common" {{#if (eq item.system.craftsmanship "common")}}selected{{/if}}>Common</option>
                  <option value="good" {{#if (eq item.system.craftsmanship "good")}}selected{{/if}}>Good</option>
                  <option value="best" {{#if (eq item.system.craftsmanship "best")}}selected{{/if}}>Best</option>
                </select>
              </div>
              <div class="wh40k-field">
                <label>Weight (kg)</label>
                <input type="number" name="system.weight" value="{{item.system.weight}}" 
                       data-dtype="Number" min="0" step="0.1"
                       class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                       {{#unless inEditMode}}readonly{{/unless}} />
              </div>
              {{#unless hideThroneGelt}}
              <div class="wh40k-field">
                <label>Cost (Thrones)</label>
                <input type="number" name="system.cost.dh2.homebrew.throneGelt" value="{{item.system.cost.dh2.homebrew.throneGelt}}"
                       data-dtype="Number" min="0"
                       class="{{#unless inEditMode}}wh40k-input--readonly{{/unless}}"
                       {{#unless inEditMode}}readonly{{/unless}} />
              </div>
              {{/unless}}
            </div>
          </div>
        </div>

        {{!-- Special Properties (consolidated from Properties tab) --}}
        <div class="wh40k-armour-section">
          <div class="wh40k-armour-section__header">
            <i class="fas fa-star"></i>
            <h3>Special Properties</h3>
            {{#if propertiesArray.length}}
            <span class="wh40k-armour-section__count">{{propertiesArray.length}}</span>
            {{/if}}
          </div>
          <div class="wh40k-armour-section__body">
            {{#if propertiesArray.length}}
            <div class="wh40k-property-tags">
              {{#each propertiesArray as |prop|}}
              <div class="wh40k-property-tag">
                <span class="wh40k-property-tag__label">{{prop.label}}</span>
                {{#if ../inEditMode}}
                <button type="button" class="wh40k-property-tag__remove" 
                        data-action="removeProperty" data-property="{{prop.id}}"
                        title="Remove property">
                  <i class="fas fa-times"></i>
                </button>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{!-- Property descriptions (inline) --}}
            <div class="wh40k-property-descriptions">
              {{#each propertiesArray as |prop|}}
              {{#if prop.description}}
              <div class="wh40k-property-detail">
                <div class="wh40k-property-detail__name">{{prop.label}}</div>
                <div class="wh40k-property-detail__desc">{{prop.description}}</div>
              </div>
              {{/if}}
              {{/each}}
            </div>
            {{else}}
            <p class="wh40k-empty-text">No special properties</p>
            {{/if}}
            
            {{!-- Add property control (only in edit mode) --}}
            {{#if inEditMode}}
            {{#if availableProperties}}
            <div class="wh40k-property-add">
              <select class="wh40k-property-add__select" name="new-property">
                <option value="">-- Add Property --</option>
                {{#each availableProperties as |prop key|}}
                <option value="{{key}}">{{prop.label}}</option>
                {{/each}}
              </select>
              <button type="button" class="wh40k-btn wh40k-btn--primary" data-action="addProperty">
                <i class="fas fa-plus"></i>
                Add
              </button>
            </div>
            {{/if}}
            {{/if}}
          </div>
        </div>

      </div>

      {{!-- MODIFICATIONS TAB --}}
      <div class="wh40k-armour-panel tab" data-tab="mods" data-group="primary">
        
        <div class="wh40k-armour-section">
          <div class="wh40k-armour-section__header">
            <i class="fas fa-wrench"></i>
            <h3>Modification Slots</h3>
            <span class="wh40k-armour-section__count">
              {{modificationsArray.length}} / {{system.modificationSlots}}
            </span>
          </div>
          <div class="wh40k-armour-section__body">
            <div class="wh40k-mod-slots">
              <label>Total Slots:</label>
              <input type="number" name="system.modificationSlots" value="{{source.modificationSlots}}" 
                     data-dtype="Number" min="0" max="10" />
              <span class="wh40k-mod-slots__available">
                {{system.availableModSlots}} available
              </span>
            </div>
            
            {{#if modificationsArray.length}}
            <div class="wh40k-mod-list">
              {{#each modificationsArray as |mod idx|}}
              <div class="wh40k-mod-item">
                <div class="wh40k-mod-item__info">
                  <i class="fas fa-wrench"></i>
                  <span class="wh40k-mod-item__name">{{mod.name}}</span>
                </div>
                <div class="wh40k-mod-item__actions">
                  <button type="button" class="wh40k-btn wh40k-btn--secondary wh40k-btn--icon"
                          data-action="editMod" data-mod-index="{{idx}}"
                          title="Edit Modification">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button type="button" class="wh40k-btn wh40k-btn--secondary wh40k-btn--icon wh40k-btn--danger"
                          data-action="removeMod" data-mod-index="{{idx}}"
                          title="Remove Modification">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              </div>
              {{/each}}
            </div>
            {{else}}
            <div class="wh40k-empty-state wh40k-empty-state--mods">
              <i class="fas fa-wrench"></i>
              <span>No Modifications Installed</span>
              <p>Drag armour modification items here to install them.</p>
            </div>
            {{/if}}
            
            <button type="button" class="wh40k-btn wh40k-btn--primary wh40k-btn--full" data-action="addModification">
              <i class="fas fa-plus"></i>
              Add Modification
            </button>
          </div>
        </div>

      </div>

      {{!-- DESCRIPTION TAB --}}
      <div class="wh40k-armour-panel tab" data-tab="description" data-group="primary">
        
        {{!-- Effect --}}
        <div class="wh40k-armour-section">
          <div class="wh40k-armour-section__header">
            <i class="fas fa-bolt"></i>
            <h3>Effect</h3>
          </div>
          <div class="wh40k-armour-section__body wh40k-armour-section__body--editor">
            {{#if inEditMode}}
            {{editor system.effect target="system.effect" button=true editable=editable engine="prosemirror"}}
            {{else}}
            <div class="wh40k-description-content">{{{system.effect}}}</div>
            {{/if}}
          </div>
        </div>

        {{!-- Description --}}
        <div class="wh40k-armour-section">
          <div class="wh40k-armour-section__header">
            <i class="fas fa-book"></i>
            <h3>Description</h3>
          </div>
          <div class="wh40k-armour-section__body wh40k-armour-section__body--editor">
            {{#if inEditMode}}
            {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
            {{else}}
            <div class="wh40k-description-content">{{{system.description.value}}}</div>
            {{/if}}
          </div>
        </div>

        {{!-- Notes --}}
        <div class="wh40k-armour-section">
          <div class="wh40k-armour-section__header">
            <i class="fas fa-sticky-note"></i>
            <h3>Notes</h3>
          </div>
          <div class="wh40k-armour-section__body">
            <textarea name="system.notes" rows="4" placeholder="GM notes, acquisition details, etc.">{{item.system.notes}}</textarea>
          </div>
        </div>

        {{!-- Source --}}
        <div class="wh40k-armour-section">
          <div class="wh40k-armour-section__header">
            <i class="fas fa-book-open"></i>
            <h3>Source</h3>
          </div>
          <div class="wh40k-armour-section__body">
            <input type="text" name="system.source" value="{{item.system.source}}" 
                   placeholder="Rogue Trader Core Rulebook, pg. 123" />
          </div>
        </div>

      </div>

      {{!-- EFFECTS TAB --}}
      <div class="wh40k-armour-panel tab" data-tab="effects" data-group="primary">
        {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
      </div>

    </div>


</div>
