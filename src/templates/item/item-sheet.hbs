{{!-- Generic item-sheet fallback.
     Used by any item type that does not register its own template.
     Composed from the shared item partials so the chrome matches the
     dedicated sheets without copy-paste. --}}
<div class="wh40k-item-sheet wh40k-{{item.type}}-sheet tw-flex tw-flex-col tw-h-full tw-overflow-hidden tw-bg-[var(--wh40k-sheet-bg)] tw-text-[var(--wh40k-text-dark)]">
    <form autocomplete="off" class="tw-flex tw-flex-col tw-flex-1 tw-min-h-0">

        {{> systems/wh40k-rpg/templates/item/panel/item-header.hbs}}

        {{> systems/wh40k-rpg/templates/item/partial/item-tab-strip.hbs tabs=(array
            (object tab="description" label=(localize "WH40K.Description") icon="fa-scroll" active=true)
            (object tab="effects"     label=(localize "WH40K.Effects.Label") icon="fa-magic"))}}

        <section class="wh40k-tab-content tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-[var(--wh40k-space-md)]">
            <div class="tab active" data-tab="description" data-group="primary">
                {{> systems/wh40k-rpg/templates/item/panel/description-panel.hbs}}
            </div>

            <div class="tab" data-tab="effects" data-group="primary">
                {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
            </div>
        </section>
    </form>
</div>
