{{!-- Active Effects Panel
     List and manage active effects attached to this item
--}}
<div class="wh40k-effects-panel">
  <header class="wh40k-panel-header">
    <i class="fas fa-magic"></i>
    <span>{{localize "WH40K.Effects.Label"}}</span>
    {{#unless item.isEmbedded}}
    <button type="button" 
            class="wh40k-btn-icon wh40k-btn-add" 
            data-action="createEffect" 
            title="{{localize 'WH40K.Effects.Create'}}">
      <i class="fas fa-plus"></i>
    </button>
    {{/unless}}
  </header>

  <div class="wh40k-panel-body">
    {{#if effects.length}}
    <div class="wh40k-effects-list tw-flex tw-flex-col tw-gap-2 tw-mb-3">
      {{#each effects as |effect|}}
      <div class="wh40k-effect-item {{#if effect.disabled}}wh40k-effect-item--disabled{{/if}}">
        <div class="wh40k-effect-item__icon">
          <i class="fas {{#if effect.disabled}}fa-circle-xmark{{else}}fa-circle-check{{/if}}"></i>
        </div>
        
        <div class="wh40k-effect-item__info">
          <span class="wh40k-effect-item__name">{{effect.label}}</span>
          {{#if effect.duration}}
          <span class="wh40k-effect-item__duration">
            <i class="fas fa-clock"></i>
            {{effect.duration.label}}
          </span>
          {{/if}}
        </div>
        
        {{#unless @root.item.isEmbedded}}
        <div class="wh40k-effect-item__controls">
          <button type="button" 
                  class="wh40k-btn-icon" 
                  data-action="editEffect" 
                  data-effect-id="{{effect.id}}" 
                  title="{{localize 'WH40K.Effects.Edit'}}">
            <i class="fas fa-edit"></i>
          </button>
          
          {{#if effect.disabled}}
          <button type="button" 
                  class="wh40k-btn-icon" 
                  data-action="enableEffect" 
                  data-effect-id="{{effect.id}}" 
                  title="{{localize 'WH40K.Effects.Enable'}}">
            <i class="fas fa-toggle-off"></i>
          </button>
          {{else}}
          <button type="button" 
                  class="wh40k-btn-icon" 
                  data-action="disableEffect" 
                  data-effect-id="{{effect.id}}" 
                  title="{{localize 'WH40K.Effects.Disable'}}">
            <i class="fas fa-toggle-on"></i>
          </button>
          {{/if}}
          
          <button type="button" 
                  class="wh40k-btn-icon wh40k-btn-icon--danger" 
                  data-action="deleteEffect" 
                  data-effect-id="{{effect.id}}" 
                  title="{{localize 'WH40K.Effects.Delete'}}">
            <i class="fas fa-trash"></i>
          </button>
        </div>
        {{/unless}}
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="wh40k-empty-state tw-flex tw-flex-col tw-items-center tw-justify-center tw-text-center">
      <i class="fas fa-magic"></i>
      <p>{{localize "WH40K.Effects.None"}}</p>
      {{#unless item.isEmbedded}}
      <button type="button" 
              class="wh40k-btn-secondary" 
              data-action="createEffect">
        <i class="fas fa-plus"></i>
        {{localize "WH40K.Effects.CreateFirst"}}
      </button>
      {{/unless}}
    </div>
    {{/if}}
  </div>
</div>
