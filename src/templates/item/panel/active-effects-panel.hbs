{{!-- Active Effects Panel
     List and manage active effects attached to this item
--}}
<div class="tw-flex tw-flex-col">
  <header class="tw-flex tw-flex-row tw-items-center tw-gap-1.5 tw-px-3 tw-py-1.5 tw-bg-gradient-to-b tw-from-gold/15 tw-to-gold/5 tw-border-b tw-border-solid tw-border-black/10 tw-font-heading tw-font-bold tw-text-gold tw-uppercase tw-tracking-wide tw-w-full tw-box-border">
    <i class="fas fa-magic"></i>
    <span>{{localize "WH40K.Effects.Label"}}</span>
    {{#unless item.isEmbedded}}
    <button type="button"
            class="tw-ml-auto tw-w-[22px] tw-h-[22px] tw-bg-transparent tw-border-none tw-text-success tw-rounded-sm tw-cursor-pointer hover:tw-bg-success/10 hover:tw-text-success tw-shrink-0"
            data-action="createEffect"
            title="{{localize 'WH40K.Effects.Create'}}">
      <i class="fas fa-plus"></i>
    </button>
    {{/unless}}
  </header>

  <div class="tw-p-3">
    {{#if effects.length}}
    <div class="tw-flex tw-flex-col tw-gap-2 tw-mb-3">
      {{#each effects as |effect|}}
      <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-1.5 tw-bg-black/5 tw-border tw-border-solid tw-border-black/10 tw-rounded-sm {{#if effect.disabled}}tw-opacity-50{{/if}}">
        <div class="tw-shrink-0 tw-w-5 tw-h-5 tw-flex tw-items-center tw-justify-center">
          <i class="fas {{#if effect.disabled}}fa-circle-xmark{{else}}fa-circle-check{{/if}}"></i>
        </div>

        <div class="tw-flex-1 tw-flex tw-flex-col tw-min-w-0">
          <span class="tw-font-semibold tw-text-sm tw-truncate">{{effect.label}}</span>
          {{#if effect.duration}}
          <span class="tw-text-xs tw-text-gray-500 tw-flex tw-items-center tw-gap-1">
            <i class="fas fa-clock"></i>
            {{effect.duration.label}}
          </span>
          {{/if}}
        </div>

        {{#unless @root.item.isEmbedded}}
        <div class="tw-flex tw-items-center tw-gap-1 tw-shrink-0">
          <button type="button"
                  class="tw-w-[22px] tw-h-[22px] tw-bg-transparent tw-border-none tw-text-gray-500 tw-rounded-sm tw-cursor-pointer hover:tw-bg-black/5 hover:tw-text-gray-800"
                  data-action="editEffect"
                  data-effect-id="{{effect.id}}"
                  title="{{localize 'WH40K.Effects.Edit'}}">
            <i class="fas fa-edit"></i>
          </button>

          {{#if effect.disabled}}
          <button type="button"
                  class="tw-w-[22px] tw-h-[22px] tw-bg-transparent tw-border-none tw-text-gray-500 tw-rounded-sm tw-cursor-pointer hover:tw-bg-black/5 hover:tw-text-gray-800"
                  data-action="enableEffect"
                  data-effect-id="{{effect.id}}"
                  title="{{localize 'WH40K.Effects.Enable'}}">
            <i class="fas fa-toggle-off"></i>
          </button>
          {{else}}
          <button type="button"
                  class="tw-w-[22px] tw-h-[22px] tw-bg-transparent tw-border-none tw-text-gray-500 tw-rounded-sm tw-cursor-pointer hover:tw-bg-black/5 hover:tw-text-gray-800"
                  data-action="disableEffect"
                  data-effect-id="{{effect.id}}"
                  title="{{localize 'WH40K.Effects.Disable'}}">
            <i class="fas fa-toggle-on"></i>
          </button>
          {{/if}}

          <button type="button"
                  class="tw-w-[22px] tw-h-[22px] tw-bg-transparent tw-border-none tw-text-failure tw-rounded-sm tw-cursor-pointer hover:tw-bg-failure/10 hover:tw-text-failure"
                  data-action="deleteEffect"
                  data-effect-id="{{effect.id}}"
                  title="{{localize 'WH40K.Effects.Delete'}}">
            <i class="fas fa-trash"></i>
          </button>
        </div>
        {{/unless}}
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-text-center tw-py-6 tw-text-gray-500">
      <i class="fas fa-magic tw-text-4xl tw-mb-3 tw-opacity-50"></i>
      <p class="tw-m-0 tw-text-sm tw-italic">{{localize "WH40K.Effects.None"}}</p>
      {{#unless item.isEmbedded}}
      <button type="button"
              class="tw-flex tw-items-center tw-gap-1 tw-mt-3 tw-px-3 tw-py-1.5 tw-text-sm tw-bg-transparent tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-cursor-pointer hover:tw-border-gold hover:tw-text-gold"
              data-action="createEffect">
        <i class="fas fa-plus"></i>
        {{localize "WH40K.Effects.CreateFirst"}}
      </button>
      {{/unless}}
    </div>
    {{/if}}
  </div>
</div>
