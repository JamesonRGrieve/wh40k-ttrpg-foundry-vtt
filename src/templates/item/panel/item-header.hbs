{{! Item Header - Talent/Trait/Condition Style
     Compact header for non-physical items with image + name + type badge
}}
<header class="wh40k-item-header wh40k-item-header--talent">
    <div class="wh40k-item-header__image" data-action="editImage" data-edit="img">
        <img src="{{item.img}}" alt="{{item.name}}" />
        <div class="wh40k-item-header__image-overlay">
            <i class="fas fa-edit"></i>
        </div>
    </div>

    <div class="wh40k-item-header__info">
        <input type="text" class="wh40k-item-header__name" name="name" value="{{item.name}}" placeholder="{{localize 'WH40K.Item.NamePlaceholder'}}" />

        <div class="wh40k-item-header__meta">
            {{! Item Type Badge }}
            <span class="wh40k-badge wh40k-badge--type" title="{{localize (concat 'TYPES.Item.' item.type)}}">
                <i class="fas {{item.icon}}"></i>
                {{localize (concat "TYPES.Item." item.type)}}
            </span>

            {{! Additional type-specific badges can be added here by child templates }}
            {{#if system.tier}}
                <span class="wh40k-badge wh40k-badge--tier" title="Tier {{system.tier}}">
                    <i class="fas fa-layer-group"></i>
                    T{{system.tier}}
                </span>
            {{/if}}

            {{#if system.category}}
                <span class="wh40k-badge wh40k-badge--category" title="{{system.category}}">
                    <i class="fas fa-tag"></i>
                    {{system.category}}
                </span>
            {{/if}}
        </div>
    </div>
</header>