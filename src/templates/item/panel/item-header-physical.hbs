{{!-- Item Header - Physical Item Style
     Header for physical items with image + name + class/type/craftsmanship badges + equipped toggle
--}}
<header class="tw-grid tw-grid-cols-[80px_minmax(0,1fr)_auto] tw-gap-4 tw-border-b-2 tw-border-[var(--wh40k-gold-dark)] tw-bg-[linear-gradient(180deg,rgba(212,175,55,0.15)_0%,transparent_100%)] tw-px-4 tw-py-3 tw-shrink-0">
  <div class="tw-group tw-relative tw-h-20 tw-w-20 tw-cursor-pointer tw-overflow-hidden tw-rounded-md tw-border-2 tw-border-[var(--wh40k-gold)] tw-shadow-[var(--wh40k-shadow-md),0_0_10px_rgba(212,175,55,0.3)] tw-transition-all hover:tw-scale-105 hover:tw-shadow-[var(--wh40k-shadow-lg),0_0_20px_rgba(212,175,55,0.5)]" data-action="editImage" data-edit="img">
    <img class="tw-h-full tw-w-full tw-object-cover" src="{{item.img}}" alt="{{item.name}}" />
    <div class="tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-bg-black/45 tw-text-[var(--wh40k-gold)] tw-opacity-0 tw-transition-opacity group-hover:tw-opacity-100">
      <i class="fas fa-edit tw-text-lg"></i>
    </div>
  </div>

  <div class="tw-flex tw-min-w-0 tw-flex-col tw-justify-center tw-gap-1">
    <input type="text"
           class="tw-w-full tw-border-0 tw-bg-transparent tw-px-2 tw-py-1 tw-font-display tw-text-xl tw-text-[var(--wh40k-gold)] tw-shadow-[0_1px_2px_var(--wh40k-text-shadow)] placeholder:tw-text-[var(--wh40k-text-muted)] focus:tw-rounded-sm focus:tw-bg-[var(--wh40k-input-bg-focus)] focus:tw-outline-none"
           name="name"
           value="{{item.name}}"
           placeholder="{{localize 'WH40K.Item.NamePlaceholder'}}" />

    <div class="tw-mt-1 tw-flex tw-flex-wrap tw-items-center tw-gap-1">
      {{!-- Item Class Badge (for weapons) --}}
      {{#if system.class}}
      <span class="wh40k-badge tw-inline-flex tw-items-center tw-gap-1 tw-whitespace-nowrap tw-rounded-full tw-border tw-border-transparent tw-bg-[rgba(100,100,120,0.3)] tw-px-2.5 tw-py-0.5 tw-text-xs tw-font-medium" title="{{system.classLabel}}">
        <i class="fas {{system.classIcon}}"></i>
        {{system.classLabel}}
      </span>
      {{/if}}

      {{!-- Item Type Badge --}}
      {{#if system.type}}
      <span class="wh40k-badge tw-inline-flex tw-items-center tw-gap-1 tw-whitespace-nowrap tw-rounded-full tw-border tw-border-transparent tw-bg-[rgba(100,100,120,0.3)] tw-px-2.5 tw-py-0.5 tw-text-xs tw-font-medium" title="{{system.typeLabel}}">
        {{system.typeLabel}}
      </span>
      {{/if}}

      {{!-- Craftsmanship Badge (if not Common) --}}
      {{#if (and system.craftsmanship (ne system.craftsmanship "common"))}}
      <span class="wh40k-badge tw-inline-flex tw-items-center tw-gap-1 tw-whitespace-nowrap tw-rounded-full tw-border tw-border-transparent tw-bg-[rgba(100,100,120,0.3)] tw-px-2.5 tw-py-0.5 tw-text-xs tw-font-medium"
            title="{{system.craftsmanshipLabel}}">
        <i class="fas fa-hammer"></i>
        {{system.craftsmanshipLabel}}
      </span>
      {{/if}}

      {{!-- Two-Handed Indicator (for weapons) --}}
      {{#if system.twoHanded}}
      <span class="wh40k-badge tw-inline-flex tw-items-center tw-gap-1 tw-whitespace-nowrap tw-rounded-full tw-border tw-border-transparent tw-bg-[rgba(100,100,120,0.3)] tw-px-2.5 tw-py-0.5 tw-text-xs tw-font-medium" title="Two-Handed">
        <i class="fas fa-hands"></i>
      </span>
      {{/if}}
    </div>
  </div>

  {{!-- Equipped Toggle (for equippable items) --}}
  {{#if system.equipped}}
  <div class="tw-flex tw-items-center tw-justify-end">
    <label class="tw-flex tw-cursor-pointer tw-items-center tw-gap-1.5 tw-rounded-md tw-border tw-border-[rgba(212,175,55,0.25)] tw-bg-[rgba(14,18,26,0.6)] tw-px-3 tw-py-1.5 tw-shadow-[0_10px_20px_rgba(0,0,0,0.3)] tw-transition-all hover:tw-border-[rgba(212,175,55,0.4)] hover:tw-bg-[rgba(20,24,34,0.7)]" title="Toggle Equipped">
      <input class="tw-hidden" type="checkbox" name="system.equipped" {{checked system.equipped}} />
      <span class="tw-text-[1.1rem] tw-text-[rgba(214,221,235,0.7)] tw-transition-colors">
        <i class="fas {{#if system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
      </span>
      <span class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.08em] tw-text-[rgba(214,221,235,0.7)] tw-transition-colors">
        {{#if system.equipped}}Equipped{{else}}Stowed{{/if}}
      </span>
    </label>
  </div>
  {{/if}}
</header>
