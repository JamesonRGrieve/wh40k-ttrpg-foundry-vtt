{{!-- 
  Quality Tags Partial
  Displays weapon qualities, armour properties, or similar tags
  
  Usage:
  {{> "systems/wh40k-rpg/templates/item/panel/quality-tags.hbs" 
      qualities=qualitiesArray
      editable=false}}
  
  @param {Array} qualities - Array of quality objects with:
    - name: Quality name
    - rating: Quality rating (optional, for Blast (3), etc.)
    - uuid: UUID for compendium lookup (optional)
    - description: Full description (optional, for expansion)
  @param {Boolean} editable - Whether to show remove buttons
  @param {Boolean} expandable - Whether tags are click-to-expand for details
--}}

<div class="tw-flex tw-flex-wrap tw-items-center tw-gap-1">
  {{#each qualities}}
  <div class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-border tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure tw-bg-[rgba(100,100,120,0.25)] tw-px-2.5 tw-py-1 tw-text-sm tw-text-[var(--color-text-secondary)] tw-transition-all {{#if ../expandable}}tw-cursor-pointer hover:tw--translate-y-px hover:tw-border-[rgba(100,100,120,0.6)] hover:tw-bg-[rgba(100,100,120,0.35)]{{/if}}"
       {{#if ../expandable}}data-action="expandQuality" data-quality-name="{{this.name}}"{{/if}}>
    <span class="tw-font-medium">
      {{this.name}}{{#if this.rating}} ({{this.rating}}){{/if}}
    </span>

    {{#if ../editable}}
    <button type="button"
            class="tw--mr-1 tw-ml-0.5 tw-inline-flex tw-h-4 tw-w-4 tw-items-center tw-justify-center tw-border-0 tw-bg-transparent tw-p-0 tw-text-inherit tw-opacity-60 tw-transition-all hover:tw-scale-110 hover:tw-text-[var(--wh40k-stat-negative)] hover:tw-opacity-100"
            data-action="removeQuality"
            data-quality-name="{{this.name}}"
            title="Remove {{this.name}}">
      <i class="fa-solid fa-xmark"></i>
    </button>
    {{/if}}
  </div>
  {{/each}}

  {{#if editable}}
  <button type="button"
          class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-border tw-border-[rgba(59,130,246,0.3)] tw-bg-[rgba(59,130,246,0.15)] tw-px-2.5 tw-py-1 tw-text-sm tw-text-[#93c5fd] tw-transition-all hover:tw-border-[rgba(59,130,246,0.5)] hover:tw-bg-[rgba(59,130,246,0.25)]"
          data-action="addQuality"
          title="Add Quality">
    <i class="fa-solid fa-plus"></i>
    <span>Add</span>
  </button>
  {{/if}}
</div>

{{#if expandable}}
{{!-- Quality expansion panels (hidden by default) --}}
<div class="tw-mt-3">
  {{#each qualities}}
  {{#if this.description}}
  <div class="wh40k-expansion-panel tw-p-2 tw-mt-1 tw-bg-[rgba(20,20,30,0.85)] tw-rounded-md tw-border-l-[3px] tw-border-solid tw-border-[var(--wh40k-accent,#3b82f6)] tw-shadow-inset" data-quality-panel="{{this.name}}" style="display: none;">
    <h4>{{this.name}}{{#if this.rating}} ({{this.rating}}){{/if}}</h4>
    <div class="tw-text-sm tw-leading-6 tw-text-[var(--color-text-secondary)]">
      {{{this.description}}}
    </div>
  </div>
  {{/if}}
  {{/each}}
</div>
{{/if}}
