{{!-- Modifiers Display/Editor Panel
  Shows stat modifiers provided by this item
--}}

<div class="tw-flex tw-flex-col tw-gap-3">

  {{!-- Characteristic Modifiers --}}
  {{#if item.system.modifiers.characteristics}}
  <div class="tw-flex tw-flex-col tw-gap-1.5">
    <h4 class="tw-flex tw-items-center tw-gap-1 tw-font-heading tw-text-sm tw-text-gold tw-uppercase tw-tracking-wide tw-mb-0 tw-pb-1 tw-border-b tw-border-solid tw-border-black/10">
      <i class="fas fa-user-circle"></i>
      Characteristics
    </h4>
    <div class="tw-flex tw-flex-col tw-gap-0.5">
      {{#each item.system.modifiers.characteristics}}
      {{#unless (eq this 0)}}
      <div class="tw-flex tw-justify-between tw-items-center tw-px-2 tw-py-1 tw-rounded-sm tw-bg-black/5">
        <span class="tw-text-sm tw-capitalize">{{capitalize @key}}</span>
        <span class="tw-font-display tw-font-bold tw-text-sm {{#if (gt this 0)}}tw-text-success{{else}}tw-text-failure{{/if}}">
          {{signedNumber this}}
        </span>
      </div>
      {{/unless}}
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Skill Modifiers --}}
  {{#if item.system.modifiers.skills}}
  <div class="tw-flex tw-flex-col tw-gap-1.5">
    <h4 class="tw-flex tw-items-center tw-gap-1 tw-font-heading tw-text-sm tw-text-gold tw-uppercase tw-tracking-wide tw-mb-0 tw-pb-1 tw-border-b tw-border-solid tw-border-black/10">
      <i class="fas fa-book"></i>
      Skills
    </h4>
    <div class="tw-flex tw-flex-col tw-gap-0.5">
      {{#each item.system.modifiers.skills}}
      {{#unless (eq this 0)}}
      <div class="tw-flex tw-justify-between tw-items-center tw-px-2 tw-py-1 tw-rounded-sm tw-bg-black/5">
        <span class="tw-text-sm tw-capitalize">{{capitalize @key}}</span>
        <span class="tw-font-display tw-font-bold tw-text-sm {{#if (gt this 0)}}tw-text-success{{else}}tw-text-failure{{/if}}">
          {{signedNumber this}}
        </span>
      </div>
      {{/unless}}
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Combat Modifiers --}}
  {{#if item.system.modifiers.combat}}
  <div class="tw-flex tw-flex-col tw-gap-1.5">
    <h4 class="tw-flex tw-items-center tw-gap-1 tw-font-heading tw-text-sm tw-text-gold tw-uppercase tw-tracking-wide tw-mb-0 tw-pb-1 tw-border-b tw-border-solid tw-border-black/10">
      <i class="fas fa-crosshairs"></i>
      Combat
    </h4>
    <div class="tw-flex tw-flex-col tw-gap-0.5">
      {{#each item.system.modifiers.combat}}
      {{#unless (eq this 0)}}
      <div class="tw-flex tw-justify-between tw-items-center tw-px-2 tw-py-1 tw-rounded-sm tw-bg-black/5">
        <span class="tw-text-sm tw-capitalize">{{capitalize @key}}</span>
        <span class="tw-font-display tw-font-bold tw-text-sm {{#if (gt this 0)}}tw-text-success{{else}}tw-text-failure{{/if}}">
          {{signedNumber this}}
        </span>
      </div>
      {{/unless}}
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Resource Modifiers --}}
  {{#if item.system.modifiers.resources}}
  <div class="tw-flex tw-flex-col tw-gap-1.5">
    <h4 class="tw-flex tw-items-center tw-gap-1 tw-font-heading tw-text-sm tw-text-gold tw-uppercase tw-tracking-wide tw-mb-0 tw-pb-1 tw-border-b tw-border-solid tw-border-black/10">
      <i class="fas fa-heart"></i>
      Resources
    </h4>
    <div class="tw-flex tw-flex-col tw-gap-0.5">
      {{#each item.system.modifiers.resources}}
      {{#unless (eq this 0)}}
      <div class="tw-flex tw-justify-between tw-items-center tw-px-2 tw-py-1 tw-rounded-sm tw-bg-black/5">
        <span class="tw-text-sm tw-capitalize">{{capitalize @key}}</span>
        <span class="tw-font-display tw-font-bold tw-text-sm {{#if (gt this 0)}}tw-text-success{{else}}tw-text-failure{{/if}}">
          {{signedNumber this}}
        </span>
      </div>
      {{/unless}}
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Other Modifiers --}}
  {{#if item.system.modifiers.other.length}}
  <div class="tw-flex tw-flex-col tw-gap-1.5">
    <h4 class="tw-flex tw-items-center tw-gap-1 tw-font-heading tw-text-sm tw-text-gold tw-uppercase tw-tracking-wide tw-mb-0 tw-pb-1 tw-border-b tw-border-solid tw-border-black/10">
      <i class="fas fa-ellipsis-h"></i>
      Other
    </h4>
    <div class="tw-flex tw-flex-col tw-gap-0.5">
      {{#each item.system.modifiers.other}}
      <div class="tw-flex tw-justify-between tw-items-center tw-px-2 tw-py-1 tw-rounded-sm tw-bg-black/5">
        <span class="tw-text-sm">{{this.label}} {{#if this.mode}}({{this.mode}}){{/if}}</span>
        <span class="tw-font-display tw-font-bold tw-text-sm {{#if (gt this.value 0)}}tw-text-success{{else}}tw-text-failure{{/if}}">
          {{signedNumber this.value}}
        </span>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- No Modifiers Message --}}
  {{#unless (or item.system.modifiers.characteristics item.system.modifiers.skills item.system.modifiers.combat item.system.modifiers.resources item.system.modifiers.other.length)}}
  <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-py-10 tw-px-5 tw-text-center tw-text-gray-500">
    <i class="fas fa-info-circle tw-text-4xl tw-mb-3 tw-opacity-30"></i>
    <p class="tw-m-1 tw-text-sm">This item does not provide any stat modifiers.</p>
    <p class="tw-m-1 tw-text-xs tw-italic tw-opacity-70">Use Active Effects to add modifiers to this item.</p>
  </div>
  {{/unless}}

</div>
