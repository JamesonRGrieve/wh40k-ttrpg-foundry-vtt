{{!-- Acquisition Panel
     Weight, Availability, and Craftsmanship configuration for physical items
     Uses PhysicalItemTemplate fields
--}}
<div class="tw-flex tw-flex-col">
  <header class="tw-flex tw-flex-row tw-items-center tw-gap-1.5 tw-px-2 tw-py-1.5 tw-border-b tw-border-solid tw-border-black/10 tw-bg-gradient-to-b tw-from-gold/15 tw-to-gold/5">
    <i class="fas fa-coins tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
    <span class="tw-font-display tw-font-semibold">{{localize "WH40K.Acquisition"}}</span>
  </header>

  <div class="tw-p-2">
    <div class="tw-grid tw-grid-cols-3 tw-gap-2">

      {{!-- Weight --}}
      <div class="tw-flex tw-flex-col tw-gap-0.5">
        <label class="tw-flex tw-items-center tw-gap-1 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide">
          <i class="fas fa-weight-hanging"></i>
          {{localize "WH40K.Weight"}}
        </label>
        <div class="tw-flex tw-items-center tw-gap-1">
          <input class="tw-flex-1 tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-px-2 tw-py-1 tw-text-sm"
                 name="system.weight"
                 type="number"
                 value="{{source.weight}}"
                 step="0.1"
                 min="0"
                 placeholder="0" />
          <span class="tw-text-xs tw-text-gray-500">kg</span>
        </div>
      </div>

      {{!-- Availability --}}
      <div class="tw-flex tw-flex-col tw-gap-0.5">
        <label class="tw-flex tw-items-center tw-gap-1 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide">
          <i class="fas fa-store"></i>
          {{localize "WH40K.Availability"}}
        </label>
        <select class="tw-w-full tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-px-2 tw-py-1 tw-text-sm" name="system.availability">
          <option value="">{{localize "WH40K.Availability.None"}}</option>
          {{#each config.availabilities}}
          <option value="{{@key}}" {{selected (eq @key ../system.availability)}}>
            {{label}} ({{signedNumber modifier}})
          </option>
          {{/each}}
        </select>
      </div>

      {{!-- Craftsmanship --}}
      <div class="tw-flex tw-flex-col tw-gap-0.5">
        <label class="tw-flex tw-items-center tw-gap-1 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide">
          <i class="fas fa-hammer"></i>
          {{localize "WH40K.Craftsmanship"}}
        </label>
        <select class="tw-w-full tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-px-2 tw-py-1 tw-text-sm" name="system.craftsmanship">
          {{#each config.craftsmanships}}
          <option value="{{@key}}" {{selected (eq @key ../system.craftsmanship)}}>
            {{label}} ({{signedNumber modifier}})
          </option>
          {{/each}}
        </select>
      </div>

    </div>

    {{!-- Acquisition Info Display --}}
    {{#if system.acquisitionInfo}}
    <div class="tw-flex tw-items-center tw-gap-1.5 tw-mt-2 tw-text-sm tw-italic tw-text-gray-500">
      <i class="fas fa-info-circle"></i>
      <span>{{system.acquisitionInfo}}</span>
    </div>
    {{/if}}
  </div>
</div>
