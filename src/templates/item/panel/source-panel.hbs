{{! Source Reference Panel
     Displays source book, page, and custom reference fields.
     Requires system.source object from DescriptionTemplate.
}}
<div class="tw-flex tw-flex-col">
    <header class="tw-flex tw-flex-row tw-items-center tw-gap-1.5 tw-px-2 tw-py-1.5 tw-border-b tw-border-solid tw-border-black/10 tw-bg-gradient-to-b tw-from-gold/15 tw-to-gold/5">
        <i class="fas fa-book tw-text-gold"></i>
        <span class="tw-font-display tw-font-semibold">{{localize "WH40K.Source.Label"}}</span>
    </header>

    <div class="tw-p-2 tw-flex tw-flex-col tw-gap-2">
        <div class="tw-grid tw-grid-cols-[1fr_auto] tw-gap-2">
            <div class="tw-flex tw-flex-col tw-gap-0.5">
                <label class="tw-flex tw-items-center tw-gap-1 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide">
                    <i class="fas fa-book"></i>
                    {{localize "WH40K.Source.Book"}}
                </label>
                <input
                    class="tw-w-full tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-px-2 tw-py-1 tw-text-sm"
                    name="system.source.book"
                    type="text"
                    value="{{source.source.book}}"
                    placeholder="{{localize 'WH40K.Source.BookPlaceholder'}}"
                />
            </div>

            <div class="tw-flex tw-flex-col tw-gap-0.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide">{{localize "WH40K.Source.Page"}}</label>
                <input
                    class="tw-w-24 tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-px-2 tw-py-1 tw-text-sm"
                    name="system.source.page"
                    type="text"
                    value="{{source.source.page}}"
                    placeholder="{{localize 'WH40K.Source.PagePlaceholder'}}"
                />
            </div>
        </div>

        <div class="tw-flex tw-flex-col tw-gap-0.5">
            <label class="tw-flex tw-items-center tw-gap-1 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide">
                <i class="fas fa-pen"></i>
                {{localize "WH40K.Source.Custom"}}
            </label>
            <input
                class="tw-w-full tw-border tw-border-solid tw-border-black/20 tw-rounded-md tw-px-2 tw-py-1 tw-text-sm"
                name="system.source.custom"
                type="text"
                value="{{source.source.custom}}"
                placeholder="{{localize 'WH40K.Source.CustomPlaceholder'}}"
            />
        </div>

        {{#if system.sourceReference}}
            <div class="tw-flex tw-items-center tw-gap-1.5 tw-text-sm tw-italic tw-text-gray-500">
                <i class="fas fa-info-circle"></i>
                <span>{{system.sourceReference}}</span>
            </div>
        {{/if}}
    </div>
</div>
