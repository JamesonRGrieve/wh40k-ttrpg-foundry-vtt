{{! Source Reference Panel
     Displays source book, page, and custom reference fields.
     Requires system.source object from DescriptionTemplate.
}}
<div class="wh40k-item-sheet__panel wh40k-source-panel">
    <header class="wh40k-panel-header">
        <i class="fas fa-book"></i>
        <span>{{localize "WH40K.Source.Label"}}</span>
    </header>

    <div class="wh40k-panel-body">
        <div class="wh40k-field-group">
            <div class="wh40k-field">
                <label class="wh40k-field__label">
                    <i class="fas fa-book"></i>
                    {{localize "WH40K.Source.Book"}}
                </label>
                <input
                    class="wh40k-field__input"
                    name="system.source.book"
                    type="text"
                    value="{{system.source.book}}"
                    placeholder="{{localize 'WH40K.Source.BookPlaceholder'}}"
                />
            </div>

            <div class="wh40k-field wh40k-field--inline">
                <label class="wh40k-field__label">{{localize "WH40K.Source.Page"}}</label>
                <input
                    class="wh40k-field__input wh40k-field__input--short"
                    name="system.source.page"
                    type="text"
                    value="{{system.source.page}}"
                    placeholder="{{localize 'WH40K.Source.PagePlaceholder'}}"
                />
            </div>
        </div>

        <div class="wh40k-field">
            <label class="wh40k-field__label">
                <i class="fas fa-pen"></i>
                {{localize "WH40K.Source.Custom"}}
            </label>
            <input
                class="wh40k-field__input"
                name="system.source.custom"
                type="text"
                value="{{system.source.custom}}"
                placeholder="{{localize 'WH40K.Source.CustomPlaceholder'}}"
            />
        </div>

        {{#if system.sourceReference}}
            <div class="wh40k-source-display">
                <i class="fas fa-info-circle"></i>
                <span>{{system.sourceReference}}</span>
            </div>
        {{/if}}
    </div>
</div>