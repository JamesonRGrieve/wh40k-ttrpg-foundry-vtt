{{!-- 
  Expandable Section Partial
  Click-to-expand content panel with header
  
  Usage:
  {{> "systems/wh40k-rpg/templates/item/panel/expandable-section.hbs" 
      id="unique-id"
      title="Section Title"
      icon="fa-solid fa-info-circle"
      expanded=false
      content=htmlContent}}
  
  @param {String} id - Unique identifier for this section
  @param {String} title - Section title/trigger text
  @param {String} icon - Font Awesome icon class (optional)
  @param {Boolean} expanded - Whether section is initially expanded (default: false)
  @param {String} content - HTML content to display when expanded
  @param {String} accentColor - CSS color for left border (optional)
--}}

<div class="tw-flex tw-flex-col" data-expandable-id="{{id}}">
  <div class="wh40k-expandable {{#if expanded}}wh40k-expandable--expanded{{/if}} tw-inline-flex tw-items-center tw-gap-1 tw-cursor-pointer tw-select-none tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-transition-opacity tw-duration-200 hover:tw-opacity-80"
       data-action="toggleExpandable"
       data-target-id="{{id}}">
    {{#if icon}}
    <i class="{{icon}}"></i>
    {{/if}}
    <span class="tw-flex-1">{{title}}</span>
  </div>

  <div class="wh40k-expansion-panel {{#if expanded}}wh40k-expansion-panel--open tw-animate-slideDown{{/if}} tw-p-2 tw-mt-1 tw-bg-[rgba(20,20,30,0.85)] tw-rounded-md tw-border-l-[3px] tw-border-solid tw-border-[var(--wh40k-accent,#3b82f6)] tw-shadow-inset"
       data-panel-id="{{id}}"
       {{#if accentColor}}style="--wh40k-accent: {{accentColor}}"{{/if}}>
    {{{content}}}
  </div>
</div>
