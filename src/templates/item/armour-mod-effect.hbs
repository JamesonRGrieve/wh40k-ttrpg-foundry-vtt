{{! Armour Modification Effect Tab }}
<div class="wh40k-tab-content wh40k-armour-mod-effect" data-tab="effect">
    <div class="wh40k-panel">
        <header class="wh40k-panel-header">
            <h3>
                <i class="fas fa-wand-magic-sparkles"></i>
                {{localize "WH40K.Modification.Effect"}}
            </h3>
        </header>

        <div class="wh40k-panel-body">
            <p class="wh40k-help-text tw-px-4 tw-py-3 tw-mb-4 tw-text-sm tw-rounded-md tw-border-l-[3px] tw-border-[var(--wh40k-accent-info)]" style="background: rgba(52,152,219,0.1); color: rgba(255,255,255,0.7)">
                Describe the special effects of this modification. Use rich text for formatting.
            </p>

            <div class="wh40k-field wh40k-field--editor">
                {{editor effect target="system.effect" button=true editable=isEditable engine="prosemirror"}}
            </div>
        </div>
    </div>

    <div class="wh40k-panel">
        <header class="wh40k-panel-header">
            <h3>
                <i class="fas fa-sticky-note"></i>
                {{localize "WH40K.Modification.Notes"}}
            </h3>
        </header>

        <div class="wh40k-panel-body">
            <div class="wh40k-field">
                <textarea
                    name="system.notes"
                    class="wh40k-field-textarea tw-w-full tw-p-2 tw-rounded-md tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(212,197,166,0.3)] tw-text-white"
                    rows="4"
                    placeholder="Additional notes or clarifications..."
                    {{disabled (not isEditable)}}
                >{{notes}}</textarea>
            </div>
        </div>
    </div>
</div>