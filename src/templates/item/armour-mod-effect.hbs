{{! Armour Modification Effect Tab }}
<div class="tw-flex tw-flex-col tw-flex-auto tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-4" data-tab="effect">
    <div class="wh40k-panel">
        <header class="wh40k-panel-header tw-border-b tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure">
            <h3>
                <i class="fas fa-wand-magic-sparkles"></i>
                {{localize "WH40K.Modification.Effect"}}
            </h3>
        </header>

        <div class="wh40k-panel-body">
            <p class="tw-px-4 tw-py-3 tw-mb-4 tw-text-sm tw-rounded-md tw-border-l-[3px] tw-border-[var(--wh40k-accent-info)]" style="background: rgba(52,152,219,0.1); color: rgba(255,255,255,0.7)">
                Describe the special effects of this modification. Use rich text for formatting.
            </p>

            <div class="tw-flex tw-flex-col [&_.editor]:tw-min-h-[250px] [&_.editor]:tw-bg-[rgba(0,0,0,0.3)] [&_.editor]:tw-border [&_.editor]:tw-border-[rgba(212,197,166,0.3)] [&_.editor]:tw-rounded-[6px] [&_.editor:focus-within]:tw-border-[var(--wh40k-color-gold)] [&_.editor:focus-within]:tw-shadow-[0_0_0_2px_rgba(212,175,55,0.2)]">
                {{editor effect target="system.effect" button=true editable=isEditable engine="prosemirror"}}
            </div>
        </div>
    </div>

    <div class="wh40k-panel">
        <header class="wh40k-panel-header">
            <h3>
                <i class="fas fa-sticky-note"></i>
                {{localize "WH40K.Modification.Notes"}}
            </h3>
        </header>

        <div class="wh40k-panel-body">
            <div class="tw-flex tw-flex-col">
                <textarea
                    name="system.notes"
                    class="tw-w-full tw-p-[0.875rem] tw-rounded-[6px] tw-bg-[rgba(0,0,0,0.3)] tw-border tw-border-[rgba(212,197,166,0.3)] tw-text-white tw-font-[inherit] tw-text-[0.9rem] tw-leading-[1.5] tw-resize-y focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)] focus:tw-shadow-[0_0_0_2px_rgba(212,175,55,0.2)] placeholder:tw-text-[rgba(255,255,255,0.3)]"
                    rows="4"
                    placeholder="Additional notes or clarifications..."
                    {{disabled (not isEditable)}}
                >{{notes}}</textarea>
            </div>
        </div>
    </div>
</div>