{{! NPC Template - Preview Tab }}
<section class="tab-content tab-preview" data-tab="preview" data-group="primary">
    {{! Threat Selector }}
    <div class="wh40k-panel">
        <header class="wh40k-panel-header">
            <h3><i class="fas fa-eye"></i> {{localize "WH40K.NPC.Template.PreviewSettings"}}</h3>
        </header>
        <div class="wh40k-panel-content">
            <div class="tw-flex tw-items-center tw-gap-4">
                <label>{{localize "WH40K.NPC.Template.PreviewAtThreat"}}</label>
                <input class="tw-flex-1" type="range" min="1" max="30" value="{{previewThreat}}" data-action="updatePreview" />
                <span class="tw-text-2xl tw-font-bold tw-min-w-[40px] tw-text-center">{{previewThreat}}</span>
            </div>
            <div class="tw-mt-4 tw-text-right">
                <button type="button" class="wh40k-btn wh40k-btn-primary" data-action="createFromPreview">
                    <i class="fas fa-user-plus"></i>
                    {{localize "WH40K.NPC.Template.CreateNPC"}}
                </button>
            </div>
        </div>
    </div>

    {{! Preview Stat Block }}
    <div class="wh40k-panel">
        <header class="wh40k-panel-header">
            <h3>{{item.name}} <span class="tw-text-sm tw-px-2 tw-py-0.5 tw-rounded-md tw-ml-2" style="background: var(--wh40k-warning)">{{localize "WH40K.NPC.ThreatLevel"}} {{previewThreat}}</span></h3>
        </header>
        <div class="wh40k-panel-content">
            {{! Characteristics Preview }}
            <div class="tw-mb-4 tw-pb-4 tw-border-b tw-border-[var(--wh40k-border-color)] last:tw-border-b-0">
                <h4 class="tw-text-sm tw-font-semibold tw-uppercase tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-mb-2">{{localize "WH40K.Characteristics"}}</h4>
                <div class="tw-flex tw-flex-wrap tw-gap-3">
                    {{#each previewData.characteristics as |char key|}}
                        <div class="tw-text-center tw-p-2 tw-rounded-md tw-min-w-[50px]" style="background: var(--wh40k-bg-secondary)">
                            <span class="tw-block tw-text-[0.625rem] tw-font-bold tw-uppercase">{{char.short}}</span>
                            <span class="tw-block tw-text-xl tw-font-bold">{{char.value}}</span>
                            {{#if char.unnatural}}
                                <span class="tw-text-xs tw-text-[var(--wh40k-warning)]">({{char.unnatural}})</span>
                            {{/if}}
                        </div>
                    {{/each}}
                </div>
            </div>

            {{! Vitals Preview }}
            <div class="tw-mb-4 tw-pb-4 tw-border-b tw-border-[var(--wh40k-border-color)]">
                <h4 class="tw-text-sm tw-font-semibold tw-uppercase tw-text-[var(--wh40k-text-muted)] tw-mb-2">{{localize "WH40K.NPC.Template.VitalStats"}}</h4>
                <div class="tw-flex tw-gap-8">
                    <div>
                        <span class="tw-text-xs tw-text-[var(--wh40k-text-muted)]">{{localize "WH40K.Wounds"}}</span>
                        <span class="tw-text-xl tw-font-bold tw-ml-2">{{previewData.wounds}}</span>
                    </div>
                    <div>
                        <span class="tw-text-xs tw-text-[var(--wh40k-text-muted)]">{{localize "WH40K.Movement"}}</span>
                        <span class="tw-text-xl tw-font-bold tw-ml-2">{{previewData.movement}}</span>
                    </div>
                    <div>
                        <span class="tw-text-xs tw-text-[var(--wh40k-text-muted)]">{{localize "WH40K.NPC.Armour"}}</span>
                        <span class="tw-text-xl tw-font-bold tw-ml-2">{{previewData.armour}}</span>
                    </div>
                </div>
            </div>

            {{! Skills Preview }}
            {{#if (gt previewData.skills.length 0)}}
                <div class="tw-mb-4 tw-pb-4 tw-border-b tw-border-[var(--wh40k-border-color)]">
                    <h4 class="tw-text-sm tw-font-semibold tw-uppercase tw-text-[var(--wh40k-text-muted)] tw-mb-2">{{localize "WH40K.Skills"}}</h4>
                    <div class="tw-flex tw-flex-wrap tw-gap-2">
                        {{#each previewData.skills as |skill|}}
                            <span class="tw-px-2 tw-py-1 tw-rounded-md tw-text-sm" style="background: var(--wh40k-bg-secondary)">{{skill.name}} {{skill.target}}</span>
                        {{/each}}
                    </div>
                </div>
            {{/if}}

            {{! Weapons Preview }}
            {{#if (gt previewData.weapons.length 0)}}
                <div class="tw-mb-4 tw-pb-4 tw-border-b tw-border-[var(--wh40k-border-color)]">
                    <h4 class="tw-text-sm tw-font-semibold tw-uppercase tw-text-[var(--wh40k-text-muted)] tw-mb-2">{{localize "WH40K.Weapons"}}</h4>
                    <div>
                        {{#each previewData.weapons as |weapon|}}
                            <div class="tw-flex tw-gap-4 tw-py-2 tw-border-b tw-border-dashed tw-border-[var(--wh40k-border-color)]">
                                <span class="tw-font-medium">{{weapon.name}}</span>
                                <span class="tw-text-[var(--wh40k-text-muted)]">{{weapon.damage}} Pen {{weapon.pen}}</span>
                                {{#if weapon.special}}
                                    <span class="tw-text-sm tw-italic">{{weapon.special}}</span>
                                {{/if}}
                            </div>
                        {{/each}}
                    </div>
                </div>
            {{/if}}

            {{! Talents & Traits Preview }}
            {{#if (or (gt previewData.talents.length 0) (gt previewData.traits.length 0))}}
                <div class="tw-mb-4 tw-pb-4 tw-border-b tw-border-[var(--wh40k-border-color)]">
                    <h4 class="tw-text-sm tw-font-semibold tw-uppercase tw-text-[var(--wh40k-text-muted)] tw-mb-2">{{localize "WH40K.NPC.Template.TalentsAndTraits"}}</h4>
                    <div class="tw-flex tw-flex-wrap tw-gap-2">
                        {{#each previewData.talents as |talent|}}
                            <span class="tw-px-2 tw-py-1 tw-rounded-md tw-text-sm" style="background: var(--wh40k-accent-color-light)">{{talent.name}}</span>
                        {{/each}}
                        {{#each previewData.traits as |trait|}}
                            <span class="tw-px-2 tw-py-1 tw-rounded-md tw-text-sm" style="background: var(--wh40k-success-light)">{{trait.name}}{{#if trait.level}} ({{trait.level}}){{/if}}</span>
                        {{/each}}
                    </div>
                </div>
            {{/if}}

            {{! Special Abilities Preview }}
            {{#if previewData.specialAbilities}}
                <div class="tw-mb-4">
                    <h4 class="tw-text-sm tw-font-semibold tw-uppercase tw-text-[var(--wh40k-text-muted)] tw-mb-2">{{localize "WH40K.NPC.Template.SpecialAbilities"}}</h4>
                    <div>
                        {{{previewData.specialAbilities}}}
                    </div>
                </div>
            {{/if}}
        </div>
    </div>
</section>