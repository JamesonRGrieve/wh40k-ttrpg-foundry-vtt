{{!-- 
  Rogue Trader Origin Path Item Sheet - Modern Tabbed Redesign
  Character creation lifepath configuration with tabbed interface
--}}
<div class="wh40k-origin-sheet">
  <form autocomplete="off">
    
    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: Compact identity with step badge
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="wh40k-origin-header">
      <div class="wh40k-origin-header__image" data-action="editImage" data-edit="img">
        <img src="{{item.img}}" alt="{{item.name}}" />
        <div class="wh40k-origin-header__image-overlay">
          <i class="fas fa-edit"></i>
        </div>
      </div>
      
      <div class="wh40k-origin-header__info">
        <input type="text" class="wh40k-origin-header__name" name="name" value="{{item.name}}" placeholder="Origin Path Name" />
        
        <div class="wh40k-origin-header__meta">
          {{!-- Step Badge --}}
          <span class="wh40k-origin-badge wh40k-origin-badge--step wh40k-origin-badge--step{{item.system.stepIndex}}" title="{{item.system.stepLabel}}">
            <i class="fas fa-map-signs"></i>
            {{item.system.stepLabel}}
          </span>
          
          {{!-- Step Index Badge --}}
          <span class="wh40k-origin-badge wh40k-origin-badge--index" title="Order in path">
            <i class="fas fa-sort-numeric-up"></i>
            Step {{add item.system.stepIndex 1}}
          </span>
        </div>
        
        {{!-- Step Configuration --}}
        <div class="wh40k-origin-header__config">
          <div class="wh40k-config-field">
            <label>Step Type</label>
            <select name="system.step" class="wh40k-config-select">
              <option value="homeWorld" {{#if (eq item.system.step "homeWorld")}}selected{{/if}}>Home World</option>
              <option value="birthright" {{#if (eq item.system.step "birthright")}}selected{{/if}}>Birthright</option>
              <option value="lureOfTheVoid" {{#if (eq item.system.step "lureOfTheVoid")}}selected{{/if}}>Lure of the Void</option>
              <option value="trialsAndTravails" {{#if (eq item.system.step "trialsAndTravails")}}selected{{/if}}>Trials &amp; Travails</option>
              <option value="motivation" {{#if (eq item.system.step "motivation")}}selected{{/if}}>Motivation</option>
              <option value="career" {{#if (eq item.system.step "career")}}selected{{/if}}>Career</option>
              <option value="lineage" {{#if (eq item.system.step "lineage")}}selected{{/if}}>Lineage</option>
              <option value="eliteAdvance" {{#if (eq item.system.step "eliteAdvance")}}selected{{/if}}>Elite Advance</option>
            </select>
          </div>
          
          <div class="wh40k-config-field">
            <label>Step Index</label>
            <input type="number" name="system.stepIndex" value="{{item.system.stepIndex}}" min="0" max="8" class="wh40k-config-input" />
          </div>
        </div>
      </div>
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ --}}
    <nav class="wh40k-origin-tabs" data-group="primary">
      <button type="button" class="wh40k-origin-tab active" data-tab="grants" data-group="primary">
        <i class="fas fa-gift"></i>
        <span>Grants</span>
      </button>
      <button type="button" class="wh40k-origin-tab" data-tab="requirements" data-group="primary">
        <i class="fas fa-lock"></i>
        <span>Requirements</span>
      </button>
      <button type="button" class="wh40k-origin-tab" data-tab="choices" data-group="primary">
        <i class="fas fa-question-circle"></i>
        <span>Choices</span>
      </button>
      <button type="button" class="wh40k-origin-tab" data-tab="description" data-group="primary">
        <i class="fas fa-book"></i>
        <span>Description</span>
      </button>
    </nav>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <section class="wh40k-origin-content">
      
      {{!-- GRANTS TAB --}}
      <div class="wh40k-origin-panel active" data-tab="grants" data-group="primary">
        
        {{!-- Characteristic Modifiers --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-dumbbell"></i> {{localize "WH40K.CharacteristicModifiers"}}
          </h3>
          
          <div class="wh40k-characteristics-grid">
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">WS</label>
              <input type="number" name="system.modifiers.characteristics.weaponSkill" value="{{item.system.modifiers.characteristics.weaponSkill}}" class="wh40k-char-input" placeholder="0" />
            </div>
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">BS</label>
              <input type="number" name="system.modifiers.characteristics.ballisticSkill" value="{{item.system.modifiers.characteristics.ballisticSkill}}" class="wh40k-char-input" placeholder="0" />
            </div>
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">S</label>
              <input type="number" name="system.modifiers.characteristics.strength" value="{{item.system.modifiers.characteristics.strength}}" class="wh40k-char-input" placeholder="0" />
            </div>
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">T</label>
              <input type="number" name="system.modifiers.characteristics.toughness" value="{{item.system.modifiers.characteristics.toughness}}" class="wh40k-char-input" placeholder="0" />
            </div>
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">Ag</label>
              <input type="number" name="system.modifiers.characteristics.agility" value="{{item.system.modifiers.characteristics.agility}}" class="wh40k-char-input" placeholder="0" />
            </div>
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">Int</label>
              <input type="number" name="system.modifiers.characteristics.intelligence" value="{{item.system.modifiers.characteristics.intelligence}}" class="wh40k-char-input" placeholder="0" />
            </div>
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">Per</label>
              <input type="number" name="system.modifiers.characteristics.perception" value="{{item.system.modifiers.characteristics.perception}}" class="wh40k-char-input" placeholder="0" />
            </div>
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">WP</label>
              <input type="number" name="system.modifiers.characteristics.willpower" value="{{item.system.modifiers.characteristics.willpower}}" class="wh40k-char-input" placeholder="0" />
            </div>
            <div class="wh40k-char-field">
              <label class="wh40k-char-label">Fel</label>
              <input type="number" name="system.modifiers.characteristics.fellowship" value="{{item.system.modifiers.characteristics.fellowship}}" class="wh40k-char-input" placeholder="0" />
            </div>
          </div>
        </div>
        
        {{!-- Other Bonuses --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-heart"></i> {{localize "WH40K.OtherBonuses"}}
          </h3>
          
          <div class="wh40k-bonuses-grid">
            <div class="wh40k-bonus-field">
              <label class="wh40k-bonus-label">Wounds</label>
              <input type="number" name="system.grants.wounds" value="{{item.system.grants.wounds}}" class="wh40k-bonus-input" placeholder="0" />
            </div>
            
            <div class="wh40k-bonus-field">
              <label class="wh40k-bonus-label">Fate Threshold</label>
              <input type="number" name="system.grants.fateThreshold" value="{{item.system.grants.fateThreshold}}" min="0" class="wh40k-bonus-input" placeholder="0" />
            </div>
            
            <div class="wh40k-bonus-field wh40k-bonus-field--checkbox">
              <label class="wh40k-bonus-label-inline">
                <input type="checkbox" name="system.grants.blessedByEmperor" {{checked item.system.grants.blessedByEmperor}} />
                <span>Blessed by Emperor</span>
              </label>
            </div>
          </div>
        </div>
        
        {{!-- Skills Granted --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-graduation-cap"></i> {{localize "WH40K.SkillsGranted"}}
          </h3>
          
          {{#if item.system.grants.skills.length}}
          <div class="wh40k-grants-list">
            {{#each item.system.grants.skills as |skill index|}}
            <div class="wh40k-grant-card wh40k-grant-card--skill">
              <div class="wh40k-grant-card__content">
                <span class="wh40k-grant-name">{{skill.name}}</span>
                {{#if skill.specialization}}
                <span class="wh40k-grant-spec">({{skill.specialization}})</span>
                {{/if}}
              </div>
              <span class="wh40k-grant-badge wh40k-grant-badge--{{skill.level}}">
                {{#if (eq skill.level "trained")}}T{{/if}}
                {{#if (eq skill.level "plus10")}}+10{{/if}}
                {{#if (eq skill.level "plus20")}}+20{{/if}}
              </span>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="wh40k-empty-state wh40k-empty-state--compact">
            <i class="fas fa-graduation-cap"></i>
            <p>No skills granted</p>
          </div>
          {{/if}}
        </div>
        
        {{!-- Talents Granted --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-star"></i> {{localize "WH40K.TalentsGranted"}}
          </h3>
          
          {{#if item.system.grants.talents.length}}
          <div class="wh40k-grants-list">
            {{#each item.system.grants.talents as |talent index|}}
            <div class="wh40k-grant-card wh40k-grant-card--talent">
              <div class="wh40k-grant-card__content">
                <span class="wh40k-grant-name">{{talent.name}}</span>
                {{#if talent.specialization}}
                <span class="wh40k-grant-spec">({{talent.specialization}})</span>
                {{/if}}
              </div>
              <i class="fas fa-star wh40k-grant-icon"></i>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="wh40k-empty-state wh40k-empty-state--compact">
            <i class="fas fa-star"></i>
            <p>No talents granted</p>
          </div>
          {{/if}}
        </div>
        
        {{!-- Traits Granted --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-shield-alt"></i> {{localize "WH40K.TraitsGranted"}}
          </h3>
          
          {{#if item.system.grants.traits.length}}
          <div class="wh40k-grants-list">
            {{#each item.system.grants.traits as |trait index|}}
            <div class="wh40k-grant-card wh40k-grant-card--trait">
              <div class="wh40k-grant-card__content">
                <span class="wh40k-grant-name">{{trait.name}}</span>
                {{#if trait.level}}
                <span class="wh40k-grant-level">({{trait.level}})</span>
                {{/if}}
              </div>
              <i class="fas fa-shield-alt wh40k-grant-icon"></i>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="wh40k-empty-state wh40k-empty-state--compact">
            <i class="fas fa-shield-alt"></i>
            <p>No traits granted</p>
          </div>
          {{/if}}
        </div>
        
        {{!-- Aptitudes Granted --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-brain"></i> {{localize "WH40K.AptitudesGranted"}}
          </h3>
          
          {{#if item.system.grants.aptitudes.length}}
          <div class="wh40k-aptitudes-display">
            {{#each item.system.grants.aptitudes as |apt|}}
            <span class="wh40k-aptitude-tag">{{apt}}</span>
            {{/each}}
          </div>
          {{else}}
          <div class="wh40k-empty-state wh40k-empty-state--compact">
            <i class="fas fa-brain"></i>
            <p>No aptitudes granted</p>
          </div>
          {{/if}}
        </div>
        
        {{!-- Equipment Granted --}}
        {{#if item.system.grants.equipment.length}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-toolbox"></i> {{localize "WH40K.EquipmentGranted"}}
          </h3>
          
          <div class="wh40k-grants-list">
            {{#each item.system.grants.equipment as |equip index|}}
            <div class="wh40k-grant-card wh40k-grant-card--equipment">
              <div class="wh40k-grant-card__content">
                <span class="wh40k-grant-name">{{equip.name}}</span>
                {{#if (gt equip.quantity 1)}}
                <span class="wh40k-grant-qty">×{{equip.quantity}}</span>
                {{/if}}
              </div>
              <i class="fas fa-toolbox wh40k-grant-icon"></i>
            </div>
            {{/each}}
          </div>
        </div>
        {{/if}}
        
        {{!-- Special Abilities --}}
        {{#if item.system.grants.specialAbilities.length}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-bolt"></i> {{localize "WH40K.SpecialAbilities"}}
          </h3>
          
          {{#each item.system.grants.specialAbilities as |ability index|}}
          <div class="wh40k-ability-card">
            <h4 class="wh40k-ability-name">{{ability.name}}</h4>
            <div class="wh40k-ability-description">
              {{{ability.description}}}
            </div>
          </div>
          {{/each}}
        </div>
        {{/if}}
      </div>
      
      {{!-- REQUIREMENTS TAB --}}
      <div class="wh40k-origin-panel" data-tab="requirements" data-group="primary">
        {{#if item.system.hasRequirements}}
          {{!-- Text Requirements --}}
          {{#if item.system.requirements.text}}
          <div class="wh40k-origin-section">
            <h3 class="wh40k-section-title">
              <i class="fas fa-file-alt"></i> Text Description
            </h3>
            
            <div class="wh40k-property">
              <label class="wh40k-property-label">Requirements</label>
              <textarea name="system.requirements.text" rows="3" class="wh40k-property-textarea" placeholder="e.g., Must have Void Born homeworld">{{item.system.requirements.text}}</textarea>
            </div>
            
            <div class="wh40k-requirement-display">
              <p>{{item.system.requirements.text}}</p>
            </div>
          </div>
          {{/if}}
          
          {{!-- Previous Steps Required --}}
          {{#if item.system.requirements.previousSteps.length}}
          <div class="wh40k-origin-section">
            <h3 class="wh40k-section-title">
              <i class="fas fa-check-circle"></i> Required Previous Steps
            </h3>
            
            <div class="wh40k-requirement-list">
              <p class="wh40k-requirement-note">Character must have ONE of these:</p>
              {{#each item.system.requirements.previousSteps as |step|}}
              <div class="wh40k-requirement-tag wh40k-requirement-tag--required">
                <i class="fas fa-check"></i>
                {{step}}
              </div>
              {{/each}}
            </div>
          </div>
          {{/if}}
          
          {{!-- Excluded Steps --}}
          {{#if item.system.requirements.excludedSteps.length}}
          <div class="wh40k-origin-section">
            <h3 class="wh40k-section-title">
              <i class="fas fa-ban"></i> Excluded Steps
            </h3>
            
            <div class="wh40k-requirement-list">
              <p class="wh40k-requirement-note">Character cannot have ANY of these:</p>
              {{#each item.system.requirements.excludedSteps as |step|}}
              <div class="wh40k-requirement-tag wh40k-requirement-tag--excluded">
                <i class="fas fa-times"></i>
                {{step}}
              </div>
              {{/each}}
            </div>
          </div>
          {{/if}}
        {{else}}
        <div class="wh40k-empty-state">
          <i class="fas fa-unlock"></i>
          <p>No requirements defined</p>
          <p class="wh40k-field-hint">This origin path is available to all characters</p>
        </div>
        {{/if}}
      </div>
      
      {{!-- CHOICES TAB --}}
      <div class="wh40k-origin-panel" data-tab="choices" data-group="primary">
        {{#if item.system.grants.choices.length}}
          {{#each item.system.grants.choices as |choice index|}}
          <div class="wh40k-origin-section">
            <h3 class="wh40k-section-title">
              <i class="fas fa-random"></i> {{choice.label}}
            </h3>
            
            <div class="wh40k-choice-info">
              <span class="wh40k-choice-badge wh40k-choice-badge--{{choice.type}}">
                <i class="fas {{#if (eq choice.type "skill")}}fa-graduation-cap{{else if (eq choice.type "talent")}}fa-star{{else if (eq choice.type "characteristic")}}fa-dumbbell{{else}}fa-toolbox{{/if}}"></i>
                {{capitalize choice.type}}
              </span>
              <span class="wh40k-choice-count">Choose {{choice.count}}</span>
            </div>
            
            <div class="wh40k-choice-options">
              {{#each choice.options as |option|}}
              <div class="wh40k-choice-option">
                <i class="fas fa-circle"></i>
                {{option}}
              </div>
              {{/each}}
            </div>
          </div>
          {{/each}}
        {{else}}
        <div class="wh40k-empty-state">
          <i class="fas fa-question-circle"></i>
          <p>No player choices required</p>
          <p class="wh40k-field-hint">All grants are automatic</p>
        </div>
        {{/if}}
      </div>
      
      {{!-- DESCRIPTION TAB --}}
      <div class="wh40k-origin-panel" data-tab="description" data-group="primary">
        {{!-- Effect Text --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-magic"></i> Effect Text
          </h3>
          
          <p class="wh40k-field-hint" style="margin-bottom: 0.75rem;">
            <i class="fas fa-info-circle"></i> Brief mechanical summary or flavor text
          </p>
          
          <div class="wh40k-editor-container">
            {{#if inEditMode}}
            {{editor system.effectText target="system.effectText" button=true editable=editable engine="prosemirror"}}
            {{else}}
            <div class="wh40k-description-content">{{{system.effectText}}}</div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Description --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-book"></i> Description
          </h3>
          
          <p class="wh40k-field-hint" style="margin-bottom: 0.75rem;">
            <i class="fas fa-info-circle"></i> Full lore and background information
          </p>
          
          <div class="wh40k-editor-container">
            {{#if inEditMode}}
            {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
            {{else}}
            <div class="wh40k-description-content">{{{system.description.value}}}</div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Notes --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-sticky-note"></i> Notes
          </h3>
          
          <div class="wh40k-property">
            <textarea name="system.notes" rows="4" class="wh40k-property-textarea" placeholder="GM notes, balance considerations, etc.">{{item.system.notes}}</textarea>
          </div>
        </div>
        
        {{!-- Source --}}
        <div class="wh40k-origin-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-book-bookmark"></i> Source
          </h3>
          
          <div class="wh40k-property">
            <input type="text" name="system.source" value="{{item.system.source}}" class="wh40k-property-input" placeholder="Core Rulebook, pg. XX" />
          </div>
        </div>
      </div>
      
    </section>{{!-- .wh40k-origin-content --}}
  </form>
</div>{{!-- .wh40k-origin-sheet --}}
