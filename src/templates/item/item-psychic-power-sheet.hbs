<div class="wh40k-item-sheet tw-flex tw-flex-col tw-h-full tw-overflow-hidden tw-bg-[var(--wh40k-sheet-bg)] tw-text-[var(--wh40k-text-dark)]">
    <form autocomplete="off" class="tw-flex tw-flex-col tw-flex-1 tw-min-h-0">
        <!-- Item Header -->
        <header class="tw-grid tw-gap-3 tw-px-4 tw-py-3 tw-shrink-0 tw-bg-[linear-gradient(180deg,rgba(212,175,55,0.15)_0%,transparent_100%)] tw-border-b-2 tw-border-gold-dark" style="grid-template-columns: 80px 1fr;">
            {{> systems/wh40k-rpg/templates/shared/editable-portrait.hbs src=item.img alt=item.name title=item.name action=false overlay=false extraClass="tw-shrink-0"}}

            <div class="tw-flex tw-flex-col tw-justify-center tw-gap-1 tw-min-w-0">
                <input type="text" class="tw-font-display tw-text-xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-bg-transparent tw-border-none tw-w-full tw-px-1 tw-py-0.5" name="name" value="{{item.name}}" placeholder="Psychic Power Name" />
                <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-opacity-70 tw-uppercase tw-tracking-wide">
                    <i class="fas fa-brain tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                    <span>{{item.system.discipline}} Power</span>
                </div>
                <div class="tw-flex tw-flex-wrap tw-gap-1 tw-mt-1 tw-items-center">
                    {{#if item.system.subtype}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs">
                        <i class="fas fa-tags"></i> {{item.system.subtype}}
                    </span>
                    {{/if}}
                    {{#if item.system.source}}
                    <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-xs">
                        <i class="fas fa-book"></i> {{item.system.source}}
                    </span>
                    {{/if}}
                </div>
            </div>
        </header>

        <!-- Quick Stats Bar -->
        <div class="tw-flex tw-flex-wrap tw-gap-2 tw-px-3 tw-py-2 tw-shrink-0 tw-bg-[var(--wh40k-panel-bg-translucent)] tw-border-b tw-border-[var(--wh40k-border-color-light)]">
            {{#if item.system.action}}
            <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm tw-border tw-border-[#8b00ff] tw-bg-[linear-gradient(135deg,rgba(106,13,173,0.4)_0%,rgba(139,0,255,0.2)_100%)]">
                <span class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"><i class="fas fa-bolt"></i></span>
                <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">ACTION</span>
                <span class="tw-font-semibold">{{item.system.action}}</span>
            </div>
            {{/if}}

            {{#if item.system.range}}
            <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm tw-border tw-border-[color:var(--wh40k-border-color-light)] tw-bg-[color:var(--wh40k-panel-bg)]">
                <span class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"><i class="fas fa-arrows-left-right"></i></span>
                <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">RANGE</span>
                <span class="tw-font-semibold">{{item.system.range}}</span>
            </div>
            {{/if}}

            {{#if item.system.sustained}}
            <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm tw-border tw-border-[color:var(--wh40k-border-color-light)] tw-bg-[color:var(--wh40k-panel-bg)]">
                <span class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"><i class="fas fa-clock"></i></span>
                <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">SUSTAINED</span>
                <span class="tw-font-semibold">{{item.system.sustained}}</span>
            </div>
            {{/if}}

            {{#if item.system.subtype}}
            <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm tw-border tw-border-[color:var(--wh40k-border-color-light)] tw-bg-[color:var(--wh40k-panel-bg)]">
                <span class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"><i class="fas fa-tags"></i></span>
                <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">TYPE</span>
                <span class="tw-font-semibold">{{item.system.subtype}}</span>
            </div>
            {{/if}}

            {{#if item.system.cost}}
            <div class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-md tw-text-sm tw-border tw-border-[color:var(--wh40k-border-color-light)] tw-bg-[color:var(--wh40k-panel-bg)]">
                <span class="tw-w-4 tw-h-4 tw-flex tw-items-center tw-justify-center tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"><i class="fas fa-gem"></i></span>
                <span class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">XP</span>
                <span class="tw-font-semibold">{{item.system.cost}}</span>
            </div>
            {{/if}}
        </div>

        <!-- Tab Navigation -->
        {{> systems/wh40k-rpg/templates/item/partial/item-tab-strip.hbs tabs=(array
            (object tab="power"       label="Power"       icon="fa-hand-sparkles" active=true)
            (object tab="damage"      label="Damage"      icon="fa-burst")
            (object tab="description" label="Description" icon="fa-scroll")
            (object tab="effects"     label="Effects"     icon="fa-magic"))}}

        <!-- Tab Content -->
        <section class="wh40k-tab-content tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-3">
            <!-- Power Tab -->
            <div class="tab active" data-tab="power" data-group="primary">
                <div class="wh40k-panel tw-rounded-lg tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3 class="tw-m-0 tw-font-display tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-uppercase tw-tracking-wide tw-text-sm"><i class="fas fa-brain tw-mr-2 tw-opacity-80"></i> Power Details</h3>
                    </div>
                    <div class="tw-p-3">
                        <div class="tw-grid tw-grid-cols-3 tw-gap-3">
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Discipline</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.discipline" value="{{item.system.discipline}}" placeholder="e.g., Telepathy" />
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">XP Cost</label>
                                <input type="number" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.cost" value="{{item.system.cost}}" />
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Source</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.source" value="{{item.system.source}}" />
                            </div>
                        </div>

                        <div class="tw-grid tw-grid-cols-3 tw-gap-3 tw-mt-4">
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Action</label>
                                <select class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-cursor-pointer" name="system.action">
                                    {{selectOptions (arrayToObject dh.combat.action_speeds) selected=item.system.action}}
                                </select>
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Sustained</label>
                                <select class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-cursor-pointer" name="system.sustained">
                                    {{selectOptions (arrayToObject dh.combat.sustained_speeds) selected=item.system.sustained}}
                                </select>
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Subtype</label>
                                <select class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-cursor-pointer" name="system.subtype">
                                    {{selectOptions (arrayToObject dh.combat.psychic_subtypes) selected=item.system.subtype}}
                                </select>
                            </div>
                        </div>

                        <div class="tw-grid tw-grid-cols-2 tw-gap-3 tw-mt-4">
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Range</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.range" value="{{item.system.range}}" placeholder="e.g., 10m x PR" />
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Prerequisites</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.prerequisites" value="{{item.system.prerequisites}}" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wh40k-panel tw-rounded-lg tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3 class="tw-m-0 tw-font-display tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-uppercase tw-tracking-wide tw-text-sm"><i class="fas fa-crosshairs tw-mr-2 tw-opacity-80"></i> Focus Test</h3>
                    </div>
                    <div class="tw-p-3">
                        <div class="tw-grid tw-grid-cols-3 tw-gap-3">
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Bonus</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.target.bonus" value="{{item.system.target.bonus}}" placeholder="+0" />
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Use Skill</label>
                                <div class="tw-pt-2">
                                    <input type="checkbox" name="system.target.useSkill" {{checked item.system.target.useSkill}} />
                                </div>
                            </div>
                            {{#if item.system.target.useSkill}}
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Skill</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.target.skill" value="{{item.system.target.skill}}" />
                            </div>
                            {{else}}
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Characteristic</label>
                                <select class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-cursor-pointer" name="system.target.characteristic">
                                    {{selectOptions dh.combat.characteristics selected=item.system.target.characteristic}}
                                </select>
                            </div>
                            {{/if}}
                        </div>

                        <div class="tw-grid tw-grid-cols-3 tw-gap-3 tw-mt-4">
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Is Opposed</label>
                                <div class="tw-pt-2">
                                    <input type="checkbox" name="system.target.isOpposed" {{checked item.system.target.isOpposed}} />
                                </div>
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Use Opposed Skill</label>
                                <div class="tw-pt-2">
                                    <input type="checkbox" name="system.target.useOpposedSkill" {{checked item.system.target.useOpposedSkill}} />
                                </div>
                            </div>
                            {{#if item.system.target.useOpposedSkill}}
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Opposed Skill</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.target.opposedSkill" value="{{item.system.target.opposedSkill}}" />
                            </div>
                            {{else}}
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Opposed Characteristic</label>
                                <select class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-cursor-pointer" name="system.target.opposed">
                                    {{selectOptions dh.combat.characteristics selected=item.system.target.opposed}}
                                </select>
                            </div>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Damage Tab -->
            <div class="tab" data-tab="damage" data-group="primary">
                <div class="wh40k-panel tw-rounded-lg tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3 class="tw-m-0 tw-font-display tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-uppercase tw-tracking-wide tw-text-sm"><i class="fas fa-burst tw-mr-2 tw-opacity-80"></i> Damage</h3>
                    </div>
                    <div class="tw-p-3">
                        <div class="tw-grid tw-grid-cols-4 tw-gap-3">
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Attack Type</label>
                                <select class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-cursor-pointer" name="system.attackType">
                                    {{selectOptions (arrayToObject dh.combat.psychic_attacks) selected=item.system.attackType}}
                                </select>
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Damage</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.damage" value="{{item.system.damage}}" placeholder="e.g., 1d10+PR" />
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Type</label>
                                <select class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-cursor-pointer" name="system.damageType">
                                    {{selectOptions (arrayToObject dh.combat.damage_types) selected=item.system.damageType}}
                                </select>
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-1">
                                <label class="tw-text-xs tw-uppercase tw-tracking-wide tw-opacity-70">Penetration</label>
                                <input type="text" class="tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm" name="system.penetration" value="{{item.system.penetration}}" placeholder="0" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wh40k-panel tw-rounded-lg tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3 class="tw-m-0 tw-font-display tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-uppercase tw-tracking-wide tw-text-sm"><i class="fas fa-star tw-mr-2 tw-opacity-80"></i> Attack Specials</h3>
                        <div class="tw-flex tw-gap-1">
                            <button type="button" class="tw-inline-flex tw-items-center tw-gap-1 tw-px-3 tw-py-1 tw-rounded-md tw-cursor-pointer tw-text-sm">
                                <i class="fas fa-plus"></i> Add Special
                            </button>
                        </div>
                    </div>
                    <div class="tw-p-3">
                        <div class="tw-flex tw-flex-wrap tw-gap-1">
                            {{#each item.items as |embedded|}}
                            {{#if embedded.isAttackSpecial}}
                            <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-full tw-text-xs tw-border tw-border-[#8b00ff] tw-bg-[rgba(106,13,173,0.2)] tw-text-[#6a0dad] dark:tw-bg-[rgba(106,13,173,0.3)] dark:tw-text-[#d8a8ff]" data-item-id="{{embedded.id}}">
                                {{embedded.name}}
                                {{#if embedded.system.level}}({{embedded.system.level}}){{/if}}
                                <i class="fas fa-times item-delete tw-cursor-pointer tw-ml-1" data-item-id="{{embedded.id}}"></i>
                            </span>
                            {{/if}}
                            {{/each}}
                        </div>

                        {{#unless item.items.length}}
                        <p class="tw-text-center tw-p-4 tw-italic tw-rounded-md">No attack specials. Drag attack specials here to add them.</p>
                        {{/unless}}
                    </div>
                </div>
            </div>

            <!-- Description Tab -->
            <div class="tab" data-tab="description" data-group="primary">
                <div class="wh40k-panel tw-rounded-lg tw-mb-3 tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-3 tw-py-2 tw-bg-gradient-to-r tw-from-[rgba(212,175,55,0.15)] tw-to-transparent tw-border-b tw-border-[var(--wh40k-border-color-light)]">
                        <h3 class="tw-m-0 tw-font-display tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-uppercase tw-tracking-wide tw-text-sm"><i class="fas fa-scroll tw-mr-2 tw-opacity-80"></i> Description</h3>
                    </div>
                    <div class="tw-p-3">
                        <div class="tw-rounded-md tw-p-3 tw-min-h-[80px]">
                            {{#if inEditMode}}
                              {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
                            {{else}}
                              <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.description.value}}}</div>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Effects Tab -->
            <div class="tab" data-tab="effects" data-group="primary">
                {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
            </div>
        </section>
    </form>
</div>
