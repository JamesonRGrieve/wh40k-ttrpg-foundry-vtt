{{!-- 
  Rogue Trader Gear Item Sheet - V2 Redesign
  Compact 2-column layout with consumable emphasis
--}}
<form class="tw-flex tw-flex-col tw-h-full" autocomplete="off">
    
    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: Compact gear identity with category icon overlay
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-shrink-0 tw-border-b tw-border-[var(--wh40k-border-color)]">
      <div class="tw-relative tw-w-14 tw-h-14 tw-shrink-0 tw-cursor-pointer" data-action="editImage" data-edit="img">
        <img class="tw-w-full tw-h-full tw-object-cover tw-rounded-md" src="{{item.img}}" alt="{{item.name}}" />
        <div class="tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-bg-black/45 tw-opacity-0 hover:tw-opacity-100 tw-transition-opacity tw-rounded-md">
          <i class="fas {{categoryIcon}}"></i>
        </div>
      </div>
      
      <div class="tw-flex tw-flex-col tw-gap-1 tw-min-w-0 tw-flex-1">
        <input type="text" class="tw-font-display tw-text-xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-bg-transparent tw-border-none tw-w-full tw-p-1" name="name" value="{{item.name}}" placeholder="Gear Name" />
        
        <div class="tw-flex tw-flex-wrap tw-gap-1">
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-bg-[rgba(100,100,120,0.3)] tw-px-2 tw-py-0.5 tw-text-xs" title="Category">
            <i class="fas {{categoryIcon}}"></i>
            {{categoryLabel}}
          </span>
          {{#if (ne system.craftsmanship "common")}}
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-bg-[rgba(100,100,120,0.3)] tw-px-2 tw-py-0.5 tw-text-xs" title="Craftsmanship">
            <i class="fas fa-hammer"></i>
            {{system.craftsmanshipLabel}}
          </span>
          {{/if}}
          {{#if (gt system.quantity 1)}}
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-bg-[rgba(100,100,120,0.3)] tw-px-2 tw-py-0.5 tw-text-xs" title="Quantity">
            <i class="fas fa-layer-group"></i>
            ×{{system.quantity}}
          </span>
          {{/if}}
        </div>
      </div>
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         STAT BAR: Key gear statistics with quick adjusters
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[var(--wh40k-border-color)] tw-bg-[var(--wh40k-panel-bg-translucent)]">
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-1 tw-justify-center">
        <div class="tw-opacity-60">
          <i class="fas {{categoryIcon}}"></i>
        </div>
        <div>
          <span class="tw-text-xs tw-uppercase tw-tracking-wider tw-opacity-70">Category</span>
          <span class="tw-font-medium">{{categoryLabel}}</span>
        </div>
      </div>
      
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-1 tw-justify-center">
        <div class="tw-opacity-60">
          <i class="fas fa-cubes"></i>
        </div>
        <div>
          <span class="tw-text-xs tw-uppercase tw-tracking-wider tw-opacity-70">Quantity</span>
          <span class="tw-font-medium">×{{system.quantity}}</span>
        </div>
      </div>
      
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-1 tw-justify-center">
        <div class="tw-opacity-60">
          <i class="fas fa-weight-hanging"></i>
        </div>
        <div>
          <span class="tw-text-xs tw-uppercase tw-tracking-wider tw-opacity-70">Weight</span>
          <span class="tw-font-medium">{{system.effectiveTotalWeight}}kg</span>
        </div>
      </div>
      
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-1 tw-justify-center">
        <div class="tw-opacity-60">
          <i class="fas fa-shop"></i>
        </div>
        <div>
          <span class="tw-text-xs tw-uppercase tw-tracking-wider tw-opacity-70">Availability</span>
          <span class="tw-font-medium">{{system.availabilityLabel}}</span>
        </div>
      </div>
      
      {{#unless hideThroneGelt}}
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-1 tw-justify-center">
        <div class="tw-opacity-60">
          <i class="fas fa-coins"></i>
        </div>
        <div>
          <span class="tw-text-xs tw-uppercase tw-tracking-wider tw-opacity-70">Cost</span>
          <span class="tw-font-medium">{{system.cost.dh2.homebrew.throneGelt}}₮</span>
        </div>
      </div>
      {{/unless}}
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ --}}
    <nav class="wh40k-tabs tw-flex tw-flex-shrink-0 tw-border-b-2 tw-border-[var(--wh40k-border-color)] tw-bg-[var(--wh40k-panel-bg-translucent)]" data-group="primary">
      <button type="button" class="wh40k-tab active tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-gold)] tw-bg-transparent tw-border-b-2 tw-border-b-[var(--wh40k-gold)] tw--mb-0.5 tw-cursor-pointer" data-tab="overview" data-group="primary">
        <i class="fas fa-info-circle tw-mr-1"></i>
        <span>Overview</span>
      </button>
      {{#if hasLimitedUses}}
      <button type="button" class="wh40k-tab tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-text-muted)] tw-bg-transparent tw-border-b-2 tw-border-b-transparent tw--mb-0.5 tw-cursor-pointer hover:tw-text-[var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="usage" data-group="primary">
        <i class="fas fa-hourglass-half tw-mr-1"></i>
        <span>Usage</span>
      </button>
      {{/if}}
      <button type="button" class="wh40k-tab tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-text-muted)] tw-bg-transparent tw-border-b-2 tw-border-b-transparent tw--mb-0.5 tw-cursor-pointer hover:tw-text-[var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="description" data-group="primary">
        <i class="fas fa-book tw-mr-1"></i>
        <span>Description</span>
      </button>
      <button type="button" class="wh40k-tab tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-text-muted)] tw-bg-transparent tw-border-b-2 tw-border-b-transparent tw--mb-0.5 tw-cursor-pointer hover:tw-text-[var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="effects" data-group="primary">
        <i class="fas fa-sparkles tw-mr-1"></i>
        <span>Effects</span>
      </button>
    </nav>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <section class="wh40k-tab-content tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-3">
      
      {{!-- OVERVIEW TAB --}}
      <div class="tab active" data-tab="overview" data-group="primary">
        
        {{!-- 2-Column Layout --}}
        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
          
          {{!-- LEFT COLUMN --}}
          <div class="tw-flex tw-flex-col tw-gap-4">
            
            {{!-- Category & Classification --}}
            <div class="tw-mb-4">
              <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
                <i class="fas fa-tags"></i>
                <h3 class="tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">Classification</h3>
              </div>
              <div class="tw-flex tw-flex-col tw-gap-2">
                <div class="tw-flex tw-flex-col tw-gap-1">
                  <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Category</label>
                  <select name="system.category" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]">
                    <option value="general" {{#if (eq system.category "general")}}selected{{/if}}>General Equipment</option>
                    <option value="tools" {{#if (eq system.category "tools")}}selected{{/if}}>Tools</option>
                    <option value="drugs" {{#if (eq system.category "drugs")}}selected{{/if}}>Drugs</option>
                    <option value="consumable" {{#if (eq system.category "consumable")}}selected{{/if}}>Consumable</option>
                    <option value="medical" {{#if (eq system.category "medical")}}selected{{/if}}>Medical</option>
                    <option value="tech" {{#if (eq system.category "tech")}}selected{{/if}}>Tech</option>
                    <option value="clothing" {{#if (eq system.category "clothing")}}selected{{/if}}>Clothing</option>
                    <option value="survival" {{#if (eq system.category "survival")}}selected{{/if}}>Survival</option>
                    <option value="communications" {{#if (eq system.category "communications")}}selected{{/if}}>Communications</option>
                    <option value="detection" {{#if (eq system.category "detection")}}selected{{/if}}>Detection</option>
                    <option value="religious" {{#if (eq system.category "religious")}}selected{{/if}}>Religious</option>
                    <option value="luxury" {{#if (eq system.category "luxury")}}selected{{/if}}>Luxury</option>
                    <option value="contraband" {{#if (eq system.category "contraband")}}selected{{/if}}>Contraband</option>
                  </select>
                </div>

                <div class="tw-flex tw-flex-col tw-gap-1">
                  <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Craftsmanship</label>
                  <select name="system.craftsmanship" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]">
                    <option value="poor" {{#if (eq system.craftsmanship "poor")}}selected{{/if}}>Poor</option>
                    <option value="common" {{#if (eq system.craftsmanship "common")}}selected{{/if}}>Common</option>
                    <option value="good" {{#if (eq system.craftsmanship "good")}}selected{{/if}}>Good</option>
                    <option value="best" {{#if (eq system.craftsmanship "best")}}selected{{/if}}>Best</option>
                  </select>
                </div>

                <div class="tw-flex tw-flex-col tw-gap-1">
                  <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Availability</label>
                  <select name="system.availability" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]">
                    <option value="ubiquitous" {{#if (eq system.availability "ubiquitous")}}selected{{/if}}>Ubiquitous</option>
                    <option value="abundant" {{#if (eq system.availability "abundant")}}selected{{/if}}>Abundant</option>
                    <option value="plentiful" {{#if (eq system.availability "plentiful")}}selected{{/if}}>Plentiful</option>
                    <option value="common" {{#if (eq system.availability "common")}}selected{{/if}}>Common</option>
                    <option value="average" {{#if (eq system.availability "average")}}selected{{/if}}>Average</option>
                    <option value="scarce" {{#if (eq system.availability "scarce")}}selected{{/if}}>Scarce</option>
                    <option value="rare" {{#if (eq system.availability "rare")}}selected{{/if}}>Rare</option>
                    <option value="very-rare" {{#if (eq system.availability "very-rare")}}selected{{/if}}>Very Rare</option>
                    <option value="extremely-rare" {{#if (eq system.availability "extremely-rare")}}selected{{/if}}>Extremely Rare</option>
                    <option value="near-unique" {{#if (eq system.availability "near-unique")}}selected{{/if}}>Near Unique</option>
                    <option value="unique" {{#if (eq system.availability "unique")}}selected{{/if}}>Unique</option>
                  </select>
                </div>
              </div>
            </div>
            
            {{!-- Storage --}}
            <div class="tw-mb-4">
              <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
                <i class="fas fa-box"></i>
                <h3>Storage</h3>
              </div>
              <div class="tw-mb-3">
                <div class="tw-flex tw-flex-col tw-gap-1">
                  <label class="wh40k-checkbox">
                    <input type="checkbox" name="system.equipped" {{checked system.equipped}} />
                    <i class="fas {{#if system.equipped}}fa-check-square{{else}}fa-square{{/if}}"></i>
                    <span>Equipped</span>
                  </label>
                  <label class="wh40k-checkbox">
                    <input type="checkbox" name="system.inBackpack" {{checked system.inBackpack}} />
                    <i class="fas {{#if system.inBackpack}}fa-check-square{{else}}fa-square{{/if}}"></i>
                    <span>In Backpack</span>
                  </label>
                </div>
              </div>
            </div>
            
          </div>
          
          {{!-- RIGHT COLUMN --}}
          <div class="tw-flex tw-flex-col tw-gap-4">
            
            {{!-- Physical Properties --}}
            <div class="tw-mb-4">
              <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
                <i class="fas fa-cubes"></i>
                <h3>Physical Properties</h3>
              </div>
              <div class="tw-flex tw-flex-col tw-gap-2">
                <div class="tw-flex tw-flex-col tw-gap-1">
                  <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Quantity</label>
                  <input type="number" name="system.quantity" value="{{source.quantity}}"
                         data-dtype="Number" min="1" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]" />
                </div>

                <div class="tw-flex tw-flex-col tw-gap-1">
                  <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Weight per Unit (kg)</label>
                  <input type="number" name="system.weight" value="{{source.weight}}"
                         data-dtype="Number" min="0" step="0.1" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]" />
                </div>

                <div class="tw-flex tw-flex-col tw-gap-1">
                  <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Total Weight</label>
                  <input type="text" value="{{source.effectiveTotalWeight}} kg" disabled class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-muted)] tw-opacity-60" />
                </div>
              </div>
            </div>
            
            {{!-- Economic --}}
            {{#unless hideThroneGelt}}
            <div class="tw-mb-4">
              <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
                <i class="fas fa-coins"></i>
                <h3>Economic</h3>
              </div>
              <div class="tw-mb-3">
                <div class="tw-flex tw-flex-col tw-gap-1">
                  <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Cost (Thrones)</label>
                  <input type="number" name="system.cost.dh2.homebrew.throneGelt" value="{{source.cost.dh2.homebrew.throneGelt}}"
                         data-dtype="Number" min="0" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]" />
                </div>
              </div>
            </div>
            {{/unless}}
            
            {{!-- Consumable Toggle --}}
            <div class="tw-mb-4">
              <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
                <i class="fas fa-flask"></i>
                <h3>Consumable</h3>
              </div>
              <div class="tw-mb-3">
                <label class="wh40k-checkbox">
                  <input type="checkbox" name="system.consumable" {{checked system.consumable}} />
                  <i class="fas {{#if system.consumable}}fa-check-square{{else}}fa-square{{/if}}"></i>
                  <span>Has Limited Uses</span>
                </label>
                
                {{#if system.consumable}}
                <div class="tw-flex tw-flex-col tw-gap-1 tw-mt-2">
                  <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Maximum Uses</label>
                  <input type="number" name="system.uses.max" value="{{source.uses.max}}"
                         data-dtype="Number" min="0" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]" />
                </div>
                {{/if}}
              </div>
            </div>
            
          </div>
          
        </div>
        
      </div>

      {{!-- USAGE TAB (if consumable) --}}
      {{#if hasLimitedUses}}
      <div class="tab" data-tab="usage" data-group="primary">
        
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
            <i class="fas fa-hourglass-half"></i>
            <h3>Consumable Properties</h3>
            <span class="tw-ml-auto tw-text-xs {{#if usesExhausted}}tw-text-red-400{{/if}}">
              {{usesDisplay}}
            </span>
          </div>
          <div class="tw-mb-3">
            
            {{!-- Uses Bar --}}
            <div class="tw-mb-3">
              <div class="tw-relative tw-h-2 tw-rounded-full tw-overflow-hidden tw-mb-1">
                <div class="tw-h-full tw-rounded-full tw-transition-all" {{#if usesExhausted}}data-exhausted="true"{{/if}}
                     style="width: {{multiply (divide system.uses.value system.uses.max) 100}}%"></div>
              </div>
              <div class="tw-text-xs tw-opacity-70">
                {{system.uses.value}} / {{system.uses.max}} Uses Remaining
              </div>
            </div>
            
            <div class="tw-flex tw-flex-col tw-gap-1">
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Current Uses</label>
                <input type="number" name="system.uses.value" value="{{source.uses.value}}"
                       data-dtype="Number" min="0" max="{{system.uses.max}}" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Maximum Uses</label>
                <input type="number" name="system.uses.max" value="{{source.uses.max}}"
                       data-dtype="Number" min="0" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]" />
              </div>
            </div>

            <div class="tw-flex tw-flex-col tw-gap-1">
              <label class="tw-text-xs tw-uppercase tw-tracking-wider tw-text-[color:var(--wh40k-text-muted)]">Duration / Recovery</label>
              <input type="text" name="system.duration" value="{{source.duration}}"
                     placeholder="e.g., 1 hour, 1d6 rounds, permanent" class="tw-bg-[var(--wh40k-input-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-sm tw-px-2 tw-py-1 tw-text-[color:var(--wh40k-text-dark)]" />
            </div>

            {{!-- Quick Actions --}}
            <div class="tw-flex tw-gap-2 tw-mt-3">
              <button type="button" class="tw-inline-flex tw-items-center tw-gap-1 tw-px-3 tw-py-2 tw-bg-[var(--wh40k-btn-bg)] tw-border tw-border-[var(--wh40k-border-color)] tw-rounded-md tw-text-[color:var(--wh40k-text-dark)] tw-text-sm tw-cursor-pointer hover:tw-border-[var(--wh40k-gold)] hover:tw-text-gold" data-action="consumeUse" {{#if usesExhausted}}disabled{{/if}}>
                <i class="fas fa-minus"></i>
                Use One
              </button>
              <button type="button" class="tw-inline-flex tw-items-center tw-gap-1 tw-px-3 tw-py-2 tw-bg-gradient-to-br tw-from-[var(--wh40k-gold-dark)] tw-to-[var(--wh40k-gold)] tw-border tw-border-[var(--wh40k-gold)] tw-rounded-md tw-text-[#1a1a1a] tw-text-sm tw-cursor-pointer" data-action="resetUses">
                <i class="fas fa-redo"></i>
                Reset to Max
              </button>
            </div>
            
          </div>
        </div>
        
      </div>
      {{/if}}

      {{!-- DESCRIPTION TAB --}}
      <div class="tab" data-tab="description" data-group="primary">
        
        {{!-- Mechanical Effect --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
            <i class="fas fa-bolt"></i>
            <h3>Mechanical Effect</h3>
          </div>
          <div class="tw-mb-3">
            {{editor system.effect target="system.effect" button=true editable=editable engine="prosemirror"}}
          </div>
        </div>

        {{!-- Full Description --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
            <i class="fas fa-book"></i>
            <h3>Description</h3>
          </div>
          <div class="tw-mb-3">
            {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
          </div>
        </div>

        {{!-- GM Notes --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-2">
            <i class="fas fa-sticky-note"></i>
            <h3>GM Notes</h3>
          </div>
          <div class="tw-mb-3">
            <textarea name="system.notes" rows="4" placeholder="Special rules, GM notes, etc.">{{system.notes}}</textarea>
          </div>
        </div>

        {{!-- Source --}}
        <div class="tw-mb-4">
