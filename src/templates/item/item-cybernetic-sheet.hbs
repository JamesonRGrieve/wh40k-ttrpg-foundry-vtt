{{!-- 
  Rogue Trader Cybernetic Item Sheet - V2 Complete Redesign
  Comprehensive cybernetic augmentation configuration
--}}
<form class="tw-flex tw-flex-col tw-h-full" autocomplete="off">
    
    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: Compact cybernetic identity with inline badges
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-shrink-0 tw-border-b tw-border-[var(--wh40k-border-color)]">
      {{> systems/wh40k-rpg/templates/shared/editable-portrait.hbs src=item.img alt=item.name sizeClass="tw-w-14 tw-h-14" frameClass="" overlayTextClass="" overlayIconClass="" extraClass="tw-shrink-0"}}
      
      <div class="tw-flex tw-flex-col tw-gap-1 tw-min-w-0 tw-flex-1">
        <input type="text" class="tw-font-display tw-text-xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure" name="name" value="{{item.name}}" placeholder="Cybernetic Name" />
        
        <div class="tw-flex tw-flex-wrap tw-gap-1">
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-bg-[rgba(100,100,120,0.3)] tw-px-2 tw-py-0.5 tw-text-xs" title="Cybernetic Type">
            <i class="fas fa-microchip"></i>
            {{system.typeLabel}}
          </span>
          {{#if system.locations.size}}
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-bg-[rgba(100,100,120,0.3)] tw-px-2 tw-py-0.5 tw-text-xs" title="Body Locations">
            <i class="fas fa-location-dot"></i>
            {{system.locationsLabel}}
          </span>
          {{/if}}
          {{#if (ne system.craftsmanship "common")}}
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-bg-[rgba(100,100,120,0.3)] tw-px-2 tw-py-0.5 tw-text-xs" title="Craftsmanship">
            <i class="fas fa-hammer"></i>
            {{system.craftsmanshipLabel}}
          </span>
          {{/if}}
          {{#if system.hasArmourPoints}}
          <span class="tw-inline-flex tw-items-center tw-gap-1 tw-rounded-full tw-bg-[rgba(100,100,120,0.3)] tw-px-2 tw-py-0.5 tw-text-xs" title="Provides Armour">
            <i class="fas fa-shield-halved"></i>
            Armoured
          </span>
          {{/if}}
        </div>
      </div>
      
      <div class="tw-flex tw-items-center tw-justify-end tw-shrink-0">
        <label class="tw-flex tw-items-center tw-cursor-pointer tw-gap-1" title="Toggle Equipped">
          <input type="checkbox" name="system.equipped" {{checked system.equipped}} class="tw-sr-only" />
          <span class="tw-text-xl tw-transition-colors {{#if system.equipped}}tw-text-[color:var(--wh40k-green-bright)]{{else}}tw-text-white/50{{/if}}">
            <i class="fas {{#if system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
          </span>
          <span class="tw-text-xs {{#if system.equipped}}tw-text-[color:var(--wh40k-green-bright)]{{else}}tw-text-[color:rgba(214,221,235,0.7)]{{/if}}">{{#if system.equipped}}Installed{{else}}Uninstalled{{/if}}</span>
        </label>
      </div>
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         STATS BAR: Key cybernetic info at a glance
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-2 tw-border-b tw-border-[var(--wh40k-border-color)] tw-bg-[var(--wh40k-panel-bg-translucent)]">
      {{!-- Type --}}
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-1 tw-justify-center">
        <div class="tw-opacity-60">
          <i class="fas fa-microchip"></i>
        </div>
        <div>
          <span class="tw-text-xs tw-uppercase tw-tracking-wider tw-opacity-70">Type</span>
          <span class="tw-font-medium">{{system.typeLabel}}</span>
        </div>
      </div>
      
      {{!-- Weight --}}
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-1 tw-justify-center">
        <div class="tw-opacity-60">
          <i class="fas fa-weight-hanging"></i>
        </div>
        <div>
          <span class="tw-text-xs tw-uppercase tw-tracking-wider tw-opacity-70">Weight</span>
          <span class="tw-font-medium">{{system.weight}}kg</span>
        </div>
      </div>
      
      {{!-- Availability --}}
      <div class="tw-flex tw-items-center tw-gap-1.5 tw-flex-1 tw-justify-center">
        <div class="tw-opacity-60">
          <i class="fas fa-store"></i>
        </div>
        <div>
          <span class="tw-text-xs tw-uppercase tw-tracking-wider tw-opacity-70">Availability</span>
          <span class="tw-font-medium">{{system.availabilityLabel}}</span>
        </div>
      </div>
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ --}}
    <nav class="wh40k-tabs tw-flex tw-flex-shrink-0 tw-border-b-2 tw-border-[var(--wh40k-border-color)] tw-bg-[var(--wh40k-panel-bg-translucent)]" data-group="primary">
      <button type="button" class="wh40k-tab active tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-gold)] tw-bg-transparent tw-border-b-2 tw-border-b-[var(--wh40k-gold)] tw--mb-0.5 tw-cursor-pointer" data-tab="properties" data-group="primary">
        <i class="fas fa-cog tw-mr-1"></i>
        <span>Properties</span>
      </button>
      <button type="button" class="wh40k-tab tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-text-muted)] tw-bg-transparent tw-border-b-2 tw-border-b-transparent tw--mb-0.5 tw-cursor-pointer hover:tw-text-[var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="effects" data-group="primary">
        <i class="fas fa-bolt tw-mr-1"></i>
        <span>Effects</span>
      </button>
      <button type="button" class="wh40k-tab tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-text-muted)] tw-bg-transparent tw-border-b-2 tw-border-b-transparent tw--mb-0.5 tw-cursor-pointer hover:tw-text-[var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="armour" data-group="primary">
        <i class="fas fa-shield-halved tw-mr-1"></i>
        <span>Armour</span>
      </button>
      <button type="button" class="wh40k-tab tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-text-muted)] tw-bg-transparent tw-border-b-2 tw-border-b-transparent tw--mb-0.5 tw-cursor-pointer hover:tw-text-[var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="installation" data-group="primary">
        <i class="fas fa-syringe tw-mr-1"></i>
        <span>Installation</span>
      </button>
      <button type="button" class="wh40k-tab tw-px-4 tw-py-2 tw-font-display tw-text-xs tw-uppercase tw-tracking-widest tw-text-[var(--wh40k-text-muted)] tw-bg-transparent tw-border-b-2 tw-border-b-transparent tw--mb-0.5 tw-cursor-pointer hover:tw-text-[var(--wh40k-gold)] hover:tw-bg-[rgba(212,175,55,0.08)]" data-tab="description" data-group="primary">
        <i class="fas fa-book tw-mr-1"></i>
        <span>Description</span>
      </button>
    </nav>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-tab-content tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-3">
      
      {{!-- PROPERTIES TAB --}}
      <div class="tab active" data-tab="properties" data-group="primary">
        
        {{!-- Cybernetic Type & Locations --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-microchip"></i>
            <h3>Cybernetic Configuration</h3>
          </div>
          <div class="tw-mb-3">
            <div class="tw-grid tw-grid-cols-2 tw-gap-3">
              
              {{!-- Type --}}
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">
                  <i class="fas fa-tag"></i> Type
                </label>
                <select name="system.type" class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]">
                  {{#select system.type}}
                  <option value="replacement">Replacement</option>
                  <option value="implant">Implant</option>
                  <option value="augmetic">Augmetic</option>
                  <option value="bionic">Bionic</option>
                  <option value="mechadendrite">Mechadendrite</option>
                  <option value="integrated-weapon">Integrated Weapon</option>
                  {{/select}}
                </select>
              </div>
              
              {{!-- Slot/Location Toggles --}}
              <div class="tw-flex tw-flex-col tw-gap-1.5 tw-col-span-2">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">
                  <i class="fas fa-location-dot"></i> Body Locations
                </label>
                <div class="tw-flex tw-flex-wrap tw-gap-2">
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="head" 
                           {{#if (includes system.locations "head")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-head-side-brain"></i> Head
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="eyes" 
                           {{#if (includes system.locations "eyes")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-eye"></i> Eyes
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="ears" 
                           {{#if (includes system.locations "ears")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-ear-listen"></i> Ears
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="mouth" 
                           {{#if (includes system.locations "mouth")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-face-grin-tongue"></i> Mouth
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="brain" 
                           {{#if (includes system.locations "brain")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-brain"></i> Brain
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="leftArm" 
                           {{#if (includes system.locations "leftArm")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-hand-fist"></i> Left Arm
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="rightArm" 
                           {{#if (includes system.locations "rightArm")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-hand-fist"></i> Right Arm
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="body" 
                           {{#if (includes system.locations "body")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-shield"></i> Body
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="organs" 
                           {{#if (includes system.locations "organs")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-heart-pulse"></i> Organs
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="leftLeg" 
                           {{#if (includes system.locations "leftLeg")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-boot"></i> Left Leg
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="rightLeg" 
                           {{#if (includes system.locations "rightLeg")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-boot"></i> Right Leg
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="spine" 
                           {{#if (includes system.locations "spine")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-spine"></i> Spine
                    </span>
                  </label>
                  <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2 tw-py-1 tw-rounded tw-border tw-border-[var(--wh40k-border-color)] tw-cursor-pointer">
                    <input type="checkbox" name="system.locations" value="internal" 
                           {{#if (includes system.locations "internal")}}checked{{/if}} />
                    <span class="tw-text-sm">
                      <i class="fas fa-gears"></i> Internal
                    </span>
                  </label>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        {{!-- Physical Properties --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-box"></i>
            <h3>Physical Properties</h3>
          </div>
          <div class="tw-mb-3">
            <div class="tw-grid tw-grid-cols-2 tw-gap-3">
              
              {{!-- Weight --}}
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">
                  <i class="fas fa-weight-hanging"></i> Weight (kg)
                </label>
                <input type="number" name="system.weight" value="{{source.weight}}" 
                       step="0.1" min="0" class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]" />
              </div>
              
              {{!-- Craftsmanship --}}
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">
                  <i class="fas fa-hammer"></i> Craftsmanship
                </label>
                <select name="system.craftsmanship" class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]">
                  {{#select system.craftsmanship}}
                  <option value="poor">Poor</option>
                  <option value="common">Common</option>
                  <option value="good">Good</option>
                  <option value="best">Best</option>
                  {{/select}}
                </select>
              </div>
              
              {{!-- Availability --}}
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">
                  <i class="fas fa-store"></i> Availability
                </label>
                <select name="system.availability" class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]">
                  {{#select system.availability}}
                  <option value="ubiquitous">Ubiquitous</option>
                  <option value="abundant">Abundant</option>
                  <option value="plentiful">Plentiful</option>
                  <option value="common">Common</option>
                  <option value="average">Average</option>
                  <option value="scarce">Scarce</option>
                  <option value="rare">Rare</option>
                  <option value="veryRare">Very Rare</option>
                  <option value="extremelyRare">Extremely Rare</option>
                  <option value="nearUnique">Near Unique</option>
                  <option value="unique">Unique</option>
                  {{/select}}
                </select>
              </div>
            </div>
          </div>
        </div>
        
      </div>
      
      {{!-- EFFECTS TAB --}}
      <div class="tab" data-tab="effects" data-group="primary">
        
        {{!-- Effect Description --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-bolt"></i>
            <h3>Effect</h3>
          </div>
          <div class="tw-mb-3">
            <p class="tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-italic tw-mb-2">
              <i class="fas fa-info-circle"></i> Describe the mechanical benefits or abilities granted by this cybernetic.
            </p>
            <div class="tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-md tw-p-2 [&_.editor]:tw-min-h-[150px]">
              {{#if inEditMode}}
              {{editor system.effect target="system.effect" button=true editable=editable engine="prosemirror"}}
              {{else}}
              <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.effect}}}</div>
              {{/if}}
            </div>
          </div>
        </div>
        
        {{!-- Drawbacks --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-exclamation-triangle"></i>
            <h3>Drawbacks</h3>
          </div>
          <div class="tw-mb-3">
            <p class="tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-italic tw-mb-2">
              <i class="fas fa-info-circle"></i> Any negative effects, limitations, or complications from this cybernetic.
            </p>
            <div class="tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-md tw-p-2 [&_.editor]:tw-min-h-[150px]">
              {{#if inEditMode}}
              {{editor system.drawbacks target="system.drawbacks" button=true editable=editable engine="prosemirror"}}
              {{else}}
              <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.drawbacks}}}</div>
              {{/if}}
            </div>
          </div>
        </div>
        
        {{!-- Modifiers Display --}}
        {{#if (or system.modifiers.characteristics system.modifiers.skills system.modifiers.combat system.modifiers.wounds system.modifiers.movement)}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-chart-line"></i>
            <h3>Stat Modifiers</h3>
          </div>
          <div class="tw-mb-3">
            <div class="tw-flex tw-flex-col tw-gap-3 tw-p-3 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-md">
              
              {{#if system.modifiers.characteristics}}
              <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)]">
                <h4 class="tw-text-[0.8rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-gold tw-m-0 tw-pb-1.5 tw-border-b tw-border-b-[var(--color-border-light)]">Characteristics</h4>
                <div class="tw-flex tw-flex-col tw-gap-1">
                  {{#each system.modifiers.characteristics}}
                  <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)]">
                    <span class="tw-text-[color:var(--color-text-secondary)] tw-font-semibold">{{capitalize @key}}</span>
                    <span class="tw-font-display tw-font-bold tw-text-[0.95rem] {{#if (gt this 0)}}positive tw-text-[color:var(--wh40k-accent-green-bright)]{{else}}negative tw-text-[color:var(--wh40k-accent-combat)]{{/if}}">
                      {{signedNumber this}}
                    </span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}

              {{#if system.modifiers.skills}}
              <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)]">
                <h4 class="tw-text-[0.8rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-gold tw-m-0 tw-pb-1.5 tw-border-b tw-border-b-[var(--color-border-light)]">Skills</h4>
                <div class="tw-flex tw-flex-col tw-gap-1">
                  {{#each system.modifiers.skills}}
                  <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)]">
                    <span class="tw-text-[color:var(--color-text-secondary)] tw-font-semibold">{{capitalize @key}}</span>
                    <span class="tw-font-display tw-font-bold tw-text-[0.95rem] {{#if (gt this 0)}}positive tw-text-[color:var(--wh40k-accent-green-bright)]{{else}}negative tw-text-[color:var(--wh40k-accent-combat)]{{/if}}">
                      {{signedNumber this}}
                    </span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}

              {{#if system.modifiers.combat}}
              <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)]">
                <h4 class="tw-text-[0.8rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-gold tw-m-0 tw-pb-1.5 tw-border-b tw-border-b-[var(--color-border-light)]">Combat</h4>
                <div class="tw-flex tw-flex-col tw-gap-1">
                  {{#each system.modifiers.combat}}
                  <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)]">
                    <span class="tw-text-[color:var(--color-text-secondary)] tw-font-semibold">{{capitalize @key}}</span>
                    <span class="tw-font-display tw-font-bold tw-text-[0.95rem] {{#if (gt this 0)}}positive tw-text-[color:var(--wh40k-accent-green-bright)]{{else}}negative tw-text-[color:var(--wh40k-accent-combat)]{{/if}}">
                      {{signedNumber this}}
                    </span>
                  </div>
                  {{/each}}
                </div>
              </div>
              {{/if}}

              {{#if system.modifiers.wounds}}
              <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)]">
                <h4 class="tw-text-[0.8rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-gold tw-m-0 tw-pb-1.5 tw-border-b tw-border-b-[var(--color-border-light)]">Other</h4>
                <div class="tw-flex tw-flex-col tw-gap-1">
                  <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)]">
                    <span class="tw-text-[color:var(--color-text-secondary)] tw-font-semibold">Wounds</span>
                    <span class="tw-font-display tw-font-bold tw-text-[0.95rem] {{#if (gt system.modifiers.wounds 0)}}positive tw-text-[color:var(--wh40k-accent-green-bright)]{{else}}negative tw-text-[color:var(--wh40k-accent-combat)]{{/if}}">
                      {{signedNumber system.modifiers.wounds}}
                    </span>
                  </div>
                </div>
              </div>
              {{/if}}

              {{#if system.modifiers.movement}}
              <div class="tw-flex tw-flex-col tw-gap-[var(--wh40k-space-sm)]">
                <h4 class="tw-text-[0.8rem] tw-font-bold tw-uppercase tw-tracking-[0.05em] tw-text-gold tw-m-0 tw-pb-1.5 tw-border-b tw-border-b-[var(--color-border-light)]">Movement</h4>
                <div class="tw-flex tw-flex-col tw-gap-1">
                  <div class="tw-flex tw-items-center tw-gap-[var(--wh40k-space-md)]">
                    <span class="tw-text-[color:var(--color-text-secondary)] tw-font-semibold">Movement Bonus</span>
                    <span class="tw-font-display tw-font-bold tw-text-[0.95rem] {{#if (gt system.modifiers.movement 0)}}positive tw-text-[color:var(--wh40k-accent-green-bright)]{{else}}negative tw-text-[color:var(--wh40k-accent-combat)]{{/if}}">
                      {{signedNumber system.modifiers.movement}}
                    </span>
                  </div>
                </div>
              </div>
              {{/if}}
            </div>
            
            <p class="tw-mt-4 tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-italic">
              <i class="fas fa-info-circle"></i> Modifiers are configured via Active Effects. This panel is read-only.
            </p>
          </div>
        </div>
        {{else}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-center tw-opacity-70">
            <i class="fas fa-chart-line"></i>
            <p>No stat modifiers defined</p>
            <p class="tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-italic tw-mb-2">Use Active Effects tab to add bonuses</p>
          </div>
        </div>
        {{/if}}
        
      </div>
      
      {{!-- ARMOUR TAB --}}
      <div class="tab" data-tab="armour" data-group="primary">
        
        {{!-- Armour Points Toggle --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-shield-halved"></i>
            <h3>Armour Protection</h3>
          </div>
          <div class="tw-mb-3">
            <div class="tw-flex tw-flex-col tw-gap-1.5 tw-justify-center">
              <label class="tw-flex tw-items-center tw-gap-2 tw-cursor-pointer tw-text-[0.85rem] tw-text-[color:var(--color-text-primary)]">
                <input type="checkbox" name="system.hasArmourPoints" {{checked system.hasArmourPoints}} />
                <span>This cybernetic provides armour protection</span>
              </label>
            </div>
          </div>
        </div>
        
        {{!-- Armour Points Grid (if enabled) --}}
        {{#if system.hasArmourPoints}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-shield-halved"></i>
            <h3>Armour Points by Location</h3>
          </div>
          <div class="tw-mb-3">
            <div class="tw-grid tw-grid-cols-3 tw-gap-3">
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label><i class="fas fa-head-side-brain"></i> Head</label>
                <input type="number" name="system.armourPoints.head" value="{{source.armourPoints.head}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label><i class="fas fa-hand-fist"></i> Left Arm</label>
                <input type="number" name="system.armourPoints.leftArm" value="{{source.armourPoints.leftArm}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label><i class="fas fa-hand-fist"></i> Right Arm</label>
                <input type="number" name="system.armourPoints.rightArm" value="{{source.armourPoints.rightArm}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label><i class="fas fa-shield"></i> Body</label>
                <input type="number" name="system.armourPoints.body" value="{{source.armourPoints.body}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label><i class="fas fa-boot"></i> Left Leg</label>
                <input type="number" name="system.armourPoints.leftLeg" value="{{source.armourPoints.leftLeg}}" 
                       data-dtype="Number" min="0" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1">
                <label><i class="fas fa-boot"></i> Right Leg</label>
                <input type="number" name="system.armourPoints.rightLeg" value="{{source.armourPoints.rightLeg}}" 
                       data-dtype="Number" min="0" />
              </div>
            </div>
            <p class="tw-mt-4 tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-italic">
              <i class="fas fa-info-circle"></i> Cybernetic armour stacks with worn armour at the affected locations.
            </p>
          </div>
        </div>
        {{else}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-6 tw-text-center tw-opacity-70">
            <i class="fas fa-shield-halved"></i>
            <p>This cybernetic does not provide armour</p>
            <p class="tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-italic tw-mb-2">Enable armour protection above to configure AP values</p>
          </div>
        </div>
        {{/if}}
        
      </div>
      
      {{!-- INSTALLATION TAB --}}
      <div class="tab" data-tab="installation" data-group="primary">
        
        {{!-- Installation Requirements --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-syringe"></i>
            <h3>Installation Requirements</h3>
          </div>
          <div class="tw-mb-3">
            <div class="tw-grid tw-grid-cols-2 tw-gap-3">
              
              {{!-- Surgery Required --}}
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">
                  <i class="fas fa-user-doctor"></i> Surgery Type
                </label>
                <input type="text" name="system.installation.surgery" value="{{source.installation.surgery}}" 
                       class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]" placeholder="e.g., Major, Simple, Complex" />
              </div>
              
              {{!-- Difficulty --}}
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">
                  <i class="fas fa-gauge-high"></i> Difficulty
                </label>
                <input type="text" name="system.installation.difficulty" value="{{source.installation.difficulty}}" 
                       class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]" placeholder="e.g., Challenging (-10), Difficult (-20)" />
              </div>
              
              {{!-- Recovery Time --}}
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">
                  <i class="fas fa-clock"></i> Recovery Time
                </label>
                <input type="text" name="system.installation.recoveryTime" value="{{source.installation.recoveryTime}}" 
                       class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]" placeholder="e.g., 1d5 days, 2 weeks" />
              </div>
            </div>
            
            <p class="tw-mt-4 tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-italic">
              <i class="fas fa-info-circle"></i> Installation typically requires a successful Medicae test. Failed installations may cause complications or injury.
            </p>
          </div>
        </div>
        
      </div>
      
      {{!-- DESCRIPTION TAB --}}
      <div class="tab" data-tab="description" data-group="primary">
        
        {{!-- Description --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-book"></i>
            <h3>Description</h3>
          </div>
          <div class="tw-mb-3">
            <p class="tw-text-[0.7rem] tw-text-[color:var(--color-text-tertiary)] tw-italic tw-mb-2">
              <i class="fas fa-info-circle"></i> Flavor text, appearance, and background information.
            </p>
            <div class="tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-md tw-p-2 [&_.editor]:tw-min-h-[150px]">
              {{#if inEditMode}}
              {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
              {{else}}
              <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.description.value}}}</div>
              {{/if}}
            </div>
          </div>
        </div>
        
        {{!-- Notes --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-sticky-note"></i>
            <h3>Notes</h3>
          </div>
          <div class="tw-mb-3">
            <div class="tw-flex tw-flex-col tw-gap-1.5">
              <textarea name="system.notes" rows="4" class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm tw-min-h-[80px] tw-resize-y focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]"
                        placeholder="GM notes, house rules, special considerations...">{{system.notes}}</textarea>
            </div>
          </div>
        </div>
        
        {{!-- Source --}}
        <div class="tw-mb-4">
          <div class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-display tw-mb-3">
            <i class="fas fa-book-bookmark"></i>
            <h3>Source</h3>
          </div>
          <div class="tw-mb-3">
            <div class="tw-grid tw-grid-cols-2 tw-gap-3">
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">Book</label>
                <input type="text" name="system.source.book" value="{{source.source.book}}" 
                       class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]" placeholder="RT: Core Rulebook" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1.5">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">Page</label>
                <input type="text" name="system.source.page" value="{{source.source.page}}" 
                       class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]" placeholder="142" />
              </div>
              <div class="tw-flex tw-flex-col tw-gap-1.5 tw-col-span-2">
                <label class="tw-text-xs tw-font-semibold tw-uppercase tw-tracking-[0.05em] tw-text-[color:var(--color-text-secondary)]">Custom Reference</label>
                <input type="text" name="system.source.custom" value="{{source.source.custom}}" 
                       class="tw-w-full tw-px-3 tw-py-2 tw-bg-[var(--color-bg-option)] tw-border tw-border-[var(--color-border-secondary)] tw-rounded-sm tw-text-[color:var(--color-text-primary)] tw-text-sm focus:tw-outline-none focus:tw-border-[var(--wh40k-color-gold)]" placeholder="Optional: Custom source text overrides book/page" />
              </div>
            </div>
          </div>
        </div>
        
      </div>
      
    </div>
</form>
