{{! Rogue Trader Peer/Enemy Sheet - Modern Design }}
<form class="tw-flex tw-flex-col tw-h-full" autocomplete="off">
    {{! Header }}
    <div>
        <div class="tw-pl-4">
            <div class="tw-flex tw-flex-col tw-gap-1">
                <label>Name</label>
                <input name="name" type="text" value="{{item.name}}" />
            </div>
        </div>
    </div>

    {{! Main Fields }}
    <div class="tw-p-3">
        <div class="tw-flex tw-flex-col tw-gap-1">
            <label>Modifier</label>
            <input class="tw-w-24" name="system.modifier" type="number" data-dtype="Number" value="{{item.system.modifier}}" />
        </div>
    </div>

    {{! Description }}
    <div class="tw-p-4 tw-border-t tw-border-gold bc:tw-border-crimson-light dh1e:tw-border-gold-raw-l5 dh2e:tw-border-gold-raw dw:tw-border-accent-combat ow:tw-border-brass-l20 rt:tw-border-gold im:tw-border-failure">
        <div class="tw-flex tw-flex-col tw-gap-1">
            <label>Description</label>
            <textarea class="tw-w-full tw-p-2 tw-rounded tw-border tw-border-[rgba(255,255,255,0.1)] tw-bg-[rgba(0,0,0,0.2)] tw-text-[var(--color-text-primary)]" name="system.description.value">{{item.system.description.value}}</textarea>
        </div>
    </div>
</form>
