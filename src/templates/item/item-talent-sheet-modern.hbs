{{!-- 
  Rogue Trader Talent Item Sheet - Modern Tabbed Redesign
  Comprehensive talent configuration with tabbed interface
--}}
<div class="wh40k-talent-sheet">
  <form autocomplete="off">
    
    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: Compact talent identity with inline badges
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="wh40k-talent-header">
      <div class="wh40k-talent-header__image" data-action="editImage" data-edit="img">
        <img src="{{item.img}}" alt="{{item.name}}" />
        <div class="wh40k-talent-header__image-overlay">
          <i class="fas fa-edit"></i>
        </div>
      </div>
      
      <div class="wh40k-talent-header__info">
        <input type="text" class="wh40k-talent-header__name" name="name" value="{{item.name}}" placeholder="Talent Name" />
        
        <div class="wh40k-talent-header__meta">
          {{!-- Tier Badge --}}
          {{#if (gt item.system.tier 0)}}
          <span class="wh40k-talent-badge wh40k-talent-badge--tier wh40k-talent-badge--tier{{item.system.tier}}" title="Tier {{item.system.tier}}">
            <i class="fas fa-layer-group"></i>
            T{{item.system.tier}}
          </span>
          {{/if}}
          
          {{!-- Category Badge --}}
          <span class="wh40k-talent-badge wh40k-talent-badge--category" title="{{item.system.categoryLabel}}">
            <i class="fas fa-tag"></i>
            {{item.system.categoryLabel}}
          </span>
          
          {{!-- XP Cost Badge --}}
          {{#if (gt item.system.cost 0)}}
          <span class="wh40k-talent-badge wh40k-talent-badge--cost" title="Experience Cost">
            <i class="fas fa-coins"></i>
            {{item.system.cost}} XP
          </span>
          {{/if}}
          
          {{!-- Passive Indicator --}}
          {{#if item.system.isPassive}}
          <span class="wh40k-talent-badge wh40k-talent-badge--passive" title="Passive Talent">
            <i class="fas fa-circle-check"></i>
            Passive
          </span>
          {{/if}}
          
          {{!-- Stackable Indicator --}}
          {{#if item.system.stackable}}
          <span class="wh40k-talent-badge wh40k-talent-badge--stackable" title="Can Take Multiple Times">
            <i class="fas fa-layer-group"></i>
            Rank {{item.system.rank}}
          </span>
          {{/if}}
        </div>
      </div>
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         STATS BAR: Key talent info at a glance
    ═══════════════════════════════════════════════════════════════════ --}}
    <div class="wh40k-talent-stats">
      {{!-- Tier --}}
      {{#if (gt item.system.tier 0)}}
      <div class="wh40k-talent-stat wh40k-talent-stat--tier">
        <div class="wh40k-talent-stat__icon">
          <i class="fas fa-layer-group"></i>
        </div>
        <div class="wh40k-talent-stat__content">
          <span class="wh40k-talent-stat__label">Tier</span>
          <span class="wh40k-talent-stat__value">{{item.system.tier}}</span>
        </div>
      </div>
      {{/if}}
      
      {{!-- XP Cost --}}
      {{#if (gt item.system.cost 0)}}
      <div class="wh40k-talent-stat wh40k-talent-stat--cost">
        <div class="wh40k-talent-stat__icon">
          <i class="fas fa-coins"></i>
        </div>
        <div class="wh40k-talent-stat__content">
          <span class="wh40k-talent-stat__label">XP Cost</span>
          <span class="wh40k-talent-stat__value">{{item.system.cost}}</span>
        </div>
      </div>
      {{/if}}
      
      {{!-- Category --}}
      <div class="wh40k-talent-stat">
        <div class="wh40k-talent-stat__icon">
          <i class="fas fa-tag"></i>
        </div>
        <div class="wh40k-talent-stat__content">
          <span class="wh40k-talent-stat__label">Category</span>
          <span class="wh40k-talent-stat__value">{{item.system.categoryLabel}}</span>
        </div>
      </div>
      
      {{!-- Type --}}
      <div class="wh40k-talent-stat">
        <div class="wh40k-talent-stat__icon">
          <i class="fas {{#if item.system.isPassive}}fa-circle-check{{else}}fa-bolt{{/if}}"></i>
        </div>
        <div class="wh40k-talent-stat__content">
          <span class="wh40k-talent-stat__label">Type</span>
          <span class="wh40k-talent-stat__value">{{#if item.system.isPassive}}Passive{{else}}Active{{/if}}</span>
        </div>
      </div>
      
      {{!-- Rank (if stackable) --}}
      {{#if item.system.stackable}}
      <div class="wh40k-talent-stat">
        <div class="wh40k-talent-stat__icon">
          <i class="fas fa-layer-group"></i>
        </div>
        <div class="wh40k-talent-stat__content">
          <span class="wh40k-talent-stat__label">Rank</span>
          <span class="wh40k-talent-stat__value">{{item.system.rank}}</span>
        </div>
      </div>
      {{/if}}
    </div>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ═══════════════════════════════════════════════════════════════════ --}}
    <nav class="wh40k-tabs wh40k-tabs--talent wh40k-talent-tabs" data-group="primary">
      <button type="button" class="wh40k-tab wh40k-talent-tab active" data-tab="properties" data-group="primary">
        <i class="fas fa-cog"></i>
        <span>Properties</span>
      </button>
      <button type="button" class="wh40k-tab wh40k-talent-tab" data-tab="prerequisites" data-group="primary">
        <i class="fas fa-lock"></i>
        <span>Prerequisites</span>
      </button>
      <button type="button" class="wh40k-tab wh40k-talent-tab" data-tab="effects" data-group="primary">
        <i class="fas fa-magic"></i>
        <span>Effects</span>
      </button>
      <button type="button" class="wh40k-tab wh40k-talent-tab" data-tab="description" data-group="primary">
        <i class="fas fa-book"></i>
        <span>Description</span>
      </button>
    </nav>

    {{!-- ═══════════════════════════════════════════════════════════════════
         TAB CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <section class="wh40k-talent-content wh40k-tab-content wh40k-tab-content--talent">
      
      {{!-- PROPERTIES TAB --}}
      <div class="wh40k-talent-panel tab active" data-tab="properties" data-group="primary">
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-info-circle"></i> Basic Properties
          </h3>
          
          <div class="wh40k-properties-grid">
            {{!-- Category --}}
            <div class="wh40k-property">
              <label class="wh40k-property-label">Category</label>
              <select name="system.category" class="wh40k-property-input">
                {{#select item.system.category}}
                <option value="">General</option>
                <option value="general">General</option>
                <option value="combat">Combat</option>
                <option value="social">Social</option>
                <option value="investigation">Investigation</option>
                <option value="psychic">Psychic</option>
                <option value="navigator">Navigator</option>
                <option value="tech">Tech</option>
                <option value="leadership">Leadership</option>
                <option value="career">Career</option>
                <option value="unique">Unique</option>
                {{/select}}
              </select>
            </div>
            
            {{!-- Tier --}}
            <div class="wh40k-property">
              <label class="wh40k-property-label">Tier</label>
              <select name="system.tier" class="wh40k-property-input">
                <option value="0" {{#if (eq item.system.tier 0)}}selected{{/if}}>—</option>
                <option value="1" {{#if (eq item.system.tier 1)}}selected{{/if}}>Tier 1</option>
                <option value="2" {{#if (eq item.system.tier 2)}}selected{{/if}}>Tier 2</option>
                <option value="3" {{#if (eq item.system.tier 3)}}selected{{/if}}>Tier 3</option>
              </select>
            </div>
            
            {{!-- XP Cost --}}
            <div class="wh40k-property">
              <label class="wh40k-property-label">XP Cost</label>
              <input type="number" name="system.cost" value="{{item.system.cost}}" min="0" class="wh40k-property-input" placeholder="0" />
            </div>
            
            {{!-- Passive/Active --}}
            <div class="wh40k-property wh40k-property--checkbox">
              <label class="wh40k-property-label-inline">
                <input type="checkbox" name="system.isPassive" {{checked item.system.isPassive}} />
                <span>Passive Talent</span>
              </label>
            </div>
            
            {{!-- Stackable --}}
            <div class="wh40k-property wh40k-property--checkbox">
              <label class="wh40k-property-label-inline">
                <input type="checkbox" name="system.stackable" {{checked item.system.stackable}} />
                <span>Can Take Multiple Times</span>
              </label>
            </div>
            
            {{!-- Rank (if stackable) --}}
            {{#if item.system.stackable}}
            <div class="wh40k-property">
              <label class="wh40k-property-label">Current Rank</label>
              <input type="number" name="system.rank" value="{{item.system.rank}}" min="1" class="wh40k-property-input" />
            </div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Aptitudes --}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-star"></i> Aptitudes
          </h3>
          
          {{#if item.system.aptitudes.length}}
          <div class="wh40k-aptitudes-display">
            {{#each item.system.aptitudes}}
            <span class="wh40k-aptitude-tag">{{this}}</span>
            {{/each}}
          </div>
          {{/if}}
          
          <div class="wh40k-property" style="margin-top: {{#if item.system.aptitudes.length}}0.75rem{{else}}0{{/if}};">
            <label class="wh40k-property-label">Aptitudes <span class="wh40k-field-hint">(comma-separated)</span></label>
            <input type="text" name="system.aptitudes" value="{{join item.system.aptitudes ", "}}" class="wh40k-property-input" placeholder="Finesse, Agility, General" />
          </div>
        </div>
        
        {{!-- Specialization --}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-wrench"></i> Specialization
          </h3>
          
          <div class="wh40k-property">
            <label class="wh40k-property-label">Specialization <span class="wh40k-field-hint">(e.g., "Weapon Training (Las)")</span></label>
            <input type="text" name="system.specialization" value="{{item.system.specialization}}" class="wh40k-property-input" placeholder="Enter specialization..." />
          </div>
        </div>
      </div>
      
      {{!-- PREREQUISITES TAB --}}
      <div class="wh40k-talent-panel tab" data-tab="prerequisites" data-group="primary">
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-lock"></i> Text Description
          </h3>
          
          <div class="wh40k-property">
            <label class="wh40k-property-label">Prerequisites <span class="wh40k-field-hint">(freeform text)</span></label>
            <textarea name="system.prerequisites.text" rows="3" class="wh40k-property-textarea" placeholder="e.g., Agility 40+, Dodge skill, Lightning Reflexes">{{item.system.prerequisites.text}}</textarea>
          </div>
        </div>
        
        {{#if item.system.hasPrerequisites}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-list-check"></i> Summary
          </h3>
          
          <div class="wh40k-prerequisites-display">
            <p class="wh40k-prereq-label">{{item.system.prerequisitesLabel}}</p>
          </div>
        </div>
        {{else}}
        <div class="wh40k-talent-section">
          <div class="wh40k-empty-state">
            <i class="fas fa-unlock"></i>
            <p>No prerequisites defined</p>
          </div>
        </div>
        {{/if}}
      </div>
      
      {{!-- EFFECTS TAB --}}
      <div class="wh40k-talent-panel tab" data-tab="effects" data-group="primary">
        {{!-- Benefit/Effect Description --}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-magic"></i> Benefit
          </h3>
          
          <div class="wh40k-editor-container">
            {{#if inEditMode}}
              {{editor system.benefit target="system.benefit" button=true editable=editable engine="prosemirror"}}
            {{else}}
              <div class="wh40k-description-content">{{{system.benefit}}}</div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Grants Display --}}
        {{#if item.system.hasGrants}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-gift"></i> Grants
          </h3>
          
          <div class="wh40k-grants-display">
            <p class="wh40k-field-hint" style="margin-bottom: 0.75rem;">
              <i class="fas fa-info-circle"></i> This talent automatically grants the following abilities when acquired:
            </p>
            
            {{#if item.system.grants.talents.length}}
            <div class="wh40k-grants-group">
              <h4 class="wh40k-grants-group-title">
                <i class="fas fa-book"></i> Talents
              </h4>
              <ul class="wh40k-grants-list">
                {{#each item.system.grants.talents}}
                <li class="wh40k-grants-item">
                  <i class="fas fa-chevron-right"></i>
                  <span class="wh40k-grants-name">{{this.name}}</span>
                  {{#if this.specialization}}
                    <span class="wh40k-grants-specialization">({{this.specialization}})</span>
                  {{/if}}
                </li>
                {{/each}}
              </ul>
            </div>
            {{/if}}
            
            {{#if item.system.grants.skills.length}}
            <div class="wh40k-grants-group">
              <h4 class="wh40k-grants-group-title">
                <i class="fas fa-graduation-cap"></i> Skills
              </h4>
              <ul class="wh40k-grants-list">
                {{#each item.system.grants.skills}}
                <li class="wh40k-grants-item">
                  <i class="fas fa-chevron-right"></i>
                  <span class="wh40k-grants-name">{{this.name}}</span>
                  {{#if this.specialization}}
                    <span class="wh40k-grants-specialization">({{this.specialization}})</span>
                  {{/if}}
                  <span class="wh40k-grants-level">— {{capitalize this.level}}</span>
                </li>
                {{/each}}
              </ul>
            </div>
            {{/if}}
            
            {{#if item.system.grants.traits.length}}
            <div class="wh40k-grants-group">
              <h4 class="wh40k-grants-group-title">
                <i class="fas fa-dna"></i> Traits
              </h4>
              <ul class="wh40k-grants-list">
                {{#each item.system.grants.traits}}
                <li class="wh40k-grants-item">
                  <i class="fas fa-chevron-right"></i>
                  <span class="wh40k-grants-name">{{this.name}}</span>
                  {{#if this.level}}
                    <span class="wh40k-grants-level">— Level {{this.level}}</span>
                  {{/if}}
                </li>
                {{/each}}
              </ul>
            </div>
            {{/if}}
            
            {{#if item.system.grants.specialAbilities.length}}
            <div class="wh40k-grants-group">
              <h4 class="wh40k-grants-group-title">
                <i class="fas fa-star"></i> Special Abilities
              </h4>
              {{#each item.system.grants.specialAbilities}}
              <div class="wh40k-grants-special">
                <h5 class="wh40k-grants-special-name">{{this.name}}</h5>
                <div class="wh40k-grants-special-description">
                  {{{this.description}}}
                </div>
              </div>
              {{/each}}
            </div>
            {{/if}}
          </div>
        </div>
        {{/if}}
        
        {{!-- Modifiers Display --}}
        {{#if (or item.system.modifiers.characteristics item.system.modifiers.skills item.system.modifiers.combat item.system.modifiers.wounds item.system.modifiers.fate item.system.modifiers.movement)}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-chart-line"></i> Modifiers
          </h3>
          
          <div class="wh40k-modifiers-display">
            {{#if item.system.modifiers.characteristics}}
            <div class="wh40k-modifier-group">
              <h4 class="wh40k-modifier-group-title">Characteristics</h4>
              <div class="wh40k-modifier-list">
                {{#each item.system.modifiers.characteristics}}
                <div class="wh40k-modifier-item">
                  <span class="wh40k-modifier-name">{{capitalize @key}}</span>
                  <span class="wh40k-modifier-value {{#if (gt this 0)}}positive{{else}}negative{{/if}}">
                    {{signedNumber this}}
                  </span>
                </div>
                {{/each}}
              </div>
            </div>
            {{/if}}
            
            {{#if item.system.modifiers.skills}}
            <div class="wh40k-modifier-group">
              <h4 class="wh40k-modifier-group-title">Skills</h4>
              <div class="wh40k-modifier-list">
                {{#each item.system.modifiers.skills}}
                <div class="wh40k-modifier-item">
                  <span class="wh40k-modifier-name">{{capitalize @key}}</span>
                  <span class="wh40k-modifier-value {{#if (gt this 0)}}positive{{else}}negative{{/if}}">
                    {{signedNumber this}}
                  </span>
                </div>
                {{/each}}
              </div>
            </div>
            {{/if}}
            
            {{#if item.system.modifiers.combat}}
            <div class="wh40k-modifier-group">
              <h4 class="wh40k-modifier-group-title">Combat</h4>
              <div class="wh40k-modifier-list">
                {{#each item.system.modifiers.combat}}
                <div class="wh40k-modifier-item">
                  <span class="wh40k-modifier-name">{{capitalize @key}}</span>
                  <span class="wh40k-modifier-value {{#if (gt this 0)}}positive{{else}}negative{{/if}}">
                    {{signedNumber this}}
                  </span>
                </div>
                {{/each}}
              </div>
            </div>
            {{/if}}
            
            {{#if item.system.modifiers.wounds}}
            <div class="wh40k-modifier-group">
              <h4 class="wh40k-modifier-group-title">Other</h4>
              <div class="wh40k-modifier-list">
                <div class="wh40k-modifier-item">
                  <span class="wh40k-modifier-name">Wounds</span>
                  <span class="wh40k-modifier-value {{#if (gt item.system.modifiers.wounds 0)}}positive{{else}}negative{{/if}}">
                    {{signedNumber item.system.modifiers.wounds}}
                  </span>
                </div>
              </div>
            </div>
            {{/if}}
            
            {{#if item.system.modifiers.fate}}
            <div class="wh40k-modifier-group">
              <h4 class="wh40k-modifier-group-title">Resources</h4>
              <div class="wh40k-modifier-list">
                <div class="wh40k-modifier-item">
                  <span class="wh40k-modifier-name">Fate Points</span>
                  <span class="wh40k-modifier-value positive">
                    {{signedNumber item.system.modifiers.fate}}
                  </span>
                </div>
              </div>
            </div>
            {{/if}}
            
            {{#if item.system.modifiers.movement}}
            <div class="wh40k-modifier-group">
              <h4 class="wh40k-modifier-group-title">Movement</h4>
              <div class="wh40k-modifier-list">
                <div class="wh40k-modifier-item">
                  <span class="wh40k-modifier-name">Movement Bonus</span>
                  <span class="wh40k-modifier-value {{#if (gt item.system.modifiers.movement 0)}}positive{{else}}negative{{/if}}">
                    {{signedNumber item.system.modifiers.movement}}
                  </span>
                </div>
              </div>
            </div>
            {{/if}}
          </div>
          
          <p class="wh40k-field-hint" style="margin-top: 1rem;">
            <i class="fas fa-info-circle"></i> Modifiers are configured via Active Effects. This panel is read-only.
          </p>
        </div>
        {{else}}
        <div class="wh40k-talent-section">
          <div class="wh40k-empty-state">
            <i class="fas fa-chart-line"></i>
            <p>No modifiers defined</p>
            <p class="wh40k-field-hint">Use Active Effects tab to add stat bonuses</p>
          </div>
        </div>
        {{/if}}
      </div>
      
      {{!-- DESCRIPTION TAB --}}
      <div class="wh40k-talent-panel tab" data-tab="description" data-group="primary">
        {{!-- Description --}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-book"></i> Description
          </h3>
          
          <div class="wh40k-editor-container">
            {{#if inEditMode}}
              {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
            {{else}}
              <div class="wh40k-description-content">{{{system.description.value}}}</div>
            {{/if}}
          </div>
        </div>
        
        {{!-- Notes --}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-sticky-note"></i> Notes
          </h3>
          
          <div class="wh40k-property">
            <textarea name="system.notes" rows="4" class="wh40k-property-textarea" placeholder="GM notes, house rules, clarifications, etc.">{{item.system.notes}}</textarea>
          </div>
        </div>
        
        {{!-- Source --}}
        <div class="wh40k-talent-section">
          <h3 class="wh40k-section-title">
            <i class="fas fa-book-bookmark"></i> Source
          </h3>
          
          <div class="wh40k-property">
            <input type="text" name="system.source" value="{{item.system.source}}" class="wh40k-property-input" placeholder="Core Rulebook, pg. XX" />
          </div>
        </div>
      </div>
      
    </section>{{!-- .wh40k-talent-content --}}
  </form>
</div>{{!-- .wh40k-talent-sheet --}}
