<div class="wh40k-item-sheet ship-component tw-flex tw-flex-col tw-h-full tw-overflow-hidden tw-bg-[var(--wh40k-sheet-bg)] tw-text-[var(--wh40k-text-dark)]">
    <form autocomplete="off">
        {{!-- Item Header (canonical partial) --}}
        {{> systems/wh40k-rpg/templates/item/panel/item-header.hbs
            namePlaceholder="Component Name"
            typeLabelKey="WH40K.ShipComponent"
            typeIcon="fa-cog"}}

        {{> systems/wh40k-rpg/templates/item/partial/item-tab-strip.hbs tabs=(array
            (object tab="details" label=(localize "WH40K.Item.Tabs.Details") icon="fa-info-circle" active=true)
            (object tab="effects" label=(localize "WH40K.Item.Tabs.Effects") icon="fa-magic"))}}

        <!-- Tab Content -->
        <section class="tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-[var(--wh40k-space-md)]">
            <!-- Details Tab -->
            <div class="tab active" data-tab="details" data-group="primary">
                <!-- Basic Properties -->
                <div class="tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-[var(--wh40k-radius-lg)] tw-mb-[var(--wh40k-space-md)] tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-border-b tw-border-[var(--wh40k-border-color-light)]" style="background: linear-gradient(90deg, rgba(212,175,55,0.15) 0%, transparent 100%)">
                        <h3 class="tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-md)] tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-m-0 tw-uppercase tw-tracking-[0.05em]"><i class="fas fa-cog tw-mr-[var(--wh40k-space-sm)] tw-opacity-80"></i> Component Properties</h3>
                    </div>
                    <div class="tw-p-[var(--wh40k-space-md)]">
                        <div class="form-group">
                            <label>{{localize "WH40K.ShipComponent.Type"}}</label>
                            <select name="system.componentType">
                                {{selectOptions componentTypes selected=source.componentType}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>{{localize "WH40K.HullType"}}</label>
                            <select name="system.hullType" multiple>
                                {{selectOptions hullTypes selected=source.hullType}}
                            </select>
                            <p class="hint">Hold Ctrl/Cmd to select multiple hull types</p>
                        </div>

                        <div class="form-group">
                            <label>{{localize "WH40K.Availability"}}</label>
                            <select name="system.availability">
                                {{selectOptions availabilities selected=source.availability}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>{{localize "WH40K.ShipComponent.Condition"}}</label>
                            <select name="system.condition">
                                {{selectOptions conditions selected=source.condition}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>
                                <input type="checkbox" name="system.essential" {{checked system.essential}} />
                                {{localize "WH40K.ShipComponent.Essential"}}
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Resource Requirements -->
                <div class="tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-[var(--wh40k-radius-lg)] tw-mb-[var(--wh40k-space-md)] tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-border-b tw-border-[var(--wh40k-border-color-light)]" style="background: linear-gradient(90deg, rgba(212,175,55,0.15) 0%, transparent 100%)">
                        <h3 class="tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-md)] tw-text-[color:var(--wh40k-gold)] tw-m-0 tw-uppercase tw-tracking-[0.05em]"><i class="fas fa-battery-half tw-mr-[var(--wh40k-space-sm)] tw-opacity-80"></i> Resource Requirements</h3>
                    </div>
                    <div class="tw-p-[var(--wh40k-space-md)]">
                        <div class="form-row">
                            <div class="form-group">
                                <label>{{localize "WH40K.ShipComponent.Power"}} (Used)</label>
                                <input type="number" name="system.power.used" value="{{source.power.used}}" />
                            </div>
                            <div class="form-group">
                                <label>{{localize "WH40K.ShipComponent.Power"}} (Generated)</label>
                                <input type="number" name="system.power.generated" value="{{source.power.generated}}" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>{{localize "WH40K.ShipComponent.Space"}}</label>
                                <input type="number" name="system.space" value="{{source.space}}" />
                            </div>
                            <div class="form-group">
                                <label>{{localize "WH40K.ShipComponent.ShipPoints"}}</label>
                                <input type="number" name="system.shipPoints" value="{{source.shipPoints}}" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stat Modifiers -->
                <div class="tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-[var(--wh40k-radius-lg)] tw-mb-[var(--wh40k-space-md)] tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-border-b tw-border-[var(--wh40k-border-color-light)]" style="background: linear-gradient(90deg, rgba(212,175,55,0.15) 0%, transparent 100%)">
                        <h3 class="tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-md)] tw-text-[color:var(--wh40k-gold)] tw-m-0 tw-uppercase tw-tracking-[0.05em]"><i class="fas fa-chart-line tw-mr-[var(--wh40k-space-sm)] tw-opacity-80"></i> Stat Modifiers</h3>
                    </div>
                    <div class="tw-p-[var(--wh40k-space-md)]">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Speed</label>
                                <input type="number" name="system.modifiers.speed" value="{{source.modifiers.speed}}" />
                            </div>
                            <div class="form-group">
                                <label>Manoeuvrability</label>
                                <input type="number" name="system.modifiers.manoeuvrability" value="{{source.modifiers.manoeuvrability}}" />
                            </div>
                            <div class="form-group">
                                <label>Detection</label>
                                <input type="number" name="system.modifiers.detection" value="{{source.modifiers.detection}}" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Armour</label>
                                <input type="number" name="system.modifiers.armour" value="{{source.modifiers.armour}}" />
                            </div>
                            <div class="form-group">
                                <label>Hull Integrity</label>
                                <input type="number" name="system.modifiers.hullIntegrity" value="{{source.modifiers.hullIntegrity}}" />
                            </div>
                            <div class="form-group">
                                <label>Turret Rating</label>
                                <input type="number" name="system.modifiers.turretRating" value="{{source.modifiers.turretRating}}" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Void Shields</label>
                                <input type="number" name="system.modifiers.voidShields" value="{{source.modifiers.voidShields}}" />
                            </div>
                            <div class="form-group">
                                <label>Morale</label>
                                <input type="number" name="system.modifiers.morale" value="{{source.modifiers.morale}}" />
                            </div>
                            <div class="form-group">
                                <label>Crew Rating</label>
                                <input type="number" name="system.modifiers.crewRating" value="{{source.modifiers.crewRating}}" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Effect -->
                <div class="tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-[var(--wh40k-radius-lg)] tw-mb-[var(--wh40k-space-md)] tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-border-b tw-border-[var(--wh40k-border-color-light)]" style="background: linear-gradient(90deg, rgba(212,175,55,0.15) 0%, transparent 100%)">
                        <h3 class="tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-md)] tw-text-[color:var(--wh40k-gold)] tw-m-0 tw-uppercase tw-tracking-[0.05em]"><i class="fas fa-magic tw-mr-[var(--wh40k-space-sm)] tw-opacity-80"></i> Effect</h3>
                    </div>
                    <div class="tw-p-[var(--wh40k-space-md)]">
                        {{#if inEditMode}}
                          {{editor system.effect target="system.effect" button=true editable=editable engine="prosemirror"}}
                        {{else}}
                          <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.effect}}}</div>
                        {{/if}}
                    </div>
                </div>

                <!-- Notes -->
                <div class="tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-[var(--wh40k-radius-lg)] tw-mb-[var(--wh40k-space-md)] tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-border-b tw-border-[var(--wh40k-border-color-light)]" style="background: linear-gradient(90deg, rgba(212,175,55,0.15) 0%, transparent 100%)">
                        <h3 class="tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-md)] tw-text-[color:var(--wh40k-gold)] tw-m-0 tw-uppercase tw-tracking-[0.05em]"><i class="fas fa-sticky-note tw-mr-[var(--wh40k-space-sm)] tw-opacity-80"></i> Notes</h3>
                    </div>
                    <div class="tw-p-[var(--wh40k-space-md)]">
                        <textarea name="system.notes" rows="3">{{system.notes}}</textarea>
                    </div>
                </div>

                <!-- Description -->
                <div class="tw-bg-[var(--wh40k-panel-bg)] tw-border tw-border-[var(--wh40k-border-color-light)] tw-rounded-[var(--wh40k-radius-lg)] tw-mb-[var(--wh40k-space-md)] tw-overflow-hidden">
                    <div class="tw-flex tw-items-center tw-justify-between tw-px-[var(--wh40k-space-md)] tw-py-[var(--wh40k-space-sm)] tw-border-b tw-border-[var(--wh40k-border-color-light)]" style="background: linear-gradient(90deg, rgba(212,175,55,0.15) 0%, transparent 100%)">
                        <h3 class="tw-font-[var(--wh40k-font-display)] tw-text-[var(--wh40k-font-size-md)] tw-text-[color:var(--wh40k-gold)] tw-m-0 tw-uppercase tw-tracking-[0.05em]"><i class="fas fa-scroll tw-mr-[var(--wh40k-space-sm)] tw-opacity-80"></i> Description</h3>
                    </div>
                    <div class="tw-p-[var(--wh40k-space-md)]">
                        {{#if inEditMode}}
                          {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
                        {{else}}
                          <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold [&_strong]:tw-text-[color:var(--wh40k-text-dark)]">{{{system.description.value}}}</div>
                        {{/if}}
                    </div>
                </div>
            </div>

            <!-- Effects Tab -->
            <div class="tab" data-tab="effects" data-group="primary">
                {{> systems/wh40k-rpg/templates/item/panel/active-effects-panel.hbs}}
            </div>
        </section>
    </form>
</div>
