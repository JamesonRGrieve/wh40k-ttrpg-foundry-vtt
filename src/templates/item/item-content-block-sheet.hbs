{{!--
  Shared content-block item sheet — used by the "second-class" content item
  family: specialAbility, malignancy, mutation, mentalDisorder (issue #221).

  Context contract (supplied per-type via the sheet's prepareContext):
    - contentFields  : Array<{ name, labelKey, value }>  — HTML/ProseMirror fields
    - contentScalars : Array<                                — select / checkbox fields
        { kind: 'select',   name, labelKey, value, options: [{ value, labelKey, selected }] }
      | { kind: 'checkbox', name, labelKey, checked } >
    - notes          : system.notes (rendered directly below)

  Editing is gated: canEdit / inEditMode already require the Freeform Character
  Editing world setting via FreeformGatedItemSheet, so the pencil and the
  ProseMirror editors only surface when that setting is on.
--}}
<div class="tw-flex tw-flex-col tw-h-full">
  <form autocomplete="off" class="tw-flex tw-flex-col tw-flex-1 tw-min-h-0">

    {{!-- ═══════════════════════════════════════════════════════════════════
         HEADER: portrait + name + edit-mode toggle
    ═══════════════════════════════════════════════════════════════════ --}}
    <header class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-shrink-0">
      {{> systems/wh40k-rpg/templates/shared/editable-portrait.hbs src=item.img alt=item.name sizeClass="tw-w-16 tw-h-16" extraClass="tw-shrink-0"}}

      <div class="tw-flex tw-flex-col tw-gap-1 tw-min-w-0 tw-flex-1">
        {{#if inEditMode}}
        {{> systems/wh40k-rpg/templates/item/partial/item-name-input.hbs placeholderKey="WH40K.OriginPath.NamePlaceholder"}}
        {{else}}
        <h1 class="tw-font-display tw-text-xl tw-m-0 tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-p-1">{{item.name}}</h1>
        {{/if}}
      </div>

      {{#if canEdit}}
      <div class="tw-flex tw-gap-1 tw-shrink-0">
        {{> systems/wh40k-rpg/templates/shared/sheet-action-button.hbs action="toggleEditMode" icon="fa-pen-to-square" activeIcon="fa-lock-open" isActive=inEditMode titleKey="WH40K.OriginPath.ToggleEditMode"}}
      </div>
      {{/if}}
    </header>

    {{!-- ═══════════════════════════════════════════════════════════════════
         CONTENT
    ═══════════════════════════════════════════════════════════════════ --}}
    <section class="wh40k-tab-content tw-flex-1 tw-overflow-y-auto tw-overflow-x-hidden tw-min-h-0 tw-p-2">

      {{!-- Scalar fields (selects / checkboxes) --}}
      {{#each contentScalars}}
      <div class="tw-mb-3">
        <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-mb-2 tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-sliders tw-opacity-70"></i> {{localize this.labelKey}}
        </h3>
        <div class="tw-px-1">
          {{#if (eq this.kind "select")}}
            {{#if ../inEditMode}}
            <select name="{{this.name}}" class="tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm">
              {{#each this.options}}
              <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{localize this.labelKey}}</option>
              {{/each}}
            </select>
            {{else}}
            <div class="tw-text-sm">{{#each this.options}}{{#if this.selected}}{{localize this.labelKey}}{{/if}}{{/each}}</div>
            {{/if}}
          {{else if (eq this.kind "checkbox")}}
            {{#if ../inEditMode}}
            <label class="tw-flex tw-items-center tw-gap-2 tw-cursor-pointer tw-text-sm">
              <input type="checkbox" name="{{this.name}}" {{checked this.checked}} />
              <span>{{localize this.labelKey}}</span>
            </label>
            {{else}}
            <div class="tw-text-sm">{{#if this.checked}}{{localize "WH40K.Yes"}}{{else}}{{localize "WH40K.No"}}{{/if}}</div>
            {{/if}}
          {{/if}}
        </div>
      </div>
      {{/each}}

      {{!-- Description --}}
      <div class="tw-mb-3">
        <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-mb-2 tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-book tw-opacity-70"></i> {{localize "WH40K.Item.Tabs.Description"}}
        </h3>
        <div class="tw-px-1">
          {{#if inEditMode}}
          {{editor system.description.value target="system.description.value" button=true editable=editable engine="prosemirror"}}
          {{else}}
          <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold">{{{system.description.value}}}</div>
          {{/if}}
        </div>
      </div>

      {{!-- Type-specific HTML fields --}}
      {{#each contentFields}}
      <div class="tw-mb-3">
        <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-mb-2 tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-bolt tw-opacity-70"></i> {{localize this.labelKey}}
        </h3>
        <div class="tw-px-1">
          {{#if ../inEditMode}}
          {{editor this.value target=this.name button=true editable=../editable engine="prosemirror"}}
          {{else}}
          <div class="tw-text-[color:var(--wh40k-text-dark)] tw-leading-[1.5] tw-text-sm [&_p]:tw-mb-2 [&_strong]:tw-font-bold">{{{this.value}}}</div>
          {{/if}}
        </div>
      </div>
      {{/each}}

      {{!-- Notes --}}
      <div class="tw-mb-3">
        <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-mb-2 tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-sticky-note tw-opacity-70"></i> {{localize "WH40K.Item.Tabs.Notes"}}
        </h3>
        <div class="tw-px-1">
          {{#if inEditMode}}
          <textarea name="system.notes" rows="3" class="tw-w-full tw-px-2 tw-py-1 tw-rounded-sm tw-text-sm tw-resize-y">{{item.system.notes}}</textarea>
          {{else}}
          <div class="tw-text-sm tw-whitespace-pre-line">{{item.system.notes}}</div>
          {{/if}}
        </div>
      </div>

      {{!-- Modifiers --}}
      <div class="tw-mb-3">
        <h3 class="tw-flex tw-items-center tw-gap-2 tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-mb-2 tw-text-gold bc:tw-text-crimson-light dh1:tw-text-gold-raw-l5 dh2:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure">
          <i class="fas fa-chart-line tw-opacity-70"></i> {{localize "WH40K.Item.Tabs.Modifiers"}}
        </h3>
        <div class="tw-px-1">
          {{#if inEditMode}}
          {{> systems/wh40k-rpg/templates/item/panel/modifiers-editor-panel.hbs config=dh}}
          {{else}}
          {{> systems/wh40k-rpg/templates/item/panel/modifiers-panel.hbs}}
          {{/if}}
        </div>
      </div>

    </section>

    {{!-- ═══════════════════════════════════════════════════════════════════
         PERSISTENCE FOOTNOTE
    ═══════════════════════════════════════════════════════════════════ --}}
    {{#if inEditMode}}
    <footer class="tw-flex tw-shrink-0 tw-items-start tw-gap-2 tw-px-3 tw-py-2 tw-text-xs tw-italic tw-opacity-80 tw-border-t tw-border-[var(--wh40k-border-color)]">
      <i class="fas fa-circle-info tw-mt-0.5"></i>
      <span>{{localize "WH40K.Item.PersistenceFootnote"}}</span>
    </footer>
    {{/if}}
  </form>
</div>
