{{!-- Armour Modification Modifiers Tab --}}
<div class="tw-flex tw-flex-col tw-gap-0" data-tab="modifiers">
    <div class="wh40k-panel">
        <header class="wh40k-panel-header">
            <h3>
                <i class="fas fa-chart-line"></i>
                {{localize "WH40K.Modification.Modifiers"}}
            </h3>
        </header>

        <div class="wh40k-panel-body">
            {{!-- Armour Points --}}
            <div class="tw-flex tw-items-center tw-gap-5 tw-p-5 tw-border tw-border-[rgba(212,197,166,0.15)] tw-rounded-lg tw-mb-4 tw-transition-all hover:tw-border-[rgba(212,175,55,0.3)]" style="background: rgba(255,255,255,0.02)">
                <div class="tw-shrink-0 tw-w-12 tw-h-12 tw-flex tw-items-center tw-justify-center tw-rounded-full tw-border tw-border-[rgba(212,175,55,0.3)]" style="background: linear-gradient(135deg,rgba(212,175,55,0.2) 0%,rgba(212,175,55,0.1) 100%)">
                    <i class="fas fa-shield-halved tw-text-2xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                </div>
                <div class="tw-flex-1">
                    <label class="tw-block tw-font-bold tw-text-base tw-mb-1" style="color: rgba(255,255,255,0.95)">{{localize "WH40K.Modification.APLabel"}}</label>
                    <p class="tw-text-xs tw-m-0" style="color: rgba(255,255,255,0.5)">Bonus or penalty to Armour Points</p>
                </div>
                <div class="tw-flex tw-items-center tw-gap-3">
                    <button type="button"
                            class="tw-w-9 tw-h-9 tw-flex tw-items-center tw-justify-center tw-border tw-border-[rgba(212,175,55,0.3)] tw-rounded-md tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-transition-all disabled:tw-opacity-30"
                            style="background: rgba(212,175,55,0.1)"
                            data-action="adjustModifier"
                            data-field="modifiers.armourPoints"
                            data-delta="-1"
                            {{disabled (not isEditable)}}>
                        <i class="fas fa-minus"></i>
                    </button>

                    <div class="tw-min-w-[80px] tw-text-center tw-text-2xl tw-font-bold {{#if (gt modifiers.armourPoints 0)}}tw-text-success{{else if (lt modifiers.armourPoints 0)}}tw-text-failure{{/if}}" style="font-family: 'Roboto Mono', monospace">
                        {{#if (gte modifiers.armourPoints 0)}}+{{/if}}{{modifiers.armourPoints}}
                    </div>

                    <button type="button"
                            class="tw-w-9 tw-h-9 tw-flex tw-items-center tw-justify-center tw-border tw-border-[rgba(212,175,55,0.3)] tw-rounded-md tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-transition-all disabled:tw-opacity-30"
                            style="background: rgba(212,175,55,0.1)"
                            data-action="adjustModifier"
                            data-field="modifiers.armourPoints"
                            data-delta="1"
                            {{disabled (not isEditable)}}>
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>

            {{!-- Max Agility --}}
            <div class="tw-flex tw-items-center tw-gap-5 tw-p-5 tw-border tw-border-[rgba(212,197,166,0.15)] tw-rounded-lg tw-mb-4 tw-transition-all hover:tw-border-[rgba(212,175,55,0.3)]" style="background: rgba(255,255,255,0.02)">
                <div class="tw-shrink-0 tw-w-12 tw-h-12 tw-flex tw-items-center tw-justify-center tw-rounded-full tw-border tw-border-[rgba(212,175,55,0.3)]" style="background: linear-gradient(135deg,rgba(212,175,55,0.2) 0%,rgba(212,175,55,0.1) 100%)">
                    <i class="fas fa-running tw-text-2xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                </div>
                <div class="tw-flex-1">
                    <label class="tw-block tw-font-bold tw-text-base tw-mb-1" style="color: rgba(255,255,255,0.95)">{{localize "WH40K.Modification.AgilityLabel"}}</label>
                    <p class="tw-text-xs tw-m-0" style="color: rgba(255,255,255,0.5)">Bonus or penalty to maximum Agility</p>
                </div>
                <div class="tw-flex tw-items-center tw-gap-3">
                    <button type="button"
                            class="tw-w-9 tw-h-9 tw-flex tw-items-center tw-justify-center tw-border tw-border-[rgba(212,175,55,0.3)] tw-rounded-md tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-transition-all disabled:tw-opacity-30"
                            style="background: rgba(212,175,55,0.1)"
                            data-action="adjustModifier"
                            data-field="modifiers.maxAgility"
                            data-delta="-5"
                            {{disabled (not isEditable)}}>
                        <i class="fas fa-minus"></i>
                    </button>

                    <div class="tw-min-w-[80px] tw-text-center tw-text-2xl tw-font-bold {{#if (gt modifiers.maxAgility 0)}}tw-text-success{{else if (lt modifiers.maxAgility 0)}}tw-text-failure{{/if}}" style="font-family: 'Roboto Mono', monospace">
                        {{#if (gte modifiers.maxAgility 0)}}+{{/if}}{{modifiers.maxAgility}}
                    </div>

                    <button type="button"
                            class="tw-w-9 tw-h-9 tw-flex tw-items-center tw-justify-center tw-border tw-border-[rgba(212,175,55,0.3)] tw-rounded-md tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-transition-all disabled:tw-opacity-30"
                            style="background: rgba(212,175,55,0.1)"
                            data-action="adjustModifier"
                            data-field="modifiers.maxAgility"
                            data-delta="5"
                            {{disabled (not isEditable)}}>
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>

            {{!-- Weight --}}
            <div class="tw-flex tw-items-center tw-gap-5 tw-p-5 tw-border tw-border-[rgba(212,197,166,0.15)] tw-rounded-lg tw-mb-4 tw-transition-all hover:tw-border-[rgba(212,175,55,0.3)]" style="background: rgba(255,255,255,0.02)">
                <div class="tw-shrink-0 tw-w-12 tw-h-12 tw-flex tw-items-center tw-justify-center tw-rounded-full tw-border tw-border-[rgba(212,175,55,0.3)]" style="background: linear-gradient(135deg,rgba(212,175,55,0.2) 0%,rgba(212,175,55,0.1) 100%)">
                    <i class="fas fa-weight-hanging tw-text-2xl tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure"></i>
                </div>
                <div class="tw-flex-1">
                    <label class="tw-block tw-font-bold tw-text-base tw-mb-1" style="color: rgba(255,255,255,0.95)">{{localize "WH40K.Modification.WeightLabel"}}</label>
                    <p class="tw-text-xs tw-m-0" style="color: rgba(255,255,255,0.5)">Weight change in kilograms</p>
                </div>
                <div class="tw-flex tw-items-center tw-gap-3">
                    <button type="button"
                            class="tw-w-9 tw-h-9 tw-flex tw-items-center tw-justify-center tw-border tw-border-[rgba(212,175,55,0.3)] tw-rounded-md tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-transition-all disabled:tw-opacity-30"
                            style="background: rgba(212,175,55,0.1)"
                            data-action="adjustModifier"
                            data-field="modifiers.weight"
                            data-delta="-0.5"
                            {{disabled (not isEditable)}}>
                        <i class="fas fa-minus"></i>
                    </button>

                    <input type="number"
                           name="system.modifiers.weight"
                           value="{{modifiers.weight}}"
                           step="0.5"
                           class="tw-w-[80px] tw-text-center tw-text-xl tw-font-bold tw-p-2 tw-rounded-md tw-border tw-border-[rgba(212,197,166,0.3)] tw-text-white focus:tw-outline-none focus:tw-border-gold"
                           style="background: rgba(0,0,0,0.3); font-family: 'Roboto Mono', monospace"
                           {{disabled (not isEditable)}}>

                    <button type="button"
                            class="tw-w-9 tw-h-9 tw-flex tw-items-center tw-justify-center tw-border tw-border-[rgba(212,175,55,0.3)] tw-rounded-md tw-text-gold bc:tw-text-crimson-light dh1e:tw-text-gold-raw-l5 dh2e:tw-text-gold-raw dw:tw-text-accent-combat ow:tw-text-brass-l20 rt:tw-text-gold im:tw-text-failure tw-cursor-pointer tw-transition-all disabled:tw-opacity-30"
                            style="background: rgba(212,175,55,0.1)"
                            data-action="adjustModifier"
                            data-field="modifiers.weight"
                            data-delta="0.5"
                            {{disabled (not isEditable)}}>
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
