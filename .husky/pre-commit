#!/usr/bin/env bash
#
# pre-commit — maximally parallelized ratchet pipeline.
#
# Phase 1 (serial):  lint-staged writes back auto-fixes; everything else reads
#                    source, so it must finish first.
# Phase 2 (parallel): codegen — i18n-keys.d.ts and icon-keys.d.ts are inputs to
#                     every TS-analysis pass in Phase 3.
# Phase 3 (parallel): every read-only analysis / ratchet runs concurrently.
#
# Each Phase 2/3 job logs to .husky/_logs/<label>-<ts>.log. On success the log
# is suppressed; on failure it's dumped with a [<label>] prefix so you can tell
# which job in a fanout failed.
#
# Memory: three tsc --noEmit passes + type-coverage + knip + deps + eslint run
# concurrently. On <16GB you may need to serialize the tsc passes; do that by
# moving them out of Phase 3 into a Phase 2.5 with their own wait_all.

set -u

ROOT="$(git rev-parse --show-toplevel)"
LOG_DIR="${ROOT}/.husky/_logs"
mkdir -p "${LOG_DIR}"
TS="$(date +%Y%m%d-%H%M%S)"

PIDS=()
LABELS=()
LOGS=()
FAILED=0

run_bg() {
    local label="$1"
    shift
    local log="${LOG_DIR}/${label}-${TS}.log"
    echo "[pre-commit] ▶ ${label}"
    ( "$@" ) >"$log" 2>&1 &
    PIDS+=("$!")
    LABELS+=("$label")
    LOGS+=("$log")
}

wait_all() {
    local i=0
    local pid
    for pid in "${PIDS[@]}"; do
        if wait "$pid"; then
            echo "[pre-commit] ✓ ${LABELS[$i]}"
        else
            echo "[pre-commit] ✗ ${LABELS[$i]} (log: ${LOGS[$i]})" >&2
            sed "s|^|[${LABELS[$i]}] |" "${LOGS[$i]}" >&2
            FAILED=1
        fi
        i=$((i + 1))
    done
    PIDS=()
    LABELS=()
    LOGS=()
}

# ---------------------------------------------------------------------------
# Phase 1: lint-staged (serial — writes back to source)
# ---------------------------------------------------------------------------
echo "[pre-commit] phase 1: lint-staged"
pnpm exec lint-staged --hide-unstaged || exit 1

# ---------------------------------------------------------------------------
# Phase 2: codegen (parallel — generated .d.ts files are inputs to Phase 3)
# ---------------------------------------------------------------------------
echo "[pre-commit] phase 2: codegen (parallel)"
run_bg "i18n-gen"  pnpm -s i18n:gen
run_bg "icons-gen" pnpm -s icons:gen
wait_all
[ "$FAILED" = "0" ] || exit 1

# ---------------------------------------------------------------------------
# Phase 3: every read-only analysis runs concurrently.
# ---------------------------------------------------------------------------
echo "[pre-commit] phase 3: ratchets + tests (parallel)"

# Start the slowest first so they overlap with the cheap ones.
run_bg "storybook-pw"   sh ./scripts/run-storybook-playwright-tests.sh
run_bg "vitest"         ./node_modules/.bin/vitest run

# tsc passes — heaviest, several GB each.
run_bg "typecheck"      pnpm -s typecheck
run_bg "strict"         pnpm -s strict:ratchet
run_bg "test-typecheck" pnpm -s test:typecheck:ratchet
run_bg "type-coverage"  pnpm -s type-coverage:ratchet

# Whole-tree analyzers.
run_bg "eslint"         pnpm -s lint:ratchet
run_bg "biome"          pnpm -s biome:ratchet
run_bg "knip"           pnpm -s knip:ratchet
run_bg "deps"           pnpm -s deps:ratchet

# CSS / template ratchets.
run_bg "css"            pnpm -s css:ratchet
run_bg "important"      pnpm -s important:ratchet
run_bg "plugin-audit"   pnpm -s css:plugin-audit
run_bg "animation"      pnpm -s animation:ratchet
run_bg "theme"          pnpm -s theme:ratchet

# Source-tree counters.
run_bg "ts-coverage"    pnpm -s ts:ratchet
run_bg "symmetry"       pnpm -s symmetry:ratchet
run_bg "preload-drift"  pnpm -s preload:drift
run_bg "lockfile"       pnpm -s lockfile:validate

# Conditional pack validation.
changed="$(git diff --cached --name-only --diff-filter=ACMR)"
if printf '%s\n' "$changed" | grep -qE '^(gulpfile\.js|src/packs(/|$))'; then
    run_bg "packs"      pnpm -s packs
fi

wait_all
[ "$FAILED" = "0" ] || exit 1

echo "[pre-commit] all phases passed"
