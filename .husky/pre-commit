pnpm exec lint-staged --hide-unstaged

# Regenerate i18n key types from src/lang/en.json. The codegen is idempotent;
# if the langpack didn't change, the file is byte-for-byte identical and git
# sees no change. New keys flow into src/module/types/i18n-keys.d.ts so the
# typed t() helper picks them up immediately.
echo "[pre-commit] regenerating i18n key types…"
pnpm -s i18n:gen

# Regenerate the icon registry from `{{icon "..."}}` references in templates
# and `icon('...')` call sites in TS. Idempotent — if no references changed,
# the output is byte-for-byte identical. The build-time generator scans
# src/templates/**/*.hbs and src/module/**/*.ts and emits both
# src/module/icons/registry.generated.ts (runtime SVG map) and
# src/module/types/icon-keys.d.ts (typed key union for the icon() helper).
echo "[pre-commit] regenerating icon registry…"
pnpm -s icons:gen

# Hard typecheck gate: tsc --noEmit must pass with zero errors.
echo "[pre-commit] running tsc…"
pnpm -s typecheck

# ESLint warning ratchet: blocks commits that increase the eslint warning
# count. Update via: pnpm lint:ratchet:update
echo "[pre-commit] running eslint ratchet…"
pnpm -s lint:ratchet

# CSS-coverage ratchet: blocks commits that increase css-only template count
# or decrease tailwind-only count. Update via: pnpm css:ratchet:update
echo "[pre-commit] running css coverage ratchet…"
pnpm -s css:ratchet

# !important ratchet: blocks commits that increase the count of `!important`
# declarations across tailwind/*.js. Each one is a cascade workaround that
# should be retired by porting the consumer template to inline `tw-*`
# utilities and removing the legacy rule. Update via: pnpm important:ratchet:update
echo "[pre-commit] running !important ratchet…"
pnpm -s important:ratchet

# Plugin-audit hard gate: fails when any `tailwind/*.js` rule references a
# `wh40k-*` class that no template/module/test/story uses. Walks nested rules
# (descendant selectors), not just top-level. No ratchet — a dead rule is a
# real bug class (silently shadows live rules via addBase dedup, see
# tailwind/design-tokens.js comment).
echo "[pre-commit] running tailwind plugin audit…"
pnpm -s css:plugin-audit

# Animation ratchet: blocks commits that increase the count of `animation:` /
# `animation-name:` declarations across the legacy CSS files under src/css/**.
# Each declaration is a rule that should migrate to `tw-animate-<name>` on the consuming template.
# Once the count reaches 0, the @keyframes safelist in tailwind.config.js can
# be dropped. Update via: pnpm animation:ratchet:update
echo "[pre-commit] running animation ratchet…"
pnpm -s animation:ratchet

# Theme ratchet: blocks commits that DECREASE the count of templates using
# per-system `<system>:tw-*` variants (`bc:`, `dh1e:`, `dh2e:`, `dw:`, `ow:`,
# `rt:`, `im:`). Direction is opposite to other ratchets — adoption climbs
# over time. Update via: pnpm theme:ratchet:update
echo "[pre-commit] running theme ratchet…"
pnpm -s theme:ratchet

# Per-rule TS-strictness ratchet: blocks commits that introduce new bare
# `: any`, ` as any`, or `@ts-expect-error` in any per-directory bucket.
# Update via: pnpm ts:ratchet:update
echo "[pre-commit] running ts coverage ratchet…"
pnpm -s ts:ratchet

# Symmetry ratchet: blocks commits that increase the count of sheets/dialogs
# without a sibling .stories.ts, or data/documents files without a sibling
# .test.ts. Update via: pnpm symmetry:ratchet:update
echo "[pre-commit] running symmetry ratchet…"
pnpm -s symmetry:ratchet

# Preload-drift gate: blocks commits where Handlebars partials are referenced
# at runtime ({{> ...}}) but missing from preloadHandlebarsTemplates(), or
# where preload entries point at non-existent templates. Hard fail (no ratchet —
# this is a real bug class).
echo "[pre-commit] running preload-drift gate…"
pnpm -s preload:drift

# Validate pack compilation when the compiler or any pack source changes.
# The prior silent-error bug in compilePacks went unnoticed because lint-staged
# only inspects the diff, not the actual Gulp pipeline. `gulp packs` exercises
# the full pipeline (including the explicit db.open() error surfacing added
# alongside this hook), so a broken compiler fails here instead of mid-release.
changed="$(git diff --cached --name-only --diff-filter=ACMR)"
if printf '%s\n' "$changed" | grep -qE '^(gulpfile\.js|src/packs(/|$))'; then
    echo "[pre-commit] gulpfile or pack sources changed — validating compilePacks…"
    pnpm -s packs
fi

echo "[pre-commit] running Vitest…"
./node_modules/.bin/vitest run

echo "[pre-commit] running Storybook Playwright integration tests…"
sh ./scripts/run-storybook-playwright-tests.sh
