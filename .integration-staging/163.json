{
    "issue": 163,
    "engine": "dw-squad-mode",
    "gameSystem": "dw",
    "datamodel": {
        "mixinFile": "src/module/data/actor/mixins/dw-mode-template.ts",
        "applyTo": "CharacterData",
        "schemaFieldsExport": "dwModeSchemaFields",
        "declarationsTypeExport": "DwModeDeclarations"
    },
    "sheetPanel": {
        "partialPath": "systems/wh40k-rpg/templates/actor/panel/dw-mode-panel.hbs",
        "preloadEntry": "systems/wh40k-rpg/templates/actor/panel/dw-mode-panel.hbs",
        "includeIn": "tab-status.hbs",
        "gateOn": "isDW"
    },
    "actions": [
        {
            "actionName": "dwEnterSquadMode",
            "module": "src/module/actions/dw-mode-actions.ts",
            "exportName": "dwEnterSquadMode"
        },
        {
            "actionName": "dwLeaveSquadMode",
            "module": "src/module/actions/dw-mode-actions.ts",
            "exportName": "dwLeaveSquadMode"
        }
    ],
    "chatPartial": {
        "partialPath": "systems/wh40k-rpg/templates/chat/dw-mode-chat.hbs",
        "preloadEntry": "systems/wh40k-rpg/templates/chat/dw-mode-chat.hbs"
    },
    "i18nKeys": "WH40K.DW.Mode.*",
    "e2eSpec": "tests/e2e/dw-squad-mode.spec.ts",
    "storybookStories": [
        "src/templates/actor/panel/dw-mode-panel.stories.ts",
        "src/templates/chat/dw-mode-chat.stories.ts"
    ],
    "contextBuilder": {
        "description": "Character sheet _prepareContext should build ctx.modePanel for DW actors. The Renown rank comes from rules/dw-renown.getRenownRank against system.renown (already wired by issue #164). Pseudocode:",
        "pseudocode": [
            "import { getSupportRange } from '../rules/dw-squad-mode.ts';",
            "import { getRenownRank } from '../rules/dw-renown.ts';",
            "if (this.actor._gameSystemId === 'dw') {",
            "  const mode = this.actor.system.combatMode ?? 'solo';",
            "  const renownRank = getRenownRank(this.actor.system.renown ?? 0);",
            "  const renownRankKey = renownRank[0].toUpperCase() + renownRank.slice(1);",
            "  const supportRange = getSupportRange(renownRank);",
            "  // Resolve sustained-ability display labels via uuidNameCache (CLAUDE.md compendium rule).",
            "  const sustainedAbilities = (this.actor.system.sustainedAbilities ?? []).map((id) => ({",
            "    id,",
            "    label: uuidNameCache.getName(id) ?? id,",
            "  }));",
            "  ctx.modePanel = { mode, renownRank, renownRankKey, supportRange, sustainedAbilities };",
            "}"
        ]
    },
    "notes": [
        "All player-facing strings already exist under WH40K.DW.Mode.* and WH40K.DW.Renown.Rank.* — no new langpack keys required.",
        "Action handlers are typed against a structural { actor } this-binding (DwModeActionThis) so the orchestrator can splice them onto CharacterSheet's static actions block without leaking sheet internals back into the action module.",
        "Leave-Squad-Mode action clears system.sustainedAbilities in the same update that flips combatMode — RAW: Sustained abilities end the moment the activator leaves Squad Mode."
    ]
}
