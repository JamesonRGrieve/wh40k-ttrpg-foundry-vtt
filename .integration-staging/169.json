{
    "issue": 169,
    "engine": "dw-mission",
    "gameSystem": "dw",
    "datamodel": {
        "mixinFile": "src/module/data/actor/mixins/dw-mission-template.ts",
        "applyTo": "CharacterData",
        "schemaFieldsExport": "dwMissionSchemaFields",
        "declarationsTypeExport": "DwMissionDeclarations"
    },
    "sheetPanel": {
        "partialPath": "systems/wh40k-rpg/templates/actor/panel/dw-mission-panel.hbs",
