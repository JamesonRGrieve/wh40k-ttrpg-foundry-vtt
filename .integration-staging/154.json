{
    "issue": 154,
    "engine": "ow-logistics",
    "gameSystem": "ow",
    "datamodel": {
        "mixinFile": "src/module/data/actor/mixins/ow-logistics-template.ts",
        "applyTo": "CharacterData",
        "schemaFieldsExport": "owLogisticsSchemaFields",
        "declarationsTypeExport": "OwLogisticsDeclarations"
    },
    "sheetPanel": {
        "partialPath": "systems/wh40k-rpg/templates/actor/panel/ow-logistics-panel.hbs",
        "preloadEntry": "systems/wh40k-rpg/templates/actor/panel/ow-logistics-panel.hbs",
        "includeIn": "tab-status.hbs",
        "gateOn": "isOW"
    },
    "actions": [
        {
            "actionName": "owLogisticsTest",
            "module": "src/module/actions/ow-logistics-actions.ts",
            "exportName": "owLogisticsTest"
        },
        {
            "actionName": "owToggleMunitorum",
            "module": "src/module/actions/ow-logistics-actions.ts",
            "exportName": "owToggleMunitorum"
        },
        {
            "actionName": "owAdjustSituational",
            "module": "src/module/actions/ow-logistics-actions.ts",
            "exportName": "owAdjustSituational"
        }
    ],
    "chatPartial": {
        "partialPath": "systems/wh40k-rpg/templates/chat/ow-logistics-chat.hbs",
        "preloadEntry": "systems/wh40k-rpg/templates/chat/ow-logistics-chat.hbs"
    },
    "dialogPartial": {
        "partialPath": "systems/wh40k-rpg/templates/prompt/logistics-test-dialog.hbs",
        "preloadEntry": "systems/wh40k-rpg/templates/prompt/logistics-test-dialog.hbs"
    },
    "i18nKeys": "WH40K.OW.Logistics.*",
    "e2eSpec": "tests/e2e/ow-logistics.spec.ts",
    "storybookStories": [
        "src/templates/actor/panel/ow-logistics-panel.stories.ts",
        "src/templates/chat/ow-logistics-chat.stories.ts",
        "src/module/applications/prompts/logistics-test-dialog.stories.ts"
    ],
    "contextBuilder": {
        "description": "Character sheet _prepareContext should build ctx.logisticsPanel for OW actors. Also set ctx.isOW. Pseudocode:",
        "pseudocode": [
            "import { OW_DEFAULT_LOGISTICS_RATING } from '../rules/ow-logistics.ts';",
            "const isOW = activeGameSystem === 'ow';",
            "context.isOW = isOW;",
            "if (isOW) {",
            "  const sys = this.actor.system as { logisticsRating?: number; munitorum?: boolean; situational?: number };",
            "  context.logisticsPanel = {",
            "    rating: sys.logisticsRating ?? OW_DEFAULT_LOGISTICS_RATING,",
            "    munitorum: sys.munitorum === true,",
            "    situational: typeof sys.situational === 'number' ? sys.situational : 0,",
            "  };",
            "}"
        ]
    }
}
